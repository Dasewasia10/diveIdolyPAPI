      "speakerName": "神崎莉央",
      "speakerNameEn": "Rio",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-rio.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/extraStoryVoice/sud_vo_adv_group_liz_07_05/sud_vo_adv_group_liz_07_05-rio006.m4a",
      "text": "だから私は……\n貴方と一緒の練習時間が作りたくてここに来たの",
