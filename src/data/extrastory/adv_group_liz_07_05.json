    {
      "type": "dialogue",
      "speakerCode": "aoi",
      "speakerName": "井川葵",
      "speakerNameEn": "Aoi",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-aoi.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/extraStoryVoice/sud_vo_adv_group_liz_07_05/sud_vo_adv_event_2405_01_05-aoi012.m4a",
      "text": "ねえ、莉央。今回のことで思ったんだけど……\n僕達は、トップアイドルを目指してるんだった……よね",
      "translations": {
        "en": "Hey‚ Rio. I thought about this…\nWe set a goal to be top idols… right?",
