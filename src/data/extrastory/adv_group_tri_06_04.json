      "speakerCode": "yu",
      "speakerName": "鈴村優",
      "speakerNameEn": "Yu",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-yu.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/extraStoryVoice/sud_vo_adv_group_tri_06_04/sud_vo_adv_group_tri_06_04-yu005.m4a",
      "text": "瑠依ちゃんのセンターの座も危ういんちゃう？",
      "translations": {
        "en": "Your center position might be in jeopardy‚ Rui-chan.",
        "id": ""
      },
