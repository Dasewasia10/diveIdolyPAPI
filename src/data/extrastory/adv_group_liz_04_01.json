    },
    {
      "type": "dialogue",
      "speakerCode": "unknown",
      "speakerName": "姫野霧子",
      "speakerNameEn": "Kiriko",
      "iconUrl": null,
      "voiceUrl": null,
      "text": "なるべく早く現場に行くから",
      "translations": {
        "en": "I'll get to the site as soon as possible‚",
        "id": ""
      },
      "startTime": 5.8,
      "sfxList": []
