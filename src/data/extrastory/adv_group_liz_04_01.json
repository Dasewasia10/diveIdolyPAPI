      "speakerCode": "unknown",
      "speakerName": "姫野霧子",
      "speakerNameEn": "Kiriko",
      "iconUrl": null,
      "voiceUrl": null,
      "text": "私は社長との会議が終わり次第向かうわ",
      "translations": {
        "en": "but I’ll be heading over as soon as my meeting with the president is finished.",
        "id": ""
