      "voiceUrl": "https://apiip.dasewasia.my.id/extraStoryVoice/sud_vo_adv_group_liz_01_04/sud_vo_adv_group_liz_01_04-rio001.m4a",
      "text": "あ……",
      "translations": {
        "en": "Ah…",
        "id": ""
      },
      "startTime": 2.1,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_vanstudio-00-noon.webp",
