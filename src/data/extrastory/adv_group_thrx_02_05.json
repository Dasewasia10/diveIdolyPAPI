      "bgName": "vanstudio-00-noon",
      "startTime": 20.7
    },
    {
      "type": "dialogue",
      "speakerCode": "kan",
      "speakerName": "kana",
      "speakerNameEn": "kana",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-kana.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/extraStoryVoice/sud_vo_adv_group_thrx_02_05/sud_vo_adv_group_thrx_02_05-kan001.m4a",
      "text": "kanaは最後に動きを止めるところで\n足がちょっとだけブレました～……",
      "translations": {
        "en": "Kana's foot wobbled a little bit\nat the end~…",
        "id": ""
      },
      "startTime": 20.7,
      "endTime": 26.5645580291,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_vanstudio-00-noon.webp",
      "bgName": "vanstudio-00-noon",
