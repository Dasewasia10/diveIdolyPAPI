      "speakerCode": "wmob1",
      "speakerName": "トレーナー",
      "speakerNameEn": "Trainer",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-wmob1.png",
      "voiceUrl": null,
      "text": "……わ、分かったわ",
      "translations": {
        "en": "…O-okay.",
        "id": ""
      },
      "startTime": 43.5,
      "endTime": 46.0666666667,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "wmob1",
      "speakerName": "トレーナー",
      "speakerNameEn": "Trainer",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-wmob1.png",
      "voiceUrl": null,
      "text": "あなた達、なんだか雰囲気が変わったわね……？",
      "translations": {
        "en": "You three‚ your atmosphere has changed… hasn't it?",
        "id": ""
      },
      "startTime": 46.0666666667,
      "endTime": 50.3157078487,
      "sfxList": []
    },
    {
      "type": "background",
