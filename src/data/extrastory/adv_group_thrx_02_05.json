    },
    {
      "type": "dialogue",
      "speakerCode": "wmob1",
      "speakerName": "トレーナー",
      "speakerNameEn": "Trainer",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-wmob1.png",
      "voiceUrl": null,
      "text": "でも……",
      "translations": {
        "en": "But…",
        "id": ""
      },
      "startTime": 26.7666666667,
      "endTime": 28.433333333300002,
      "sfxList": []
    },
    {
      "type": "background",
