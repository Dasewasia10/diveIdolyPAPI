        }
      ]
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_dressingroom-00-noon.webp",
      "bgName": "dressingroom-00-noon",
      "startTime": 57.8
    },
    {
      "type": "dialogue",
      "speakerCode": "kor",
      "speakerName": "fran",
      "speakerNameEn": "fran",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-fran.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/extraStoryVoice/sud_vo_adv_group_thrx_02_05/sud_vo_adv_group_thrx_02_05-kor003.m4a",
      "text": "あーはいはい、そこ置いておいて\n後で勝手に食べるから",
      "translations": {
        "en": "Ah‚ yeah‚ just leave them there.\nI'll eat them later.",
        "id": ""
      },
      "startTime": 57.8,
      "endTime": 63.2764717102,
      "sfxList": [
        {
          "src": "https://apiip.dasewasia.my.id/storyBgm/sud_se_adv_phone-tap-01.m4a",
