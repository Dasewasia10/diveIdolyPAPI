      "speakerCode": "wmob3",
      "speakerName": "秋宮もね",
      "speakerNameEn": "Mone",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-wmob3.png",
      "voiceUrl": null,
      "text": "ファンがアイドルを応援するように、アイドルも",
