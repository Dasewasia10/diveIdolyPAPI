      "speakerName": "秋宮もね",
      "speakerNameEn": "Mone",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-wmob3.png",
      "voiceUrl": null,
      "text": "そうだよ！　私や、おじさんやおばさん……",
