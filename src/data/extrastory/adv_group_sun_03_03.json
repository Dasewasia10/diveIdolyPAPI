      },
      "startTime": 226.3043423646,
      "endTime": 233.3747042648,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "wmob3",
      "speakerName": "秋宮もね",
      "speakerNameEn": "Mone",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-wmob3.png",
      "voiceUrl": null,
      "text": "辛いことがあった時は私達を思い出して",
      "translations": {
