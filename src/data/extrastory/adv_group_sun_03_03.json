      "bgName": "hyoszkroom-00-noon",
      "startTime": 197.7327976857
    },
    {
      "type": "dialogue",
      "speakerCode": "wmob3",
      "speakerName": "秋宮もね",
      "speakerNameEn": "Mone",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-wmob3.png",
      "voiceUrl": null,
      "text": "それよりも、あなたのことが好きで",
