        "id": ""
      },
      "startTime": 233.6413847916,
      "endTime": 238.74138275709998,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "wmob3",
      "speakerName": "秋宮もね",
      "speakerNameEn": "Mone",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-wmob3.png",
      "voiceUrl": null,
      "text": "アイドルは……私達はいつだって、あなたの味方だから",
      "translations": {
        "en": "Idols… we're always on your side.",
        "id": ""
      },
      "startTime": 238.7413827571,
      "endTime": 244.26649322490002,
      "sfxList": []
    },
