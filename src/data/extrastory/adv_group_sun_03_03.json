    },
    {
      "type": "dialogue",
      "speakerCode": "wmob3",
      "speakerName": "秋宮もね",
      "speakerNameEn": "Mone",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-wmob3.png",
      "voiceUrl": null,
      "text": "雫は絶対アイドルに向いてる。私が保証する",
      "translations": {
        "en": "You're definitely idol material. I guarantee it.",
