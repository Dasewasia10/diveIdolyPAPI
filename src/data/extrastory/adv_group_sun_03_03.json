      },
      "startTime": 188.3661249155,
      "endTime": 192.4994724904,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "wmob3",
      "speakerName": "秋宮もね",
      "speakerNameEn": "Mone",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-wmob3.png",
      "voiceUrl": null,
      "text": "雫を傷つけようとする人の言葉なんて聞かなくていいの",
      "translations": {
        "en": "You don't have to listen to people who try to hurt you.",
        "id": ""
      },
