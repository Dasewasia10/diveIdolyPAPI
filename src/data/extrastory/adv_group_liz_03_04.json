    {
      "type": "dialogue",
      "speakerCode": "ktn",
      "speakerName": "長瀬琴乃",
      "speakerNameEn": "Kotono",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-kotono.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/extraStoryVoice/sud_vo_adv_group_liz_03_04/sud_vo_adv_group_liz_03_04-ktn001.m4a",
      "text": "言っておきますけど、私は長瀬麻奈の妹です\nあなたには、負けません",
      "translations": {
        "en": "Let me make this clear‚ I am Mana Nagase’s younger sister.\nI won’t lose to you.",
        "id": ""
      },
      "startTime": 0.8,
      "endTime": 7.4573017120361325,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "rio",
      "speakerName": "神崎莉央",
      "speakerNameEn": "Rio",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-rio.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/extraStoryVoice/sud_vo_adv_group_liz_03_04/sud_vo_adv_group_liz_03_04-rio001.m4a",
      "text": "――っ！",
      "translations": {
        "en": "――!",
        "id": ""
      },
      "startTime": 7.8,
      "endTime": 9,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_vanstudio-00-noon.webp",
      "bgName": "vanstudio-00-noon",
