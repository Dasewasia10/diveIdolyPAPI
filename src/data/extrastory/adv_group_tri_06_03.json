      "speakerName": "姫野霧子",
      "speakerNameEn": "Kiriko",
      "iconUrl": null,
      "voiceUrl": null,
      "text": "すみれの故郷でのライブ、必ず成功させましょう",
      "translations": {
        "en": "Let's make sure the live performance in Sumire's hometown is a success.",
