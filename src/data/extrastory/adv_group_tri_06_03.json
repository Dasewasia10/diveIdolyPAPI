      "speakerCode": "unknown",
      "speakerName": "姫野霧子",
      "speakerNameEn": "Kiriko",
      "iconUrl": null,
      "voiceUrl": null,
      "text": "必要な人材も機材も、私が手配してあげるわ",
      "translations": {
        "en": "I'll arrange for all the necessary personnel and equipment.",
