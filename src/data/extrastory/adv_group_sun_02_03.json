      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_ichireiroom-00-noon.webp",
      "bgName": "ichireiroom",
      "startTime": 315.3333641687
    },
    {
