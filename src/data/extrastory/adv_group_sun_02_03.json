      "text": "くだらないって、どういうこと？\n優勝したのに、どうして認めてくれないの！",
      "translations": {
        "en": "Pointless‚ what do you mean?\nI won‚ why don't you acknowledge it?!",
        "id": ""
      },
      "startTime": 220.7333478927,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_ichinoseliving-00-noon.webp",
      "bgName": "ichinoseliving-00-noon",
      "startTime": 224.6000145594
    },
    {
      "type": "dialogue",
      "speakerCode": "rei",
      "speakerName": "一ノ瀬怜",
      "speakerNameEn": "Rei",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-rei.png",
