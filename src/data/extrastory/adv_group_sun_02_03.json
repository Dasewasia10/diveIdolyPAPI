      "text": "成果って、どういうこと？",
      "translations": {
        "en": "What do you mean‚ \"results\"?",
        "id": ""
      },
      "startTime": 299.9333641687,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_ichireiroom-00-noon.webp",
      "bgName": "ichireiroom",
