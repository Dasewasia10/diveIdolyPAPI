      "startTime": 198.8333356857
    },
    {
      "type": "dialogue",
      "speakerCode": "rei",
      "speakerName": "一ノ瀬怜",
      "speakerNameEn": "Rei",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-rei.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/extraStoryVoice/sud_vo_adv_group_sun_02_03/sud_vo_adv_group_sun_02_03-rei019.m4a",
      "text": "みんなが私のダンスを褒めてくれたのよ\nこれでお父さんも……",
