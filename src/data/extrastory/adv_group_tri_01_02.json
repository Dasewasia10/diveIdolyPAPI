  "script": [
    {
      "type": "dialogue",
      "speakerCode": null,
      "speakerName": "",
      "speakerNameEn": "",
      "iconUrl": null,
      "voiceUrl": null,
      "text": "――瑠依がバンプロの養成所へ入所してから",
      "translations": {
        "en": "――Two weeks have passed since Rui joined the Bump Production training school.",
        "id": ""
      },
      "startTime": 0,
      "endTime": 2.7999999788072376,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_vanstudio-00-noon.webp",
      "bgName": "vanstudio-00-noon",
      "startTime": 0
    },
    {
      "type": "dialogue",
      "speakerCode": null,
      "speakerName": "",
      "speakerNameEn": "",
      "iconUrl": null,
      "voiceUrl": null,
      "text": "二週間が過ぎた",
      "translations": {
        "en": "二週間が過ぎた",
        "id": ""
      },
      "startTime": 2.8,
      "endTime": 3.7799999925825327,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "unknown",
      "speakerName": "ダンスコーチB",
      "speakerNameEn": "Dance",
      "iconUrl": null,
      "voiceUrl": null,
      "text": "――はい、じゃあ次は天動さん",
      "translations": {
        "en": "――Okay‚ next is Ms. Tendo.",
        "id": ""
      },
      "startTime": 4.766666666666667,
      "endTime": 7.833333333333333,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "unknown",
      "speakerName": "ダンスコーチB",
      "speakerNameEn": "Dance",
      "iconUrl": null,
      "voiceUrl": null,
      "text": "Bメロから入ってサビまでね",
      "translations": {
        "en": "Go from the bridge to the chorus.",
        "id": ""
      },
      "startTime": 7.833333333333333,
      "endTime": 9.860113207499188,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "rui",
      "speakerName": "天動瑠依",
      "speakerNameEn": "Rui",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-rui.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/extraStoryVoice/sud_vo_adv_group_tri_01_02/sud_vo_adv_group_tri_01_02-rui001.m4a",
      "text": "はい……すぅ、はあ……いけます",
      "translations": {
        "en": "Yes… deep breath… I can do it.",
        "id": ""
      },
      "startTime": 10.066666666666666,
      "endTime": 16.9,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_vanstudio-00-noon.webp",
      "bgName": "vanstudio-00-noon",
      "startTime": 14.9
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_vanstudio-00-noon.webp",
      "bgName": "vanstudio-00-noon",
      "startTime": 18.333333333333332
    },
    {
      "type": "dialogue",
      "speakerCode": null,
      "speakerName": "",
      "speakerNameEn": "",
      "iconUrl": null,
      "voiceUrl": null,
      "text": "――流れ出す旋律に合わせ、瑠依の歌声が響く",
      "translations": {
        "en": "――Rui’s voice echoes along with the flowing melody.",
        "id": ""
      },
      "startTime": 19.4,
      "endTime": 22.333333333333332,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": null,
      "speakerName": "",
      "speakerNameEn": "",
      "iconUrl": null,
      "voiceUrl": null,
      "text": "誰もが聞く耳を奪われる、可憐な歌声",
      "translations": {
        "en": "A lovely singing voice that captures everyone’s ears.",
        "id": ""
      },
      "startTime": 22.333333333333332,
      "endTime": 24.713333410129213,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_vanstudio-00-noon.webp",
      "bgName": "vanstudio-00-noon",
      "startTime": 24.7
    },
    {
      "type": "dialogue",
      "speakerCode": null,
      "speakerName": "",
      "speakerNameEn": "",
      "iconUrl": null,
      "voiceUrl": null,
      "text": "――入所してからのたった二週間で、瑠依と",
      "translations": {
        "en": "――In just two weeks since joining‚",
        "id": ""
      },
      "startTime": 24.933333333333334,
      "endTime": 27.733333324461945,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": null,
      "speakerName": "",
      "speakerNameEn": "",
      "iconUrl": null,
      "voiceUrl": null,
      "text": "他の練習生との間には、高く分厚い壁ができていた",
      "translations": {
        "en": "a high and thick wall has formed between Rui",
        "id": ""
      },
      "startTime": 27.733333333333334,
      "endTime": 30.953333323131236,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_vanstudio-00-noon.webp",
      "bgName": "vanstudio-00-noon",
      "startTime": 32.46666666666667
    },
    {
      "type": "dialogue",
      "speakerCode": "unknown",
      "speakerName": "ダンスコーチB",
      "speakerNameEn": "Dance",
      "iconUrl": null,
      "voiceUrl": null,
      "text": "……はい、OKよ。音程も抑揚もばっちり",
      "translations": {
        "en": "…Okay‚ that’s good. The pitch and intonation are perfect.",
        "id": ""
      },
      "startTime": 33.43333333333333,
      "endTime": 38.4,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "unknown",
      "speakerName": "ダンスコーチB",
      "speakerNameEn": "Dance",
      "iconUrl": null,
      "voiceUrl": null,
      "text": "毎日喉のケアも怠っていないようだし",
      "translations": {
        "en": "It seems you haven't neglected your daily throat care either.",
        "id": ""
      },
      "startTime": 38.4,
      "endTime": 40.94882081349691,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "rui",
      "speakerName": "天動瑠依",
      "speakerNameEn": "Rui",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-rui.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/extraStoryVoice/sud_vo_adv_group_tri_01_02/sud_vo_adv_group_tri_01_02-rui002.m4a",
      "text": "はい。いろいろ調べて\n個人で出来ることは一通り……",
      "translations": {
        "en": "Yes. I’ve researched various things\nand I’ve done everything I can on my own…",
        "id": ""
      },
      "startTime": 41.13333333333333,
      "endTime": 45.6590092342347,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_vanstudio-00-noon.webp",
      "bgName": "vanstudio-00-noon",
      "startTime": 45.86666666666667
    },
    {
      "type": "dialogue",
      "speakerCode": "rui",
      "speakerName": "天動瑠依",
      "speakerNameEn": "Rui",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-rui.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/extraStoryVoice/sud_vo_adv_group_tri_01_02/sud_vo_adv_group_tri_01_02-rui003.m4a",
      "text": "他にどんな方法があるのかも教えて欲しいです\n出来ることはなんでもしたいんです",
      "translations": {
        "en": "I'd also like you to teach me any other methods there are.\nI want to do everything I can.",
        "id": ""
      },
      "startTime": 45.86666666666667,
      "endTime": 50.95371882120769,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "unknown",
      "speakerName": "ダンスコーチB",
      "speakerNameEn": "Dance",
      "iconUrl": null,
      "voiceUrl": null,
      "text": "え、あ……もちろんよ",
      "translations": {
        "en": "Uh‚ um… Of course.",
        "id": ""
      },
      "startTime": 51.166666666666664,
      "endTime": 54.76666666666666,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "unknown",
      "speakerName": "ダンスコーチB",
      "speakerNameEn": "Dance",
      "iconUrl": null,
      "voiceUrl": null,
      "text": "後でレクチャーしてあげる。それじゃあ次は……",
      "translations": {
        "en": "I’ll give you a lecture later. So next…",
        "id": ""
      },
      "startTime": 54.766666666666666,
      "endTime": 58.25557800928752,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_vanstudio-00-noon.webp",
      "bgName": "vanstudio-00-noon",
      "startTime": 58.46666666666667
    },
    {
      "type": "dialogue",
      "speakerCode": "unknown",
      "speakerName": "練習生B",
      "speakerNameEn": "Trainee",
      "iconUrl": null,
      "voiceUrl": null,
      "text": "……ねえ聞いた？　今の、嫌みっぽくない？",
      "translations": {
        "en": "…Hey‚ did you hear that? Didn’t she sound sarcastic just now?",
        "id": ""
      },
      "startTime": 58.46666666666667,
      "endTime": 62.9,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "unknown",
      "speakerName": "練習生B",
      "speakerNameEn": "Trainee",
      "iconUrl": null,
      "voiceUrl": null,
      "text": "褒められたのにスカしちゃってさ……",
      "translations": {
        "en": "She got praised‚ but she’s acting all smug…",
        "id": ""
      },
      "startTime": 62.9,
      "endTime": 65.20871422265967,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "unknown",
      "speakerName": "練習生C",
      "speakerNameEn": "Trainee",
      "iconUrl": null,
      "voiceUrl": null,
      "text": "自分すごい努力してるんですアピール？",
      "translations": {
        "en": "Is she trying to show off how much she’s working hard?",
        "id": ""
      },
      "startTime": 65.43333333333334,
      "endTime": 68.86666666666667,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "unknown",
      "speakerName": "練習生C",
      "speakerNameEn": "Trainee",
      "iconUrl": null,
      "voiceUrl": null,
      "text": "うっざ……",
      "translations": {
        "en": "So annoying…",
        "id": ""
      },
      "startTime": 68.86666666666666,
      "endTime": 69.73333333333335,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_vanstudio-00-noon.webp",
      "bgName": "vanstudio-00-noon",
      "startTime": 69.93333333333334
    },
    {
      "type": "dialogue",
      "speakerCode": "rui",
      "speakerName": "天動瑠依",
      "speakerNameEn": "Rui",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-rui.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/extraStoryVoice/sud_vo_adv_group_tri_01_02/sud_vo_adv_group_tri_01_02-rui004.m4a",
      "text": "（……なるほどね）\n（出る杭は打たれる……予想していた通り）",
      "translations": {
        "en": "(…I see.)\n(The nail that sticks out gets hammered down… Just as I expected.)",
        "id": ""
      },
      "startTime": 69.93333333333334,
      "endTime": 75.11616776784263,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "rui",
      "speakerName": "天動瑠依",
      "speakerNameEn": "Rui",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-rui.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/extraStoryVoice/sud_vo_adv_group_tri_01_02/sud_vo_adv_group_tri_01_02-rui005.m4a",
      "text": "（でもトップアイドルになるっていうことは）\n（どの現役アイドルよりも輝くということ）",
      "translations": {
        "en": "(But becoming a top idol means)\n(shining brighter than any active idol.)",
        "id": ""
      },
      "startTime": 75.3,
      "endTime": 81.2568386822212,
      "sfxList": [
        {
          "src": "https://apiip.dasewasia.my.id/storyBgm/sud_se_adv_walk-in-single-01.m4a",
          "delay": 9833.333333333343,
          "startTime": 85.13333333333334
        }
      ]
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_vanstudio-00-noon.webp",
      "bgName": "vanstudio-00-noon",
      "startTime": 81.43333333333334
    },
    {
      "type": "dialogue",
      "speakerCode": "rui",
      "speakerName": "天動瑠依",
      "speakerNameEn": "Rui",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-rui.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/extraStoryVoice/sud_vo_adv_group_tri_01_02/sud_vo_adv_group_tri_01_02-rui006.m4a",
      "text": "（ここでの足の引っ張り合いなんて）\n（いちいち気にしている暇なんて、ない）",
      "translations": {
        "en": "(There’s no time)\nto be bothered by such petty things here.",
        "id": ""
      },
      "startTime": 81.43333333333334,
      "endTime": 86.94988985061646,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_vanlocker-00-noon.webp",
      "bgName": "vanlocker-00-noon",
      "startTime": 88.2
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_vanlocker-00-noon.webp",
      "bgName": "vanlocker-00-noon",
      "startTime": 88.2
    },
    {
      "type": "dialogue",
      "speakerCode": "rui",
      "speakerName": "天動瑠依",
      "speakerNameEn": "Rui",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-rui.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/extraStoryVoice/sud_vo_adv_group_tri_01_02/sud_vo_adv_group_tri_01_02-rui007.m4a",
      "text": "……あれ？\n確か、ロッカーの中に入れておいたはず……",
      "translations": {
        "en": "…Huh?\nI’m sure I put it in my locker…",
        "id": ""
      },
      "startTime": 89.23333333333333,
      "endTime": 94.24648526509601,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "unknown",
      "speakerName": "練習生A",
      "speakerNameEn": "Trainee",
      "iconUrl": null,
      "voiceUrl": null,
      "text": "どうしたの、天動さん",
      "translations": {
        "en": "What’s wrong‚ Ms. Tendo?",
        "id": ""
      },
      "startTime": 94.43333333333334,
      "endTime": 97.2,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "unknown",
      "speakerName": "練習生A",
      "speakerNameEn": "Trainee",
      "iconUrl": null,
      "voiceUrl": null,
      "text": "何かなくなってた？",
      "translations": {
        "en": "Did you lose something?",
        "id": ""
      },
      "startTime": 97.2,
      "endTime": 98.9412797885015,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_vanlocker-00-noon.webp",
      "bgName": "vanlocker-00-noon",
      "startTime": 99.16666666666667
    },
    {
      "type": "dialogue",
      "speakerCode": "rui",
      "speakerName": "天動瑠依",
      "speakerNameEn": "Rui",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-rui.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/extraStoryVoice/sud_vo_adv_group_tri_01_02/sud_vo_adv_group_tri_01_02-rui008.m4a",
      "text": "はい\n練習着を入れていたはずなんですけど……",
      "translations": {
        "en": "Yes.\nI’m sure I put my practice clothes in here…",
        "id": ""
      },
      "startTime": 99.16666666666667,
      "endTime": 102.80352003822722,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_vanlocker-00-noon.webp",
      "bgName": "vanlocker-00-noon",
      "startTime": 103.16666666666667
    },
    {
      "type": "dialogue",
      "speakerCode": "unknown",
      "speakerName": "練習生B",
      "speakerNameEn": "Trainee",
      "iconUrl": null,
      "voiceUrl": null,
      "text": "ゴミと間違われて",
      "translations": {
        "en": "Maybe the cleaning staff mistook them for trash",
        "id": ""
      },
      "startTime": 103.16666666666667,
      "endTime": 104.86666666666665,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "unknown",
      "speakerName": "練習生B",
      "speakerNameEn": "Trainee",
      "iconUrl": null,
      "voiceUrl": null,
      "text": "清掃員さんに捨てられちゃってたりして",
      "translations": {
        "en": "and threw them away.",
        "id": ""
      },
      "startTime": 104.86666666666666,
      "endTime": 108.1274151484171,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "unknown",
      "speakerName": "練習生C",
      "speakerNameEn": "Trainee",
      "iconUrl": null,
      "voiceUrl": null,
      "text": "ああ、あり得る",
      "translations": {
        "en": "Ah‚ that’s possible.",
        "id": ""
      },
      "startTime": 108.33333333333331,
      "endTime": 110.13333333333334,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "unknown",
      "speakerName": "練習生C",
      "speakerNameEn": "Trainee",
      "iconUrl": null,
      "voiceUrl": null,
      "text": "汗臭くなってて処分されたのかもねぇ",
      "translations": {
        "en": "Maybe they smelled sweaty and got disposed of~",
        "id": ""
      },
      "startTime": 110.13333333333334,
      "endTime": 113.38333326180773,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_vanlocker-00-noon.webp",
      "bgName": "vanlocker-00-noon",
      "startTime": 113.6
    },
    {
      "type": "dialogue",
      "speakerCode": "rui",
      "speakerName": "天動瑠依",
      "speakerNameEn": "Rui",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-rui.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/extraStoryVoice/sud_vo_adv_group_tri_01_02/sud_vo_adv_group_tri_01_02-rui009.m4a",
      "text": "洗濯し終えた一着を忘れないよう置いてただけなので\n捨てられるなんてことは…………え？",
      "translations": {
        "en": "I just left a clean set here so I wouldn’t forget it‚\nso there’s no way they would have been thrown away… Huh?",
        "id": ""
      },
      "startTime": 113.6,
      "endTime": 120.51521530151368,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_vanlocker-00-noon.webp",
      "bgName": "vanlocker-00-noon",
      "startTime": 120.7
    },
    {
      "type": "dialogue",
      "speakerCode": "unknown",
      "speakerName": "練習生A",
      "speakerNameEn": "Trainee",
      "iconUrl": null,
      "voiceUrl": null,
      "text": "……くすくす……",
      "translations": {
        "en": "…chuckles…",
        "id": ""
      },
      "startTime": 120.7,
      "endTime": 122.16666666666666,
      "sfxList": []
    },
    {
