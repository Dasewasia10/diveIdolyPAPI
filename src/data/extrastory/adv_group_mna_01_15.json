    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_schoolclass-00-night.webp",
      "bgName": "schoolclass-00-night",
      "startTime": 149.2
    },
    {
      "type": "dialogue",
      "speakerCode": "koh",
      "speakerName": "{user}",
      "speakerNameEn": "{user}",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-kohei.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/extraStoryVoice/sud_vo_adv_group_mna_01_15/sud_vo_adv_group_mna_01_15-koh010.m4a",
      "text": "…………ぷっ\n本当に、幽霊なのか。死んでも相変わらずなんだな",
      "translations": {
        "en": "…Pfft\nAre you really a ghost? Even after death‚ you're still the same.",
        "id": ""
      },
      "startTime": 152.46666666666667,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "mna",
      "speakerName": "長瀬麻奈",
      "speakerNameEn": "Mana",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-mana.png",
      "voiceUrl": null,
      "text": "あっ、やっと笑ったね",
      "translations": {
        "en": "There‚ you finally smiled.",
