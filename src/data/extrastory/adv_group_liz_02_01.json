    },
    {
      "type": "dialogue",
      "speakerCode": null,
      "speakerName": "",
      "speakerNameEn": "",
      "iconUrl": null,
      "voiceUrl": null,
      "text": "順調にトップアイドルの階段を駆け上がっていた",
      "translations": {
        "en": "…were steadily climbing the stairs to becoming top idols.",
        "id": ""
