      "speakerCode": null,
      "speakerName": "",
      "speakerNameEn": "",
      "iconUrl": null,
      "voiceUrl": null,
      "text": "との声も上がっていた",
      "translations": {
        "en": "…the top candidates to win the next NEXT VENUS Grand Prix.",
