    {
      "type": "dialogue",
      "speakerCode": null,
      "speakerName": "",
      "speakerNameEn": "",
      "iconUrl": null,
      "voiceUrl": null,
      "text": "彼に認められることが候補生全員の目標であった",
      "translations": {
        "en": "To be acknowledged by him was the goal of every trainee.",
        "id": ""
