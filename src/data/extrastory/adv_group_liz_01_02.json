    },
    {
      "type": "dialogue",
      "speakerCode": "wmob1",
      "speakerName": "練習生A",
      "speakerNameEn": "Trainee",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-wmob1.png",
      "voiceUrl": null,
      "text": "はぁ、はぁ……",
      "translations": {
        "en": "Pant Pant…",
        "id": ""
      },
      "startTime": 6.633333333333334,
      "endTime": 10.3,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "wmob1",
      "speakerName": "練習生A",
      "speakerNameEn": "Trainee",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-wmob1.png",
      "voiceUrl": null,
      "text": "やっと終わった～～",
      "translations": {
        "en": "Finally over",
        "id": ""
      },
      "startTime": 10.3,
      "endTime": 13.083333428700762,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "wmob2",
      "speakerName": "練習生B",
      "speakerNameEn": "Trainee",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-wmob2.png",
      "voiceUrl": null,
      "text": "キッ、キツい～～",
      "translations": {
        "en": "S-so tough",
        "id": ""
      },
      "startTime": 13.3,
      "endTime": 15.900000000000002,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "wmob2",
      "speakerName": "練習生B",
      "speakerNameEn": "Trainee",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-wmob2.png",
      "voiceUrl": null,
      "text": "もう動けない……",
      "translations": {
        "en": "I can't move anymore…",
        "id": ""
      },
      "startTime": 15.9,
      "endTime": 17.930793857574457,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_vanstudio-00-noon.webp",
      "bgName": "s1",
      "startTime": 18.133333333333333
    },
    {
      "type": "dialogue",
      "speakerCode": "wmob1",
      "speakerName": "ダンスコーチB",
      "speakerNameEn": "Dance",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-wmob1.png",
      "voiceUrl": null,
      "text": "みんな、来週までに私が注意した所を直してね",
      "translations": {
        "en": "Everyone‚ make sure to fix the parts I pointed out by next week.",
        "id": ""
      },
      "startTime": 18.133333333333333,
      "endTime": 22.413900311787923,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "rio",
      "speakerName": "神崎莉央",
      "speakerNameEn": "Rio",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-rio.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/extraStoryVoice/sud_vo_adv_group_liz_01_02/sud_vo_adv_group_liz_01_02-rio002.m4a",
      "text": "あの、先生\n私にもアドバイスをお願いします",
      "translations": {
        "en": "Excuse me‚ Sensei.\nCould you give me some advice too‚ please?",
        "id": ""
      },
      "startTime": 22.6,
      "endTime": 26.406689310073855,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_vanstudio-00-noon.webp",
      "bgName": "s1",
      "startTime": 26.6
    },
    {
      "type": "dialogue",
      "speakerCode": "wmob1",
      "speakerName": "ダンスコーチB",
      "speakerNameEn": "Dance",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-wmob1.png",
      "voiceUrl": null,
      "text": "ああ、莉央は完璧だったから特に何も……",
      "translations": {
        "en": "Ah‚ Rio‚ your performance was perfect‚ so there's nothing in particular…",
        "id": ""
      },
      "startTime": 26.6,
      "endTime": 30.900000000000002,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "wmob1",
      "speakerName": "ダンスコーチB",
      "speakerNameEn": "Dance",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-wmob1.png",
      "voiceUrl": null,
      "text": "いいわ、貴方には新しいステップを教えてあげる",
      "translations": {
        "en": "Alright‚ I'll teach you a new step.",
        "id": ""
      },
      "startTime": 30.9,
      "endTime": 34.654262924194335,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "wmob1",
      "speakerName": "ダンスコーチB",
      "speakerNameEn": "Dance",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-wmob1.png",
      "voiceUrl": null,
      "text": "こっちに来なさい",
      "translations": {
        "en": "Come over here.",
        "id": ""
      },
      "startTime": 35.13333333333333,
      "endTime": 36.28333335717519,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_vanstudio-00-noon.webp",
      "bgName": "s1",
      "startTime": 36.5
    },
    {
      "type": "dialogue",
      "speakerCode": "rio",
      "speakerName": "神崎莉央",
      "speakerNameEn": "Rio",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-rio.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/extraStoryVoice/sud_vo_adv_group_liz_01_02/sud_vo_adv_group_liz_01_02-rio003.m4a",
      "text": "はい\nありがとうございます",
      "translations": {
        "en": "Yes‚ Sensei.\nThank you.",
        "id": ""
      },
      "startTime": 36.5,
      "endTime": 38.7500000476837,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_vanstudio-00-noon.webp",
      "bgName": "s1",
      "startTime": 38.93333333333333
    },
    {
      "type": "dialogue",
      "speakerCode": "wmob1",
      "speakerName": "練習生A",
      "speakerNameEn": "Trainee",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-wmob1.png",
      "voiceUrl": null,
      "text": "なんで莉央だけ特別扱いなのよ……！",
      "translations": {
        "en": "Why is Rio the only one getting special treatment?!",
        "id": ""
      },
      "startTime": 38.93333333333333,
      "endTime": 42.55350171270824,
      "sfxList": [
        {
          "src": "https://apiip.dasewasia.my.id/storyBgm/sud_se_adv_walk-in-single-01.m4a",
          "delay": 2533.3333333333385,
          "startTime": 41.46666666666667
        }
      ]
    },
    {
      "type": "dialogue",
      "speakerCode": "wmob1",
      "speakerName": "練習生A",
      "speakerNameEn": "Trainee",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-wmob1.png",
      "voiceUrl": null,
      "text": "一番後輩なのに生意気よ",
      "translations": {
        "en": "She's the most junior here‚ yet she's so cocky.",
        "id": ""
      },
      "startTime": 42.56666666666667,
      "endTime": 45.195963605244934,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_vanstudio-00-noon.webp",
      "bgName": "s1",
      "startTime": 45.4
    },
    {
      "type": "dialogue",
      "speakerCode": "wmob3",
      "speakerName": "練習生C",
      "speakerNameEn": "Trainee",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-wmob3.png",
      "voiceUrl": null,
      "text": "……でも、あの子がへばってる私達と違うのは",
      "translations": {
        "en": "…But we have to admit that she's different from us‚ who are all worn out…",
        "id": ""
      },
      "startTime": 45.4,
      "endTime": 49.143410964344824,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "wmob3",
      "speakerName": "練習生C",
      "speakerNameEn": "Trainee",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-wmob3.png",
      "voiceUrl": null,
      "text": "認めるしかないよ……マジでデビュー近いかもね",
      "translations": {
        "en": "She might seriously be close to debuting.",
        "id": ""
      },
      "startTime": 49.166666666666664,
      "endTime": 53.38833529598027,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "wmob2",
      "speakerName": "練習生B",
      "speakerNameEn": "Trainee",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-wmob2.png",
      "voiceUrl": null,
      "text": "うん、あの子の練習量凄いよ。そこは素直に感心した",
      "translations": {
        "en": "Yeah‚ the amount she practices is insane. I have to admire her for that.",
        "id": ""
      },
      "startTime": 53.56666666666667,
      "endTime": 59.26666666666667,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_vanstudio-00-noon.webp",
      "bgName": "s1",
      "startTime": 53.56666666666667
    },
    {
      "type": "dialogue",
      "speakerCode": "wmob2",
      "speakerName": "練習生B",
      "speakerNameEn": "Trainee",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-wmob2.png",
      "voiceUrl": null,
      "text": "例の話さ、きっと莉央が選ばれるんじゃない？",
      "translations": {
        "en": "You know that rumor going around? I bet Rio is the one who'll be chosen.",
        "id": ""
      },
      "startTime": 59.266666666666666,
      "endTime": 62.56666647593181,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "wmob3",
      "speakerName": "練習生C",
      "speakerNameEn": "Trainee",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-wmob3.png",
      "voiceUrl": null,
      "text": "だね",
      "translations": {
        "en": "Yeah‚ probably.",
        "id": ""
      },
      "startTime": 62.766666666666666,
      "endTime": 63.96666666666667,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "wmob3",
      "speakerName": "練習生C",
      "speakerNameEn": "Trainee",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-wmob3.png",
      "voiceUrl": null,
      "text": "悔しいけど莉央しかいないよ……",
      "translations": {
        "en": "It's frustrating‚ but she's the only one who makes sense…",
        "id": ""
      },
      "startTime": 63.96666666666667,
      "endTime": 66.76666666666667,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_vanstudio-00-noon.webp",
