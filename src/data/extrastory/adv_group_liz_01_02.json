      "type": "dialogue",
      "speakerCode": null,
      "speakerName": "",
      "speakerNameEn": "",
      "iconUrl": null,
      "voiceUrl": null,
      "text": "――三枝の言葉にレッスン場の空気が一瞬で変わった",
