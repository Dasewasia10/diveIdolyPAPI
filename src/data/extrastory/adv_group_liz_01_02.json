      "endTime": 4.322086155414581,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "wmob1",
      "speakerName": "ダンスコーチB",
      "speakerNameEn": "Dance",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-wmob1.png",
      "voiceUrl": null,
      "text": "はい、今日はここまで",
      "translations": {
        "en": "Okay‚ that's all for today.",
        "id": ""
      },
      "startTime": 4.533333333333333,
      "endTime": 6.433333357175191,
