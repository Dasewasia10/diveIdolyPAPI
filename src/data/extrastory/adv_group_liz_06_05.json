    },
    {
      "type": "dialogue",
      "speakerCode": "unknown",
      "speakerName": "オーナー",
      "speakerNameEn": "Owner",
      "iconUrl": null,
      "voiceUrl": "https://apiip.dasewasia.my.id/extraStoryVoice/sud_vo_adv_group_liz_06_05/sud_vo_adv_group_liz_06_05-owner001.m4a",
      "text": "見事だったよ、君達\nさすが朝倉くんが見込んだパフォーマーだ",
      "translations": {
        "en": "That was amazing‚ you guys.\nAs expected of the performers Asakura had his eye on.",
        "id": ""
      },
      "startTime": 280.0381444294,
      "sfxList": []
    },
    {
      "type": "background",
