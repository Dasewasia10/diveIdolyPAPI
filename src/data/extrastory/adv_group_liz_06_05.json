      "speakerName": "神崎莉央",
      "speakerNameEn": "Rio",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-rio.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/extraStoryVoice/sud_vo_adv_group_liz_06_05/sud_vo_adv_group_liz_06_05-rio011.m4a",
      "text": "くすっ、しょうがない後輩ね……",
      "translations": {
        "en": "Chuckles What troublesome juniors we have…",
        "id": ""
      },
      "startTime": 274.4381444294,
