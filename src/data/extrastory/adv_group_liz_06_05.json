      "speakerCode": "unknown",
      "speakerName": "一同",
      "speakerNameEn": "Everyone",
      "iconUrl": null,
      "voiceUrl": null,
      "text": "『Shock out, Dance!!』",
      "translations": {
        "en": "『Shock out, Dance!!』",
        "id": ""
      },
      "startTime": 177.5525222777,
      "sfxList": []
