    },
    {
      "type": "dialogue",
      "speakerCode": "rio",
      "speakerName": "神崎莉央",
      "speakerNameEn": "Rio",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-rio.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/extraStoryVoice/sud_vo_adv_group_liz_06_05/sud_vo_adv_group_liz_06_05-rio009.m4a",
      "text": "はぁ、はぁ、忘れてたわね、この一体感……\n情熱、感情……取り戻したのね、私達……",
      "translations": {
        "en": "Pant Pant I'd forgotten… this feeling of unity…\nPassion‚ emotion… We've regained them…",
        "id": ""
      },
      "startTime": 233.7381444294,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_amepark-00-noon.webp",
      "bgName": "america_park",
      "startTime": 240.3048110961
    },
    {
      "type": "dialogue",
      "speakerCode": "kkr",
      "speakerName": "赤崎こころ",
      "speakerNameEn": "Kokoro",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-kokoro.png",
