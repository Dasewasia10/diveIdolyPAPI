      "translations": {
        "en": "Actually‚ I think this semifinal\nis the biggest hurdle. More so than the finals‚ this is it.",
        "id": ""
      },
      "startTime": 287.20888774470103,
      "endTime": 295.0954637297,
      "sfxList": []
    },
    {
      "type": "background",
