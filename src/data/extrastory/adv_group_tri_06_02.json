      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_okuyamasake-00-noon.webp",
      "bgName": "s1",
      "startTime": 281.5
    },
    {
      "type": "dialogue",
      "speakerCode": "smr",
      "speakerName": "奥山すみれ",
      "speakerNameEn": "Sumire",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-sumire.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/extraStoryVoice/sud_vo_adv_group_tri_06_02/sud_vo_adv_group_tri_06_02-smr015.m4a",
      "text": "私！　二人ともっと歌いたい！！\nでも……家族のことも助けたいよ！！",
      "translations": {
        "en": "I want to sing more with you two!!\nBut… I want to help my family too!!",
        "id": ""
      },
      "startTime": 286.7,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_okuyamasake-00-noon.webp",
      "bgName": "s1",
      "startTime": 291.0333333333
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_okuyamasake-00-noon.webp",
      "bgName": "s1",
      "startTime": 294.8333333333
    },
    {
      "type": "dialogue",
      "speakerCode": "smr",
      "speakerName": "奥山すみれ",
      "speakerNameEn": "Sumire",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-sumire.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/extraStoryVoice/sud_vo_adv_group_tri_06_02/sud_vo_adv_group_tri_06_02-smr016.m4a",
      "text": "どうしたらいいのか分かんないよ……\n瑠依ちゃん、優ちゃん……私を、助けて……！",
      "translations": {
        "en": "I don't know what to do…\nRui-chan‚ Yu-chan… Help me…!",
