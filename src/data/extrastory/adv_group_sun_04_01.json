      "speakerNameEn": "？？？",
      "iconUrl": null,
      "voiceUrl": "https://apiip.dasewasia.my.id/extraStoryVoice/sud_vo_adv_group_sun_04_01/sud_vo_adv_group_sun_04_01-hoshimura005.m4a",
      "text": "アイドルがキラキラ輝けるステージを作るのが\n今の私のお仕事なのよ。今日のステージ、楽しかった？",
      "translations": {
        "en": "My job is to create a stage where idols\ncan shine brightly. Did you enjoy today's stage?",
        "id": ""
      },
      "startTime": 216.5554980518,
      "endTime": 225.2288172008,
      "sfxList": []
    },
