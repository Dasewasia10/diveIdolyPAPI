      "speakerCode": "unknown",
      "speakerName": "ダンスコーチ",
      "speakerNameEn": "Dance",
      "iconUrl": null,
      "voiceUrl": null,
      "text": "そう……受験じゃ仕方ないわね……",
      "translations": {
        "en": "I see… Well‚ if it's for your entrance exams‚ I understand…",
        "id": ""
      },
      "startTime": 245.7333934146,
      "sfxList": []
