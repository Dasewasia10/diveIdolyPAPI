      "type": "dialogue",
      "speakerCode": "unknown",
      "speakerName": "ダンスコーチ",
      "speakerNameEn": "Dance",
      "iconUrl": null,
      "voiceUrl": null,
      "text": "今度大きな大会があるんだけど",
