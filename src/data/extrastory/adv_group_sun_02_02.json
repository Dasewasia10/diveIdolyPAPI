      "speakerCode": "unknown",
      "speakerName": "ダンスコーチ",
      "speakerNameEn": "Dance",
      "iconUrl": null,
      "voiceUrl": null,
      "text": "もしその気になったら、いつでも声を掛けてちょうだい",
      "translations": {
        "en": "If you change your mind‚ you can always let me know.",
        "id": ""
      },
      "startTime": 250.3333934146,
      "sfxList": []
    },
