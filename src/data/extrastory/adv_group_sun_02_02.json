      "type": "dialogue",
      "speakerCode": "unknown",
      "speakerName": "ダンスコーチ",
      "speakerNameEn": "Dance",
      "iconUrl": null,
      "voiceUrl": null,
      "text": "良かったらあなたも参加してみない？",
      "translations": {
        "en": "would you like to participate?",
        "id": ""
      },
      "startTime": 227.3333842594,
      "sfxList": []
    },
