      "type": "dialogue",
      "speakerCode": "unknown",
      "speakerName": "ダンスコーチ",
      "speakerNameEn": "Dance",
      "iconUrl": null,
      "voiceUrl": null,
      "text": "プロになる気があるなら大会で実績を残さなきゃ",
