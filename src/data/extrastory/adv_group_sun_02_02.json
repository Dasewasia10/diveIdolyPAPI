      "speakerName": "ダンスコーチ",
      "speakerNameEn": "Dance",
      "iconUrl": null,
      "voiceUrl": null,
      "text": "今のパフォーマンス、凄く良かったわ",
      "translations": {
        "en": "That was a great performance.",
        "id": ""
      },
      "startTime": 218.6000407535,
