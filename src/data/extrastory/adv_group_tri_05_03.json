      "bgName": "stage02",
      "startTime": 319.9333333333
    },
    {
      "type": "dialogue",
      "speakerCode": "smr",
      "speakerName": "奥山すみれ",
      "speakerNameEn": "Sumire",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-sumire.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/extraStoryVoice/sud_vo_adv_group_tri_05_03/sud_vo_adv_group_tri_05_03-smr021.m4a",
      "text": "ぎ、犠牲なんて……私、そんなこと……",
      "translations": {
        "en": "S-Sacrifice…? I would never…",
        "id": ""
      },
      "startTime": 327,
      "endTime": 331.5598414421,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "mmob1",
      "speakerName": "すみれの兄",
      "speakerNameEn": "Sumire’s",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-mmob1.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/extraStoryVoice/sud_vo_adv_group_tri_05_03/sud_vo_adv_group_tri_05_03-smrbro012.m4a",
      "text": "すみれ、お前の夢が叶うように\n俺も応援してるから",
      "translations": {
        "en": "Sumire‚ I'll be supporting you\nso that your dreams come true.",
        "id": ""
      },
      "startTime": 331.7666666667,
      "endTime": 338.0000000001,
      "sfxList": []
    },
    {
      "type": "background",
