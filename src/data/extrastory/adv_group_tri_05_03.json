      "bgName": "stage02",
      "startTime": 310.1
    },
    {
      "type": "dialogue",
      "speakerCode": "mmob1",
      "speakerName": "すみれの兄",
      "speakerNameEn": "Sumire’s",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-mmob1.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/extraStoryVoice/sud_vo_adv_group_tri_05_03/sud_vo_adv_group_tri_05_03-smrbro010.m4a",
      "text": "俺は両親とこの店を守る\nいつでもお前が帰って来られるように",
      "translations": {
        "en": "I will protect our parents and this shop.\nSo that you can always come back.",
        "id": ""
      },
      "startTime": 313.9333333333,
      "endTime": 319.6666666667,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "mmob1",
      "speakerName": "すみれの兄",
      "speakerNameEn": "Sumire’s",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-mmob1.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/extraStoryVoice/sud_vo_adv_group_tri_05_03/sud_vo_adv_group_tri_05_03-smrbro011.m4a",
      "text": "だから安心して、お前はお前の夢を追え\n……今までみたいに、俺の犠牲になるな",
      "translations": {
        "en": "So don't worry‚ you chase your dreams.\n…Don't sacrifice yourself for me like you did before.",
        "id": ""
      },
      "startTime": 319.9333333333,
      "endTime": 326.7333333333,
      "sfxList": []
    },
    {
      "type": "background",
