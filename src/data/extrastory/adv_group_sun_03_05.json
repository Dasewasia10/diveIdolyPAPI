      "text": "兵藤さんの正直な気持ちを聞かせてくれないか？",
      "translations": {
        "en": "Could you tell me your honest feelings‚ Hyodo-san?",
        "id": ""
      },
      "startTime": 203.0557961699,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "szk",
      "speakerName": "兵藤雫",
      "speakerNameEn": "Shizuku",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-shizuku.png",
