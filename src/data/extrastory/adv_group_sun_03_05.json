      "startTime": 227.0458192187,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "szk",
      "speakerName": "兵藤雫",
      "speakerNameEn": "Shizuku",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-shizuku.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/extraStoryVoice/sud_vo_adv_group_sun_03_05/sud_vo_adv_group_sun_03_05-szk020.m4a",
      "text": "だから、お願いします……\n私をアイドルにして下さい……！",
      "translations": {
        "en": "So please…\nmake me an idol…!",
        "id": ""
      },
      "startTime": 234.4458192187,
      "sfxList": []
    },
