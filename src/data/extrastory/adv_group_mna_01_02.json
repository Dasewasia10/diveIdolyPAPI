      "iconUrl": null,
      "voiceUrl": "https://apiip.dasewasia.my.id/extraStoryVoice/sud_vo_adv_group_mna_01_02/sud_vo_adv_group_mna_01_02-bstudenta002.m4a",
      "text": "河野が風邪で早退しちまったよ～\nだからさ、今日、俺と――",
      "translations": {
        "en": "Kawano-chan left early because of a cold!\nSo‚ today‚ how about hanging out with me――",
        "id": ""
      },
      "startTime": 53.56666666666667,
      "sfxList": []
    },
    {
      "type": "background",
