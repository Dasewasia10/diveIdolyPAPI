  "script": [
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_schoolclass-00-noon.webp",
      "bgName": "schoolclass-00-noon",
      "startTime": null
    },
    {
      "type": "dialogue",
      "speakerCode": "mna",
      "speakerName": "長瀬麻奈",
      "speakerNameEn": "Mana",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-mana.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/extraStoryVoice/sud_vo_adv_group_mna_01_02/sud_vo_adv_group_mna_01_02-mna001.m4a",
      "text": "う～ん、行こっかな……\nでもなー。どうしよ……",
      "translations": {
        "en": "Hmm‚ should I go…\nBut I don't know…",
        "id": ""
      },
      "startTime": 4.033333333333333,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_schoolclass-00-noon.webp",
      "bgName": "schoolclass-00-noon",
      "startTime": 6.9
    },
    {
      "type": "dialogue",
      "speakerCode": "koh",
      "speakerName": "{user}",
      "speakerNameEn": "{user}",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-kohei.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/extraStoryVoice/sud_vo_adv_group_mna_01_02/sud_vo_adv_group_mna_01_02-koh001.m4a",
      "text": "長瀬、どうかした？",
      "translations": {
        "en": "Nagase‚ what's wrong?",
        "id": ""
      },
      "startTime": 6.9,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "mna",
      "speakerName": "長瀬麻奈",
      "speakerNameEn": "Mana",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-mana.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/extraStoryVoice/sud_vo_adv_group_mna_01_02/sud_vo_adv_group_mna_01_02-mna002.m4a",
      "text": "あ、{user}くんか\n実は……ちょっと迷ってて。これに誘われたの",
      "translations": {
        "en": "Oh‚ it's {user}.\nActually… I'm hesitating a bit. I was invited to this.",
        "id": ""
      },
      "startTime": 10.8,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_schoolclass-00-noon.webp",
      "bgName": "schoolclass-00-noon",
      "startTime": 15.433333333333334
    },
    {
      "type": "dialogue",
      "speakerCode": "koh",
      "speakerName": "{user}",
      "speakerNameEn": "{user}",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-kohei.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/extraStoryVoice/sud_vo_adv_group_mna_01_02/sud_vo_adv_group_mna_01_02-koh002.m4a",
      "text": "（アイドルのライブか……どこかで聞いたことのある）\n（有名なアイドルグループだ）",
      "translations": {
        "en": "（An idol concert… I've heard of this somewhere.）\n（It's a famous idol group.）",
        "id": ""
      },
      "startTime": 19.066666666666666,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "mna",
      "speakerName": "長瀬麻奈",
      "speakerNameEn": "Mana",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-mana.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/extraStoryVoice/sud_vo_adv_group_mna_01_02/sud_vo_adv_group_mna_01_02-mna003.m4a",
      "text": "良かったら{user}くんが行く？\n相手の人に連絡はしておくから",
      "translations": {
        "en": "If you want‚ {user}‚ would you go?\nI'll let the other person know.",
        "id": ""
      },
      "startTime": 23.133333333333336,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "koh",
      "speakerName": "{user}",
      "speakerNameEn": "{user}",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-kohei.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/extraStoryVoice/sud_vo_adv_group_mna_01_02/sud_vo_adv_group_mna_01_02-koh003.m4a",
      "text": "…………長瀬が行った方がいいよ",
      "translations": {
        "en": "…Nagase‚ you should go.",
        "id": ""
      },
      "startTime": 25.9,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_schoolclass-00-noon.webp",
      "bgName": "schoolclass-00-noon",
      "startTime": 29.366666666666667
    },
    {
      "type": "dialogue",
      "speakerCode": "mna",
      "speakerName": "長瀬麻奈",
      "speakerNameEn": "Mana",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-mana.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/extraStoryVoice/sud_vo_adv_group_mna_01_02/sud_vo_adv_group_mna_01_02-mna004.m4a",
      "text": "なんで？",
      "translations": {
        "en": "Why?",
        "id": ""
      },
      "startTime": 29.366666666666667,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "koh",
      "speakerName": "{user}",
      "speakerNameEn": "{user}",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-kohei.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/extraStoryVoice/sud_vo_adv_group_mna_01_02/sud_vo_adv_group_mna_01_02-koh004.m4a",
      "text": "――長瀬は歌、好きだろ？",
      "translations": {
        "en": "――Nagase‚ you like singing‚ don't you?",
        "id": ""
      },
      "startTime": 30.533333333333335,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_schoolclass-00-noon.webp",
      "bgName": "schoolclass-00-noon",
      "startTime": 33
    },
    {
      "type": "dialogue",
      "speakerCode": "mna",
      "speakerName": "長瀬麻奈",
      "speakerNameEn": "Mana",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-mana.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/extraStoryVoice/sud_vo_adv_group_mna_01_02/sud_vo_adv_group_mna_01_02-mna005.m4a",
      "text": "……うん、そうだね",
      "translations": {
        "en": "…Yeah‚ you're right.",
        "id": ""
      },
      "startTime": 33,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "mna",
      "speakerName": "長瀬麻奈",
      "speakerNameEn": "Mana",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-mana.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/extraStoryVoice/sud_vo_adv_group_mna_01_02/sud_vo_adv_group_mna_01_02-mna006.m4a",
      "text": "私が行くよ\nばいばい、{user}くん。また明日ね",
      "translations": {
        "en": "I'll go then.\nBye-bye‚ {user}. See you tomorrow.",
        "id": ""
      },
      "startTime": 38.666666666666664,
      "sfxList": [
        {
          "src": "https://apiip.dasewasia.my.id/storyBgm/sud_se_adv_walk-in-single-02.m4a",
          "delay": 4466.666666666669,
          "startTime": 43.13333333333333
        }
      ]
    },
    {
