      "bgName": "hoshiarcade-00-night",
      "startTime": 64.66666666666667
    },
    {
      "type": "dialogue",
      "speakerCode": "mna",
      "speakerName": "長瀬麻奈",
      "speakerNameEn": "Mana",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-mana.png",
