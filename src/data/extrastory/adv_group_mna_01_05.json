      "speakerCode": "unknown",
      "speakerName": "アイドルA",
      "speakerNameEn": "Idol",
      "iconUrl": null,
      "voiceUrl": null,
      "text": "星見市のみなさん、こんにちはー！",
      "translations": {
        "en": "Hello‚ everyone from Hoshimi City!",
