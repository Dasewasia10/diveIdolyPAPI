      "speakerCode": "unknown",
      "speakerName": "アイドルA",
      "speakerNameEn": "Idol",
      "iconUrl": null,
      "voiceUrl": null,
      "text": "私、来週デビューしまーす！",
      "translations": {
        "en": "I'm debuting next week!",
        "id": ""
      },
      "startTime": 67.56666666666666,
