      "speakerNameEn": "Idol",
      "iconUrl": null,
      "voiceUrl": null,
      "text": "本日は日曜日に新宿ルミナで行われる",
      "translations": {
        "en": "Today‚ I've come to promote my debut live",
        "id": ""
      },
      "startTime": 71.43333333333334,
