      "speakerNameEn": "Nurse",
      "iconUrl": null,
      "voiceUrl": null,
      "text": "分かったわ。私も手伝うから、一緒に頑張りましょう",
      "translations": {
        "en": "Alright. I'll help you‚ so let's work hard together.",
