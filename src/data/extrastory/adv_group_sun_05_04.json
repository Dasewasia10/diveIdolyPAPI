        "en": "Eh? Mana… chan?",
        "id": ""
      },
      "startTime": 339.5272034246,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_cemetery-00-noon.webp",
      "bgName": "cemetery-00-noon",
      "startTime": 343.6805368819
    },
    {
      "type": "dialogue",
      "speakerCode": "hrk",
      "speakerName": "佐伯遙子",
      "speakerNameEn": "Haruko",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-haruko.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/extraStoryVoice/sud_vo_adv_group_sun_05_04/sud_vo_adv_group_sun_05_04-hrk004.m4a",
      "text": "あ……ごめんなさい。こっちをじっと見てるから\nてっきりここのお墓に用があるのかと思って……",
      "translations": {
        "en": "Ah… sorry. Since you were staring this way‚\nI thought you had business at this grave…",
        "id": ""
      },
      "startTime": 348.1000386556,
      "sfxList": []
    },
    {
      "type": "background",
