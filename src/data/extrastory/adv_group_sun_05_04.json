    {
      "type": "dialogue",
      "speakerCode": "hrk",
      "speakerName": "佐伯遙子",
      "speakerNameEn": "Haruko",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-haruko.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/extraStoryVoice/sud_vo_adv_group_sun_05_04/sud_vo_adv_group_sun_05_04-hrk005.m4a",
      "text": "ええ、彼女はみんなに愛されていたわ\n今でもこんなに愛されて……私とは全然違うわね……",
      "translations": {
        "en": "Yes‚ she was loved by everyone.\nStill so loved even now… It's completely different from me…",
        "id": ""
      },
      "startTime": 365.0000386556,
      "sfxList": []
    },
    {
