          "startTime": 324.4333424886
        }
      ]
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_cemetery-00-noon.webp",
      "bgName": "cemetery-00-noon",
      "startTime": 324.1139842111
    },
    {
      "type": "dialogue",
      "speakerCode": "skr",
      "speakerName": "川咲さくら",
