    },
    {
      "type": "dialogue",
      "speakerCode": "unknown",
      "speakerName": "女の子",
      "speakerNameEn": "Girl",
      "iconUrl": null,
      "voiceUrl": "https://apiip.dasewasia.my.id/extraStoryVoice/sud_vo_adv_group_sun_05_01/sud_vo_adv_group_sun_05_01-tomo004.m4a",
      "text": "……お母さんが大好きなんだね\nあなたは優しいなぁ",
      "translations": {
        "en": "…You really love your mom‚ don't you?\nYou're so kind.",
        "id": ""
      },
      "startTime": 415.8811792372,
      "endTime": 420.80120367989997,
      "sfxList": []
    },
    {
