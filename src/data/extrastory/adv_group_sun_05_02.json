      "speakerNameEn": "Sakura's",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-wmob1.png",
      "voiceUrl": null,
      "text": "夏祭りの会場が騒がしいわね。何か始まったのかしら？",
      "translations": {
        "en": "The festival grounds are getting noisy. Did something start?",
        "id": ""
