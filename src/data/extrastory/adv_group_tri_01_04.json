      "bgName": "s2",
      "startTime": 104.78376683197509
    },
    {
      "type": "sfx",
      "src": "https://apiip.dasewasia.my.id/storyBgm/sud_se_adv_walk-in-single-01.m4a",
      "startTime": 106.13333333333334
    },
    {
      "type": "dialogue",
      "speakerCode": "wmob3",
      "speakerName": "ダンスコーチB",
      "speakerNameEn": "Dance",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-wmob3.png",
      "voiceUrl": null,
      "text": "みんな、集まってちょうだい。突然だけど",
      "translations": {
        "en": "Everyone‚ gather around please. This is sudden‚ but",
        "id": ""
      },
      "startTime": 107.06666666666666,
      "endTime": 111.2,
      "sfxList": [
        {
          "src": "https://apiip.dasewasia.my.id/storyBgm/sud_se_adv_walk-in-single-01.m4a",
          "delay": 0,
          "startTime": 106.76666666666668
        }
      ]
    },
    {
      "type": "dialogue",
      "speakerCode": "wmob3",
      "speakerName": "ダンスコーチB",
      "speakerNameEn": "Dance",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-wmob3.png",
      "voiceUrl": null,
      "text": "一週間後にオーディションを行うことになったわ",
      "translations": {
        "en": "we’ll be holding an audition in a week.",
        "id": ""
      },
      "startTime": 111.2,
      "endTime": 114.79848086039227,
      "sfxList": []
    },
    {
      "type": "background",
