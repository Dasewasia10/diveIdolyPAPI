    },
    {
      "type": "dialogue",
      "speakerCode": null,
      "speakerName": "",
      "speakerNameEn": "",
      "iconUrl": null,
      "voiceUrl": null,
      "text": "――レッスンルームの前。三人は防音扉の窓から",
      "translations": {
        "en": "――In front of the lesson room. The three of them peek through the window of the soundproof door",
        "id": ""
      },
      "startTime": 124.07095315676605,
      "endTime": 128.03095305186187,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": null,
      "speakerName": "",
      "speakerNameEn": "",
      "iconUrl": null,
      "voiceUrl": null,
      "text": "練習しているアイドルの様子を覗き見る",
      "translations": {
        "en": "to watch the idols practicing.",
        "id": ""
      },
      "startTime": 128.03761982343303,
      "endTime": 131.27761973760235,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_dancestudiocorridor-00-noon.webp",
      "bgName": "bg2",
      "startTime": 131.4709531567661
    },
    {
      "type": "dialogue",
      "speakerCode": "rui",
      "speakerName": "天動瑠依",
      "speakerNameEn": "Rui",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-rui.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/extraStoryVoice/sud_vo_adv_group_tri_02_05/sud_vo_adv_group_tri_02_05-rui009.m4a",
      "text": "あの子達は、確か……",
      "translations": {
        "en": "Those girls are‚ if I’m not mistaken…",
        "id": ""
      },
      "startTime": 131.4709531567661,
      "endTime": 133.6448306820957,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "yu",
      "speakerName": "鈴村優",
      "speakerNameEn": "Yu",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-yu.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/extraStoryVoice/sud_vo_adv_group_tri_02_05/sud_vo_adv_group_tri_02_05-yu010.m4a",
      "text": "星見プロの新人さん達やんなぁ\nなんや、見違えたなぁ",
      "translations": {
        "en": "Aren’t they the rookies from Hoshimi Pro?\nWow‚ they’ve changed a lot~",
        "id": ""
      },
      "startTime": 133.84483068209568,
      "endTime": 139.59483049136082,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_dancestudiocorridor-00-noon.webp",
      "bgName": "bg2",
