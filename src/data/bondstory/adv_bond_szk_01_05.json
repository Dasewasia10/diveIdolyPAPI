    },
    {
      "type": "dialogue",
      "speakerCode": "rio",
      "speakerName": "神崎莉央",
      "speakerNameEn": "Rio",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-rio.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/bondStoryVoice/sud_vo_adv_bond_szk_01_05/sud_vo_adv_bond_szk_01_05-rio011.m4a",
      "text": "もしもし{user}さん\nちょっと雫のことで話があるんだけど",
      "translations": {
        "en": "Hello‚ {user}-san.\nI have something to discuss regarding Shizuku.",
