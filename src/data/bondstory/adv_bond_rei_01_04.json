      "text": "…………すー……すー……",
      "translations": {
        "en": "……Zzz… zzz…",
        "id": ""
      },
      "startTime": 65.1999979895,
      "sfxList": [
        {
          "src": "https://apiip.dasewasia.my.id/storyBgm/sud_se_adv_walk-living-single-01.m4a",
          "delay": 5533.33534379999
        }
