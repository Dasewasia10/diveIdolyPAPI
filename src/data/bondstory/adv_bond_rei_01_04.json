    {
      "type": "dialogue",
      "speakerCode": "rei",
      "speakerName": "一ノ瀬怜",
      "speakerNameEn": "Rei",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-rei.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/bondStoryVoice/sud_vo_adv_bond_rei_01_04/sud_vo_adv_bond_rei_01_04-rei004.m4a",
      "text": "んん……なんなのよぉ……",
      "translations": {
        "en": "Mmm… what is it now…",
