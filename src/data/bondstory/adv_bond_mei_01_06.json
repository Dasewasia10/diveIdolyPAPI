      "bgName": "dressingroom-00-noon",
      "startTime": 35.1666688919
    },
    {
      "type": "dialogue",
      "speakerCode": "mei",
      "speakerName": "早坂芽衣",
      "speakerNameEn": "早坂芽衣",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-mei.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/bondStoryVoice/sud_vo_adv_bond_mei_01_06/sud_vo_adv_bond_mei_01_06-mei004.m4a",
      "text": "ほら、見て見て！　猫耳とおひげが付く\nフィルターとかあるんだよ！　にゃんにゃ～ん",
      "translations": {
        "en": "ほら、見て見て！　猫耳とおひげが付く\nフィルターとかあるんだよ！　にゃんにゃ～ん",
        "id": ""
      },
      "startTime": 35.1666688919,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_dressingroom-00-noon.webp",
      "bgName": "dressingroom-00-noon",
      "startTime": 42.2333363216
    },
    {
      "type": "dialogue",
      "speakerCode": "ski",
      "speakerName": "白石沙季",
      "speakerNameEn": "白石沙季",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-saki.png",
