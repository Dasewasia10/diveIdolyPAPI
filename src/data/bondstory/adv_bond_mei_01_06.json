    },
    {
      "type": "dialogue",
      "speakerCode": "ski",
      "speakerName": "白石沙季",
      "speakerNameEn": "白石沙季",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-saki.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/bondStoryVoice/sud_vo_adv_bond_mei_01_06/sud_vo_adv_bond_mei_01_06-ski006.m4a",
      "text": "……あれ？　何もないところにフィルターが\n反応して……？　壊れているのかもしれませんね",
      "translations": {
        "en": "……あれ？　何もないところにフィルターが\n反応して……？　壊れているのかもしれませんね",
