    {
      "type": "dialogue",
      "speakerCode": "mei",
      "speakerName": "早坂芽衣",
      "speakerNameEn": "早坂芽衣",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-mei.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/bondStoryVoice/sud_vo_adv_bond_mei_01_06/sud_vo_adv_bond_mei_01_06-mei008.m4a",
      "text": "えー？　壊れてないと思うけど……\nほら、ちゃんと芽衣にも反応するよー？",
      "translations": {
        "en": "えー？　壊れてないと思うけど……\nほら、ちゃんと芽衣にも反応するよー？",
