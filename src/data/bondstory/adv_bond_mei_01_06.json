    {
      "type": "dialogue",
      "speakerCode": "ski",
      "speakerName": "白石沙季",
      "speakerNameEn": "白石沙季",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-saki.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/bondStoryVoice/sud_vo_adv_bond_mei_01_06/sud_vo_adv_bond_mei_01_06-ski008.m4a",
      "text": "で、でも今、本当に何もない所に……！\n……あれ……気のせいだったのかもしれません……",
      "translations": {
        "en": "で、でも今、本当に何もない所に……！\n……あれ……気のせいだったかもしれません……",
