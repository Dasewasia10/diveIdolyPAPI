      "bgName": "dressingroom-00-noon",
      "startTime": 114.0666635514
    },
    {
      "type": "dialogue",
      "speakerCode": "ski",
      "speakerName": "白石沙季",
      "speakerNameEn": "白石沙季",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-saki.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/bondStoryVoice/sud_vo_adv_bond_mei_01_06/sud_vo_adv_bond_mei_01_06-ski007.m4a",
      "text": "……ひっ！　今、顔が笑って……！？\nこれ、おかしいです……！　開発元に連絡しないと……",
      "translations": {
        "en": "……ひっ！　今、顔が笑って……！？\nこれ、おかしいです……！　開発元に連絡しないと……",
