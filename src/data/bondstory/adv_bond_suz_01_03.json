    },
    {
      "type": "dialogue",
      "speakerCode": "suz",
      "speakerName": "成宮すず",
      "speakerNameEn": "Suzu",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-suzu.png",
      "voiceUrl": null,
      "text": "怜、あなたは本当に運がいいですわね！",
      "translations": {
        "en": "Rei‚ you're so lucky!",
        "id": ""
      },
      "startTime": 67.5333336513,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "suz",
      "speakerName": "成宮すず",
      "speakerNameEn": "Suzu",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-suzu.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/bondStoryVoice/sud_vo_adv_bond_suz_01_03/sud_vo_adv_bond_suz_01_03-suz007.m4a",
      "text": "私ちょーど暇をしていましたの！　相手をして下さる？",
      "translations": {
        "en": "I was so bored! Will you play with me?",
        "id": ""
      },
      "startTime": 71.8000010173,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "rei",
