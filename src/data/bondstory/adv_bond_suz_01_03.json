      "startTime": 86.3,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "rei",
      "speakerName": "一ノ瀬怜",
      "speakerNameEn": "Rei",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-rei.png",
