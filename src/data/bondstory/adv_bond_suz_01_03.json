    },
    {
      "type": "dialogue",
      "speakerCode": "suz",
      "speakerName": "成宮すず",
      "speakerNameEn": "Suzu",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-suzu.png",
      "voiceUrl": null,
      "text": "まあいいですわ。とりあえずやりますわよ",
      "translations": {
        "en": "Well‚ it's okay. Let's just play it for now",
