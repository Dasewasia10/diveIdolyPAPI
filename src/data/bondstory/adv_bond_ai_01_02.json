      "speakerNameEn": "Ai",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-ai.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/bondStoryVoice/sud_vo_adv_bond_ai_01_02/sud_vo_adv_bond_ai_01_02-ai010.m4a",
      "text": "筋トレは好きだからやってるだけだし……\n理想の体型……うーん……",
