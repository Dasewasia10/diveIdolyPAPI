    },
    {
      "type": "dialogue",
      "speakerCode": "rei",
      "speakerName": "一ノ瀬怜",
      "speakerNameEn": "Rei",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-rei.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/bondStoryVoice/sud_vo_adv_bond_rei_01_01/sud_vo_adv_bond_rei_01_01-rei008.m4a",
      "text": "あ……こ、こほんっ",
      "translations": {
        "en": "Ah… C-Cough",
        "id": ""
      },
      "startTime": 53.7000039419,
      "sfxList": []
    },
    {
      "type": "background",
