      "speakerCode": "rei",
      "speakerName": "一ノ瀬怜",
      "speakerNameEn": "Rei",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-rei.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/bondStoryVoice/sud_vo_adv_bond_rei_01_01/sud_vo_adv_bond_rei_01_01-rei017.m4a",
      "text": "（とんかつパワーで、一ノ瀬怜、完全復活っ！）",
      "translations": {
        "en": "（With power of pork cutlet‚ Rei Ichinose‚ completely revived!）",
