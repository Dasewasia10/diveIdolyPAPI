      "bgName": "tokyosmrroom-00-night",
      "startTime": 63.5666665714
    },
    {
      "type": "dialogue",
      "speakerCode": "smr",
      "speakerName": "奥山すみれ",
      "speakerNameEn": "Sumire",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-sumire.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/bondStoryVoice/sud_vo_adv_bond_kkr_01_04/sud_vo_adv_bond_kkr_01_04-smr005.m4a",
      "text": "子役の子をからかったり、悪戯したりしなければ\nいいだけじゃないかな……？",
      "translations": {
        "en": "Isn't it fine if you don't tease or prank\nchild actor…?",
        "id": ""
      },
      "startTime": 63.5666665714,
      "sfxList": []
    },
    {
      "type": "background",
