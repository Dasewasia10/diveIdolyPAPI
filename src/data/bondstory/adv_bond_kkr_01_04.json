      "text": "そ、そんなまっすぐな目で見つめられても\n困るっちゃ～……",
      "translations": {
        "en": "I-It's difficult for you to look at me with\nsuch straight eyes~…",
        "id": ""
      },
      "startTime": 75.4999953271,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_tokyosmrroom-01-night.webp",
      "bgName": "tokyosmrroom-00-night",
      "startTime": 80.9333271345
    },
    {
      "type": "dialogue",
      "speakerCode": "kkr",
      "speakerName": "赤崎こころ",
      "speakerNameEn": "Kokoro",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-kokoro.png",
