      "startTime": 72.4333333334
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_tokyosmrroom-01-night.webp",
      "bgName": "tokyosmrroom-00-night",
      "startTime": 75.4999953271
    },
    {
      "type": "dialogue",
      "speakerCode": "smr",
      "speakerName": "奥山すみれ",
