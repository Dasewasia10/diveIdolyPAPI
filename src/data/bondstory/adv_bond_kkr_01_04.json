      "text": "すみれちゃん！　こころの妹になってくれませんか！？",
      "translations": {
        "en": "Sumire-chan! Would you be a Kokoro's imouto!?",
        "id": ""
      },
      "startTime": 0.8,
      "sfxList": []
    },
    {
      "type": "background",
