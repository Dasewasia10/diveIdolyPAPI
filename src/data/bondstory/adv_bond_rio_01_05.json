    },
    {
      "type": "dialogue",
      "speakerCode": "rio",
      "speakerName": "神崎莉央",
      "speakerNameEn": "Rio",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-rio.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/bondStoryVoice/sud_vo_adv_bond_rio_01_05/sud_vo_adv_bond_rio_01_05-rio015.m4a",
      "text": "あぁ……シロサイと一緒に帰ってしまったわ\n……この感じだとしばらくシロサイと共に過ごしそうね",
      "translations": {
