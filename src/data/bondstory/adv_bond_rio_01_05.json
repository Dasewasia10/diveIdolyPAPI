    },
    {
      "type": "dialogue",
      "speakerCode": "kan",
      "speakerName": "kana",
      "speakerNameEn": "kana",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-kana.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/bondStoryVoice/sud_vo_adv_bond_rio_01_05/sud_vo_adv_bond_rio_01_05-kan007.m4a",
      "text": "はい、五分経った！　もうkanaは帰るわ！\nマネージャーには莉央から言っといて、じゃあお疲れ！",
      "translations": {
        "en": "Alright‚ five minutes are up! kana is going home!\nRio‚ you tell the manager. See ya!",
