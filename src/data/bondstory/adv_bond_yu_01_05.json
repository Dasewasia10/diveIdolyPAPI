      "speakerCode": "yu",
      "speakerName": "鈴村優",
      "speakerNameEn": "Yu",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-yu.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/bondStoryVoice/sud_vo_adv_bond_yu_01_05/sud_vo_adv_bond_yu_01_05-yu020.m4a",
      "text": "（すみれちゃんには沖田総司をやってもらったら）\n（トリエルで新選組ごっこが出来そうやな！　うん、完璧）",
      "translations": {
        "en": "（If I have Sumire-chan play Okita Souji‚）\n（we can play Shinsengumi as TRINITYAiLE! Yes‚ perfect.）",
        "id": ""
      },
      "startTime": 166.7562632362,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_schoolclass-00-noon.webp",
      "bgName": "env_adv_2d_schoolclass-00-noon",
      "startTime": 176.7690520088
    },
    {
      "type": "dialogue",
      "speakerCode": "yu",
      "speakerName": "鈴村優",
      "speakerNameEn": "Yu",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-yu.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/bondStoryVoice/sud_vo_adv_bond_yu_01_05/sud_vo_adv_bond_yu_01_05-yu021.m4a",
