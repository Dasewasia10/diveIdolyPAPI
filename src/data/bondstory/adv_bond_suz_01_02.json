      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-suzu.png",
      "voiceUrl": null,
      "text": "頂上までは行きませんわ。ほら、あそこを見てください",
      "translations": {
        "en": "We're not going to the top. Look over",
        "id": ""
      },
      "startTime": 94.233334577,
      "sfxList": []
    },
