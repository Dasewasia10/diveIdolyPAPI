      "speakerNameEn": "Suzu",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-suzu.png",
      "voiceUrl": null,
      "text": "とっても楽しくて、気持ち良くて",
      "translations": {
        "en": "Really fun‚ feels good",
