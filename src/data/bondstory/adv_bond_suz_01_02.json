      "text": "あら？　怜は楽しくないんですの？",
      "translations": {
        "en": "Oh? Rei‚ you're not having fun?",
        "id": ""
      },
      "startTime": 69.1666679103,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_mountainroad-00-noon.webp",
      "bgName": "mountainroad-00-noon",
      "startTime": 69.1666679103
    },
    {
      "type": "dialogue",
      "speakerCode": "suz",
      "speakerName": "成宮すず",
      "speakerNameEn": "Suzu",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-suzu.png",
