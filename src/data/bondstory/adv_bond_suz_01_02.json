      "text": "びよーんってなる所ですわ！",
      "translations": {
        "en": "where I think‚ Boingー!",
        "id": ""
      },
      "startTime": 30.4333333333,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "rei",
