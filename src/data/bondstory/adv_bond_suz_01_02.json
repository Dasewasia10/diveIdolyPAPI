      "text": "自分が大きくなった感じがして好きですわ",
      "translations": {
        "en": "and I like the feeling of growing up",
        "id": ""
      },
      "startTime": 79.7666666667,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "rei",
      "speakerName": "一ノ瀬怜",
