      "speakerNameEn": "Rei",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-rei.png",
      "voiceUrl": null,
      "text": "いや、だからどこよ。全く分かんない",
      "translations": {
        "en": "No‚ so where is it? I have no idea",
        "id": ""
      },
      "startTime": 33.6000002264,
      "sfxList": []
    },
    {
      "type": "background",
