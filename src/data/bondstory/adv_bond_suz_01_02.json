      "text": "もしかして、山の頂上ってこと……？",
      "translations": {
        "en": "Maybe‚ is this the top of the mountain…?",
        "id": ""
      },
      "startTime": 89.9666666667,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "suz",
      "speakerName": "成宮すず",
