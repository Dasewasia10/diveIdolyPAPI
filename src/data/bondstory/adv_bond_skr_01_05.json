      "text": "（むしろ起きている方が偉いんじゃないかな？　えへへ）",
      "translations": {
        "en": "（isn't it actually impressive that I'm even awake? Ehehe.）",
        "id": ""
      },
      "startTime": 29.3333333333,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "skr",
      "speakerName": "川咲さくら",
      "speakerNameEn": "Sakura",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-sakura.png",
