      "type": "dialogue",
      "speakerCode": "yu",
      "speakerName": "鈴村優",
      "speakerNameEn": "Yu",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-yu.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/bondStoryVoice/sud_vo_adv_bond_ai_01_01/sud_vo_adv_bond_ai_01_01-yu009.m4a",
      "text": "ん？　注目されてんのは愛ちゃんも同じやん",
      "translations": {
        "en": "Hmm? Ai-chan is getting the same attention",
        "id": ""
      },
      "startTime": 110.1000045137,
      "sfxList": []
    },
