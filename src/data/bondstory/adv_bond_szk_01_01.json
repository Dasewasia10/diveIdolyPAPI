      "text": "えっ？　{user}さんから？\nなんだろう、大事なことかな？",
      "translations": {
        "en": "Huh? From {user}-san?\nWhat is it‚ is it important?",
        "id": ""
      },
      "startTime": 98.2666767715,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_schoolhallway-00-noon.webp",
      "bgName": "schoolhallway-00-noon",
      "startTime": 104.4333434382
    },
    {
