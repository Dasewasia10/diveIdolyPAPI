      "speakerCode": "szk",
      "speakerName": "兵藤雫",
      "speakerNameEn": "Shizuku",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-shizuku.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/bondStoryVoice/sud_vo_adv_bond_szk_01_01/sud_vo_adv_bond_szk_01_01-szk014.m4a",
      "text": "私は伝令係。一言一句漏らさず伝える……\n「午後の仕事は雫と学校から向かってくれ」とのこと",
      "translations": {
        "en": "I'm the messenger. I'll deliver every word…\n'For the afternoon work‚ please leave school with Shizuku'",
        "id": ""
      },
      "startTime": 104.4333434382,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_schoolhallway-00-noon.webp",
      "bgName": "schoolhallway-00-noon",
      "startTime": 115.5333398777
    },
    {
      "type": "dialogue",
      "speakerCode": "skr",
      "speakerName": "川咲さくら",
      "speakerNameEn": "Sakura",
