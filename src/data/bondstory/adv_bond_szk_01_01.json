      "text": "雫ちゃーん！",
      "translations": {
        "en": "Shizuku-chan!",
        "id": ""
      },
      "startTime": 78.7333307225,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "szk",
      "speakerName": "兵藤雫",
