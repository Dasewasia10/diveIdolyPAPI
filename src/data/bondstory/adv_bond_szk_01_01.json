      "text": "（さくらちゃんの幻聴まで……）",
      "translations": {
        "en": "（Even Sakura-chan's auditory hallucinations…）",
        "id": ""
      },
      "startTime": 81.133336826,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "skr",
      "speakerName": "川咲さくら",
      "speakerNameEn": "Sakura",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-sakura.png",
