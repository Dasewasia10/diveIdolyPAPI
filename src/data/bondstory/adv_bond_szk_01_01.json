      "text": "ねぇ、雫ちゃんってば！　どうしたの？\n私に用事？",
      "translations": {
        "en": "Hey‚ Shizuku-chan! What's going on?\nDo you have anything to do?",
        "id": ""
      },
      "startTime": 83.9666767715,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_schoolhallway-00-noon.webp",
      "bgName": "schoolhallway-00-noon",
      "startTime": 84.0000101066
    },
    {
      "type": "background",
