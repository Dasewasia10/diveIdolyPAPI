      "speakerName": "川咲さくら",
      "speakerNameEn": "Sakura",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-sakura.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/bondStoryVoice/sud_vo_adv_bond_szk_01_01/sud_vo_adv_bond_szk_01_01-skr005.m4a",
      "text": "ふふふ、雫ちゃんメッセでも良かったのに\nでも、ありがとう",
      "translations": {
        "en": "Hehehe‚ Shizuku-chan‚ message would have been fine‚ too\nBut‚ thank you",
        "id": ""
      },
      "startTime": 118.7000024753,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_schoolhallway-00-noon.webp",
