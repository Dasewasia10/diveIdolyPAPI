      "text": "だから、あんなにいい表情をしていたんですね",
      "translations": {
        "en": "That's why you made such a nice face.",
        "id": ""
      },
      "startTime": 450.1845795909,
      "endTime": 453.7925842086,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "stm",
      "speakerName": "橋本さとみ",
