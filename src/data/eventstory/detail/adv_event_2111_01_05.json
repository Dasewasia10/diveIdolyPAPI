    },
    {
      "type": "dialogue",
      "speakerCode": "rei",
      "speakerName": "一ノ瀬怜",
      "speakerNameEn": "Rei",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-rei.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/eventStoryVoice/sud_vo_adv_event_2111_01_05/sud_vo_adv_event_2111_01_05-rei009.m4a",
      "text": "みなさん、聴いて下さい。私達の新曲――",
      "translations": {
        "en": "Everyone please listen. This is our new song—",
        "id": ""
      },
      "startTime": 82.8666666667,
      "endTime": 87.43333333336668,
