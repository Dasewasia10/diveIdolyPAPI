      "speakerCode": "mei",
      "speakerName": "早坂芽衣",
      "speakerNameEn": "Mei",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-mei.png",
      "voiceUrl": null,
      "text": "えへへ、二人が真面目にしゃべってる",
      "translations": {
        "en": "Hee hee. I was watching the two",
