{
  "id": "adv_event_2108_01_01",
  "title": "月夜に輝く恋の魔法第1話　盗み聞き？",
  "script": [
    {
      "type": "dialogue",
      "speakerCode": "mei",
      "speakerName": "早坂芽衣",
      "speakerNameEn": "Mei",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-mei.png",
      "voiceUrl": null,
      "text": "みんな、おっはよーっ！",
      "translations": {
        "en": "Good morning everyone!",
        "id": ""
      },
      "startTime": 0.8,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "mei",
      "speakerName": "早坂芽衣",
      "speakerNameEn": "Mei",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-mei.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/eventStoryVoice/sud_vo_adv_event_2108_01_01/sud_vo_adv_event_2108_01_01-mei001.m4a",
      "text": "今日もいい天気！　爽やかな朝だよ！",
      "translations": {
        "en": "It’s fine weather again today! A fresh morning!",
        "id": ""
      },
      "startTime": 3.2666666666666666,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "ktn",
      "speakerName": "長瀬琴乃",
      "speakerNameEn": "Kotono",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-kotono.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/eventStoryVoice/sud_vo_adv_event_2108_01_01/sud_vo_adv_event_2108_01_01-ktn001.m4a",
      "text": "……おはよ、芽衣",
      "translations": {
        "en": "…Morning Mei.",
