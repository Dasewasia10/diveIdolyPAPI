      "startTime": 50.9,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "mei",
      "speakerName": "早坂芽衣",
      "speakerNameEn": "Mei",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-mei.png",
      "voiceUrl": null,
      "text": "それでね、物陰に隠れて",
      "translations": {
        "en": "Well‚ I was standing behind something‚",
        "id": ""
