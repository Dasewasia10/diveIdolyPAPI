    {
      "type": "dialogue",
      "speakerCode": "rui",
      "speakerName": "天動瑠依",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-rui.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/eventStoryVoice/sud_vo_adv_event_2409_01_01/sud_vo_adv_event_2409_01_01-rui008.m4a",
