      "text": "その気持ち、よく分かりますわ",
      "translations": {
        "en": "I really know how you feel!",
        "id": ""
      },
      "startTime": 180.63333333333333,
      "endTime": 183.86666666666667,
      "sfxList": []
    },
    {
      "type": "dialogue",
