      "speakerName": "井川葵",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-aoi.png",
      "voiceUrl": null,
      "text": "あの男が僕とすれ違った時に落としていったんだ",
      "startTime": 17.6333333333,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "aoi",
      "speakerName": "井川葵",
