      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-rio.png",
      "voiceUrl": null,
      "text": "ま、どこの世界にもいい人もいれば悪い人もいる",
      "startTime": 69.3333333333,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "rio",
      "speakerName": "神崎莉央",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-rio.png",
