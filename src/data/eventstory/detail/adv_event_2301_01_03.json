      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-kokoro.png",
      "voiceUrl": null,
      "text": "…………お、お二人の言う通りです！",
      "startTime": 45.3333333333,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "kkr",
      "speakerName": "赤崎こころ",
