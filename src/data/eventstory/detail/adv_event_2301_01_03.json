      "bgName": "okinawahotel-00-noon",
      "startTime": 111.6666666667
    },
    {
      "type": "dialogue",
      "speakerCode": "aoi",
      "speakerName": "井川葵",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-aoi.png",
      "voiceUrl": null,
      "text": "そんな訳で、今日のミーティングはおしまい",
      "startTime": 111.6666666667,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "aoi",
      "speakerName": "井川葵",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-aoi.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/eventStoryVoice/sud_vo_adv_event_2301_01_03/sud_vo_adv_event_2301_01_03-aoi006.m4a",
      "text": "僕は自分の部屋に戻るよ。お休み",
      "startTime": 114.9666666667,
      "sfxList": [
        {
          "src": "https://apiip.dasewasia.my.id/storyBgm/sud_se_adv_walk-living-single-01.m4a",
          "delay": 9400.000000000005
