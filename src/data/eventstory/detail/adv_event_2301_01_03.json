      "text": "必ずしてるから、こんなことしても無駄なのに……",
      "startTime": 37.1,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_okinawahotel-00-noon.webp",
      "bgName": "okinawahotel-00-noon",
      "startTime": 40.7333333333
    },
    {
      "type": "dialogue",
      "speakerCode": "aoi",
      "speakerName": "井川葵",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-aoi.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/eventStoryVoice/sud_vo_adv_event_2301_01_03/sud_vo_adv_event_2301_01_03-aoi003.m4a",
      "text": "うん、プロなら道具の確認は当然だしね",
      "startTime": 40.7333333333,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_okinawahotel-00-noon.webp",
      "bgName": "okinawahotel-00-noon",
