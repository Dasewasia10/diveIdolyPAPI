      "bgName": "okinawahotel-00-noon",
      "startTime": 119.3
    },
    {
      "type": "dialogue",
      "speakerCode": "ai",
      "speakerName": "小美山愛",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-ai.png",
