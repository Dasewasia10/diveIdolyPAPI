      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-kokoro.png",
      "voiceUrl": null,
      "text": "あの……莉央さん、本当にこのままでいいんですか？",
      "startTime": 126.0666666667,
      "sfxList": []
    },
    {
      "type": "background",
