      "startTime": 96.1
    },
    {
      "type": "dialogue",
      "speakerCode": "kkr",
      "speakerName": "赤崎こころ",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-kokoro.png",
      "voiceUrl": null,
      "text": "え～っ？　せっかくお仕置き出来る",
      "startTime": 96.1,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "kkr",
