    {
      "type": "dialogue",
      "speakerCode": "buriburi",
      "speakerName": "ブリ山ブリスケ",
      "speakerNameEn": "",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-buriburi.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/eventStoryVoice/sud_vo_adv_event_2604_02_05/sud_vo_adv_event_2604_02_04-buriburi001.m4a",
      "text": "フッ……雫ちゃんと出会えて体も心も成長したオラは\n本物のブリになれた。ありがとう、また会おう……",
      "translations": {
        "en": "",
        "id": ""
      },
      "startTime": 0.8,
      "endTime": 12.2585206986,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "koh",
      "speakerName": "ナレーション",
      "speakerNameEn": "{user}",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-makino.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/eventStoryVoice/sud_vo_adv_event_2604_02_05/sud_vo_adv_event_2604_02_04-koh001.m4a",
      "text": "ブリスケは優しく微笑むと、ゆっくり、ゆっくり\n釣り上げられていったのでした",
      "translations": {
        "en": "",
        "id": ""
      },
      "startTime": 12.4666666667,
      "endTime": 21.5237085979,
      "sfxList": []
