{
  "id": "adv_event_2401_02_01",
  "title": "24年正月",
  "script": [
    {
      "type": "sfx",
      "src": "https://apiip.dasewasia.my.id/storyBgm/sud_se_adv_walk-in-single-02.m4a",
      "startTime": 0
    },
    {
      "type": "dialogue",
      "speakerCode": "ngs",
      "speakerName": "伊吹渚",
      "speakerNameEn": "Nagisa",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-nagisa.png",
      "voiceUrl": null,
      "text": "あっ！　{user}\nさん発見！",
      "translations": {
        "en": "Ah! I found you‚\n{user}-san!",
        "id": ""
      },
      "startTime": 1.3,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "ngs",
      "speakerName": "伊吹渚",
      "speakerNameEn": "Nagisa",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-nagisa.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/eventStoryVoice/sud_vo_adv_event_2401_02_01/sud_vo_adv_event_2401_02_01-ngs001.m4a",
      "text": "あけまして\nおめでとうございます！",
      "translations": {
        "en": "Happy New Year!",
        "id": ""
      },
      "startTime": 3.9399385293,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "ski",
      "speakerName": "白石沙季",
      "speakerNameEn": "Saki",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-saki.png",
      "voiceUrl": null,
      "text": "新年から{user}\nさんに会えるなんて",
      "translations": {
        "en": "It looks like we’re going to\nhave lots of good fortune\nthis year",
        "id": ""
      },
      "startTime": 6.8,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "ski",
      "speakerName": "白石沙季",
      "speakerNameEn": "Saki",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-saki.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/eventStoryVoice/sud_vo_adv_event_2401_02_01/sud_vo_adv_event_2401_02_01-ski001.m4a",
      "text": "今年もいいことが\n沢山ありそうですね",
      "translations": {
        "en": "since we've met\n{user}-san on\nNew Year's day.",
        "id": ""
      },
      "startTime": 9.8666666667,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "ktn",
      "speakerName": "長瀬琴乃",
      "speakerNameEn": "Kotono",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-kotono.png",
      "voiceUrl": null,
      "text": "いつも私達のために頑張って\nくれてありがとうございます",
      "translations": {
        "en": "Thank you for always\nworking so hard for us.",
        "id": ""
      },
      "startTime": 12.6666666667,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "ktn",
      "speakerName": "長瀬琴乃",
      "speakerNameEn": "Kotono",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-kotono.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/eventStoryVoice/sud_vo_adv_event_2401_02_01/sud_vo_adv_event_2401_02_01-ktn001.m4a",
      "text": "お正月くらいは\nゆっくりして下さい！",
      "translations": {
        "en": "Please take it easy\nat least during the\nNew Year’s holidays!",
        "id": ""
      },
      "startTime": 17.5,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "suz",
      "speakerName": "成宮すず",
      "speakerNameEn": "Suzu",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-suzu.png",
      "voiceUrl": null,
      "text": "ゆっくりは出来ない……？　\nそれならお正月のプロ",
      "translations": {
        "en": "You can’t relax…?\nThen the New Year’s pro‚",
        "id": ""
      },
      "startTime": 20.3666666667,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "suz",
      "speakerName": "成宮すず",
      "speakerNameEn": "Suzu",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-suzu.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/eventStoryVoice/sud_vo_adv_event_2401_02_01/sud_vo_adv_event_2401_02_01-suz001.m4a",
      "text": "成宮すずがゆっくりの仕方を\n教えてあげますわ！",
      "translations": {
        "en": "Narumiya Suzu‚\nwill teach you how to relax!",
        "id": ""
      },
      "startTime": 25.8,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "mei",
      "speakerName": "早坂芽衣",
      "speakerNameEn": "Mei",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-mei.png",
      "voiceUrl": null,
      "text": "すずにゃん\nお正月のプロだったの！？",
      "translations": {
        "en": "Suzu-nyan‚\nyou’re a New Year’s pro!?",
        "id": ""
      },
      "startTime": 30.6,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "mei",
      "speakerName": "早坂芽衣",
      "speakerNameEn": "Mei",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-mei.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/eventStoryVoice/sud_vo_adv_event_2401_02_01/sud_vo_adv_event_2401_02_01-mei001.m4a",
      "text": "芽衣も知りたい！",
      "translations": {
        "en": "I want to know too!",
        "id": ""
      },
      "startTime": 34.3666666667,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "suz",
      "speakerName": "成宮すず",
      "speakerNameEn": "Suzu",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-suzu.png",
      "voiceUrl": null,
      "text": "まずは、おせちを食べて\nゴロゴロ～！",
      "translations": {
        "en": "First‚ we eat osechi\nand laze around~!",
        "id": ""
      },
      "startTime": 36.0333333333,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "suz",
      "speakerName": "成宮すず",
      "speakerNameEn": "Suzu",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-suzu.png",
      "voiceUrl": null,
      "text": "次はお年玉をもらって\nゴロゴロ～！",
      "translations": {
        "en": "Then we get New Year’s\nmoney and laze around~!",
        "id": ""
      },
      "startTime": 40.6,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "suz",
      "speakerName": "成宮すず",
      "speakerNameEn": "Suzu",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-suzu.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/eventStoryVoice/sud_vo_adv_event_2401_02_01/sud_vo_adv_event_2401_02_01-suz002.m4a",
      "text": "その後は\nこたつに入って――",
      "translations": {
        "en": "After that‚\nwe get in the kotatsu――",
        "id": ""
      },
      "startTime": 44.6,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "ngs",
      "speakerName": "伊吹渚",
      "speakerNameEn": "Nagisa",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-nagisa.png",
      "voiceUrl": null,
      "text": "ゴロゴロするんだね……\n確かにゆっくりは出来そう",
      "translations": {
        "en": "And laze around… right?\nIt is true that’s one way\nto relax‚",
        "id": ""
      },
      "startTime": 47.3666623434,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "ngs",
      "speakerName": "伊吹渚",
      "speakerNameEn": "Nagisa",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-nagisa.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/eventStoryVoice/sud_vo_adv_event_2401_02_01/sud_vo_adv_event_2401_02_01-ngs002.m4a",
      "text": "だけど、ほぼゴロゴロしてる\nだけ、かな",
      "translations": {
        "en": "but it’s basically\njust lazing around.",
        "id": ""
      },
      "startTime": 51.1999956768,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "mei",
      "speakerName": "早坂芽衣",
      "speakerNameEn": "Mei",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-mei.png",
      "voiceUrl": null,
      "text": "でも{user}さんも\n一緒に",
      "translations": {
        "en": "But wouldn’t it be fun",
        "id": ""
      },
      "startTime": 55.7333325705,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "mei",
      "speakerName": "早坂芽衣",
      "speakerNameEn": "Mei",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-mei.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/eventStoryVoice/sud_vo_adv_event_2401_02_01/sud_vo_adv_event_2401_02_01-mei002.m4a",
      "text": "みんなでゴロゴローって\nするの楽しそうじゃない？",
      "translations": {
        "en": "if {user}-san joined us\nand we all lazed around\ntogether?",
        "id": ""
      },
      "startTime": 58.1666659039,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "ski",
      "speakerName": "白石沙季",
      "speakerNameEn": "Saki",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-saki.png",
      "voiceUrl": null,
      "text": "今年はそんなにゴロゴロ\nしている暇はありませんよ！",
      "translations": {
        "en": "We don’t have time to\nlaze around that\nmuch this year!",
        "id": ""
      },
      "startTime": 61.8999992372,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "ski",
      "speakerName": "白石沙季",
      "speakerNameEn": "Saki",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-saki.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/eventStoryVoice/sud_vo_adv_event_2401_02_01/sud_vo_adv_event_2401_02_01-ski002.m4a",
      "text": "ありがたいことに年始から\nお仕事が詰まっているので",
      "translations": {
        "en": "We have a lot of work\nlined up from the beginning\nof the year‚ thankfully.",
        "id": ""
      },
      "startTime": 65.7333325705,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "ktn",
      "speakerName": "長瀬琴乃",
      "speakerNameEn": "Kotono",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-kotono.png",
      "voiceUrl": null,
      "text": "あ、そうだった！",
      "translations": {
        "en": "Oh‚ that’s right!",
        "id": ""
      },
      "startTime": 69.5333325705,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "ktn",
      "speakerName": "長瀬琴乃",
      "speakerNameEn": "Kotono",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-kotono.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/eventStoryVoice/sud_vo_adv_event_2401_02_01/sud_vo_adv_event_2401_02_01-ktn002.m4a",
      "text": "{user}さんも\n一緒にお仕事でしたね",
      "translations": {
        "en": "You have work too‚\n{user}-san.",
        "id": ""
      },
      "startTime": 72.1333325705,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "suz",
      "speakerName": "成宮すず",
      "speakerNameEn": "Suzu",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-suzu.png",
      "voiceUrl": null,
      "text": "まぁ、忙しいのは\nいいことですわ！",
      "translations": {
        "en": "Well‚ being busy is\na good thing!",
        "id": ""
      },
      "startTime": 74.9666659039,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "suz",
      "speakerName": "成宮すず",
      "speakerNameEn": "Suzu",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-suzu.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/eventStoryVoice/sud_vo_adv_event_2401_02_01/sud_vo_adv_event_2401_02_01-suz003.m4a",
      "text": "今年も私達のために\n馬車馬のごとく働きなさい！",
      "translations": {
        "en": "Keep working like\na carriage horse for us\nthis year!",
        "id": ""
      },
      "startTime": 78.6999992372,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "ski",
      "speakerName": "白石沙季",
      "speakerNameEn": "Saki",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-saki.png",
      "voiceUrl": null,
      "text": "すずちゃん\n{user}さんには",
      "translations": {
        "en": "Suzu-chan‚ we definitely\nneed {user}-san's\nhard work‚",
        "id": ""
      },
      "startTime": 84.3999992372,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "ski",
      "speakerName": "白石沙季",
      "speakerNameEn": "Saki",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-saki.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/eventStoryVoice/sud_vo_adv_event_2401_02_01/sud_vo_adv_event_2401_02_01-ski003.m4a",
      "text": "頑張ってもらわないとですが\nその言い方は……",
      "translations": {
        "en": "but that way of\nputting it is…",
        "id": ""
      },
      "startTime": 86.5666659039,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "mei",
      "speakerName": "早坂芽衣",
      "speakerNameEn": "Mei",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-mei.png",
      "voiceUrl": null,
      "text": "もちろん、芽衣達も\n{user}さんに",
      "translations": {
        "en": "Of course‚\nwe’ll work hard too‚",
        "id": ""
      },
      "startTime": 90.2999992372,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "mei",
      "speakerName": "早坂芽衣",
      "speakerNameEn": "Mei",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-mei.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/eventStoryVoice/sud_vo_adv_event_2401_02_01/sud_vo_adv_event_2401_02_01-mei003.m4a",
      "text": "負けないぐらい頑張るよ！",
      "translations": {
        "en": "as much as\n{user}-san does!",
        "id": ""
      },
      "startTime": 92.3333325705,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "ngs",
      "speakerName": "伊吹渚",
      "speakerNameEn": "Nagisa",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-nagisa.png",
      "voiceUrl": null,
      "text": "ふふっ、そうだね\nまだまだこんなところで",
      "translations": {
        "en": "Hehe‚ you’re right.\nWe can’t afford",
        "id": ""
      },
      "startTime": 94.4666659039,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "ngs",
      "speakerName": "伊吹渚",
      "speakerNameEn": "Nagisa",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-nagisa.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/eventStoryVoice/sud_vo_adv_event_2401_02_01/sud_vo_adv_event_2401_02_01-ngs003.m4a",
      "text": "立ち止まっていられないもん",
      "translations": {
        "en": "to stop here.",
        "id": ""
      },
      "startTime": 98.1333325705,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "ktn",
      "speakerName": "長瀬琴乃",
      "speakerNameEn": "Kotono",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-kotono.png",
      "voiceUrl": null,
      "text": "それじゃあ改めて\n{user}さん",
      "translations": {
        "en": "Well then‚ once again‚\n{user}-san.",
        "id": ""
      },
      "startTime": 100.1999987286,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "ktn",
      "speakerName": "長瀬琴乃",
      "speakerNameEn": "Kotono",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-kotono.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/eventStoryVoice/sud_vo_adv_event_2401_02_01/sud_vo_adv_event_2401_02_01-ktn003.m4a",
      "text": "私達、トップアイドル\n目指して一生懸命頑張るので",
      "translations": {
        "en": "We’re going to work hard\nto become top idols‚ so…",
        "id": ""
      },
      "startTime": 103.8999987286,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "ktn",
      "speakerName": "一同",
      "speakerNameEn": "Everyone",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-kotono.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/eventStoryVoice/sud_vo_adv_event_2401_02_01/sud_vo_adv_event_2401_02_01-mei004.m4a",
      "text": "今年も\nよろしくお願いします！",
      "translations": {
        "en": "Please support us\nthis year!",
        "id": ""
      },
      "startTime": 108.8666653952,
      "sfxList": []
    }
  ]
}