      "text": "みんな、好きなの取ってね！　早い者勝ちだよ～",
      "translations": {
        "en": "Everyone take the kind you like! First come‚ first served!",
        "id": ""
      },
      "startTime": 80.93333333333334,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "suz",
      "speakerName": "成宮すず",
      "speakerNameEn": "Suzu",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-suzu.png",
      "voiceUrl": null,
      "text": "私はいちご味を！　しゃくしゃくしゃく！",
      "translations": {
        "en": "I want strawberry flavor! *munch* *munch*",
        "id": ""
      },
      "startTime": 84.9,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "suz",
      "speakerName": "成宮すず",
      "speakerNameEn": "Suzu",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-suzu.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/eventStoryVoice/sud_vo_adv_event_2108_01_03/sud_vo_adv_event_2108_01_03-suz003.m4a",
      "text": "う～ん、冷たくて甘いですわ！　美味！",
