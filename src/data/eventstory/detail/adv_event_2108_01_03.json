      "text": "もう！　仕方ないですね",
      "translations": {
        "en": "You all just can’t be helped.",
        "id": ""
      },
      "startTime": 103,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "suz",
      "speakerName": "成宮すず",
      "speakerNameEn": "Suzu",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-suzu.png",
      "voiceUrl": null,
      "text": "しゃくしゃく、買ってきてしまったものはしゃくしゃく",
      "translations": {
        "en": "*munch munch* She bought it already *munch*",
        "id": ""
      },
      "startTime": 105.4,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "suz",
      "speakerName": "成宮すず",
      "speakerNameEn": "Suzu",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-suzu.png",
