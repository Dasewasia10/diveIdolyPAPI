      ]
    },
    {
      "type": "dialogue",
      "speakerCode": "mei",
      "speakerName": "早坂芽衣",
      "speakerNameEn": "Mei",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-mei.png",
      "voiceUrl": null,
      "text": "あははは！　慌てて食べるからだよ～",
      "translations": {
        "en": "Ahaha. That‘s what you get for gulping it down.",
        "id": ""
      },
      "startTime": 116.03333333333333,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "mei",
      "speakerName": "早坂芽衣",
