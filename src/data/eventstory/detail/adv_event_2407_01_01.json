      "startTime": 19.7666666667,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "rei",
      "speakerName": "一ノ瀬怜",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-rei.png",
      "voiceUrl": null,
      "text": "千紗はちゃんと成長してるんだから、自信を持って",
