      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "rei",
      "speakerName": "一ノ瀬怜",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-rei.png",
      "voiceUrl": null,
