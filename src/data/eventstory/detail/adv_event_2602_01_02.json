      "speakerCode": "mei",
      "speakerName": "早坂芽衣",
      "speakerNameEn": "Mei Hayasaka",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-mei.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/eventStoryVoice/sud_vo_adv_event_2602_01_02/sud_vo_adv_event_2602_01_02-mei010.m4a",
      "text": "わーーーーい！\nすずにゃーーーーん！　負けないぞー！　とりゃーー！",
