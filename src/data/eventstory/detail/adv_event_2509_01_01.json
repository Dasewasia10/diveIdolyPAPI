    {
      "type": "dialogue",
      "speakerCode": "ngs",
      "speakerName": "伊吹渚",
      "speakerNameEn": "伊吹渚",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-nagisa.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/eventStoryVoice/sud_vo_adv_event_2509_01_01/sud_vo_adv_event_2509_01_01-ngs001.m4a",
      "text": "ふふっ、すずちゃん頼もしいね\n私は、ちょっと緊張しちゃってるかも",
      "translations": {
        "en": "ふふっ、すずちゃん頼もしいね\n私は、ちょっと緊張しちゃってるかも",
        "id": ""
      },
      "startTime": 17.6457824707,
      "endTime": 25.708390045199998,
      "sfxList": []
    },
    {
      "type": "background",
