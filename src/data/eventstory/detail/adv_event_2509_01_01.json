    {
      "type": "dialogue",
      "speakerCode": "mei",
      "speakerName": "早坂芽衣",
      "speakerNameEn": "早坂芽衣",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-mei.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/eventStoryVoice/sud_vo_adv_event_2509_01_01/sud_vo_adv_event_2509_01_01-mei001.m4a",
      "text": "凄ーい！　お客さん、超盛り上がってるよ！\nすずにゃん、震えてるけど大丈夫？",
      "translations": {
        "en": "凄ーい！　お客さん、超盛り上がってるよ！\nすずにゃん、震えてるけど大丈夫？",
        "id": ""
      },
      "startTime": 0.8,
      "endTime": 10.2041727066,
      "sfxList": []
    },
    {
      "type": "background",
