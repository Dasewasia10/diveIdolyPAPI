      "bgName": "stagesleeves-00-noon",
      "startTime": 25.9042173386
    },
    {
      "type": "dialogue",
      "speakerCode": "ski",
      "speakerName": "白石沙季",
      "speakerNameEn": "白石沙季",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-saki.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/eventStoryVoice/sud_vo_adv_event_2509_01_01/sud_vo_adv_event_2509_01_01-ski001.m4a",
      "text": "程よい緊張はいいパフォーマンスに繋がります\nとはいえ、楽しむことも忘れずにいきましょう",
      "translations": {
        "en": "程よい緊張はいいパフォーマンスに繋がります\nとはいえ、楽しむことも忘れずにいきましょう",
        "id": ""
      },
      "startTime": 25.9042173386,
      "endTime": 34.0522674561,
      "sfxList": []
    },
    {
      "type": "background",
