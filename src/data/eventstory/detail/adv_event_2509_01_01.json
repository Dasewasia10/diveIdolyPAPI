    {
      "type": "dialogue",
      "speakerCode": "mku",
      "speakerName": "初音ミク",
      "speakerNameEn": "初音ミク",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-mku.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/eventStoryVoice/sud_vo_adv_event_2509_01_01/sud_vo_adv_event_2509_01_01-mku001.m4a",
      "text": "うん！　楽しみだな、みんなとのライブ\n曲を通して共有出来た想いを次はファンにも届けよう！",
      "translations": {
        "en": "うん！　楽しみだな、みんなとのライブ\n曲を通して共有出来た想いを次はファンにも届けよう！",
        "id": ""
      },
      "startTime": 45.6605518341,
      "endTime": 55.536531066900004,
      "sfxList": []
    },
    {
      "type": "background",
