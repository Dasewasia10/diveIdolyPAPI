    },
    {
      "type": "dialogue",
      "speakerCode": "suz",
      "speakerName": "成宮すず",
      "speakerNameEn": "Suzu",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-suzu.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/eventStoryVoice/sud_vo_adv_event_2406_01_02/sud_vo_adv_event_2406_01_02-suz001.m4a",
      "text": "第一回！\nどりきゅんライブバトル対策会議～！",
      "translations": {
        "en": "First!\nDoriKyun Live Battle Strategy Meeting～！",
        "id": ""
      },
      "startTime": 2.8000000317,
      "endTime": 7.8870521862,
      "sfxList": []
    },
    {
      "type": "background",
