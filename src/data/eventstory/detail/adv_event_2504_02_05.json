{
  "id": "adv_event_2504_02_05",
  "title": "時空の狭間からの脱出",
  "script": [
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_spacetimegap-00-noon.webp",
      "bgName": "zikuu",
      "startTime": 0
    },
    {
      "type": "dialogue",
      "speakerCode": null,
      "speakerName": "",
      "speakerNameEn": "",
      "iconUrl": null,
      "voiceUrl": null,
      "text": "――時空の狭間が閉じるまであと10分",
      "translations": {
        "en": "—10 Minutes Until the Space-Time Rift Closes",
        "id": ""
      },
      "startTime": 0,
      "endTime": 1.9533333063,
      "sfxList": [
        {
          "src": "https://apiip.dasewasia.my.id/storyBgm/sud_se_adv_watch-01.m4a",
          "delay": 0
        },
        {
          "src": "https://apiip.dasewasia.my.id/storyBgm/sud_se_adv_watch-01.m4a",
          "delay": 600
        },
        {
          "src": "https://apiip.dasewasia.my.id/storyBgm/sud_se_adv_watch-01.m4a",
          "delay": 1200
        },
        {
          "src": "https://apiip.dasewasia.my.id/storyBgm/sud_se_adv_watch-01.m4a",
