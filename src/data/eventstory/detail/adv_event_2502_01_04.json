      "iconUrl": null,
      "voiceUrl": null,
      "text": "――サニピの限定イベント当日",
      "translations": {
        "en": "—The day of Sunny Peace’s limited-time event",
        "id": ""
      },
      "startTime": 0.8,
      "endTime": 4.1933334826,
      "sfxList": [
        {
          "src": "https://apiip.dasewasia.my.id/storyBgm/sud_se_adv_cheers-in-01.m4a",
