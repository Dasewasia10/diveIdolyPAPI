      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-shizuku.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/eventStoryVoice/sud_vo_adv_event_2502_01_04/sud_vo_adv_event_2502_01_04-szk005.m4a",
