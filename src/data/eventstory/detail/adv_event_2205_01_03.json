    },
    {
      "type": "dialogue",
      "speakerCode": "ski",
      "speakerName": "白石沙季",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-saki.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/eventStoryVoice/sud_vo_adv_event_2205_01_03/sud_vo_adv_event_2205_01_03-ski001.wav",
      "text": "1、2、3……ここで……っ！",
      "startTime": 2,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "chs",
      "speakerName": "白石千紗",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-chisa.png",
      "voiceUrl": null,
      "text": "ひゃっ？　お、お姉ちゃん？",
      "startTime": 5.1666666667,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "chs",
      "speakerName": "白石千紗",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-chisa.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/eventStoryVoice/sud_vo_adv_event_2205_01_03/sud_vo_adv_event_2205_01_03-chs001.wav",
      "text": "どうして急に一歩引いたの？",
      "startTime": 7.6,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "ski",
      "speakerName": "白石沙季",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-saki.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/eventStoryVoice/sud_vo_adv_event_2205_01_03/sud_vo_adv_event_2205_01_03-ski002.wav",
      "text": "ここはブレイクが入るでしょう？",
      "startTime": 10.3666666667,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "ski",
      "speakerName": "白石沙季",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-saki.png",
      "voiceUrl": null,
      "text": "ここで千紗が前に出て私が真後ろに立てば",
      "startTime": 13.0666666667,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "ski",
      "speakerName": "白石沙季",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-saki.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/eventStoryVoice/sud_vo_adv_event_2205_01_03/sud_vo_adv_event_2205_01_03-ski003.wav",
      "text": "千紗がもっと目立てるかなって",
      "startTime": 16.8333333333,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "chs",
      "speakerName": "白石千紗",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-chisa.png",
      "voiceUrl": null,
      "text": "で、でも、そしたら……お姉ちゃんの動きだけとっても",
      "startTime": 19.8,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "chs",
      "speakerName": "白石千紗",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-chisa.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/eventStoryVoice/sud_vo_adv_event_2205_01_03/sud_vo_adv_event_2205_01_03-chs002.wav",
      "text": "大げさになるよ？　不自然じゃないかな……？",
      "startTime": 24.9,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "ski",
      "speakerName": "白石沙季",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-saki.png",
      "voiceUrl": null,
      "text": "大丈夫、心配しないで",
      "startTime": 29.5,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "ski",
      "speakerName": "白石沙季",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-saki.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/eventStoryVoice/sud_vo_adv_event_2205_01_03/sud_vo_adv_event_2205_01_03-ski004.wav",
      "text": "……これでいいのよ",
      "startTime": 32.7333333333,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "chs",
      "speakerName": "白石千紗",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-chisa.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/eventStoryVoice/sud_vo_adv_event_2205_01_03/sud_vo_adv_event_2205_01_03-chs003.wav",
      "text": "お姉ちゃん……",
      "startTime": 34.9,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "ski",
      "speakerName": "白石沙季",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-saki.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/eventStoryVoice/sud_vo_adv_event_2205_01_03/sud_vo_adv_event_2205_01_03-ski005.wav",
      "text": "ふぅ、今日の練習はこれくらいにしておこうか",
      "startTime": 38.9333333333,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "chs",
      "speakerName": "白石千紗",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-chisa.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/eventStoryVoice/sud_vo_adv_event_2205_01_03/sud_vo_adv_event_2205_01_03-chs004.wav",
      "text": "うん……お疲れ様",
      "startTime": 44.2,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "ski",
      "speakerName": "白石沙季",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-saki.png",
      "voiceUrl": null,
      "text": "あら？　{user}さんが呼んでる……",
      "startTime": 47.0666666667,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "ski",
      "speakerName": "白石沙季",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-saki.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/eventStoryVoice/sud_vo_adv_event_2205_01_03/sud_vo_adv_event_2205_01_03-ski006.wav",
      "text": "私を呼んでるみたい。ちょっと行ってくるね",
      "startTime": 50.7,
      "sfxList": [
        {
          "src": "https://apiip.dasewasia.my.id/storyBgm/sud_se_adv_walk-in-single-01.m4a",
          "delay": 4266.666666699997
        }
      ]
    },
    {
      "type": "dialogue",
      "speakerCode": "chs",
      "speakerName": "白石千紗",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-chisa.png",
      "voiceUrl": null,
      "text": "お姉ちゃん……練習の間",
      "startTime": 56.0666666667,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "chs",
      "speakerName": "白石千紗",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-chisa.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/eventStoryVoice/sud_vo_adv_event_2205_01_03/sud_vo_adv_event_2205_01_03-chs005.wav",
      "text": "ずっと私を目立たせようとばかりしてた……",
      "startTime": 59.1333333333,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "chs",
      "speakerName": "白石千紗",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-chisa.png",
      "voiceUrl": null,
      "text": "なんだか、大会が始まる前より酷くなってる気がする",
      "startTime": 63.3333333333,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "chs",
      "speakerName": "白石千紗",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-chisa.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/eventStoryVoice/sud_vo_adv_event_2205_01_03/sud_vo_adv_event_2205_01_03-chs006.wav",
      "text": "言った方がいいのかな？　でも……",
      "startTime": 68.6,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "chs",
      "speakerName": "白石千紗",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-chisa.png",
      "voiceUrl": null,
      "text": "お姉ちゃんは何も言わないし……",
      "startTime": 72.8333333333,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "chs",
      "speakerName": "白石千紗",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-chisa.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/eventStoryVoice/sud_vo_adv_event_2205_01_03/sud_vo_adv_event_2205_01_03-chs007.wav",
      "text": "聞いちゃいけないかな……",
      "startTime": 75.5,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "chs",
      "speakerName": "白石千紗",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-chisa.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/eventStoryVoice/sud_vo_adv_event_2205_01_03/sud_vo_adv_event_2205_01_03-chs008.wav",
      "text": "このままじゃきっとダメなのに……",
      "startTime": 78.0333333333,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "chs",
      "speakerName": "白石千紗",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-chisa.png",
      "voiceUrl": null,
      "text": "どうして私は、肝心な時にお姉ちゃんの力に",
      "startTime": 81.8666666667,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "chs",
      "speakerName": "白石千紗",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-chisa.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/eventStoryVoice/sud_vo_adv_event_2205_01_03/sud_vo_adv_event_2205_01_03-chs009.wav",
      "text": "なれないんだろ……情けないな、私……",
      "startTime": 85.8666666667,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "chs",
      "speakerName": "白石千紗",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-chisa.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/eventStoryVoice/sud_vo_adv_event_2205_01_03/sud_vo_adv_event_2205_01_03-chs010.wav",
      "text": "はぁ……",
      "startTime": 92.7333333333,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "ngs",
      "speakerName": "伊吹渚",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-nagisa.png",
      "voiceUrl": null,
      "text": "千紗ちゃん、どうしたの？",
      "startTime": 94.6666666667,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "ngs",
      "speakerName": "伊吹渚",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-nagisa.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/eventStoryVoice/sud_vo_adv_event_2205_01_03/sud_vo_adv_event_2205_01_03-ngs001.wav",
      "text": "もしかして、お皿洗いがイヤになったとか？",
      "startTime": 96.7,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "chs",
      "speakerName": "白石千紗",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-chisa.png",
      "voiceUrl": null,
      "text": "う、ううん、違うよ、ごめんね？",
      "startTime": 100.5,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "chs",
      "speakerName": "白石千紗",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-chisa.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/eventStoryVoice/sud_vo_adv_event_2205_01_03/sud_vo_adv_event_2205_01_03-chs011.wav",
      "text": "その……あ、いや、やっぱり、なんでもない、よ",
      "startTime": 104.5333333333,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "ngs",
      "speakerName": "伊吹渚",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-nagisa.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/eventStoryVoice/sud_vo_adv_event_2205_01_03/sud_vo_adv_event_2205_01_03-ngs002.wav",
      "text": "……もしかして、沙季ちゃんとのユニットで悩んでる？",
      "startTime": 112.7333333333,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "chs",
      "speakerName": "白石千紗",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-chisa.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/eventStoryVoice/sud_vo_adv_event_2205_01_03/sud_vo_adv_event_2205_01_03-chs012.wav",
      "text": "へっ！？　え、あ、な、なんで分かるの……？",
      "startTime": 117.4,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "ngs",
      "speakerName": "伊吹渚",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-nagisa.png",
      "voiceUrl": null,
      "text": "だって最近、千紗ちゃんも沙季ちゃんもずっと",
      "startTime": 121.3333333333,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "ngs",
      "speakerName": "伊吹渚",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-nagisa.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/eventStoryVoice/sud_vo_adv_event_2205_01_03/sud_vo_adv_event_2205_01_03-ngs003.wav",
      "text": "悩んだ顔してるんだもん。みんなも心配してるよ？",
      "startTime": 124.5333333333,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "chs",
      "speakerName": "白石千紗",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-chisa.png",
      "voiceUrl": null,
      "text": "わ、わわ、みんなに心配させちゃってたんだ……",
      "startTime": 128.8333333333,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "chs",
      "speakerName": "白石千紗",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-chisa.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/eventStoryVoice/sud_vo_adv_event_2205_01_03/sud_vo_adv_event_2205_01_03-chs013.wav",
      "text": "ご、ごめんなさい……",
      "startTime": 133.5333333333,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "ngs",
      "speakerName": "伊吹渚",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-nagisa.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/eventStoryVoice/sud_vo_adv_event_2205_01_03/sud_vo_adv_event_2205_01_03-ngs004.wav",
      "text": "気にしなくていいよ。みんなで支え合ってこそでしょ？",
      "startTime": 136.0666666667,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "ngs",
      "speakerName": "伊吹渚",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-nagisa.png",
      "voiceUrl": null,
      "text": "ね、悩み……聞かせてもらってもいい？",
      "startTime": 140.5333333333,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "ngs",
      "speakerName": "伊吹渚",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-nagisa.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/eventStoryVoice/sud_vo_adv_event_2205_01_03/sud_vo_adv_event_2205_01_03-ngs005.wav",
      "text": "力になれるかは分からないけど",
      "startTime": 145.8333333333,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "chs",
      "speakerName": "白石千紗",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-chisa.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/eventStoryVoice/sud_vo_adv_event_2205_01_03/sud_vo_adv_event_2205_01_03-chs014.wav",
      "text": "……う、うん、その……聞いてくれる？",
      "startTime": 148.8,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "ngs",
      "speakerName": "伊吹渚",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-nagisa.png",
      "voiceUrl": null,
      "text": "もちろんだよ。でもその前に……",
      "startTime": 153.5666666667,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "ngs",
      "speakerName": "伊吹渚",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-nagisa.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/eventStoryVoice/sud_vo_adv_event_2205_01_03/sud_vo_adv_event_2205_01_03-ngs006.wav",
      "text": "残りのお皿洗いを頑張って終わらせないとね",
      "startTime": 157.6333333333,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "chs",
      "speakerName": "白石千紗",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-chisa.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/eventStoryVoice/sud_vo_adv_event_2205_01_03/sud_vo_adv_event_2205_01_03-chs015.wav",
      "text": "う、うんっ！",
      "startTime": 161.5333333333,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "ngs",
      "speakerName": "伊吹渚",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-nagisa.png",
      "voiceUrl": null,
      "text": "そっか、千紗ちゃんも沙季ちゃんも",
      "startTime": 165.1666666667,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "ngs",
      "speakerName": "伊吹渚",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-nagisa.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/eventStoryVoice/sud_vo_adv_event_2205_01_03/sud_vo_adv_event_2205_01_03-ngs007.wav",
      "text": "お互い譲り合っちゃってるんだね",
      "startTime": 168.2,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "chs",
      "speakerName": "白石千紗",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-chisa.png",
      "voiceUrl": null,
      "text": "な、渚ちゃんから見て、私とお姉ちゃんのユニットは",
      "startTime": 171.1333333333,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "chs",
      "speakerName": "白石千紗",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-chisa.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/eventStoryVoice/sud_vo_adv_event_2205_01_03/sud_vo_adv_event_2205_01_03-chs016.wav",
      "text": "どう見えてたかな……？",
      "startTime": 175.6,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "ngs",
      "speakerName": "伊吹渚",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-nagisa.png",
      "voiceUrl": null,
      "text": "とっても素敵だと思うよ",
      "startTime": 177.7333333333,
      "sfxList": []
    },
    {
