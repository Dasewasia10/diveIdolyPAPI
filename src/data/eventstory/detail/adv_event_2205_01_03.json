      },
      "startTime": 367.5666666667,
      "endTime": 373.4226983706,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "ski",
      "speakerName": "白石沙季",
      "speakerNameEn": "Saki",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-saki.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/eventStoryVoice/sud_vo_adv_event_2205_01_03/sud_vo_adv_event_2205_01_03-ski009.m4a",
      "text": "準決勝もなんとか勝てたわね",
