      "speakerNameEn": "Rei Ichinose",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-rei.png",
      "voiceUrl": null,
      "text": "それは……十回も回して出ないなんて悔しいじゃない",
      "translations": {
        "en": "",
        "id": ""
      },
      "startTime": 60.3666656176,
      "sfxList": []
    },
    {
      "type": "dialogue",
