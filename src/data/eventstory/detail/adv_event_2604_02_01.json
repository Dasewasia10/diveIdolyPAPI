      "speakerNameEn": "Chisa Shiraishi",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-chisa.png",
      "voiceUrl": null,
      "text": "二人とも喧嘩しないで～！　途中で怜ちゃんもヤケに",
      "translations": {
        "en": "",
        "id": ""
      },
      "startTime": 51.5333322842,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "chs",
      "speakerName": "白石千紗",
      "speakerNameEn": "Chisa Shiraishi",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-chisa.png",
