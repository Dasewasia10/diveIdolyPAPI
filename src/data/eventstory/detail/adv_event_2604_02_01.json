      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-sakura.png",
      "voiceUrl": null,
      "text": "そう！　その通りだよ！　優ちゃんも言ってたよ！",
      "translations": {
        "en": "",
        "id": ""
      },
      "startTime": 69.7999989509,
      "sfxList": []
    },
    {
