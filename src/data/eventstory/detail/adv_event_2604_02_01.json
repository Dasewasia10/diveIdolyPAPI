    },
    {
      "type": "dialogue",
      "speakerCode": "szk",
      "speakerName": "兵藤雫",
      "speakerNameEn": "Shizuku Hyodo",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-shizuku.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/eventStoryVoice/sud_vo_adv_event_2604_02_01/sud_vo_adv_event_2604_02_01-szk003.m4a",
      "text": "私達の想いを磯のアイスマン星見大五郎の限定ロッドに\n込めて。みんなで釣り上げるよ……せーのっ！",
      "translations": {
        "en": "",
        "id": ""
      },
      "startTime": 105.3666701954,
      "endTime": 115.0333333333,
      "sfxList": [
        {
          "src": "https://apiip.dasewasia.my.id/storyBgm/sud_se_adv_fishing-03.m4a",
          "delay": 14862.215645899994
        },
        {
          "src": "https://apiip.dasewasia.my.id/storyBgm/sud_se_adv_water-pacha-01.m4a",
          "delay": 9799.99491369999
        },
        {
          "src": "https://apiip.dasewasia.my.id/storyBgm/sud_se_adv_water-pacha-01.m4a",
          "delay": 11733.329804599989
        },
        {
          "src": "https://apiip.dasewasia.my.id/storyBgm/sud_se_adv_water-pacha-01.m4a",
          "delay": 13599.996471299988
        }
      ]
    },
    {
      "type": "dialogue",
      "speakerCode": "unknown",
      "speakerName": "一同",
      "speakerNameEn": "",
      "iconUrl": null,
      "voiceUrl": null,
      "text": "うんとこしょ、どっこいしょ～！",
      "translations": {
        "en": "",
        "id": ""
      },
      "startTime": 115.1666651091,
      "endTime": 118.7333318076,
      "sfxList": [
        {
          "src": "https://apiip.dasewasia.my.id/storyBgm/sud_se_adv_fishing-03.m4a",
          "delay": 5033.336035400012
        }
      ]
    },
    {
      "type": "dialogue",
      "speakerCode": "unknown",
      "speakerName": "一同",
      "speakerNameEn": "",
      "iconUrl": null,
      "voiceUrl": null,
      "text": "うんとこしょ、ぐるぐるぐるぐる～～～～！",
      "translations": {
        "en": "",
        "id": ""
      },
      "startTime": 118.7333318076,
      "endTime": 122.93334706649999,
      "sfxList": [
