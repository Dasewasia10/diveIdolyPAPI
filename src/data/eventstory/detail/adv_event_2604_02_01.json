      "voiceUrl": "https://apiip.dasewasia.my.id/eventStoryVoice/sud_vo_adv_event_2604_02_01/sud_vo_adv_event_2604_02_01-skr002.m4a",
      "text": "が欲しかったんだもん！　すぐ出ると思ったんだもん！",
      "translations": {
        "en": "",
        "id": ""
      },
      "startTime": 46.5999989827,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "chs",
