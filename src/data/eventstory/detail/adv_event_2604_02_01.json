      "text": "魚の調達を命じられ、星見市の海で釣りをしていました",
      "translations": {
        "en": "",
        "id": ""
      },
      "startTime": 9.1666666667,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "skr",
      "speakerName": "川咲さくら",
      "speakerNameEn": "Sakura Kawasaki",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-sakura.png",
      "voiceUrl": null,
      "text": "はぁ～、どうしよう。お魚さん、全然釣れないね……",
      "translations": {
        "en": "",
        "id": ""
      },
      "startTime": 16.6333326657,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "skr",
      "speakerName": "川咲さくら",
