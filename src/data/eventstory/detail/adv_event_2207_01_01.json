    },
    {
      "type": "dialogue",
      "speakerCode": "kan",
      "speakerName": "kana",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-kana.png",
      "voiceUrl": null,
      "text": "はぁ～？　誰もかばってほしいなんて言ってませ～ん",
      "startTime": 71,
