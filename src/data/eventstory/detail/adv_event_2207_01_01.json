      "text": "ごめんなさい。この子、口が悪くて……",
      "startTime": 54.9333333333,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "kan",
      "speakerName": "kana",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-kana.png",
      "voiceUrl": null,
      "text": "あー、何一人だけいい子ぶってるの！？",
