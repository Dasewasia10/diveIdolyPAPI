    {
      "type": "dialogue",
      "speakerCode": "yu",
      "speakerName": "鈴村優",
      "speakerNameEn": "Yuu Suzumura",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-yu.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/eventStoryVoice/sud_vo_adv_event_2510_01_01/sud_vo_adv_event_2510_01_01-yu028.m4a",
      "text": "瑠依ちゃんが毎日手伝ってくれとるんもあって\n小さな悩みは順調に解決出来てるんやけどな",
      "translations": {
        "en": "",
        "id": ""
      },
      "startTime": 394.0981438995,
      "endTime": 401.416051519,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_studentcouncilroom-00-noon.webp",
      "bgName": "seitokai",
      "startTime": 401.6314711293
    },
    {
      "type": "dialogue",
      "speakerCode": "yu",
      "speakerName": "鈴村優",
      "speakerNameEn": "Yuu Suzumura",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-yu.png",
