      ]
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_carinside-00-noon.webp",
      "bgName": "s2",
      "startTime": 160.0845358852
    },
    {
      "type": "dialogue",
      "speakerCode": "kan",
      "speakerName": "kana",
