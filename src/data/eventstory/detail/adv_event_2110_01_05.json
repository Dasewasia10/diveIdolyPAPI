      "text": "あはは……芽衣ちゃんらしいね",
      "translations": {
        "en": "Hahaha‚ Mei-chan‚ that’s just like you.",
        "id": ""
      },
      "startTime": 43.2,
      "endTime": 45.93333333333334,
      "sfxList": []
    },
    {
      "type": "background",
