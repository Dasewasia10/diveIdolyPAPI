      "speakerNameEn": "{user}",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-makino.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/eventStoryVoice/sud_vo_adv_event_2504_02_02/sud_vo_adv_event_2504_02_02-koh001.m4a",
      "text": "みたいだな。このまま次の謎のヒントを見つけて……",
      "translations": {
