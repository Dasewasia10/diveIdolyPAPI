      ]
    },
    {
      "type": "dialogue",
      "speakerCode": "koh",
      "speakerName": "{user}",
      "speakerNameEn": "{user}",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-makino.png",
      "voiceUrl": null,
      "text": "……って、うわぁ！　いたたた……",
      "translations": {
        "en": "—Wait‚ whoa! Ouch…!",
        "id": ""
      },
      "startTime": 11.0024715304,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "koh",
      "speakerName": "{user}",
      "speakerNameEn": "{user}",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-makino.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/eventStoryVoice/sud_vo_adv_event_2504_02_02/sud_vo_adv_event_2504_02_02-koh002.m4a",
      "text": "なんだ……？　急に足が引っかかって……",
      "translations": {
        "en": "What the—? My feet suddenly got tangled…",
        "id": ""
      },
      "startTime": 15.6666666627,
      "sfxList": [
        {
          "src": "https://apiip.dasewasia.my.id/storyBgm/sud_se_adv_run-in-single-02.m4a",
          "delay": 3091.222596099998
        }
      ]
    },
    {
      "type": "dialogue",
      "speakerCode": "skr",
      "speakerName": "ザグラ",
      "speakerNameEn": "Zagura",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-sakura.png",
      "voiceUrl": null,
      "text": "ゲーシゲシゲシ！　かかったゲシな！",
      "translations": {
        "en": "Geee-shi geshi geshi! Gotcha‚ geshi!",
        "id": ""
      },
      "startTime": 18.7578892588,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "skr",
      "speakerName": "ザグラ",
      "speakerNameEn": "Zagura",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-sakura.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/eventStoryVoice/sud_vo_adv_event_2504_02_02/sud_vo_adv_event_2504_02_02-skr001.m4a",
      "text": "両足の靴紐をこっそり結んでおいたゲシよ！",
      "translations": {
        "en": "I secretly tied your shoelaces together‚ geshi!",
        "id": ""
      },
      "startTime": 21.6578891079,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "smr",
      "speakerName": "ズミレ",
      "speakerNameEn": "Zumire",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-sumire.png",
      "voiceUrl": null,
      "text": "無様な転びっぷりやなぁ、あんちゃん……",
      "translations": {
        "en": "That was one pathetic fall‚ bro…",
        "id": ""
      },
      "startTime": 25.6912223378,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "smr",
      "speakerName": "ズミレ",
      "speakerNameEn": "Zumire",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-sumire.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/eventStoryVoice/sud_vo_adv_event_2504_02_02/sud_vo_adv_event_2504_02_02-smr001.m4a",
      "text": "ちょっとボケっとし過ぎとちゃいますか？",
      "translations": {
        "en": "Ain’t you spacing out a bit too much?",
        "id": ""
      },
      "startTime": 29.957889235,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "skr",
      "speakerName": "ザグラ",
      "speakerNameEn": "Zagura",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-sakura.png",
      "voiceUrl": null,
      "text": "そうゲシ！　ボケっとしてないで",
      "translations": {
        "en": "That’s right‚ geshi! Instead of zoning out‚",
        "id": ""
      },
      "startTime": 34.0578884958,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "skr",
      "speakerName": "ザグラ",
      "speakerNameEn": "Zagura",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-sakura.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/eventStoryVoice/sud_vo_adv_event_2504_02_02/sud_vo_adv_event_2504_02_02-skr002.m4a",
      "text": "早く私達にBIG4の仕事を用意しろゲシ！",
      "translations": {
        "en": "hurry up and line up BIG4 jobs for us‚ geshi!",
        "id": ""
      },
      "startTime": 36.5912225683,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "koh",
      "speakerName": "{user}",
      "speakerNameEn": "{user}",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-makino.png",
      "voiceUrl": null,
      "text": "なんて無駄に邪悪なんだ……！　というか仕事って",
      "translations": {
        "en": "Why are you so needlessly evil…! And jobs?",
        "id": ""
      },
      "startTime": 40.6912220834,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "koh",
      "speakerName": "{user}",
      "speakerNameEn": "{user}",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-makino.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/eventStoryVoice/sud_vo_adv_event_2504_02_02/sud_vo_adv_event_2504_02_02-koh003.m4a",
      "text": "まさかさくら達の仕事をかわりにやる気なのか！？",
      "translations": {
        "en": "Don’t tell me you’re planning to take over Sakura and the others’ jobs!?",
        "id": ""
      },
      "startTime": 44.7666666627,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "skr",
      "speakerName": "ザグラ",
      "speakerNameEn": "Zagura",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-sakura.png",
      "voiceUrl": null,
      "text": "私達がBIG4なんだから当たり前ゲシ！　おいバルゴ",
      "translations": {
        "en": "Of course! We’re the BIG4‚ geshi! Hey‚ Barugo!",
        "id": ""
      },
      "startTime": 48.2029002387,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "skr",
      "speakerName": "ザグラ",
      "speakerNameEn": "Zagura",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-sakura.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/eventStoryVoice/sud_vo_adv_event_2504_02_02/sud_vo_adv_event_2504_02_02-skr003.m4a",
      "text": "お前に仕事を管理する任務を与えるゲシ！",
      "translations": {
        "en": "I assign you the mission of managing our jobs‚ geshi!",
        "id": ""
      },
      "startTime": 53.436234057,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "hrk",
      "speakerName": "バルゴ",
      "speakerNameEn": "Barugo",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-haruko.png",
      "voiceUrl": null,
      "text": "十七歳に重大任務！　ぴちぴち十代、ひらめいた！",
      "translations": {
        "en": "A huge mission for a seventeen-year-old! This fresh young teen just had a brilliant idea!",
        "id": ""
      },
      "startTime": 57.002896424,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "hrk",
      "speakerName": "バルゴ",
      "speakerNameEn": "Barugo",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-haruko.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/eventStoryVoice/sud_vo_adv_event_2504_02_02/sud_vo_adv_event_2504_02_02-hrk001.m4a",
      "text": "まずは『ラジオ収録』で世界掌握！　チェケラ！",
      "translations": {
        "en": "First‚ we conquer the world through a “radio recording”! Check it out!",
        "id": ""
      },
      "startTime": 61.736234057,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "koh",
      "speakerName": "{user}",
      "speakerNameEn": "{user}",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-makino.png",
      "voiceUrl": null,
      "text": "（くそっ、さくら達の大事な仕事を……！）",
      "translations": {
        "en": "（Damn it… They’re taking Sakura and the others’ important jobs…!）",
        "id": ""
      },
      "startTime": 66.2362279771,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "koh",
      "speakerName": "{user}",
      "speakerNameEn": "{user}",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-makino.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/eventStoryVoice/sud_vo_adv_event_2504_02_02/sud_vo_adv_event_2504_02_02-koh004.m4a",
      "text": "（だが脱出計画がバレたら何をされるか分からない……）",
      "translations": {
        "en": "（But if they find out about the escape plan‚ who knows what they’ll do…）",
        "id": ""
      },
      "startTime": 69.499999996,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "koh",
      "speakerName": "{user}",
      "speakerNameEn": "{user}",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-makino.png",
      "voiceUrl": null,
      "text": "……分かりました、ラジオの仕事を取ってきます",
      "translations": {
        "en": "…Understood. I’ll arrange the radio job.",
        "id": ""
      },
      "startTime": 73.4954795081,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "koh",
      "speakerName": "{user}",
      "speakerNameEn": "{user}",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-makino.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/eventStoryVoice/sud_vo_adv_event_2504_02_02/sud_vo_adv_event_2504_02_02-koh005.m4a",
      "text": "くぅっ、早く戻って来てくれ、さくら――！",
      "translations": {
        "en": "Ugh—please come back soon‚ Sakura―!",
        "id": ""
      },
      "startTime": 77.6333333294,
      "sfxList": []
    },
