        "id": ""
      },
      "startTime": 103.3688069223,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "koh",
      "speakerName": "{user}",
      "speakerNameEn": "{user}",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-makino.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/eventStoryVoice/sud_vo_adv_event_2504_02_02/sud_vo_adv_event_2504_02_02-koh006.m4a",
      "text": "ざわついてるぞ……！　なんとか言い訳しないと……",
      "translations": {
