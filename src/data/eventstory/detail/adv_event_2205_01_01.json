      "voiceUrl": "https://apiip.dasewasia.my.id/eventStoryVoice/sud_vo_adv_event_2205_01_01/sud_vo_adv_event_2205_01_01-szk001.wav",
      "text": "千紗ちゃん、今のところ、すっごく良かった……",
      "startTime": 15.1666666667,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "chs",
      "speakerName": "白石千紗",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-chisa.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/eventStoryVoice/sud_vo_adv_event_2205_01_01/sud_vo_adv_event_2205_01_01-chs003.wav",
      "text": "そ、そう？　ありがとう、えへへ",
      "startTime": 19.5333333333,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "chs",
      "speakerName": "白石千紗",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-chisa.png",
