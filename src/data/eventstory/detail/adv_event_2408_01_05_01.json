    {
      "type": "dialogue",
      "speakerCode": "koh",
      "speakerName": "{user}",
      "speakerNameEn": "{user}",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-makino.png",
      "voiceUrl": null,
      "text": "さすがにそこまでは考えてませんでしたけど……",
      "translations": {
        "en": "I wasn't really thinking that far ahead…",
        "id": ""
      },
      "startTime": 92.6000001192,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "koh",
      "speakerName": "{user}",
      "speakerNameEn": "{user}",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-makino.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/eventStoryVoice/sud_vo_adv_event_2408_01_05_01/sud_vo_adv_event_2408_01_05-koh002.m4a",
      "text": "でも本当に肝が冷えたんですからね！？",
      "translations": {
        "en": "But I really was scared out of my mind!?",
