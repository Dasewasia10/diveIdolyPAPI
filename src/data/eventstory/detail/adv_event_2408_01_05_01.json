    },
    {
      "type": "dialogue",
      "speakerCode": "kan",
      "speakerName": "kana",
      "speakerNameEn": "kana",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-kana.png",
      "voiceUrl": null,
      "text": "それにしてもさあ、あんた達、見てた？",
      "translations": {
        "en": "But anyway‚ you guys‚ did you see it?",
