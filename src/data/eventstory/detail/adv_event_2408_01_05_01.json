    {
      "type": "dialogue",
      "speakerCode": "kan",
      "speakerName": "kana",
      "speakerNameEn": "kana",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-kana.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/eventStoryVoice/sud_vo_adv_event_2408_01_05_01/sud_vo_adv_event_2408_01_05-kan003.m4a",
      "text": "最後に喧嘩してた時の{user}の顔！",
      "translations": {
        "en": "{user}'s face when we were fighting at the end!",
        "id": ""
      },
      "startTime": 81.4666666667,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "kan",
      "speakerName": "kana",
      "speakerNameEn": "kana",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-kana.png",
      "voiceUrl": null,
      "text": "こりゃ事務所クビになるな、再就職どうしようって",
      "translations": {
        "en": "Like‚ \"I'm gonna get fired… How will I find another job?\"",
