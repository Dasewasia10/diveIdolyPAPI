      "speakerCode": "smr",
      "speakerName": "奥山すみれ",
      "speakerNameEn": "Sumire",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-sumire.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/eventStoryVoice/sud_vo_adv_event_2406_02_03/sud_vo_adv_event_2406_02_smr-smr010.m4a",
      "text": "だからまた……時々してくれると嬉しいっちゃ……",
