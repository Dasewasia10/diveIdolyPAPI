{
  "id": "adv_event_2303_01_02",
  "title": "ドキドキ\n新ユニット\n企画会議",
  "script": [
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_tokyoconference-00-noon.webp",
      "bgName": "tokyoconference-00-noon",
      "startTime": 0
    },
    {
      "type": "dialogue",
      "speakerCode": "suz",
      "speakerName": "成宮すず",
      "speakerNameEn": "Suzu",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-suzu.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/eventStoryVoice/sud_vo_adv_event_2303_01_02/sud_vo_adv_event_2303_01_02-suz001.m4a",
      "text": "それでは「第一回、祝・橋本さとみ初プロデュース！\nドキドキ新ユニット企画会議」の開催を宣言しますわ！",
      "translations": {
        "en": "Now‚ I declare the start of the \"Satomi Hashimoto's First Production!\"\nThe Heart-pounding New Unit Project Meeting!\"",
        "id": ""
      },
      "startTime": 0.8,
      "endTime": 12.440861511200001,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_tokyoconference-00-noon.webp",
      "bgName": "tokyoconference-00-noon",
      "startTime": 6.8666666667
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_tokyoconference-00-noon.webp",
      "bgName": "tokyoconference-00-noon",
