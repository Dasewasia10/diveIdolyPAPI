    },
    {
      "type": "dialogue",
      "speakerCode": "kkr",
      "speakerName": "赤崎こころ",
      "speakerNameEn": "Kokoro",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-kokoro.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/eventStoryVoice/sud_vo_adv_event_2303_01_02/sud_vo_adv_event_2303_01_02-kkr001.m4a",
      "text": "どんどん、ぱふぱふ～",
      "translations": {
        "en": "Rub-a-dub‚ rub-a-dub~",
        "id": ""
      },
      "startTime": 12.6475278537,
      "endTime": 14.805169550599999,
      "sfxList": []
    },
    {
      "type": "background",
