      "text": "{user}さんはこの曲のこと\n知っていましたか？",
      "translations": {
        "en": "Did you know about this song‚\n{user}-san?",
        "id": ""
      },
      "startTime": 30.1333249133,
      "endTime": 33.5322530388,
      "sfxList": []
    },
    {
      "type": "dialogue",
