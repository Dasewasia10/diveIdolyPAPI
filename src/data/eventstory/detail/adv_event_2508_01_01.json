      "text": "『彼は私の、歌手活動のマネージャーです\n契約の専門家でもあるので、今日は来てもらいました』",
      "translations": {
        "en": "『彼は私の、歌手活動のマネージャーです\n契約の専門家でもあるので、今日は来てもらいました』",
        "id": ""
      },
      "startTime": 101.1174830754,
      "endTime": 108.32686637249999,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_preconference-00-noon.webp",
      "bgName": "preconference-00-noon",
