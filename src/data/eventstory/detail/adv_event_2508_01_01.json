      "text": "『ごきげんよう、ミスター・ラムジー\n今日はお時間をいただき、ありがとうございます』",
      "translations": {
        "en": "『ごきげんよう、ミスター・ラムジー\n今日はお時間をいただき、ありがとうございます』",
        "id": ""
      },
      "startTime": 95.1174830754,
      "endTime": 100.9318139394,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "kor",
      "speakerName": "fran",
      "speakerNameEn": "fran",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-fran.png",
