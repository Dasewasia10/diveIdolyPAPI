      "voiceUrl": "https://apiip.dasewasia.my.id/eventStoryVoice/sud_vo_adv_event_2305_01_02/sud_vo_adv_event_2305_01_02-konmugi002.wav",
      "text": "するかもね～",
      "startTime": 94.2491796815,
      "sfxList": []
    },
