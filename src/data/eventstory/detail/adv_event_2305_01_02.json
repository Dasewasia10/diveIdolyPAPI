      "text": "スピーカーモードで大丈夫らしいので、電話しますね",
      "startTime": 24.0333332698,
      "sfxList": [
        {
          "src": "https://apiip.dasewasia.my.id/storyBgm/sud_se_adv_phone-dialtone-01.m4a",
          "delay": 3914.467247299999
        }
      ]
    },
    {
      "type": "dialogue",
      "speakerCode": "konyui",
