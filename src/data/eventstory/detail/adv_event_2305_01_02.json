      "text": "こんな感じで毎日お茶してるよ！",
      "startTime": 78.433330218,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "ai",
      "speakerName": "小美山愛",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-ai.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/eventStoryVoice/sud_vo_adv_event_2305_01_02/sud_vo_adv_event_2305_01_02-ai002.wav",
      "text": "えっと、それだけだとさすがに……",
