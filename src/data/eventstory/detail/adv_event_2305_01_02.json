      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-konyui.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/eventStoryVoice/sud_vo_adv_event_2305_01_02/sud_vo_adv_event_2305_01_02-konyui001.wav",
      "text": "もしもーし。こころちゃん、元気～？",
      "startTime": 29.2206317664,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "kkr",
      "speakerName": "赤崎こころ",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-kokoro.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/eventStoryVoice/sud_vo_adv_event_2305_01_02/sud_vo_adv_event_2305_01_02-kkr003.wav",
      "text": "は～い、元気で～す",
      "startTime": 33.1997473639,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "suz",
      "speakerName": "成宮すず",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-suzu.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/eventStoryVoice/sud_vo_adv_event_2305_01_02/sud_vo_adv_event_2305_01_02-suz002.wav",
      "text": "こころとこころが喋ってるみたいですわね……",
      "startTime": 35.8628311714,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "kkr",
      "speakerName": "赤崎こころ",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-kokoro.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/eventStoryVoice/sud_vo_adv_event_2305_01_02/sud_vo_adv_event_2305_01_02-kkr004.wav",
      "text": "急にごめんなさい。唯さんは何をしてたんですか？",
      "startTime": 39.6358470839,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "konyui",
      "speakerName": "平沢唯",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-konyui.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/eventStoryVoice/sud_vo_adv_event_2305_01_02/sud_vo_adv_event_2305_01_02-konyui002.wav",
      "text": "私達は～、部室でお茶してるよ？",
      "startTime": 43.6027405025,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "konazusa",
      "speakerName": "中野梓",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-konazusa.png",
