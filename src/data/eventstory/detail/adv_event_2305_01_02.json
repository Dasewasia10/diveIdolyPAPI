{
  "id": "adv_event_2305_01_02",
  "title": "放課後\nティータイム\nの日常",
  "script": [
    {
      "type": "dialogue",
      "speakerCode": "ai",
      "speakerName": "小美山愛",
      "speakerNameEn": "小美山愛",
