      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-rio.png",
      "voiceUrl": null,
      "text": "そういえば、番組の中でも張り切っていたわね",
      "startTime": 25.416165924,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "rio",
