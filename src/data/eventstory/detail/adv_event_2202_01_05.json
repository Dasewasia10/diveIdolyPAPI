      "text": "固定概念を破って企画を生み出したんですよ！？",
      "startTime": 132.6666666667,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "kkr",
      "speakerName": "赤崎こころ",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-kokoro.png",
