      "text": "ヒントが、すぐそばにあったんですよ",
      "startTime": 23.0666666667,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_dressingroom-00-noon.webp",
      "bgName": "dressingroom-00-noon",
      "startTime": 25.8
    },
    {
      "type": "dialogue",
      "speakerCode": "aoi",
      "speakerName": "井川葵",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-aoi.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/eventStoryVoice/sud_vo_adv_event_2202_01_05/sud_vo_adv_event_2202_01_05-aoi002.wav",
      "text": "ん？　それは何？",
      "startTime": 25.8,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_dressingroom-00-noon.webp",
