    },
    {
      "type": "dialogue",
      "speakerCode": "lala",
      "speakerName": "ララ",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-lala.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/eventStoryVoice/sud_vo_adv_event_2512_01_01/sud_vo_adv_event_2512_01_01-lala002.wav",
      "text": "地球の人が言うところの、宇宙人なんだ",
      "startTime": 144.9666692098,
      "sfxList": []
    },
    {
      "type": "dialogue",
