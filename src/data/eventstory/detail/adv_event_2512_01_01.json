      "text": "きゃあっ！",
      "startTime": 64.1886620839,
      "sfxList": [
        {
          "src": "https://apiip.dasewasia.my.id/storyBgm/sud_se_adv_down-02.m4a",
          "delay": 6.316590099999075
        }
      ]
    },
    {
      "type": "dialogue",
      "speakerCode": "rei",
      "speakerName": "一ノ瀬怜",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-rei.png",
      "voiceUrl": null,
      "text": "ええっ！？",
      "startTime": 67.3219933193,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "rei",
      "speakerName": "一ノ瀬怜",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-rei.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/eventStoryVoice/sud_vo_adv_event_2512_01_01/sud_vo_adv_event_2512_01_01-rei002.wav",
      "text": "何もないところから、いきなり人が落ちてきた！？",
      "startTime": 68.2553287506,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "lala",
      "speakerName": "ララ",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-lala.png",
      "voiceUrl": null,
