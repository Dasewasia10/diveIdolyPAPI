    },
    {
      "type": "dialogue",
      "speakerCode": "koh",
      "speakerName": "{user}",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-makino.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/eventStoryVoice/sud_vo_adv_event_2512_01_01/sud_vo_adv_event_2512_01_01-koh005.wav",
      "text": "うう……なんだ？　背中に柔らかい感触が……",
      "startTime": 81.8333379109,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "kyui",
      "speakerName": "古手川唯",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-kyui.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/eventStoryVoice/sud_vo_adv_event_2512_01_01/sud_vo_adv_event_2512_01_01-kyui001.wav",
      "text": "きゃあっ！　お尻の下に男の人が！？",
      "startTime": 87.8160137814,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "momo",
      "speakerName": "モモ",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-momo.png",
      "voiceUrl": null,
