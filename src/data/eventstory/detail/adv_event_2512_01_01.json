      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "koh",
      "speakerName": "{user}",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-makino.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/eventStoryVoice/sud_vo_adv_event_2512_01_01/sud_vo_adv_event_2512_01_01-koh007.wav",
      "text": "鼻の下伸ばしてないから！　君達、早く降りてくれ！",
      "startTime": 117.9666681926,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "kyui",
      "speakerName": "古手川唯",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-kyui.png",
      "voiceUrl": null,
      "text": "ご、ごめんなさい！　すぐに降ります！",
      "startTime": 122.6326084457,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "kyui",
      "speakerName": "古手川唯",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-kyui.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/eventStoryVoice/sud_vo_adv_event_2512_01_01/sud_vo_adv_event_2512_01_01-kyui002.wav",
      "text": "えっと……ここは、一体どこなのかしら？",
      "startTime": 126.1000025432,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "rei",
      "speakerName": "一ノ瀬怜",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-rei.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/eventStoryVoice/sud_vo_adv_event_2512_01_01/sud_vo_adv_event_2512_01_01-rei003.wav",
      "text": "星見プロよ",
      "startTime": 130.5992629053,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "momo",
      "speakerName": "モモ",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-momo.png",
      "voiceUrl": null,
      "text": "星見プロ？　聞いたことありませんが",
      "startTime": 132.2992629053,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "momo",
      "speakerName": "モモ",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-momo.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/eventStoryVoice/sud_vo_adv_event_2512_01_01/sud_vo_adv_event_2512_01_01-momo002.wav",
      "text": "お笑い事務所ですか？",
      "startTime": 136.2000025432,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "rei",
      "speakerName": "一ノ瀬怜",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-rei.png",
