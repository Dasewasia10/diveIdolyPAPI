      "startTime": 91.0493491492,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "momo",
      "speakerName": "モモ",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-momo.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/eventStoryVoice/sud_vo_adv_event_2512_01_01/sud_vo_adv_event_2512_01_01-momo001.wav",
      "text": "私達を受け止めてくれたみたいですね",
      "startTime": 93.2333358765,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "yami",
      "speakerName": "金色の闇",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-yami.png",
      "voiceUrl": null,
      "text": "受け止めたというより",
