      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "kan",
      "speakerName": "kana",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-kana.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/eventStoryVoice/sud_vo_adv_event_2307_01_01/sud_vo_adv_event_2307_01_01-kan004.wav",
      "text": "仕事ってことくらいちゃんと分かってますけどー？",
      "startTime": 76.6965079944,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "kor",
      "speakerName": "fran",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-fran.png",
      "voiceUrl": null,
