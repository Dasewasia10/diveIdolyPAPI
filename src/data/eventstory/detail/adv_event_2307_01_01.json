      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "mhk",
      "speakerName": "miho",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-miho.png",
      "voiceUrl": null,
      "text": "『恋々Poison』。デビューは私達より後だけど",
      "startTime": 85.8011529288,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "mhk",
      "speakerName": "miho",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-miho.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/eventStoryVoice/sud_vo_adv_event_2307_01_01/sud_vo_adv_event_2307_01_01-mhk004.wav",
      "text": "今のランクは確か、私達や月ストよりも上のはず",
