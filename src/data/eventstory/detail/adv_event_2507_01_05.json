      "speakerName": "小島叶",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-kana.png",
      "voiceUrl": null,
      "text": "でもアメリカの住所表記って分かり辛いんだよなー",
      "startTime": 6.5050341606,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "kan",
