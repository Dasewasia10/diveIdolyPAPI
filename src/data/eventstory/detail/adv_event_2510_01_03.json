      "speakerName": "鈴村優",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-yu.png",
      "voiceUrl": null,
      "text": "葵ちゃん！？　これまためずらしいお客さんやなぁ",
      "startTime": 160.0470801156,
      "sfxList": []
    },
    {
      "type": "background",
