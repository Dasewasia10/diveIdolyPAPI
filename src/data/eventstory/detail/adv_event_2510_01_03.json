      "voiceUrl": "https://apiip.dasewasia.my.id/eventStoryVoice/sud_vo_adv_event_2510_01_03/sud_vo_adv_event_2510_01_03-aoi002.m4a",
      "text": "お化け役の子が全く怖くなくて困っててさ",
      "startTime": 171.9666679382,
