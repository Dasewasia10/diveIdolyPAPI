      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-aoi.png",
      "voiceUrl": null,
      "text": "僕達のクラスはお化け屋敷をすることになったんだけど",
      "startTime": 167.7137355925,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "aoi",
      "speakerName": "井川葵",
