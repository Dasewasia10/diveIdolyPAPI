      "speakerName": "天動瑠依",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-rui.png",
      "voiceUrl": null,
      "text": "し、仕事が速いわね……でも別にいいわよ",
      "startTime": 142.6554024499,
      "sfxList": []
    },
    {
      "type": "dialogue",
