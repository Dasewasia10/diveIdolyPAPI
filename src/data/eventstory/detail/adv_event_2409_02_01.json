      "text": "夜泊まる旅館も、優ちゃんのオススメの旅館なんだよね",
      "translations": {
        "en": "The inn we're staying at tonight is also Yu-chan's recommendation‚ right?",
        "id": ""
      },
      "startTime": 90.0487170337,
      "endTime": 94.5687807201,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_kamogawa-00-noon.webp",
      "bgName": "kamogawa-00-noon",
      "startTime": 94.7820457894
    },
    {
      "type": "dialogue",
      "speakerCode": "rui",
      "speakerName": "天動瑠依",
      "speakerNameEn": "Rui",
