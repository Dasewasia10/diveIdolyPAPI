      "text": "でも、なんで京都なんですの？\n私はハワイとかロサンゼルスを希望しましたのよ",
      "translations": {
        "en": "But why Kyoto?\nI requested Hawaii or Los Angeles.",
        "id": ""
      },
      "startTime": 107.3820457894,
      "endTime": 115.0949710328,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_kamogawa-00-noon.webp",
      "bgName": "kamogawa-00-noon",
      "startTime": 115.2820457894
    },
    {
      "type": "dialogue",
      "speakerCode": "chs",
      "speakerName": "白石千紗",
      "speakerNameEn": "Chisa",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-chisa.png",
