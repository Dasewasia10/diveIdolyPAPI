      "text": "温泉もあるみたいだから\n夜はゆっくり日頃の疲れを癒せそうね",
      "translations": {
        "en": "There seems to be a hot spring too‚\nso we can relax and recover from our daily fatigue tonight.",
        "id": ""
      },
      "startTime": 102.4153791228,
      "endTime": 107.1632021387,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_kamogawa-00-noon.webp",
      "bgName": "kamogawa-00-noon",
      "startTime": 107.3820457894
    },
    {
      "type": "dialogue",
      "speakerCode": "suz",
      "speakerName": "成宮すず",
      "speakerNameEn": "Suzu",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-suzu.png",
