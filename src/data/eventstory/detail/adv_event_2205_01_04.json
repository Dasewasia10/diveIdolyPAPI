      },
      "startTime": 138.4,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "ski",
      "speakerName": "白石沙季",
      "speakerNameEn": "Saki",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-saki.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/eventStoryVoice/sud_vo_adv_event_2205_01_04/sud_vo_adv_event_2205_01_04-ski008.m4a",
      "text": "私の、本当にやりたいこと……か",
      "translations": {
        "en": "What is it… that I truly want to do…?",
        "id": ""
      },
      "startTime": 143.0666666667,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "chs",
      "speakerName": "白石千紗",
      "speakerNameEn": "Chisa",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-chisa.png",
      "voiceUrl": null,
      "text": "お姉ちゃんは私や月ストの",
      "translations": {
        "en": "Onee-chan‚ you've always been trying to",
