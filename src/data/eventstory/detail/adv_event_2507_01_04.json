    {
      "type": "dialogue",
      "speakerCode": "mhk",
      "speakerName": "miho",
      "speakerNameEn": "miho",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-miho.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/eventStoryVoice/sud_vo_adv_event_2507_01_04/sud_vo_adv_event_2507_01_04-mhk001.m4a",
      "text": "（VENUSランキング不動の一位のアイドル……）\n（ヨーコさんは常に彼女を支え共にトップを走っていた）",
      "translations": {
        "en": "（VENUSランキング不動の一位のアイドル……）\n（ヨーコさんは常に彼女を支え共にトップを走っていた）",
