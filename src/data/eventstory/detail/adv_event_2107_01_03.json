      "bgName": "bg1",
      "startTime": 27.4
    },
    {
      "type": "dialogue",
      "speakerCode": "hrk",
      "speakerName": "佐伯遙子",
      "speakerNameEn": "Haruko",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-haruko.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/eventStoryVoice/sud_vo_adv_event_2107_01_03/sud_vo_adv_event_2107_01_03-hrk003.m4a",
      "text": "えっ！　優ちゃん！？\nどうしてあなたがここにいるの？",
      "translations": {
        "en": "Eh! Yu-chan!?\nWhy are you here?",
        "id": ""
      },
      "startTime": 27.4,
      "endTime": 31.366666666666667,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_okinawastreet-00-noon.webp",
      "bgName": "bg1",
      "startTime": 31.566666666666666
    },
    {
      "type": "dialogue",
      "speakerCode": "yu",
      "speakerName": "鈴村優",
      "speakerNameEn": "Yu",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-yu.png",
