      "startTime": 61.6,
      "endTime": 67.66666666666667,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_okinawastreet-00-noon.webp",
      "bgName": "bg1",
      "startTime": 67.86666666666666
    },
    {
      "type": "dialogue",
