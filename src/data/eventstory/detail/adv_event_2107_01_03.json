      "text": "そうだったの……。偶然って凄いわね",
      "translations": {
        "en": "Really? Coincidence‚ how amazing.",
        "id": ""
      },
      "startTime": 49.2,
      "endTime": 53.466666666666676,
      "sfxList": []
    },
    {
      "type": "background",
