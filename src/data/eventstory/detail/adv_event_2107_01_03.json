      "text": "これもご縁やし、うちが沖縄を案内しましょうか？\n沖縄には楽しい所が沢山あるんよ",
      "translations": {
        "en": "Since we happened to cross paths‚ how 'bout I show y'all 'round Okinawa?\nOkinawa's got heaps of fun places.",
        "id": ""
      },
      "startTime": 53.666666666666664,
      "endTime": 61.43333333333333,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_okinawastreet-00-noon.webp",
      "bgName": "bg1",
      "startTime": 61.6
    },
    {
      "type": "dialogue",
      "speakerCode": "hrk",
      "speakerName": "佐伯遙子",
      "speakerNameEn": "Haruko",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-haruko.png",
