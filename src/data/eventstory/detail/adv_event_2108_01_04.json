      "text": "終わってしまいましたわね……",
      "startTime": 3.966666666666667,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "mei",
      "speakerName": "早坂芽衣",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-mei.png",
