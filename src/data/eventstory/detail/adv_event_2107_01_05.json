      "speakerCode": "yu",
      "speakerName": "鈴村優",
      "speakerNameEn": "Yu",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-yu.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/eventStoryVoice/sud_vo_adv_event_2107_01_05/sud_vo_adv_event_2107_01_05-yu022.m4a",
      "text": "何言うてんの。うちらの夏はまだまだこれからやろ",
      "translations": {
        "en": "What in tarnation are y'all talkin' about? This summer's just gettin' started",
        "id": ""
      },
      "startTime": 307.76666666666665,
      "endTime": 312.6912923494975,
      "sfxList": []
    },
    {
      "type": "background",
