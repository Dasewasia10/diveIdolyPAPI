      "bgName": "bg3",
      "startTime": 302.8
    },
    {
      "type": "dialogue",
      "speakerCode": "hrk",
      "speakerName": "佐伯遙子",
      "speakerNameEn": "Haruko",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-haruko.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/eventStoryVoice/sud_vo_adv_event_2107_01_05/sud_vo_adv_event_2107_01_05-hrk022.m4a",
      "text": "今年はみんなと楽しい思い出が出来て最高の夏だったわ",
      "translations": {
        "en": "This year was the best summer ever‚ as I made fun memories with you all.",
        "id": ""
      },
      "startTime": 302.8,
      "endTime": 307.57483015060427,
      "sfxList": []
    },
    {
