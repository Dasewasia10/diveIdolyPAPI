      "speakerNameEn": "Rei",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-rei.png",
      "voiceUrl": null,
      "text": "でも、みんなの前ではそんな素振りさえ見せない",
      "translations": {
        "en": "But you never show signs of it in front of everyone‚ and",
        "id": ""
