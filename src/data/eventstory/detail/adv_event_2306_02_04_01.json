      "text": "わわっ、そうだよね！",
      "translations": {
        "en": "Oh‚ right!",
        "id": ""
      },
      "startTime": 26.5333333333,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "skr",
