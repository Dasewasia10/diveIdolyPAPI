      "text": "次は私達サニーピースの番です",
      "translations": {
        "en": "Next up is our turn‚ Sunny Peace.",
        "id": ""
      },
      "startTime": 11.5009260231,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_gpstage-00-noon.webp",
