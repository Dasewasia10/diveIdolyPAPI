      "speakerNameEn": "Sakura",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-sakura.png",
      "voiceUrl": null,
      "text": "えっと……二人がいつもヘトヘトになるまで",
      "translations": {
        "en": "Um… I know that you two always work hard",
        "id": ""
      },
      "startTime": 28.9666666667,
      "sfxList": []
    },
    {
