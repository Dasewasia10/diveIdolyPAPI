      "text": "その頃は野外ライブとかしてたん？",
      "startTime": 55.36666666666667,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "hrk",
      "speakerName": "佐伯遙子",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-haruko.png",
      "voiceUrl": null,
      "text": "え、ええ、そうね……",
      "startTime": 58.43333333333333,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "hrk",
      "speakerName": "佐伯遙子",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-haruko.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/eventStoryVoice/sud_vo_adv_event_2107_01_01/sud_vo_adv_event_2107_01_01-hrk002.m4a",
      "text": "一人で野外イベントに出演したこともあるけど……",
      "startTime": 60.8,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "chs",
      "speakerName": "白石千紗",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-chisa.png",
      "voiceUrl": null,
      "text": "知らなかった",
      "startTime": 65.03333333333333,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "chs",
      "speakerName": "白石千紗",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-chisa.png",
