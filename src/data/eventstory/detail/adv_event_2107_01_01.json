    },
    {
      "type": "dialogue",
      "speakerCode": "skr",
      "speakerName": "川咲さくら",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-sakura.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/eventStoryVoice/sud_vo_adv_event_2107_01_01/sud_vo_adv_event_2107_01_01-skr003.m4a",
