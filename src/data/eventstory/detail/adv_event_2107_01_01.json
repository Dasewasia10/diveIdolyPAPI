      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "skr",
      "speakerName": "川咲さくら",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-sakura.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/eventStoryVoice/sud_vo_adv_event_2107_01_01/sud_vo_adv_event_2107_01_01-skr002.m4a",
      "text": "さっき{user}さんから聞いたんだけど",
      "startTime": 90.23333333333333,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "skr",
      "speakerName": "川咲さくら",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-sakura.png",
