{
  "id": "adv_event_2406_01_05",
  "title": "君を照らすムーンライトロード 5話 待ってるよ",
  "script": [
    {
      "type": "dialogue",
      "speakerCode": null,
      "speakerName": "",
      "iconUrl": null,
      "voiceUrl": null,
      "text": "――ライブバトルから数日後",
      "startTime": 0.8,
      "sfxList": [
        {
          "src": "https://apiip.dasewasia.my.id/storyBgm/sud_se_adv_walk-in-single-01.m4a",
          "delay": 4066.6666667
        }
      ]
    },
    {
      "type": "dialogue",
      "speakerCode": "ski",
      "speakerName": "白石沙季",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-saki.png",
      "voiceUrl": null,
      "text": "おはようございます",
      "startTime": 5.5666667302,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "ski",
      "speakerName": "白石沙季",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-saki.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/eventStoryVoice/sud_vo_adv_event_2406_01_05/sud_vo_adv_event_2406_01_05-ski001.m4a",
      "text": "お二人とも早いですね",
      "startTime": 7.2171310149,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "ngs",
      "speakerName": "伊吹渚",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-nagisa.png",
      "voiceUrl": null,
      "text": "完成した新曲のデモを聴いたら、じっとしてられなくて",
      "startTime": 9.7086620808,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "ngs",
      "speakerName": "伊吹渚",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-nagisa.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/eventStoryVoice/sud_vo_adv_event_2406_01_05/sud_vo_adv_event_2406_01_05-ngs001.m4a",
      "text": "いつもより早めにスタジオに来ちゃった",
      "startTime": 13.6,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "ski",
      "speakerName": "白石沙季",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-saki.png",
      "voiceUrl": null,
      "text": "分かります。私もあの歌を聴いてから",
      "startTime": 16.5165305933,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "ski",
      "speakerName": "白石沙季",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-saki.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/eventStoryVoice/sud_vo_adv_event_2406_01_05/sud_vo_adv_event_2406_01_05-ski002.m4a",
      "text": "振り付けのアイデアが次々とわいてきています",
      "startTime": 20.1666666667,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "ktn",
      "speakerName": "長瀬琴乃",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-kotono.png",
      "voiceUrl": null,
      "text": "私達の曲に込めたい想いがうまく伝わって",
      "startTime": 23.6165985267,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "ktn",
      "speakerName": "長瀬琴乃",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-kotono.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/eventStoryVoice/sud_vo_adv_event_2406_01_05/sud_vo_adv_event_2406_01_05-ktn001.m4a",
      "text": "とても素敵な歌詞になったわね",
      "startTime": 27.1029868054,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "ngs",
      "speakerName": "伊吹渚",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-nagisa.png",
      "voiceUrl": null,
      "text": "眩しい太陽の光とは違う……そっと道を照らして",
      "startTime": 30.1852379322,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "ngs",
      "speakerName": "伊吹渚",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-nagisa.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/eventStoryVoice/sud_vo_adv_event_2406_01_05/sud_vo_adv_event_2406_01_05-ngs002.m4a",
      "text": "大事なことに気付かせてくれる優しい光……",
      "startTime": 36.5202490489,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "ski",
      "speakerName": "白石沙季",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-saki.png",
      "voiceUrl": null,
      "text": "静かに寄り添う優しさと、迷いを吹き飛ばす勇気と強さ",
      "startTime": 40.2147845428,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "ski",
      "speakerName": "白石沙季",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-saki.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/eventStoryVoice/sud_vo_adv_event_2406_01_05/sud_vo_adv_event_2406_01_05-ski003.m4a",
      "text": "……月のテンペストらしさが込められた、いい曲です",
      "startTime": 46.2535823822,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "ngs",
      "speakerName": "伊吹渚",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-nagisa.png",
      "voiceUrl": null,
      "text": "最高の曲に負けないように",
      "startTime": 49.6271879991,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "ngs",
      "speakerName": "伊吹渚",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-nagisa.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/eventStoryVoice/sud_vo_adv_event_2406_01_05/sud_vo_adv_event_2406_01_05-ngs003.m4a",
      "text": "私達も最高のパフォーマンスをしないとね",
      "startTime": 51.9202490489,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "ktn",
      "speakerName": "長瀬琴乃",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-kotono.png",
      "voiceUrl": null,
      "text": "決戦の日まで残り僅か。この短期間でパフォーマンスの",
      "startTime": 55.416031472,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "ktn",
      "speakerName": "長瀬琴乃",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-kotono.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/eventStoryVoice/sud_vo_adv_event_2406_01_05/sud_vo_adv_event_2406_01_05-ktn002.m4a",
      "text": "完成度をどこまで高められるかが勝負よ",
      "startTime": 60.4138311241,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "ski",
      "speakerName": "白石沙季",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-saki.png",
      "voiceUrl": null,
      "text": "時間との勝負ですね",
      "startTime": 63.5266891957,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "ski",
      "speakerName": "白石沙季",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-saki.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/eventStoryVoice/sud_vo_adv_event_2406_01_05/sud_vo_adv_event_2406_01_05-ski004.m4a",
      "text": "実際、かなり厳しいですが……",
      "startTime": 66.0825165112,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "ski",
      "speakerName": "白石沙季",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-saki.png",
      "voiceUrl": null,
      "text": "今日だって芽衣ちゃんとすずちゃんはお仕事で",
      "startTime": 69.66480697,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "ski",
      "speakerName": "白石沙季",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-saki.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/eventStoryVoice/sud_vo_adv_event_2406_01_05/sud_vo_adv_event_2406_01_05-ski005.m4a",
      "text": "夜にならないと五人揃って練習出来ませんから",
      "startTime": 72.9825165112,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "ngs",
      "speakerName": "伊吹渚",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-nagisa.png",
      "voiceUrl": null,
      "text": "それでもやるしかないよ！",
      "startTime": 76.8278226854,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "ngs",
      "speakerName": "伊吹渚",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-nagisa.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/eventStoryVoice/sud_vo_adv_event_2406_01_05/sud_vo_adv_event_2406_01_05-ngs004.m4a",
      "text": "みんなで力を合わせて頑張ろう！",
      "startTime": 78.9609809853,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "ktn",
      "speakerName": "長瀬琴乃",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-kotono.png",
      "voiceUrl": null,
      "text": "そうね。今は出来ることをやりましょう",
      "startTime": 81.9190926713,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "ktn",
      "speakerName": "長瀬琴乃",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-kotono.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/eventStoryVoice/sud_vo_adv_event_2406_01_05/sud_vo_adv_event_2406_01_05-ktn003.m4a",
      "text": "まずは新曲の振り付けを完成させて――",
      "startTime": 86.0333333333,
      "sfxList": [
        {
          "src": "https://apiip.dasewasia.my.id/storyBgm/sud_se_adv_walk-in-single-01.m4a",
          "delay": 3333.3333333999917
        }
      ]
    },
    {
      "type": "dialogue",
      "speakerCode": "skr",
      "speakerName": "川咲さくら",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-sakura.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/eventStoryVoice/sud_vo_adv_event_2406_01_05/sud_vo_adv_event_2406_01_05-skr001.m4a",
      "text": "おっはようございまーす！！",
      "startTime": 89.1814566137,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "ktn",
      "speakerName": "長瀬琴乃",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-kotono.png",
      "voiceUrl": null,
      "text": "さくら！？",
      "startTime": 91.5538358768,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "ktn",
      "speakerName": "長瀬琴乃",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-kotono.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/eventStoryVoice/sud_vo_adv_event_2406_01_05/sud_vo_adv_event_2406_01_05-ktn004.m4a",
      "text": "それに雫も……どうしてあなた達がここに？",
      "startTime": 93.000004069,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "szk",
      "speakerName": "兵藤雫",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-shizuku.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/eventStoryVoice/sud_vo_adv_event_2406_01_05/sud_vo_adv_event_2406_01_05-szk001.m4a",
      "text": "新曲のデモ……私達も聴かせてもらった……",
      "startTime": 97.7212510189,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "skr",
      "speakerName": "川咲さくら",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-sakura.png",
      "voiceUrl": null,
      "text": "それがすっごく良くて、琴乃ちゃん達が歌う姿を",
      "startTime": 102.1879176856,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "skr",
      "speakerName": "川咲さくら",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-sakura.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/eventStoryVoice/sud_vo_adv_event_2406_01_05/sud_vo_adv_event_2406_01_05-skr002.m4a",
      "text": "想像したら、いても立ってもいられなくなって……",
      "startTime": 106.4666666667,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "ktn",
      "speakerName": "長瀬琴乃",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-kotono.png",
      "voiceUrl": null,
      "text": "それで私達の様子を見に来たの？",
      "startTime": 110.6881921531,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "ktn",
      "speakerName": "長瀬琴乃",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-kotono.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/eventStoryVoice/sud_vo_adv_event_2406_01_05/sud_vo_adv_event_2406_01_05-ktn005.m4a",
      "text": "その行動力はさくららしいわね",
      "startTime": 115.5000066121,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "skr",
      "speakerName": "川咲さくら",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-sakura.png",
      "voiceUrl": null,
      "text": "えへへ～。でも来たのは私だけじゃないよ",
      "startTime": 119.5135892313,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "skr",
      "speakerName": "川咲さくら",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-sakura.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/eventStoryVoice/sud_vo_adv_event_2406_01_05/sud_vo_adv_event_2406_01_05-skr003.m4a",
      "text": "これから新曲の振り付けを作るんでしょ？",
      "startTime": 125.0991895358,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "skr",
      "speakerName": "川咲さくら",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-sakura.png",
      "voiceUrl": null,
      "text": "そこで助っ人のスーパーコーチを連れて来ました！",
      "startTime": 128.4554940939,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "skr",
      "speakerName": "川咲さくら",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-sakura.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/eventStoryVoice/sud_vo_adv_event_2406_01_05/sud_vo_adv_event_2406_01_05-skr004.m4a",
      "text": "じゃーん、先生、お願いします！",
      "startTime": 132.8991895358,
      "sfxList": [
        {
          "src": "https://apiip.dasewasia.my.id/storyBgm/sud_se_adv_walk-in-single-01.m4a",
          "delay": 4383.991169600023
        }
      ]
    },
    {
      "type": "dialogue",
      "speakerCode": "rei",
      "speakerName": "一ノ瀬怜",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-rei.png",
      "voiceUrl": null,
      "text": "ちょっと、変な呼び込みしないでよ",
      "startTime": 137.1148138125,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "rei",
      "speakerName": "一ノ瀬怜",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-rei.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/eventStoryVoice/sud_vo_adv_event_2406_01_05/sud_vo_adv_event_2406_01_05-rei001.m4a",
      "text": "恥ずかしいじゃない",
      "startTime": 140.9420313239,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "ngs",
      "speakerName": "伊吹渚",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-nagisa.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/eventStoryVoice/sud_vo_adv_event_2406_01_05/sud_vo_adv_event_2406_01_05-ngs005.m4a",
      "text": "コーチって……怜ちゃんが私達を手伝ってくれるの？",
      "startTime": 143.3165373881,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "rei",
      "speakerName": "一ノ瀬怜",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-rei.png",
      "voiceUrl": null,
      "text": "月ストの新曲、私も聴いたけど凄く良かったわ",
      "startTime": 148.6092127561,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "rei",
      "speakerName": "一ノ瀬怜",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-rei.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/eventStoryVoice/sud_vo_adv_event_2406_01_05/sud_vo_adv_event_2406_01_05-rei002.m4a",
      "text": "ぜひ振り付けを作るのを手伝わせてもらえないかしら",
      "startTime": 154.3325228691,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "szk",
      "speakerName": "兵藤雫",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-shizuku.png",
      "voiceUrl": null,
      "text": "私はみんなのダンスをばっちり撮影する……",
      "startTime": 158.5945641279,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "szk",
      "speakerName": "兵藤雫",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-shizuku.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/eventStoryVoice/sud_vo_adv_event_2406_01_05/sud_vo_adv_event_2406_01_05-szk002.m4a",
      "text": "振り付けの確認と分析は任せて……",
      "startTime": 162.2751349322,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "skr",
      "speakerName": "川咲さくら",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-sakura.png",
      "voiceUrl": null,
      "text": "怜ちゃんと雫ちゃんだけじゃないよ",
      "startTime": 165.7945641279,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "skr",
      "speakerName": "川咲さくら",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-sakura.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/eventStoryVoice/sud_vo_adv_event_2406_01_05/sud_vo_adv_event_2406_01_05-skr005.m4a",
      "text": "私や遙子ちゃん、千紗ちゃん……",
      "startTime": 168.7325228691,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "skr",
      "speakerName": "川咲さくら",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-sakura.png",
      "voiceUrl": null,
      "text": "それに他の星見プロのみんなも月ストを手伝うから",
      "startTime": 172.0890538294,
      "sfxList": []
    },
    {
      "type": "dialogue",
