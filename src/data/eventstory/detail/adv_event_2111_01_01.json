      "text": "きっと軽薄な仕事だと思ってるのよ",
      "startTime": 122.36666666666666,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "mei",
      "speakerName": "早坂芽衣",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-mei.png",
