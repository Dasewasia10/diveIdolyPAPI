    {
      "type": "dialogue",
      "speakerCode": "mei",
      "speakerName": "早坂芽衣",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-mei.png",
      "voiceUrl": null,
      "text": "大好きだよ、これからもずーっと一緒にいようね！",
