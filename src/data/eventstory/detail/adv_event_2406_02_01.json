      "text": "{user}さんはデビュー当時から\n私達のことを、ずっと支えてきてくれましたよね",
      "translations": {
        "en": "{user}-san‚ you’ve been supporting us\never since our debut.",
        "id": ""
      },
      "startTime": 202.8105491636,
      "endTime": 208.51887102109998,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "ski",
