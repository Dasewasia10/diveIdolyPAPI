    },
    {
      "type": "dialogue",
      "speakerCode": "yu",
      "speakerName": "鈴村優",
      "speakerNameEn": "Yu",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-yu.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/eventStoryVoice/sud_vo_adv_event_2409_01_03/sud_vo_adv_event_2409_01_03-yu012.m4a",
      "text": "はぁ……もし人生で一度だけ、時を巻き戻せるなら……\nあの日のあほな自分を引っぱたきに行くわ……",
      "translations": {
        "en": "Haa… If I could turn back time just once‚ in my life…\nI'd go and punish myself for being so stupid back then…",
