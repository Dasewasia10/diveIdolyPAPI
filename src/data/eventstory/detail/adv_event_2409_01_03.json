      "bgName": "tokyocafe-00-noon",
      "startTime": 390.7862942455
    },
    {
      "type": "dialogue",
      "speakerCode": "rui",
      "speakerName": "天動瑠依",
      "speakerNameEn": "Rui",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-rui.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/eventStoryVoice/sud_vo_adv_event_2409_01_03/sud_vo_adv_event_2409_01_03-rui010.m4a",
      "text": "……いい、お母さんね。優の自主性を尊重して\n今も遠くから、優しく見守ってくれているのね",
      "translations": {
        "en": "…Great‚ mother. Respect Yu's independence\nEven now‚ from afar‚ she is watching over you kindly",
        "id": ""
      },
      "startTime": 391.8362942455,
      "endTime": 400.4633463619,
      "sfxList": []
    },
    {
      "type": "background",
