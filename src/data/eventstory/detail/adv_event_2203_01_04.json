      "text": "る、瑠依さんを、私に下さい……！",
      "startTime": 132.8666666667,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "smr",
      "speakerName": "奥山すみれ",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-sumire.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/eventStoryVoice/sud_vo_adv_event_2203_01_04/sud_vo_adv_event_2203_01_04-smr006.m4a",
      "text": "新ユニットどころかプロポーズ！？",
      "startTime": 137.8666666667,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "rui",
