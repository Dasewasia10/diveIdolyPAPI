      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "szk",
      "speakerName": "兵藤雫",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-shizuku.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/eventStoryVoice/sud_vo_adv_event_2203_01_04/sud_vo_adv_event_2203_01_04-szk006.m4a",
      "text": "その……優ちゃん、すみれちゃん……いい、ですか？",
      "startTime": 155.8333333333,
