      "text": "この歌で麻奈ちゃんの想いも伝えたいの……",
      "startTime": 19.6700010537,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "hrk",
      "speakerName": "佐伯遙子",
