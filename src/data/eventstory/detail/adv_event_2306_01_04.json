      "text": "じゃあ、私達に歌ってほしい曲って……",
      "startTime": 10.8666666667,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "hrk",
      "speakerName": "佐伯遙子",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-haruko.png",
