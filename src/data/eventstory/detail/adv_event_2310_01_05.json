      "startTime": 34.5906805039,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "mei",
      "speakerName": "早坂芽衣",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-mei.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/eventStoryVoice/sud_vo_adv_event_2310_01_05/sud_vo_adv_event_2310_01_05-mei002.m4a",
      "text": "それだと芽衣ばっかりやりやすくなっちゃわない！？",
      "startTime": 38.4999996185,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "suz",
      "speakerName": "成宮すず",
