      "text": "だから、芽衣と組む以上は私が芽衣のポテンシャルを",
      "startTime": 25.181814162,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "suz",
      "speakerName": "成宮すず",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-suzu.png",
