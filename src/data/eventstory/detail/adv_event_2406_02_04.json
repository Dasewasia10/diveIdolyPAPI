    },
    {
      "type": "dialogue",
      "speakerCode": "aoi",
      "speakerName": "井川葵",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-aoi.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/eventStoryVoice/sud_vo_adv_event_2406_02_04/sud_vo_adv_event_2406_02_aoi-aoi003.wav",
      "text": "……って言いたいところだけど、短過ぎるかな？",
      "startTime": 93.577649752,
