      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "aoi",
      "speakerName": "井川葵",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-aoi.png",
      "voiceUrl": null,
      "text": "ドラマの再放送を観て、気になったらしいんだけど……",
