    },
    {
      "type": "dialogue",
      "speakerCode": "aoi",
      "speakerName": "井川葵",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-aoi.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/eventStoryVoice/sud_vo_adv_event_2406_02_04/sud_vo_adv_event_2406_02_aoi-aoi009.wav",
      "text": "意識してドキドキするものだ、って言うからさ",
