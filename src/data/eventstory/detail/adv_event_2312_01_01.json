      "text": "でも今日のお仕事……まだ終わりじゃない……\nこの後、ラジオの生放送……",
      "translations": {
        "en": "でも今日のお仕事……まだ終わりじゃない……\nこの後、ラジオの生放送……",
        "id": ""
      },
      "startTime": 19.6777325789,
      "endTime": 26.7866896787,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_talkstudio-00-noon.webp",
      "bgName": "talkstudio-00-noon",
      "startTime": 27.0006352583
    },
    {
      "type": "dialogue",
      "speakerCode": "chs",
      "speakerName": "白石千紗",
      "speakerNameEn": "白石千紗",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-chisa.png",
