      "text": "今日は朝から分刻みのスケジュールで\n仕事してるんだから仕方ないわよ",
      "translations": {
        "en": "今日は朝から分刻みのスケジュールで\n仕事してるんだから仕方ないわよ",
        "id": ""
      },
      "startTime": 13.1110659122,
      "endTime": 19.481746053600002,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "szk",
      "speakerName": "兵藤雫",
      "speakerNameEn": "兵藤雫",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-shizuku.png",
