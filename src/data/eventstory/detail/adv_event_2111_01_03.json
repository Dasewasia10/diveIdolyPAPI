      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-mei.png",
      "voiceUrl": null,
      "text": "――という訳で、芽衣達",
      "translations": {
        "en": "What she means is‚ we’ve just been",
        "id": ""
      },
      "startTime": 75.9666666667,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "mei",
      "speakerName": "早坂芽衣",
