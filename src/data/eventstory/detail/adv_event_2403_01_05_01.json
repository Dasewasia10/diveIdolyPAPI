      "text": "ライブツアーもとうとう最終日\nなんだかあっという間だったわね",
      "translations": {
        "en": "The live tour has finally reached its last day.\nIt feels like it went by in the blink of an eye.",
        "id": ""
      },
      "startTime": 9.0999999523,
      "endTime": 14.203695631,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_livehousemiddle-00-noon.webp",
      "bgName": "livehousemiddle-00-noon",
      "startTime": 14.4199314594
    },
    {
      "type": "dialogue",
      "speakerCode": "szk",
      "speakerName": "兵藤雫",
      "speakerNameEn": "Shizuku",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-shizuku.png",
