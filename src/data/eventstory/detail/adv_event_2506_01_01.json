      "endTime": 161.1215837002,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "ai",
      "speakerName": "小美山愛",
      "speakerNameEn": "小美山愛",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-ai.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/eventStoryVoice/sud_vo_adv_event_2506_01_01/sud_vo_adv_event_2506_01_01-ai006.m4a",
      "text": "ツアーを成功させたい気持ちはみんな同じです\n無理しないで、もっと私達を頼って下さい",
      "translations": {
        "en": "ツアーを成功させたい気持ちはみんな同じです\n無理しないで、もっと私達を頼って下さい",
        "id": ""
      },
      "startTime": 161.3215836048,
      "endTime": 168.53825011249998,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "skr",
      "speakerName": "川咲さくら",
      "speakerNameEn": "川咲さくら",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-sakura.png",
