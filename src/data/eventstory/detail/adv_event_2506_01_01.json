      },
      "startTime": 115.3636300247,
      "endTime": 120.6304779213,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "ai",
      "speakerName": "小美山愛",
      "speakerNameEn": "小美山愛",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-ai.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/eventStoryVoice/sud_vo_adv_event_2506_01_01/sud_vo_adv_event_2506_01_01-ai005.m4a",
      "text": "もう決まったんですか！？\nさすが{user}さんです！",
      "translations": {
        "en": "もう決まったんですか！？\nさすが{user}さんです！",
        "id": ""
      },
      "startTime": 120.8438111783,
      "endTime": 124.8640832425,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "mei",
      "speakerName": "早坂芽衣",
      "speakerNameEn": "早坂芽衣",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-mei.png",
