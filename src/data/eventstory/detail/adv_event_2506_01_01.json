    {
      "type": "dialogue",
      "speakerCode": "ai",
      "speakerName": "小美山愛",
      "speakerNameEn": "小美山愛",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-ai.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/eventStoryVoice/sud_vo_adv_event_2506_01_01/sud_vo_adv_event_2506_01_01-ai004.m4a",
      "text": "信じて頑張れば願いは叶います！\n私達は{user}さんを応援します！",
      "translations": {
        "en": "信じて頑張れば願いは叶います！\n私達は{user}さんを応援します！",
        "id": ""
      },
      "startTime": 92.8143093586,
      "endTime": 99.5070076466,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "koh",
      "speakerName": "{user}",
      "speakerNameEn": "{user}",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-makino.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/eventStoryVoice/sud_vo_adv_event_2506_01_01/sud_vo_adv_event_2506_01_01-koh004.m4a",
      "text": "……そうだな、いつもみんなに頑張れと言っておいて\n俺がやる前から諦めちゃいけないよな",
      "translations": {
        "en": "……そうだな、いつもみんなに頑張れと言っておいて\n俺がやる前から諦めちゃいけないよな",
        "id": ""
