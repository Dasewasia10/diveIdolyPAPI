      "startTime": 144.5730212063,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "suz",
      "speakerName": "成宮すず",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-suzu.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/eventStoryVoice/sud_vo_adv_event_2304_01_05/sud_vo_adv_event_2304_01_05-suz007.wav",
      "text": "あ、えっと、その、怜……？",
