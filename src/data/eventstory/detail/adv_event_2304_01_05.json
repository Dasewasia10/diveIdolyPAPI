      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-saki.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/eventStoryVoice/sud_vo_adv_event_2304_01_05/sud_vo_adv_event_2304_01_05-ski002.wav",
      "text": "負けないからね、千紗",
      "startTime": 77,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "chs",
      "speakerName": "白石千紗",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-chisa.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/eventStoryVoice/sud_vo_adv_event_2304_01_05/sud_vo_adv_event_2304_01_05-chs001.wav",
      "text": "お姉ちゃん……私だって、負けないから！",
      "startTime": 78.872742947,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "szk",
