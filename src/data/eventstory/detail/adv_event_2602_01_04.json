        }
      ]
    },
    {
      "type": "dialogue",
      "speakerCode": "ngs",
      "speakerName": "伊吹渚",
      "speakerNameEn": "Nagisa Ibuki",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-nagisa.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/eventStoryVoice/sud_vo_adv_event_2602_01_04/sud_vo_adv_event_2602_01_04-ngs002.m4a",
      "text": "そ、想像以上だよ……\nこんなことまでやってくれるなんて……",
      "translations": {
        "en": "",
        "id": ""
      },
      "startTime": 261.0821145063,
      "endTime": 267.8887582784,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "ski",
