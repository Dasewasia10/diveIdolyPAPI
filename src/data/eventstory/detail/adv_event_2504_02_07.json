    {
      "type": "dialogue",
      "speakerCode": "hrk",
      "speakerName": "佐伯遙子",
      "speakerNameEn": "Haruko",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-haruko.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/eventStoryVoice/sud_vo_adv_event_2504_02_07/sud_vo_adv_event_2504_02_07-hrk006.m4a",
      "text": "あら……？　あれは、飛行機？　いたっ！　いたた！\nどうして私、攻撃されてるの！？",
      "translations": {
        "en": "Huh…? Is that an airplane? Ow! Ouch!\nWhy am I being attacked!?",
        "id": ""
      },
      "startTime": 58.1059809447,
      "endTime": 67.61804473420001,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "hrk",
      "speakerName": "佐伯遙子",
      "speakerNameEn": "Haruko",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-haruko.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/eventStoryVoice/sud_vo_adv_event_2504_02_07/sud_vo_adv_event_2504_02_07-hrk007.m4a",
      "text": "もしかして私、怪獣と間違われてる！？\n違うの、誤解なの！　攻撃しないで～！",
      "translations": {
        "en": "Don’t tell me they think I’m a monster!?\nThat’s not it—it’s a misunderstanding! Don’t attack me~!",
