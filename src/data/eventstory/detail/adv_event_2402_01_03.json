      "bgName": "dressingroom-00-noon",
      "startTime": 243.6922764778
    },
    {
      "type": "dialogue",
      "speakerCode": "ai",
      "speakerName": "小美山愛",
      "speakerNameEn": "Ai",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-ai.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/eventStoryVoice/sud_vo_adv_event_2402_01_03/sud_vo_adv_event_2402_01_03-ai008.m4a",
      "text": "すっごくいいですね！\n冬の北海道と言えば、ミクちゃんですし！",
      "translations": {
        "en": "That’s a great idea!\nSpeaking of winter in Hokkaido‚ it’s Miku-chan!",
        "id": ""
      },
      "startTime": 243.6922764778,
      "endTime": 249.24685697549998,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_dressingroom-00-noon.webp",
      "bgName": "dressingroom-00-noon",
      "startTime": 249.4535236994
    },
    {
      "type": "dialogue",
      "speakerCode": "aoi",
      "speakerName": "井川葵",
      "speakerNameEn": "Aoi",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-aoi.png",
