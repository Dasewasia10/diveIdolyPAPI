{
  "id": "adv_event_2504_02_06",
  "title": "邂逅！さくらとザグラ",
  "script": [
    {
      "type": "dialogue",
      "speakerCode": null,
      "speakerName": "",
      "speakerNameEn": "",
      "iconUrl": null,
      "voiceUrl": null,
      "text": "――時空の狭間が閉じるまであと10分",
      "translations": {
        "en": "—10 Minutes Until the Space-Time Rift Closes",
        "id": ""
      },
      "startTime": 0,
      "endTime": 1.8333334048,
      "sfxList": [
