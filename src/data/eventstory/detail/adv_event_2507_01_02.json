      "text": "何着てこうかな、でも可愛い服ろくに持って来てないし\nあ。franって確か、昔作った服持って来てたよね？",
      "translations": {
        "en": "何着てこうかな、でも可愛い服ろくに持って来てないし\nあ。franって確か、昔作った服持って来てたよね？",
        "id": ""
      },
      "startTime": 57.3734914147,
      "endTime": 68.0856685007,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_ameapart-00-night.webp",
      "bgName": "ameapart-00-night",
      "startTime": 68.3009064361
    },
    {
      "type": "dialogue",
      "speakerCode": "kor",
      "speakerName": "fran",
      "speakerNameEn": "fran",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-fran.png",
