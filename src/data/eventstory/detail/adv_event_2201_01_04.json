    },
    {
      "type": "dialogue",
      "speakerCode": "unknown",
      "speakerName": "さくらの父",
      "speakerNameEn": "Sakura’s",
      "iconUrl": null,
      "voiceUrl": null,
      "text": "いやぁ～、君達が噂の！",
      "translations": {
        "en": "Wow‚ we’ve heard all about you girls!",
        "id": ""
      },
      "startTime": 5.5291835467,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "skrdad",
      "speakerName": "さくらの父",
      "speakerNameEn": "Sakura’s",
      "iconUrl": null,
      "voiceUrl": "https://apiip.dasewasia.my.id/eventStoryVoice/sud_vo_adv_event_2201_01_04/sud_vo_adv_event_2201_01_04-skrdad001.m4a",
      "text": "いつもテレビで観てるよ！",
      "translations": {
        "en": "We often see you on TV!",
        "id": ""
      },
      "startTime": 8.7666666667,
      "sfxList": []
    },
    {
