      "text": "遠慮しないでくつろいでちょうだい",
      "translations": {
        "en": "Please‚ make yourselves at home.",
        "id": ""
      },
      "startTime": 17.1,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_kawasakiliving-00-noon.webp",
      "bgName": "bg1",
      "startTime": 19.6651020209
    },
    {
      "type": "dialogue",
      "speakerCode": "hrk",
      "speakerName": "佐伯遙子",
      "speakerNameEn": "Haruko",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-haruko.png",
      "voiceUrl": null,
      "text": "お邪魔します",
      "translations": {
        "en": "Thank you.",
        "id": ""
      },
      "startTime": 19.6651020209,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "hrk",
      "speakerName": "佐伯遙子",
      "speakerNameEn": "Haruko",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-haruko.png",
