      "bgName": "bg1",
      "startTime": 10.8780271053
    },
    {
      "type": "dialogue",
      "speakerCode": "skr",
      "speakerName": "川咲さくら",
      "speakerNameEn": "Sakura",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-sakura.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/eventStoryVoice/sud_vo_adv_event_2201_01_04/sud_vo_adv_event_2201_01_04-skr002.m4a",
      "text": "もう、お父さん、はしゃがないでよ",
      "translations": {
        "en": "Dad‚ don’t get carried away.",
        "id": ""
      },
      "startTime": 10.8780271053,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "unknown",
      "speakerName": "さくらの母",
      "speakerNameEn": "Sakura’s",
      "iconUrl": null,
      "voiceUrl": null,
      "text": "外は寒かったでしょう",
      "translations": {
        "en": "You must have been cold outside.",
        "id": ""
      },
      "startTime": 15.1362811406,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "skrmam",
      "speakerName": "さくらの母",
      "speakerNameEn": "Sakura’s",
