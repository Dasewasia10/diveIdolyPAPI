      "voiceUrl": null,
      "text": "ごめんね",
      "translations": {
        "en": "I’m sorry.",
        "id": ""
      },
      "startTime": 42.2954650323,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "skr",
