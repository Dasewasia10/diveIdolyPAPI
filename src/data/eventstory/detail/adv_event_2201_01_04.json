      "speakerNameEn": "Rei",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-rei.png",
      "voiceUrl": null,
      "text": "急に押しかけたのにこんなに歓迎されたら",
      "translations": {
        "en": "I’m feeling bad that they’re going to so much trouble to welcome us",
        "id": ""
      },
      "startTime": 35.1957367341,
      "sfxList": []
    },
