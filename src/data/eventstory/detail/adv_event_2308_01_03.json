    {
      "type": "dialogue",
      "speakerCode": "rui",
      "speakerName": "天動瑠依",
      "speakerNameEn": "Rui",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-rui.png",
      "voiceUrl": null,
      "text": "三人でBIG4を目指そうって約束したのに",
      "translations": {
        "en": "We promised to aim for the BIG4 together.",
        "id": ""
      },
      "startTime": 91.5479180811,
