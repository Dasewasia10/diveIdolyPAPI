    {
      "type": "dialogue",
      "speakerCode": "koh",
      "speakerName": "{user}",
      "speakerNameEn": "{user}",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-makino.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/eventStoryVoice/sud_vo_adv_event_2308_01_03/sud_vo_adv_event_2308_01_03-koh008.m4a",
      "text": "だから二人とも、思い詰めないでほしい",
      "translations": {
        "en": "So both of you‚ don't get too worried.",
