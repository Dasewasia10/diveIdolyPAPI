    },
    {
      "type": "dialogue",
      "speakerCode": "rui",
      "speakerName": "天動瑠依",
      "speakerNameEn": "Rui",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-rui.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/eventStoryVoice/sud_vo_adv_event_2501_01_02/sud_vo_adv_event_2501_01_02-rui002.m4a",
      "text": "みなさん、あけましておめでとうございます！\n私達……",
      "translations": {
        "en": "Everyone‚ Happy New Year!\nWe are…",
        "id": ""
      },
      "startTime": 4.0666666587,
      "endTime": 8.7668026527,
