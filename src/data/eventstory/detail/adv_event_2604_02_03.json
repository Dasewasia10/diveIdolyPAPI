      "speakerNameEn": "Rei Ichinose",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-rei.png",
      "voiceUrl": null,
      "text": "遅いわよ、二人とも。し、仕事が早く終わったから",
      "translations": {
        "en": "",
        "id": ""
      },
      "startTime": 154.2333464305,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "rei",
      "speakerName": "一ノ瀬怜",
      "speakerNameEn": "Rei Ichinose",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-rei.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/eventStoryVoice/sud_vo_adv_event_2604_02_03/sud_vo_adv_event_2604_02_02-rei004.m4a",
      "text": "付いていってあげる。それに……ブリと言えば私でしょ",
      "translations": {
        "en": "",
        "id": ""
      },
