          "src": "https://apiip.dasewasia.my.id/storyBgm/sud_se_adv_coast-01.m4a",
          "delay": 1420.000004799988
        }
      ]
    },
    {
      "type": "dialogue",
      "speakerCode": "chs",
      "speakerName": "白石千紗",
      "speakerNameEn": "Chisa Shiraishi",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-chisa.png",
      "voiceUrl": null,
      "text": "一応怜ちゃんとさくらちゃんの『まるでサカナスーツ』",
      "translations": {
        "en": "",
        "id": ""
      },
      "startTime": 144.3333464305,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "chs",
      "speakerName": "白石千紗",
      "speakerNameEn": "Chisa Shiraishi",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-chisa.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/eventStoryVoice/sud_vo_adv_event_2604_02_03/sud_vo_adv_event_2604_02_02-chs004.m4a",
      "text": "も用意して机の上に置いてきたけど……来ない、よね",
      "translations": {
        "en": "",
        "id": ""
      },
      "startTime": 147.9666712444,
      "sfxList": [
        {
          "src": "https://apiip.dasewasia.my.id/storyBgm/sud_se_adv_walk-coast-single-01.m4a",
          "delay": 6266.675186100002
        }
      ]
    },
    {
      "type": "dialogue",
