      "speakerNameEn": "{user}",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-makino.png",
      "voiceUrl": null,
      "text": "（凄い歓声だ……もう、スリクスは落ち目なんかじゃない）",
      "translations": {
        "en": "（What an amazing cheer… ⅢX isn't in decline anymore.）",
