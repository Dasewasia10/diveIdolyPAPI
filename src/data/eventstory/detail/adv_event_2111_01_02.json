      },
      "startTime": 17.5,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "rei",
      "speakerName": "一ノ瀬怜",
      "speakerNameEn": "Rei",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-rei.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/eventStoryVoice/sud_vo_adv_event_2111_01_02/sud_vo_adv_event_2111_01_02-rei002.m4a",
      "text": "昨日、私の親のこと、話したばかりでしょ",
