      },
      "startTime": 26.5666666667,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "mei",
      "speakerName": "早坂芽衣",
      "speakerNameEn": "Mei",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-mei.png",
      "voiceUrl": null,
      "text": "……でも、怜ちゃんだって",
      "translations": {
        "en": "But Rei-chan‚ you really want your father to",
