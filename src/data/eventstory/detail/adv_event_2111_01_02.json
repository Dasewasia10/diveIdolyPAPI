      "speakerCode": "mei",
      "speakerName": "早坂芽衣",
      "speakerNameEn": "Mei",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-mei.png",
      "voiceUrl": null,
      "text": "意地張ってる感じがするな～",
