      "text": "（あの仲が悪いスリクスが、抱き合って寝てるだと！？）",
      "startTime": 23.2,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "koh",
      "speakerName": "{user}",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-makino.png",
