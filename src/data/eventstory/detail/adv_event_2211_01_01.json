      "voiceUrl": "https://apiip.dasewasia.my.id/eventStoryVoice/sud_vo_adv_event_2211_01_01/sud_vo_adv_event_2211_01_01-kan001.wav",
      "text": "kana、ツアー真っ最中のアイドル様なんですけど？",
      "startTime": 40.7,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_onsenlobby-00-noon.webp",
      "bgName": "onsenlobby-00-noon"
    },
    {
      "type": "dialogue",
      "speakerCode": "kor",
      "speakerName": "fran",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-fran.png",
      "voiceUrl": null,
      "text": "あなたが「温泉入りたい、でないと殺す」とか",
      "startTime": 45.5333333333,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "kor",
      "speakerName": "fran",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-fran.png",
