      "voiceUrl": "https://apiip.dasewasia.my.id/eventStoryVoice/sud_vo_adv_event_2506_01_05/sud_vo_adv_event_2506_01_05-ai001.m4a",
      "text": "舞台袖で何してるんですか？　もうすぐ幕が開きますよ",
      "startTime": 4.0000001113,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_stagesleeves-00-noon.webp",
