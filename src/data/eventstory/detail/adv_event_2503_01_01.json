      "startTime": 162.3204762777,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "haruhi",
      "speakerName": "涼宮ハルヒ",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-haruhi.png",
      "voiceUrl": null,
      "text": "小動物担当の千紗ちゃん。そしてセットで優等生キャラ",
