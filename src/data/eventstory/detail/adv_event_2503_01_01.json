      "startTime": 153.1871429444,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "haruhi",
      "speakerName": "涼宮ハルヒ",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-haruhi.png",
