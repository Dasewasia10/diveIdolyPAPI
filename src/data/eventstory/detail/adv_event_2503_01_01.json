      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "haruhi",
      "speakerName": "涼宮ハルヒ",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-haruhi.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/eventStoryVoice/sud_vo_adv_event_2503_01_01/sud_vo_adv_event_2503_01_01-haruhi004.m4a",
