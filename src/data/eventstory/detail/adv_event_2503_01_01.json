      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "haruhi",
      "speakerName": "涼宮ハルヒ",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-haruhi.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/eventStoryVoice/sud_vo_adv_event_2503_01_01/sud_vo_adv_event_2503_01_01-haruhi003.m4a",
      "text": "第一号に聞いてみなさいよ。ね、みくるちゃん？",
      "startTime": 143.4538096111,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "mikuru",
      "speakerName": "朝比奈みくる",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-mikuru.png",
