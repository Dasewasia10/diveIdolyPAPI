      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "yu",
      "speakerName": "鈴村優",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-yu.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/eventStoryVoice/sud_vo_adv_event_2504_01_03/sud_vo_adv_event_2504_01_03-yu006.m4a",
      "text": "調子はどないですか？",
      "startTime": 98.2216346106,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "szk",
      "speakerName": "兵藤雫",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-shizuku.png",
      "voiceUrl": null,
      "text": "調子は、良くない……大声を出すのは苦手で……",
      "startTime": 100.1792329152,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "szk",
      "speakerName": "兵藤雫",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-shizuku.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/eventStoryVoice/sud_vo_adv_event_2504_01_03/sud_vo_adv_event_2504_01_03-szk004.m4a",
      "text": "セリフに感情を込めるのも、難しい……",
      "startTime": 105.1775626428,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "yu",
      "speakerName": "鈴村優",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-yu.png",
      "voiceUrl": null,
      "text": "セリフに気持ちを乗せるのって結構難しいんよね",
      "startTime": 108.6766895611,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "yu",
      "speakerName": "鈴村優",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-yu.png",
