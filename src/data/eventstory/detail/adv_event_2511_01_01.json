      "bgName": "tokyocafe-00-noon",
      "startTime": 24.4
    },
    {
      "type": "dialogue",
      "speakerCode": "kkr",
      "speakerName": "赤崎こころ",
      "speakerNameEn": "Kokoro Akazaki",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-kokoro.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/eventStoryVoice/sud_vo_adv_event_2511_01_01/sud_vo_adv_event_2511_01_01-kkr001.m4a",
      "text": "葵さんが遠慮しないのはいつものことじゃないですか\n今更それくらいでへこんだりしませんよ",
      "translations": {
        "en": "",
        "id": ""
      },
      "startTime": 24.4,
      "endTime": 31.0775510788,
      "sfxList": []
    },
    {
      "type": "background",
