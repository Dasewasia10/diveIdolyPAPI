      "bgName": "tokyocafe-00-noon",
      "startTime": 18.3666666667
    },
    {
      "type": "dialogue",
      "speakerCode": "ai",
      "speakerName": "小美山愛",
      "speakerNameEn": "Ai Komiyama",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-ai.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/eventStoryVoice/sud_vo_adv_event_2511_01_01/sud_vo_adv_event_2511_01_01-ai003.m4a",
      "text": "もちろんです！　もしダメ出しされたら\n次はもっといいものを考えてきます！",
      "translations": {
        "en": "",
        "id": ""
      },
      "startTime": 18.3666666667,
      "endTime": 24.192721049,
      "sfxList": []
    },
    {
