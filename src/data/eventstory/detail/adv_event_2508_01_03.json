      "text": "んじゃ、kanaとも話をしてきます\nあいつ、アパートにいるといいんですけどねー",
      "translations": {
        "en": "んじゃ、kanaとも話をしてきます\nあいつ、アパートにいるといいんですけどねー",
        "id": ""
      },
      "startTime": 0.8,
      "endTime": 7.308344459500001,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "kor",
      "speakerName": "fran",
      "speakerNameEn": "fran",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-fran.png",
