      "type": "dialogue",
      "speakerCode": "szk",
      "speakerName": "兵藤雫",
      "speakerNameEn": "Shizuku",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-shizuku.png",
      "voiceUrl": null,
      "text": "私も、頑張らないと",
      "translations": {
        "en": "I have to do my best too.",
        "id": ""
