      "speakerCode": "rui",
      "speakerName": "天動瑠依",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-rui.png",
      "voiceUrl": null,
      "text": "（兵藤雫……やっぱりこの子、凄く筋がいい）",
