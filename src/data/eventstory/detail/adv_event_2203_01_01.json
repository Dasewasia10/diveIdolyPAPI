      "startTime": 49.3333333333,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "ngs",
      "speakerName": "伊吹渚",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-nagisa.png",
