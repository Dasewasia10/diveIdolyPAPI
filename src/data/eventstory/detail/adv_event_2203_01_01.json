      "startTime": 58.7666666667,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "szk",
      "speakerName": "兵藤雫",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-shizuku.png",
