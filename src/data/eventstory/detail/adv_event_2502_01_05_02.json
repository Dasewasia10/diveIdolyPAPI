      "text": "私達もお客さんの声援から沢山の愛をもらいました",
      "startTime": 10.2666673336,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_dressingroom-00-noon.webp",
      "bgName": "dressingroom-00-noon"
    },
    {
      "type": "dialogue",
      "speakerCode": "szk",
      "speakerName": "兵藤雫",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-shizuku.png",
      "voiceUrl": null,
      "text": "ファンも、私達も、みんな幸せ……",
      "startTime": 15.4833436324,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "szk",
