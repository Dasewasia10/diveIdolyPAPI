      "voiceUrl": null,
      "text": "……しっかり俺も心の準備をして行くよ",
      "startTime": 105.2333322201,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "koh",
      "speakerName": "{user}",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-makino.png",
