      "text": "それじゃあぜひ、参加させてもらうね",
      "translations": {
        "en": "Then‚ I would love to participate.",
        "id": ""
      },
      "startTime": 44.1,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "smr",
