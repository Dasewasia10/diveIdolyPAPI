      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "mku",
      "speakerName": "初音ミク",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-mku.png",
      "voiceUrl": null,
      "text": "みんな……分かった、ありがとう",
      "startTime": 39.3666666667,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "mku",
      "speakerName": "初音ミク",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-mku.png",
