      "text": "それじゃあぜひ、参加させてもらうね",
      "startTime": 44.1,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "smr",
      "speakerName": "奥山すみれ",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-sumire.png",
      "voiceUrl": null,
      "text": "決まりだね！",
