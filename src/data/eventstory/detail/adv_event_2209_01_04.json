      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-sumire.png",
      "voiceUrl": null,
      "text": "決まりだね！",
      "translations": {
        "en": "It's decided!",
        "id": ""
      },
      "startTime": 47.5,
      "sfxList": []
    },
    {
