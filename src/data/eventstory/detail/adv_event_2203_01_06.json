      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-rui.png",
      "voiceUrl": null,
      "text": "そうね、私もトリエルとしてステージに上がるのと",
      "startTime": 26.7,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "rui",
