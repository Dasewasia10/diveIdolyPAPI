      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-rui.png",
      "voiceUrl": null,
      "text": "やるべきことは全てやったわ、私もあなたも",
      "startTime": 39.6,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "rui",
