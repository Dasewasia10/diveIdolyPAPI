      "speakerCode": "ktn",
      "speakerName": "長瀬琴乃",
      "speakerNameEn": "Kotono Nagase",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-kotono.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/eventStoryVoice/sud_vo_adv_event_2603_01_05_01/sud_vo_adv_event_2603_01_05-ktn018.m4a",
      "text": "星見プロのすず、さくら、遙子さん、莉央さんと一緒に\n特別な歌をみなさんに届けます",
      "translations": {
        "en": "",
        "id": ""
      },
      "startTime": 319.9191902234,
