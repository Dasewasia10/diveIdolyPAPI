      "type": "dialogue",
      "speakerCode": null,
      "speakerName": "",
      "speakerNameEn": "",
      "iconUrl": null,
      "voiceUrl": null,
      "text": "――長瀬琴乃ソロライブツアー千秋楽",
      "translations": {
        "en": "",
        "id": ""
      },
