      "speakerCode": "unknown",
      "speakerName": "一同",
      "speakerNameEn": "",
      "iconUrl": null,
      "voiceUrl": null,
      "text": "もちろん！",
      "translations": {
        "en": "",
        "id": ""
      },
      "startTime": 255.7859769419,
      "endTime": 257.3597638443,
      "sfxList": []
