      "speakerName": "長瀬琴乃",
      "speakerNameEn": "Kotono Nagase",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-kotono.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/eventStoryVoice/sud_vo_adv_event_2603_01_05_01/sud_vo_adv_event_2603_01_05-ktn017.m4a",
      "text": "今日は私のツアーに来てくれてありがとうございます！\n千秋楽、ということでサプライズを用意しました",
      "translations": {
        "en": "",
        "id": ""
      },
      "startTime": 310.6097344155,
      "endTime": 319.7358566993,
      "sfxList": []
    },
    {
      "type": "background",
