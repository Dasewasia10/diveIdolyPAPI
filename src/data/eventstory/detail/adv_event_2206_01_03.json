      "text": "二人が息抜きするって聞いてたから、私もって思って",
      "startTime": 9.8666666667,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_hillpark-00-noon.webp",
