    {
      "type": "dialogue",
      "speakerCode": "hrk",
      "speakerName": "佐伯遙子",
      "speakerNameEn": "Haruko",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-haruko.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/eventStoryVoice/sud_vo_adv_event_2206_01_03/sud_vo_adv_event_2206_01_03-hrk006.m4a",
      "text": "なんだか哲学的でステキよね",
      "translations": {
        "en": "It sounds philosophical and wonderful‚ doesn't it?",
        "id": ""
      },
      "startTime": 80.8666666667,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "skr",
      "speakerName": "川咲さくら",
      "speakerNameEn": "Sakura",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-sakura.png",
      "voiceUrl": null,
      "text": "確かに！　さっきもいい感じのフレーズ、出てたよね",
      "translations": {
        "en": "Definitely! There was a nice phrase earlier too.",
        "id": ""
