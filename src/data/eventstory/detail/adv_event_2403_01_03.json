      "text": "ふぇっ！？　えええっ！？",
      "translations": {
        "en": "Fueh!? Eeehh!?",
        "id": ""
      },
      "startTime": 47.4556703964,
      "endTime": 50.1120196262,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_mall-00-noon.webp",
      "bgName": "mall-00-noon",
      "startTime": 50.3087998627
    },
    {
      "type": "dialogue",
      "speakerCode": "rei",
