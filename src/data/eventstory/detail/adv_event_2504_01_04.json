          "delay": 9966.6666667
        }
      ]
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_livehousemiddle-00-noon.webp",
      "bgName": "livehousemiddle-00-noon",
      "startTime": 0
    },
    {
      "type": "dialogue",
      "speakerCode": "skr",
      "speakerName": "川咲さくら",
      "speakerNameEn": "Sakura",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-sakura.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/eventStoryVoice/sud_vo_adv_event_2504_01_04/sud_vo_adv_event_2504_01_04-skr001.m4a",
      "text": "みんな～、盛り上がってる～？\nライブの途中だけど、ここからは緊急特別企画だよ！",
      "translations": {
        "en": "Everyone~ are you having fun!?\nWe’re in the middle of the live‚ but from here on‚ it’s a special emergency feature!",
        "id": ""
      },
      "startTime": 2.2333332459,
      "endTime": 11.2595915237,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_livehousemiddle-00-noon.webp",
      "bgName": "livehousemiddle-00-noon",
      "startTime": 5.8666666667
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_livehousemiddle-00-noon.webp",
      "bgName": "livehousemiddle-00-noon",
      "startTime": 11.4729246854
    },
    {
      "type": "dialogue",
      "speakerCode": "szk",
      "speakerName": "兵藤雫",
      "speakerNameEn": "Shizuku",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-shizuku.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/eventStoryVoice/sud_vo_adv_event_2504_01_04/sud_vo_adv_event_2504_01_04-szk001.m4a",
      "text": "星見プロ所属の四人のアイドルと一緒に座長の私が\n立ち上げた『劇団★見』の初公演を上演する……！",
      "translations": {
        "en": "Together with four idols from Hoshimi Pro‚\nwe’ll perform the first show of Troupe★Hoshimi‚ the troupe I founded as leader…!",
        "id": ""
      },
      "startTime": 11.4729246854,
      "endTime": 20.6796362638,
      "sfxList": []
    },
    {
      "type": "sfx",
      "src": "https://apiip.dasewasia.my.id/storyBgm/sud_se_adv_cheers-in-01.m4a",
      "startTime": 17.7333333333
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_livehousemiddle-00-noon.webp",
      "bgName": "livehousemiddle-00-noon",
      "startTime": 20.8729695399
    },
    {
      "type": "dialogue",
      "speakerCode": "skr",
      "speakerName": "川咲さくら",
      "speakerNameEn": "Sakura",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-sakura.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/eventStoryVoice/sud_vo_adv_event_2504_01_04/sud_vo_adv_event_2504_01_04-skr002.m4a",
      "text": "劇団★見の初舞台を最後まで楽しんでね！\nそれじゃあ、上演開始だよ！",
      "translations": {
        "en": "Please enjoy Troupe★Hoshimi’s first stage all the way to the end!\nNow then‚ let the performance begin!",
        "id": ""
      },
      "startTime": 20.8729695399,
      "endTime": 28.1164843637,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_livehousemiddle-00-noon.webp",
      "bgName": "livehousemiddle-00-noon",
      "startTime": 25.3940130234
    },
    {
      "type": "dialogue",
      "speakerCode": "ktn",
      "speakerName": "長瀬琴乃",
      "speakerNameEn": "Kotono",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-kotono.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/eventStoryVoice/sud_vo_adv_event_2504_01_04/sud_vo_adv_event_2504_01_04-ktn001.m4a",
      "text": "――星見プロ特別公演『不思議の国のアリス』",
      "translations": {
        "en": "—Hoshimi Pro Special Performance Alice in Wonderland",
        "id": ""
      },
      "startTime": 29.0031510114,
      "endTime": 33.9158495664,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "ktn",
      "speakerName": "長瀬琴乃",
      "speakerNameEn": "Kotono",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-kotono.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/eventStoryVoice/sud_vo_adv_event_2504_01_04/sud_vo_adv_event_2504_01_04-ktn002.m4a",
      "text": "昔々あるところに、雫アリスとすずアリスという\n二人の可愛い女の子がいました",
      "translations": {
        "en": "Long‚ long ago‚ there lived two lovely girls\nnamed Shizuku Alice and Suzu Alice.",
        "id": ""
      },
      "startTime": 34.8425152857,
      "endTime": 42.016120537,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "szk",
      "speakerName": "兵藤雫",
      "speakerNameEn": "Shizuku",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-shizuku.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/eventStoryVoice/sud_vo_adv_event_2504_01_04/sud_vo_adv_event_2504_01_04-szk002.m4a",
      "text": "私は雫アリス……\n今日は天気がいいので、庭を散歩する……",
      "translations": {
        "en": "I am Shizuku Alice…\nThe weather is nice today‚ so I’ll take a walk in the garden…",
        "id": ""
      },
      "startTime": 42.2094539085,
      "endTime": 47.997798577800005,
      "sfxList": [
        {
          "src": "https://apiip.dasewasia.my.id/storyBgm/sud_se_adv_run-out-single-01.m4a",
          "delay": 12210.846850899998
        },
        {
          "src": "https://apiip.dasewasia.my.id/storyBgm/sud_se_adv_run-out-single-01.m4a",
          "delay": 14790.546091499999
        }
      ]
    },
    {
      "type": "dialogue",
      "speakerCode": "suz",
      "speakerName": "成宮すず",
      "speakerNameEn": "Suzu",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-suzu.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/eventStoryVoice/sud_vo_adv_event_2504_01_04/sud_vo_adv_event_2504_01_04-suz001.m4a",
      "text": "私はすずアリスですわ！　さあ、外で遊びますわよ！\n……あら？　あれは何かしら？",
      "translations": {
        "en": "I am Suzu Alice! Come now‚ let’s play outside!\n…Oh? What might that be?",
        "id": ""
      },
      "startTime": 48.184465273,
      "endTime": 58.445622118,
      "sfxList": [
        {
          "src": "https://apiip.dasewasia.my.id/storyBgm/sud_se_adv_run-out-single-01.m4a",
          "delay": 10474.490006799997
        }
      ]
    },
    {
      "type": "dialogue",
      "speakerCode": "skr",
      "speakerName": "川咲さくら",
      "speakerNameEn": "Sakura",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-sakura.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/eventStoryVoice/sud_vo_adv_event_2504_01_04/sud_vo_adv_event_2504_01_04-skr003.m4a",
      "text": "大変大変！　もうこんな時間！\n急がないと遅刻しちゃうよー！",
      "translations": {
        "en": "Oh no‚ oh no! It’s already this late!\nIf I don’t hurry‚ I’ll be late~!",
        "id": ""
      },
      "startTime": 58.6589552798,
      "endTime": 64.4456269183,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "szk",
      "speakerName": "兵藤雫",
      "speakerNameEn": "Shizuku",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-shizuku.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/eventStoryVoice/sud_vo_adv_event_2504_01_04/sud_vo_adv_event_2504_01_04-szk003.m4a",
      "text": "あれは、うさぎ……？\nうさぎが喋りながら走ってる……これは、夢……？",
      "translations": {
        "en": "That’s a rabbit…?\nA rabbit running while talking… is this a dream…?",
        "id": ""
      },
      "startTime": 64.6256281135,
      "endTime": 73.6531109091,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "suz",
      "speakerName": "成宮すず",
      "speakerNameEn": "Suzu",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-suzu.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/eventStoryVoice/sud_vo_adv_event_2504_01_04/sud_vo_adv_event_2504_01_04-suz002.m4a",
      "text": "いたたた！　どうして私のほっぺをつねるんですの！？\nつねるなら自分のほっぺをつねりなさい！",
      "translations": {
        "en": "Ouch! Why are you pinching my cheek!?\nIf you’re going to pinch someone‚ pinch your own cheek!",
        "id": ""
      },
      "startTime": 73.8664443569,
      "endTime": 82.07270294,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "szk",
      "speakerName": "兵藤雫",
      "speakerNameEn": "Shizuku",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-shizuku.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/eventStoryVoice/sud_vo_adv_event_2504_01_04/sud_vo_adv_event_2504_01_04-szk004.m4a",
      "text": "夢じゃない……！！",
      "translations": {
        "en": "This isn’t a dream…!!",
        "id": ""
      },
      "startTime": 82.2793697593,
      "endTime": 83.90517470809999,
      "sfxList": [
        {
          "src": "https://apiip.dasewasia.my.id/storyBgm/sud_se_adv_poi-01.m4a",
          "delay": 8487.296907400008
        },
        {
          "src": "https://apiip.dasewasia.my.id/storyBgm/sud_se_adv_poi-01.m4a",
          "delay": 8487.296907400008
        },
        {
          "src": "https://apiip.dasewasia.my.id/storyBgm/sud_se_adv_poi-01.m4a",
          "delay": 8487.296907400008
        },
        {
          "src": "https://apiip.dasewasia.my.id/storyBgm/sud_se_adv_poi-01.m4a",
          "delay": 8487.296907400008
        }
      ]
    },
    {
      "type": "dialogue",
      "speakerCode": "skr",
      "speakerName": "川咲さくら",
      "speakerNameEn": "Sakura",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-sakura.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/eventStoryVoice/sud_vo_adv_event_2504_01_04/sud_vo_adv_event_2504_01_04-skr004.m4a",
      "text": "大変大変！　早くこの穴を通って\n不思議の国に行かないと！　せーの、それっ！",
      "translations": {
        "en": "Oh no‚ oh no! Hurry and go through this hole\nto Wonderland! Ready‚ set—go!",
        "id": ""
      },
      "startTime": 84.1118413843,
      "endTime": 91.40247649320001,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "suz",
      "speakerName": "成宮すず",
      "speakerNameEn": "Suzu",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-suzu.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/eventStoryVoice/sud_vo_adv_event_2504_01_04/sud_vo_adv_event_2504_01_04-suz003.m4a",
      "text": "うさぎが穴に飛び込みましたわ！　これは大冒険の\n予感がしますわね。私達も追いかけますわよ！",
      "translations": {
        "en": "The rabbit jumped into the hole! This feels like the start\nof a grand adventure. Let’s chase after it too!",
        "id": ""
      },
      "startTime": 91.7291381116,
      "endTime": 101.2352109189,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "szk",
      "speakerName": "兵藤雫",
      "speakerNameEn": "Shizuku",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-shizuku.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/eventStoryVoice/sud_vo_adv_event_2504_01_04/sud_vo_adv_event_2504_01_04-szk005.m4a",
      "text": "分かった……二人で一緒に、穴に飛び込む……\nせーの！",
      "translations": {
        "en": "Alright… the two of us will jump into the hole together…\nReady‚ set!",
        "id": ""
      },
      "startTime": 101.4418777382,
      "endTime": 106.84963692790001,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": null,
      "speakerName": "",
      "speakerNameEn": "",
      "iconUrl": null,
      "voiceUrl": null,
      "text": "――同時刻、舞台裏",
      "translations": {
        "en": "—At the Same Time‚ Backstage",
        "id": ""
      },
      "startTime": 107.6496369279,
      "endTime": 108.7829703487,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_stagesleeves-00-noon.webp",
      "bgName": "stagesleeves-00-noon",
      "startTime": 108.7829703487
    },
    {
      "type": "dialogue",
      "speakerCode": "koh",
      "speakerName": "{user}",
      "speakerNameEn": "{user}",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-makino.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/eventStoryVoice/sud_vo_adv_event_2504_01_04/sud_vo_adv_event_2504_01_04-koh001.m4a",
      "text": "ついに舞台が始まったな。最初に雫から演劇を\nやりたいと言われた時は、どうなるかと思ったが……",
      "translations": {
        "en": "The stage has finally begun. When Shizuku first told me\nshe wanted to do theater‚ I wondered how it would turn out…",
        "id": ""
      },
      "startTime": 109.6496379451,
      "endTime": 117.16233497420001,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_stagesleeves-00-noon.webp",
      "bgName": "stagesleeves-00-noon",
      "startTime": 117.3623347835
    },
    {
      "type": "dialogue",
      "speakerCode": "yu",
      "speakerName": "鈴村優",
      "speakerNameEn": "Yu",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-yu.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/eventStoryVoice/sud_vo_adv_event_2504_01_04/sud_vo_adv_event_2504_01_04-yu001.m4a",
      "text": "結構本格的やろ？\nみんな、毎日夜遅くまで稽古頑張ったんやで",
      "translations": {
        "en": "It’s pretty serious‚ right?\nEveryone worked hard‚ rehearsing late every night.",
        "id": ""
      },
      "startTime": 117.3623347835,
      "endTime": 123.6777313785,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_stagesleeves-00-noon.webp",
      "bgName": "stagesleeves-00-noon",
      "startTime": 123.8910646356
    },
    {
      "type": "dialogue",
      "speakerCode": "koh",
      "speakerName": "{user}",
      "speakerNameEn": "{user}",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-makino.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/eventStoryVoice/sud_vo_adv_event_2504_01_04/sud_vo_adv_event_2504_01_04-koh002.m4a",
      "text": "脚本は優が書いたんだよな？\nアリスが二人とは、大胆なアレンジをしたじゃないか",
      "translations": {
        "en": "You wrote the script‚ didn’t you‚ Yu?\nHaving two Alices was a bold adaptation.",
        "id": ""
      },
      "startTime": 123.8910646356,
      "endTime": 130.037100593,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "yu",
      "speakerName": "鈴村優",
      "speakerNameEn": "Yu",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-yu.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/eventStoryVoice/sud_vo_adv_event_2504_01_04/sud_vo_adv_event_2504_01_04-yu002.m4a",
      "text": "オーディションで二人のお芝居を見て\nどっちのアリスも魅力的で甲乙付けがたかったんよ",
      "translations": {
        "en": "After seeing both of their performances at the audition‚\nboth Alices were so charming we couldn’t choose between them.",
        "id": ""
      },
      "startTime": 130.2237674312,
      "endTime": 137.19966312219998,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_stagesleeves-00-noon.webp",
      "bgName": "stagesleeves-00-noon",
      "startTime": 137.3996632175
    },
    {
      "type": "dialogue",
      "speakerCode": "yu",
      "speakerName": "鈴村優",
      "speakerNameEn": "Yu",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-yu.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/eventStoryVoice/sud_vo_adv_event_2504_01_04/sud_vo_adv_event_2504_01_04-yu003.m4a",
      "text": "それでみんなで相談して「主役を二人にしてまえ」\nってことになってなぁ",
      "translations": {
        "en": "So we talked it over and decided‚ “Let’s make them both leads.”\nThat’s how it ended up.",
        "id": ""
      },
      "startTime": 137.3996632175,
      "endTime": 143.2042666033,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "koh",
      "speakerName": "{user}",
      "speakerNameEn": "{user}",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-makino.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/eventStoryVoice/sud_vo_adv_event_2504_01_04/sud_vo_adv_event_2504_01_04-koh003.m4a",
      "text": "なるほど、これはこれで面白そうだな\n星見プロらしい楽しい舞台になりそうだ",
      "translations": {
        "en": "I see‚ that makes this interesting in its own way.\nIt feels like it’ll be a fun‚ very Hoshimi Pro–style stage.",
        "id": ""
      },
      "startTime": 143.4176000512,
      "endTime": 150.0302955543,
      "sfxList": []
    },
