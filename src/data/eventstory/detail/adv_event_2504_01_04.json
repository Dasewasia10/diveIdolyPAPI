{
  "id": "adv_event_2504_01_04",
  "title": "始まった\n初公演",
  "script": [
    {
      "type": "dialogue",
      "speakerCode": null,
      "speakerName": "",
      "speakerNameEn": "",
      "iconUrl": null,
      "voiceUrl": null,
      "text": "――サニーピースのライブ当日",
      "translations": {
        "en": "—Sunny Peace Live Day",
        "id": ""
      },
      "startTime": 0,
      "endTime": 1.3666666667,
      "sfxList": [
        {
          "src": "https://apiip.dasewasia.my.id/storyBgm/sud_se_adv_cheers-in-01.m4a",
