      "type": "dialogue",
      "speakerCode": null,
      "speakerName": "",
      "speakerNameEn": "",
      "iconUrl": null,
      "voiceUrl": null,
      "text": "――同時刻、舞台上",
      "translations": {
        "en": "—At the Same Time‚ On Stage",
        "id": ""
