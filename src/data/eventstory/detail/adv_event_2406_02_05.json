      "startTime": 54.923220857
    },
    {
      "type": "dialogue",
      "speakerCode": "kor",
      "speakerName": "fran",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-fran.png",
      "voiceUrl": null,
      "text": "ケータリングに関しても前々から思ってるとこがあって",
      "startTime": 54.923220857,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "kor",
      "speakerName": "fran",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-fran.png",
