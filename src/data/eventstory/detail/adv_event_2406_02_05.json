      "startTime": 116.2662359556,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "mhk",
      "speakerName": "miho",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-miho.png",
