      "text": "一筋縄ではいかないことも多かったですが……",
      "startTime": 89.1995692889,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_ryokan-00-noon.webp",
