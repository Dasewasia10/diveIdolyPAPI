      "text": "貴方が見てくれていたおかげで、多少は楽が出来ました",
      "startTime": 97.4995692889,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "mhk",
      "speakerName": "miho",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-miho.png",
