      "text": "クリスマスパーティーが出来ないのは残念だけど\nかわりにお客さんにいっぱい楽しんでもらうよ！",
      "translations": {
        "en": "It’s a shame we can’t have a Christmas party‚\nbut a bunch of fans will have lots of fun.",
        "id": ""
      },
      "startTime": 221.1333333333,
      "endTime": 227.7770749505,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_tokyodormcorridor-00-noon.webp",
      "bgName": "stage02",
      "startTime": 228
    },
    {
      "type": "dialogue",
      "speakerCode": "suz",
      "speakerName": "成宮すず",
