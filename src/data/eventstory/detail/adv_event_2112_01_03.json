      "speakerCode": "suz",
      "speakerName": "成宮すず",
      "speakerNameEn": "Suzu",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-suzu.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/eventStoryVoice/sud_vo_adv_event_2112_01_03/sud_vo_adv_event_2112_01_03-suz009.m4a",
      "text": "べ、別に心配していた訳ではありませんわ！",
      "translations": {
        "en": "N-no‚ I’m not particularly worried about you!",
        "id": ""
      },
      "startTime": 240.2333333333,
      "endTime": 243.85809520080002,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_tokyodormcorridor-00-noon.webp",
      "bgName": "stage02",
      "startTime": 244.0666666667
    },
    {
      "type": "dialogue",
      "speakerCode": "suz",
      "speakerName": "成宮すず",
      "speakerNameEn": "Suzu",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-suzu.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/eventStoryVoice/sud_vo_adv_event_2112_01_03/sud_vo_adv_event_2112_01_03-suz010.m4a",
      "text": "それでは私はもう寝ますわね\n明日のイベント頑張って下さいまし",
      "translations": {
        "en": "Well‚ time I went to bed too.\nGive it all you’ve got at the event tomorrow.",
        "id": ""
      },
      "startTime": 244.0666666667,
      "endTime": 250.1694394659,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "smr",
      "speakerName": "奥山すみれ",
      "speakerNameEn": "Sumire",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-sumire.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/eventStoryVoice/sud_vo_adv_event_2112_01_03/sud_vo_adv_event_2112_01_03-smr023.m4a",
      "text": "うん、おやすみ～",
      "translations": {
        "en": "Yup. Goodnight.",
        "id": ""
      },
      "startTime": 250.3666666667,
      "endTime": 252.27628115820002,
      "sfxList": [
        {
          "src": "https://apiip.dasewasia.my.id/storyBgm/sud_se_adv_walk-living-single-01.m4a",
          "delay": 333.3333332999757
        }
      ]
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_tokyodormcorridor-00-noon.webp",
      "bgName": "stage02",
