      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-fran.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/eventStoryVoice/sud_vo_adv_event_2211_01_03/sud_vo_adv_event_2211_01_03-kor003.m4a",
      "text": "……うっ",
      "translations": {
        "en": "…Uh",
        "id": ""
      },
