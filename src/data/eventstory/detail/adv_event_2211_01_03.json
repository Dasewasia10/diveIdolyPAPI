      "endTime": 110.6330839276,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "kan",
      "speakerName": "kana",
      "speakerNameEn": "kana",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-kana.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/eventStoryVoice/sud_vo_adv_event_2211_01_03/sud_vo_adv_event_2211_01_03-kan004.m4a",
      "text": "前から思ってたんだけど\nfranって、いつも可愛い下着つけてるよね～",
      "translations": {
        "en": "I've been thinking for a while‚\nFran always wears cute underwear‚ right?",
        "id": ""
      },
      "startTime": 110.9666666667,
