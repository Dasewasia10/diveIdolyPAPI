      "speakerCode": "mei",
      "speakerName": "早坂芽衣",
      "speakerNameEn": "Mei",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-mei.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/eventStoryVoice/sud_vo_adv_event_2211_01_03/sud_vo_adv_event_2211_01_03-mei003.m4a",
      "text": "ほら、遙子ちゃんも早く！",
      "translations": {
        "en": "See‚ Haruko-chan‚ come on!",
        "id": ""
      },
      "startTime": 42.4,
      "endTime": 45.0021769524,
      "sfxList": [
        {
          "src": "https://apiip.dasewasia.my.id/storyBgm/sud_se_adv_walk-in-single-02.m4a",
          "delay": 6860.180885799999
        }
      ]
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_onsenlobby-00-noon.webp",
      "bgName": "onsenlobby-00-noon",
      "startTime": 45.2
    },
    {
      "type": "dialogue",
      "speakerCode": "hrk",
      "speakerName": "佐伯遙子",
      "speakerNameEn": "Haruko",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-haruko.png",
