          "delay": 1833.3333333000041
        }
      ]
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_cemetery-00-noon.webp",
      "bgName": "cemetery-00-noon",
      "startTime": 80
    },
    {
      "type": "dialogue",
      "speakerCode": "aoi",
      "speakerName": "井川葵",
      "speakerNameEn": "Aoi",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-aoi.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/eventStoryVoice/sud_vo_adv_event_2210_01_05_02/sud_vo_adv_event_2210_01_05-aoi003.m4a",
      "text": "あっ、あそこだ\n琴乃、来たよ",
      "translations": {
        "en": "Ah‚ there it is\nKotono‚ you are here.",
        "id": ""
      },
      "startTime": 81.8666666667,
      "endTime": 85.1260177881,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_cemetery-00-noon.webp",
      "bgName": "cemetery-00-noon",
      "startTime": 85.3333333333
    },
    {
      "type": "dialogue",
      "speakerCode": "rio",
      "speakerName": "神崎莉央",
      "speakerNameEn": "Rio",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-rio.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/eventStoryVoice/sud_vo_adv_event_2210_01_05_02/sud_vo_adv_event_2210_01_05-rio016.m4a",
      "text": "おはよう\nいい天気で良かったわ",
      "translations": {
        "en": "Good morning\nI'm glad the weather is nice",
        "id": ""
      },
      "startTime": 85.3333333333,
      "endTime": 88.22013501350001,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_cemetery-00-noon.webp",
      "bgName": "cemetery-00-noon",
      "startTime": 88.4666666667
    },
    {
      "type": "dialogue",
      "speakerCode": "ktn",
      "speakerName": "長瀬琴乃",
      "speakerNameEn": "Kotono",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-kotono.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/eventStoryVoice/sud_vo_adv_event_2210_01_05_02/sud_vo_adv_event_2210_01_05-ktn019.m4a",
      "text": "はい。お二人とも貴重なお休みなのに\nすみません",
      "translations": {
        "en": "Yes. I'm sorry\nit's a precious holiday for you both.",
        "id": ""
      },
      "startTime": 88.4666666667,
      "endTime": 94.3333333333,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_cemetery-00-noon.webp",
      "bgName": "cemetery-00-noon",
      "startTime": 94.8333333333
    },
    {
      "type": "dialogue",
      "speakerCode": "rio",
      "speakerName": "神崎莉央",
      "speakerNameEn": "Rio",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-rio.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/eventStoryVoice/sud_vo_adv_event_2210_01_05_02/sud_vo_adv_event_2210_01_05-rio017.m4a",
      "text": "馬鹿ね、私達からお願いしたのよ\n貴方のお姉さんに、お線香あげたいって",
      "translations": {
        "en": "Fool‚ we asked you\nto go to your sister's rest",
        "id": ""
      },
      "startTime": 94.8333333333,
      "endTime": 101.6600629129,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "aoi",
      "speakerName": "井川葵",
      "speakerNameEn": "Aoi",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-aoi.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/eventStoryVoice/sud_vo_adv_event_2210_01_05_02/sud_vo_adv_event_2210_01_05-aoi004.m4a",
      "text": "いいかな？",
      "translations": {
        "en": "Are you okay?",
        "id": ""
      },
      "startTime": 102.0333333333,
      "endTime": 103.10000000000001,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_cemetery-00-noon.webp",
      "bgName": "cemetery-00-noon",
      "startTime": 103.5333333333
    },
    {
      "type": "dialogue",
      "speakerCode": "ktn",
      "speakerName": "長瀬琴乃",
      "speakerNameEn": "Kotono",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-kotono.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/eventStoryVoice/sud_vo_adv_event_2210_01_05_02/sud_vo_adv_event_2210_01_05-ktn020.m4a",
      "text": "もちろんです\nどうぞ",
      "translations": {
        "en": "Of course\nCome.",
        "id": ""
      },
      "startTime": 103.5333333333,
      "endTime": 106.36666666660001,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_cemetery-00-noon.webp",
      "bgName": "cemetery-00-noon",
      "startTime": 107.9666666667
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_cemetery-00-noon.webp",
      "bgName": "cemetery-00-noon",
      "startTime": 111.2333333333
    },
    {
      "type": "dialogue",
      "speakerCode": "rio",
      "speakerName": "神崎莉央",
      "speakerNameEn": "Rio",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-rio.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/eventStoryVoice/sud_vo_adv_event_2210_01_05_02/sud_vo_adv_event_2210_01_05-rio018.m4a",
      "text": "（麻奈……確かに昨日、私の隣に貴方いたわよね？）\n（感じたわよ）",
      "translations": {
        "en": "（Mana… you were next to me yesterday‚ right?）\n（I felt it）",
        "id": ""
