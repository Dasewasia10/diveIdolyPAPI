      "startTime": 94.1000104268,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "stm",
      "speakerName": "橋本さとみ",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-satomi.png",
