      "text": "新しいユニットのメンバーは、この五人です！",
      "startTime": 30.6343784133,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "kkr",
      "speakerName": "赤崎こころ",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-kokoro.png",
      "voiceUrl": null,
      "text": "そこですよ～。合宿に参加したメンバー五人で",
