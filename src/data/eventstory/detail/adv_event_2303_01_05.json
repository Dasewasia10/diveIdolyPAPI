      "text": "驚きました。みんなそのままでも凄く可愛いんですから",
      "startTime": 62.5000012715,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "suz",
      "speakerName": "成宮すず",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-suzu.png",
      "voiceUrl": null,
      "text": "ふ、ふ～ん？　私達がいついかなる時でも可愛いのは",
