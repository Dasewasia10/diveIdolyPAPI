    },
    {
      "type": "dialogue",
      "speakerCode": "chs",
      "speakerName": "白石千紗",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-chisa.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/eventStoryVoice/sud_vo_adv_event_2303_01_05/sud_vo_adv_event_2303_01_05-chs003.wav",
      "text": "でもうまくいかなくて落ち込んだり……",
      "startTime": 177.8939194993,
      "sfxList": []
    },
    {
