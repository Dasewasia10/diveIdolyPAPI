    },
    {
      "type": "dialogue",
      "speakerCode": "stm",
      "speakerName": "橋本さとみ",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-satomi.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/eventStoryVoice/sud_vo_adv_event_2303_01_05/sud_vo_adv_event_2303_01_05-stm012.wav",
