    },
    {
      "type": "dialogue",
      "speakerCode": "szk",
      "speakerName": "兵藤雫",
      "speakerNameEn": "Shizuku",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-shizuku.png",
      "voiceUrl": null,
      "text": "これだけじゃない……",
      "translations": {
        "en": "This isn't all…",
        "id": ""
      },
      "startTime": 23.4646418814,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "szk",
      "speakerName": "兵藤雫",
      "speakerNameEn": "Shizuku",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-shizuku.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/eventStoryVoice/sud_vo_adv_event_2403_01_05_02/sud_vo_adv_event_2403_01_05-szk005.m4a",
      "text": "メールやSNSからも、ファンの声が沢山届いてる……",
      "translations": {
        "en": "We've received so many messages from fans through email and social media…",
        "id": ""
      },
      "startTime": 25.1202370337,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "chs",
      "speakerName": "白石千紗",
      "speakerNameEn": "Chisa",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-chisa.png",
      "voiceUrl": null,
      "text": "この一つ一つが",
      "translations": {
        "en": "Each and every one of these",
        "id": ""
      },
      "startTime": 30.0608776335,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "chs",
      "speakerName": "白石千紗",
      "speakerNameEn": "Chisa",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-chisa.png",
