      "speakerNameEn": "Rei",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-rei.png",
      "voiceUrl": null,
      "text": "あれからタイムセールにブリを売るのが恒例になって",
      "translations": {
