      "startTime": 56.8508814684,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "szk",
      "speakerName": "兵藤雫",
      "speakerNameEn": "Shizuku",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-shizuku.png",
      "voiceUrl": null,
      "text": "場所の問い合わせが、ひっきりなしにあるから……",
      "translations": {
        "en": "Since inquiries about the location are constantly coming in…",
        "id": ""
      },
      "startTime": 61.5999000791,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "szk",
