      "speakerName": "佐伯遙子",
      "speakerNameEn": "Haruko",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-haruko.png",
      "voiceUrl": null,
      "text": "ひょっとして、この手紙の山、全部ファンレターなの？",
      "translations": {
        "en": "Wait‚ are all these mountains fan letters?",
        "id": ""
      },
      "startTime": 13.8780391936,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "hrk",
