    },
    {
      "type": "dialogue",
      "speakerCode": "koh",
      "speakerName": "{user}",
      "speakerNameEn": "{user}",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-makino.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/eventStoryVoice/sud_vo_adv_event_2307_01_05_02/sud_vo_adv_event_2307_01_05-koh008.m4a",
      "text": "（三人とも凄くはしゃいでるな。営業用でも）\n（あそこまで満面の笑顔ってのはめずらしい）",
      "translations": {
        "en": "（The three of them are really excited. Even for promotional photos‚）\n（it's rare to see such big smiles.）",
        "id": ""
      },
      "startTime": 55.76939497,
      "endTime": 62.6944064141,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_summerfes-00-noon.webp",
