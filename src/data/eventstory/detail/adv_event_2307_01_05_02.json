      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-miho.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/eventStoryVoice/sud_vo_adv_event_2307_01_05_02/sud_vo_adv_event_2307_01_05-mhk005.m4a",
      "text": "分かってるわよ",
      "translations": {
