      "speakerName": "kana",
      "speakerNameEn": "kana",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-kana.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/eventStoryVoice/sud_vo_adv_event_2307_01_05_02/sud_vo_adv_event_2307_01_05-kan005.m4a",
      "text": "kanaちゃん大勝利～～！！\nいや～もう、生放送最高、海ってば最高！！",
      "translations": {
        "en": "kana-chan's great victory~~!!\nWow‚ live broadcasts are the best‚ and the beach is awesome!!",
        "id": ""
      },
      "startTime": 13.7221260071,
      "endTime": 20.7965705871,
      "sfxList": []
    },
    {
