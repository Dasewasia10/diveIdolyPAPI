      "speakerNameEn": "A",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-wmob4.png",
      "voiceUrl": null,
      "text": "私、小さい頃からずっと病気で入院してて……",
      "translations": {
