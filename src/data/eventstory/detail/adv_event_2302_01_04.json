      "speakerCode": "yu",
      "speakerName": "鈴村優",
      "speakerNameEn": "Yu",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-yu.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/eventStoryVoice/sud_vo_adv_event_2302_01_04/sud_vo_adv_event_2302_01_04-yu028.m4a",
      "text": "すみれちゃん……なんて心強い……！\nよーし、メンバーは揃った！",
      "translations": {
        "en": "Sumire-chan… You're so reliable…!\nAlright‚ the team is complete!",
        "id": ""
      },
      "startTime": 361.166675059,
      "endTime": 368.5855972767,
