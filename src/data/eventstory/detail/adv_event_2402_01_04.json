      "speakerNameEn": "Everyone",
      "iconUrl": null,
      "voiceUrl": null,
      "text": "……はぁ……",
      "translations": {
        "en": "…Sigh…",
        "id": ""
      },
      "startTime": 107.8487056654,
      "endTime": 109.96194619340001,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_okinawahotel-00-noon.webp",
