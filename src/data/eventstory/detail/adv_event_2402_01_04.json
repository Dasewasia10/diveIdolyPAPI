      "bgName": "okinawahotel-00-noon",
      "startTime": 101.8
    },
    {
      "type": "dialogue",
      "speakerCode": "koh",
      "speakerName": "{user}",
      "speakerNameEn": "{user}",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-makino.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/eventStoryVoice/sud_vo_adv_event_2402_01_04/sud_vo_adv_event_2402_01_04-koh001.m4a",
      "text": "お疲れ様、みんな\n今後のスケジュールについて、少し話を……",
      "translations": {
        "en": "Good work‚ everyone.\nI’d like to talk to you about our upcoming schedule…",
        "id": ""
      },
      "startTime": 102.9095220169,
      "endTime": 107.6353724083,
      "sfxList": []
    },
    {
