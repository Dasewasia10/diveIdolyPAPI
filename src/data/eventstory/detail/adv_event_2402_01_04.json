    },
    {
      "type": "dialogue",
      "speakerCode": "rio",
      "speakerName": "神崎莉央",
      "speakerNameEn": "Rio",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-rio.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/eventStoryVoice/sud_vo_adv_event_2402_01_04/sud_vo_adv_event_2402_01_04-rio014.m4a",
      "text": "う……それは否定出来ない……\nそ、それじゃあミクの意見も聞きましょ！",
      "translations": {
        "en": "Ugh… I can’t deny that…\nT-Then let’s hear what Miku has to say!",
        "id": ""
      },
      "startTime": 280.4897507032,
      "endTime": 287.15492070510004,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_dressingroom-00-noon.webp",
