      "speakerNameEn": "{user}",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-makino.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/eventStoryVoice/sud_vo_adv_event_2604_02_04/sud_vo_adv_event_2604_02_03-koh001.m4a",
      "text": "『おさかな☆HEAVEN』に戻った雫達。すると\nそこでは魚達が熾烈な戦いを繰り広げていました……",
      "translations": {
        "en": "",
        "id": ""
      },
      "startTime": 0.8,
