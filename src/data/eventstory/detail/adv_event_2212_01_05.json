      "speakerName": "一同",
      "speakerNameEn": "Everyone",
      "iconUrl": null,
      "voiceUrl": null,
      "text": "この世に生まれてくれて本当にありがとう",
      "translations": {
        "en": "Thank you for being born into this world.",
