    },
    {
      "type": "dialogue",
      "speakerCode": "rei",
      "speakerName": "一ノ瀬怜",
      "speakerNameEn": "Rei",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-rei.png",
      "voiceUrl": null,
      "text": "（くっ……ステージ上でいつまでも倒れている訳には）",
      "translations": {
        "en": "（Ugh… I can’t just… collapse on stage…）",
        "id": ""
