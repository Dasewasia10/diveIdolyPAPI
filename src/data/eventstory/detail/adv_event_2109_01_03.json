      "text": "調子を崩しているそうですわね",
      "startTime": 35.06666666666667,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "suz",
      "speakerName": "成宮すず",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-suzu.png",
