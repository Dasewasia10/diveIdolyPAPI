      "speakerNameEn": "",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-mmob2.png",
      "voiceUrl": null,
      "text": "レイレイ、メイメイ、アオアオー！！",
      "translations": {
        "en": "",
        "id": ""
      },
      "startTime": 68.5405896823,
      "endTime": 73.00281077989999,
