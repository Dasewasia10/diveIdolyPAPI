      "speakerNameEn": "",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-mmob2.png",
      "voiceUrl": null,
      "text": "リングアナが掟破りのアイドルトーナメント参戦だ！",
      "translations": {
        "en": "",
        "id": ""
      },
      "startTime": 126.0143094733,
      "endTime": 131.0452586806,
      "sfxList": []
    },
    {
      "type": "background",
