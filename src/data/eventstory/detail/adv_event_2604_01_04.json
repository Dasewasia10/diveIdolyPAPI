        {
          "src": "https://apiip.dasewasia.my.id/storyBgm/sud_se_adv_cheers-in-01.m4a",
          "delay": 16400.455252699998
        }
      ]
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_prowrestlingring-00-noon.webp",
      "bgName": "prowrestlingring-00-noon",
      "startTime": 101.3843293186
    },
    {
      "type": "dialogue",
      "speakerCode": "mmob2",
      "speakerName": "リングアナウンサー鈴木",
      "speakerNameEn": "",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-mmob2.png",
      "voiceUrl": null,
      "text": "対戦相手は、パンクとラップの悪魔融合！",
      "translations": {
        "en": "",
        "id": ""
      },
      "startTime": 101.3843293186,
      "endTime": 105.6922447522,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "mmob2",
      "speakerName": "リングアナウンサー鈴木",
      "speakerNameEn": "",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-mmob2.png",
      "voiceUrl": null,
      "text": "世紀末パンクラップアイドルまきびし丸withスズキ",
      "translations": {
        "en": "",
        "id": ""
      },
      "startTime": 105.6922447522,
      "endTime": 112.0906327243,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_prowrestlingring-00-noon.webp",
      "bgName": "prowrestlingring-00-noon",
      "startTime": 112.2843293186
    },
    {
      "type": "dialogue",
      "speakerCode": "aoi",
      "speakerName": "井川葵",
      "speakerNameEn": "Aoi Igawa",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-aoi.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/eventStoryVoice/sud_vo_adv_event_2604_01_04/sud_vo_adv_event_2604_01_04-aoi003.m4a",
      "text": "あのまきびし丸って人……僕達を見て\n冷や汗をだらだら流してるけど、どうしたんだろう",
      "translations": {
        "en": "",
        "id": ""
      },
      "startTime": 112.2843293186,
      "endTime": 121.11217470119999,
      "sfxList": [
        {
          "src": "https://apiip.dasewasia.my.id/storyBgm/sud_se_adv_cheers-in-02.m4a",
          "delay": 18174.582132099986
        },
        {
          "src": "https://apiip.dasewasia.my.id/storyBgm/sud_se_adv_cheers-in-01.m4a",
          "delay": 17731.248798799996
        }
