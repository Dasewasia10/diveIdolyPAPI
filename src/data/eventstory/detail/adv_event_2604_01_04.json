    {
      "type": "dialogue",
      "speakerCode": "mmob2",
      "speakerName": "リングアナウンサー鈴木",
      "speakerNameEn": "",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-mmob2.png",
      "voiceUrl": null,
      "text": "みなさんお待ちかね！　地下闘技場最強アイドルを",
      "translations": {
        "en": "",
        "id": ""
      },
      "startTime": 44.471042299,
      "endTime": 48.2689382508,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "mmob2",
      "speakerName": "リングアナウンサー鈴木",
      "speakerNameEn": "",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-mmob2.png",
      "voiceUrl": null,
      "text": "決める弱肉強食のサバイバル、いよいよ開幕です！",
      "translations": {
        "en": "",
        "id": ""
      },
      "startTime": 48.2689382508,
      "endTime": 54.0408157822,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "mmob2",
      "speakerName": "リングアナウンサー鈴木",
      "speakerNameEn": "",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-mmob2.png",
      "voiceUrl": null,
      "text": "最後まで生き残るのは果たしてどのグループか！",
      "translations": {
        "en": "",
        "id": ""
      },
      "startTime": 54.2377089657,
      "endTime": 57.6405896823,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "mmob2",
      "speakerName": "リングアナウンサー鈴木",
      "speakerNameEn": "",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-mmob2.png",
      "voiceUrl": null,
      "text": "注目の一回戦第一試合、出場者は――",
      "translations": {
        "en": "",
        "id": ""
      },
      "startTime": 57.6405896823,
      "endTime": 62.6377093472,
      "sfxList": [
        {
          "src": "https://apiip.dasewasia.my.id/storyBgm/sud_se_adv_cheers-in-02.m4a",
          "delay": 14500.000031799998
        },
        {
          "src": "https://apiip.dasewasia.my.id/storyBgm/sud_se_adv_cheers-in-01.m4a",
          "delay": 14133.333365100001
        }
      ]
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_prowrestlingring-00-noon.webp",
      "bgName": "prowrestlingring-00-noon",
      "startTime": 62.8377089657
    },
    {
      "type": "dialogue",
      "speakerCode": "mmob2",
      "speakerName": "リングアナウンサー鈴木",
      "speakerNameEn": "",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-mmob2.png",
      "voiceUrl": null,
      "text": "正体不明！　全てが謎に包まれた、飛び入り三人娘！",
      "translations": {
        "en": "",
        "id": ""
      },
      "startTime": 62.8377089657,
      "endTime": 68.54058968230001,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_prowrestlingring-00-noon.webp",
      "bgName": "prowrestlingring-00-noon",
      "startTime": 63.9
    },
    {
