      "speakerCode": "mmob2",
      "speakerName": "リングアナウンサー鈴木",
      "speakerNameEn": "",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-mmob2.png",
      "voiceUrl": null,
      "text": "戦いの火蓋は切って落とされた！　地下闘技場最強",
      "translations": {
        "en": "",
        "id": ""
      },
      "startTime": 131.2485917087,
      "endTime": 135.3589114189,
      "sfxList": []
    },
