      "text": "すずにゃんは緊張してたみたいだけど",
      "translations": {
        "en": "It seemed like Suzunyan was nervous though",
        "id": ""
      },
      "startTime": 12.73698469,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_gpstage-00-noon.webp",
      "bgName": "gpstage-00-noon",
