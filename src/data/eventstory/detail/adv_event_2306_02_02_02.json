      "text": "一緒に過ごした一つ一つが、大切な思い出です",
      "translations": {
        "en": "Every moment we spent together is a precious memory.",
        "id": ""
      },
      "startTime": 17.3666646519,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_gpstage-00-noon.webp",
