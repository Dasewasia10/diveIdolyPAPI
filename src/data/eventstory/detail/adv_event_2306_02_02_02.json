      "speakerNameEn": "Yu",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-yu.png",
      "voiceUrl": null,
      "text": "風邪引いた時も看病してくれて、ありがとうね～",
      "translations": {
        "en": "Thanks for taking care of me when I caught a cold~",
        "id": ""
      },
