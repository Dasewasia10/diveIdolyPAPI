      "speakerNameEn": "Rui",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-rui.png",
      "voiceUrl": null,
      "text": "お二人と一緒なら、私達はどこまでも飛んでいけます",
      "translations": {
        "en": "As long as we're together with you two‚ we can fly anywhere.",
        "id": ""
