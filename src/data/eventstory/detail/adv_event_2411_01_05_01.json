      "speakerCode": "kan",
      "speakerName": "kana",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-kana.png",
      "voiceUrl": null,
      "text": "あー、こころちゃん学校に友達いないもんね～",
