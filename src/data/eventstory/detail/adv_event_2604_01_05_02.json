      "speakerCode": "unknown",
      "speakerName": "DJばぁば",
      "speakerNameEn": "",
      "iconUrl": null,
      "voiceUrl": null,
      "text": "私には真似出来ないけど……",
      "translations": {
        "en": "",
        "id": ""
      },
      "startTime": 50.2111339302,
      "endTime": 53.2710149496,
      "sfxList": [
        {
