      "speakerCode": "unknown",
      "speakerName": "DJばぁば",
      "speakerNameEn": "",
      "iconUrl": null,
      "voiceUrl": null,
      "text": "私達らしいダンスを精一杯踊りましょうね",
      "translations": {
        "en": "",
        "id": ""
      },
      "startTime": 53.4705613185,
