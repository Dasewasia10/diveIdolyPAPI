      "speakerName": "DJばぁば",
      "speakerNameEn": "",
      "iconUrl": null,
      "voiceUrl": null,
      "text": "素敵なステージで、見てて昇天するかと思ったわ",
      "translations": {
        "en": "",
        "id": ""
      },
      "startTime": 30.8662814827,
      "endTime": 36.5187706679,
      "sfxList": []
    },
    {
