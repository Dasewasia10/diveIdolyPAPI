      "speakerCode": "unknown",
      "speakerName": "DJばぁば",
      "speakerNameEn": "",
      "iconUrl": null,
      "voiceUrl": null,
      "text": "長生きはするものねぇ",
      "translations": {
        "en": "",
        "id": ""
      },
