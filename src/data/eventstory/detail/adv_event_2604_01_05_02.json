      "speakerName": "DJばぁば",
      "speakerNameEn": "",
      "iconUrl": null,
      "voiceUrl": null,
      "text": "ああ……本当に、今日は人生で一番楽しい日だわ",
      "translations": {
        "en": "",
        "id": ""
      },
      "startTime": 58.7444672635,
      "endTime": 65.66155920519999,
      "sfxList": []
    },
    {
