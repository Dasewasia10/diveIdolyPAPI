      "bgName": "tokyotown-00-night",
      "startTime": 398.6460769436
    },
    {
      "type": "dialogue",
      "speakerCode": "rui",
      "speakerName": "天動瑠依",
      "speakerNameEn": "Rui",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-rui.png",
