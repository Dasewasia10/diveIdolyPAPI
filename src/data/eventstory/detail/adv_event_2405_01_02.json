      "startTime": 289.4208418755
    },
    {
      "type": "dialogue",
      "speakerCode": "aoi",
      "speakerName": "井川葵",
      "speakerNameEn": "Aoi",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-aoi.png",
