{
  "id": "adv_event_2201_02_01",
  "title": "ハッピーニューイヤー",
  "script": [
    {
      "type": "dialogue",
      "speakerCode": "skr",
      "speakerName": "川咲さくら",
      "speakerNameEn": "Sakura",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-sakura.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/eventStoryVoice/sud_vo_adv_event_2201_02_01/sud_vo_adv_event_2201_02_01-skr001.m4a",
      "text": "あっ！　来た来た！\n{user}さん！",
      "translations": {
        "en": "Ah! {user}-san‚ you're here!",
        "id": ""
      },
      "startTime": 0.8,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "skr",
      "speakerName": "川咲さくら",
      "speakerNameEn": "Sakura",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-sakura.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/eventStoryVoice/sud_vo_adv_event_2201_02_01/sud_vo_adv_event_2201_02_01-skr002.m4a",
      "text": "みんなで挨拶したくて\n待ってたんです！",
      "translations": {
        "en": "We've been waiting to greet everyone!",
        "id": ""
      },
      "startTime": 3.8333333333,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "skr",
      "speakerName": "川咲さくら",
      "speakerNameEn": "Sakura",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-sakura.png",
      "voiceUrl": null,
      "text": "えーっと、明けまして\nおめでとうございます！",
      "translations": {
        "en": "Um‚ Happy New Year!",
        "id": ""
      },
      "startTime": 7.0333333333,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "skr",
      "speakerName": "川咲さくら",
      "speakerNameEn": "Sakura",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-sakura.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/eventStoryVoice/sud_vo_adv_event_2201_02_01/sud_vo_adv_event_2201_02_01-skr003.m4a",
      "text": "ふつつか者ですが、今年も\nよろしくお願いします！",
      "translations": {
        "en": "I'm just a humble person‚ but please take care of me this year too!",
        "id": ""
      },
      "startTime": 10.9666666667,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "hrk",
      "speakerName": "佐伯遙子",
      "speakerNameEn": "Haruko",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-haruko.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/eventStoryVoice/sud_vo_adv_event_2201_02_01/sud_vo_adv_event_2201_02_01-hrk001.m4a",
      "text": "ふふ、さくらちゃん\nそれ使いどころが違うわよ",
      "translations": {
        "en": "Hehe‚ Sakura-chan‚ you're using it in the wrong context.",
        "id": ""
      },
      "startTime": 14.6333333333,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "szk",
      "speakerName": "兵藤雫",
      "speakerNameEn": "Shizuku",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-shizuku.png",
      "voiceUrl": null,
      "text": "ふつつか者ですが……",
      "translations": {
        "en": "I'm just a humble person…",
        "id": ""
      },
      "startTime": 19.4333333333,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "szk",
      "speakerName": "兵藤雫",
      "speakerNameEn": "Shizuku",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-shizuku.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/eventStoryVoice/sud_vo_adv_event_2201_02_01/sud_vo_adv_event_2201_02_01-szk001.m4a",
      "text": "今年もよろしく、です",
      "translations": {
        "en": "Please take care of me this year too.",
        "id": ""
      },
      "startTime": 21.9224376042,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "hrk",
      "speakerName": "佐伯遙子",
      "speakerNameEn": "Haruko",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-haruko.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/eventStoryVoice/sud_vo_adv_event_2201_02_01/sud_vo_adv_event_2201_02_01-hrk002.m4a",
      "text": "もう雫ちゃん\n真似しちゃダメっ",
      "translations": {
        "en": "Haruka-chan‚ don't copy me.",
        "id": ""
      },
      "startTime": 24.9,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "hrk",
      "speakerName": "佐伯遙子",
      "speakerNameEn": "Haruko",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-haruko.png",
      "voiceUrl": null,
      "text": "何はともあれ\n今年も私達のことお願いね！",
      "translations": {
        "en": "Anyway‚ please take care of us this year too!",
        "id": ""
      },
      "startTime": 28.5,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "hrk",
      "speakerName": "佐伯遙子",
      "speakerNameEn": "Haruko",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-haruko.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/eventStoryVoice/sud_vo_adv_event_2201_02_01/sud_vo_adv_event_2201_02_01-hrk003.m4a",
      "text": "{user}君！",
      "translations": {
        "en": "{user}!",
        "id": ""
      },
      "startTime": 32.7,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "chs",
      "speakerName": "白石千紗",
      "speakerNameEn": "Chisa",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-chisa.png",
      "voiceUrl": null,
      "text": "えへへ\n賑やかで楽しい新年だね",
      "translations": {
        "en": "Hehehe‚ it's a lively and enjoyable New Year.",
        "id": ""
      },
      "startTime": 34.3666666667,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "chs",
      "speakerName": "白石千紗",
      "speakerNameEn": "Chisa",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-chisa.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/eventStoryVoice/sud_vo_adv_event_2201_02_01/sud_vo_adv_event_2201_02_01-chs001.m4a",
      "text": "私はみんなと\nいい年にしたいなぁ",
      "translations": {
        "en": "I want to have a great year with everyone.",
        "id": ""
      },
      "startTime": 38.5666666667,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "rei",
      "speakerName": "一ノ瀬怜",
      "speakerNameEn": "Rei",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-rei.png",
      "voiceUrl": null,
      "text": "そうね。今年も一緒に頂点を\n見据えて頑張りましょう",
      "translations": {
        "en": "That's right. Let's aim for the top together this year.",
        "id": ""
      },
      "startTime": 42.3333333333,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "rei",
      "speakerName": "一ノ瀬怜",
      "speakerNameEn": "Rei",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-rei.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/eventStoryVoice/sud_vo_adv_event_2201_02_01/sud_vo_adv_event_2201_02_01-rei001.m4a",
      "text": "しっかりマネジメントを\nお願いしますね！",
      "translations": {
        "en": "Please manage us well!",
        "id": ""
      },
      "startTime": 47.0333333333,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "skr",
      "speakerName": "川咲さくら",
      "speakerNameEn": "Sakura",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-sakura.png",
      "voiceUrl": null,
      "text": "うんうん、トップアイドル\n目指して頑張ろー！！",
      "translations": {
        "en": "Yeah yeah‚ let's work hard to become top idols!",
        "id": ""
      },
      "startTime": 49.8666666667,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "skr",
      "speakerName": "川咲さくら",
      "speakerNameEn": "Sakura",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-sakura.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/eventStoryVoice/sud_vo_adv_event_2201_02_01/sud_vo_adv_event_2201_02_01-skr004.m4a",
      "text": "それじゃ改めまして！",
      "translations": {
        "en": "So‚ once again!",
        "id": ""
      },
      "startTime": 54.3174311738,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "skr",
      "speakerName": "川咲さくら",
      "speakerNameEn": "Sakura",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-sakura.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/eventStoryVoice/sud_vo_adv_event_2201_02_01/sud_vo_adv_event_2201_02_01-skr005.m4a",
      "text": "せーの！",
      "translations": {
        "en": "On the count of three!",
        "id": ""
      },
      "startTime": 56.6666666667,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "skr",
      "speakerName": "一同",
      "speakerNameEn": "Everyone",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-sakura.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/eventStoryVoice/sud_vo_adv_event_2201_02_01/sud_vo_adv_event_2201_02_01-hrk004.m4a",
      "text": "ハッピーニューイヤー！！！",
      "translations": {
        "en": "Happy New Year!!!",
        "id": ""
      },
      "startTime": 58.3666666667,
      "sfxList": []
    }
  ]
}