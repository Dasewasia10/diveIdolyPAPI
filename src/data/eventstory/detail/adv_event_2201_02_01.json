{
  "id": "adv_event_2201_02_01",
  "title": "ハッピーニューイヤー",
  "script": [
    {
      "type": "dialogue",
      "speakerCode": "skr",
      "speakerName": "川咲さくら",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-sakura.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/eventStoryVoice/sud_vo_adv_event_2201_02_01/sud_vo_adv_event_2201_02_01-skr001.wav",
      "text": "あっ！　来た来た！\n{user}さん！",
      "startTime": 0.8,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "skr",
      "speakerName": "川咲さくら",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-sakura.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/eventStoryVoice/sud_vo_adv_event_2201_02_01/sud_vo_adv_event_2201_02_01-skr002.wav",
      "text": "みんなで挨拶したくて\n待ってたんです！",
      "startTime": 3.8333333333,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "skr",
      "speakerName": "川咲さくら",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-sakura.png",
      "voiceUrl": null,
      "text": "えーっと、明けまして\nおめでとうございます！",
      "startTime": 7.0333333333,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "skr",
      "speakerName": "川咲さくら",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-sakura.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/eventStoryVoice/sud_vo_adv_event_2201_02_01/sud_vo_adv_event_2201_02_01-skr003.wav",
      "text": "ふつつか者ですが、今年も\nよろしくお願いします！",
      "startTime": 10.9666666667,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "hrk",
      "speakerName": "佐伯遙子",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-haruko.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/eventStoryVoice/sud_vo_adv_event_2201_02_01/sud_vo_adv_event_2201_02_01-hrk001.wav",
      "text": "ふふ、さくらちゃん\nそれ使いどころが違うわよ",
      "startTime": 14.6333333333,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "szk",
      "speakerName": "兵藤雫",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-shizuku.png",
      "voiceUrl": null,
      "text": "ふつつか者ですが……",
      "startTime": 19.4333333333,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "szk",
      "speakerName": "兵藤雫",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-shizuku.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/eventStoryVoice/sud_vo_adv_event_2201_02_01/sud_vo_adv_event_2201_02_01-szk001.wav",
      "text": "今年もよろしく、です",
      "startTime": 21.9224376042,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "hrk",
      "speakerName": "佐伯遙子",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-haruko.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/eventStoryVoice/sud_vo_adv_event_2201_02_01/sud_vo_adv_event_2201_02_01-hrk002.wav",
      "text": "もう雫ちゃん\n真似しちゃダメっ",
      "startTime": 24.9,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "hrk",
      "speakerName": "佐伯遙子",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-haruko.png",
      "voiceUrl": null,
      "text": "何はともあれ\n今年も私達のことお願いね！",
      "startTime": 28.5,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "hrk",
      "speakerName": "佐伯遙子",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-haruko.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/eventStoryVoice/sud_vo_adv_event_2201_02_01/sud_vo_adv_event_2201_02_01-hrk003.wav",
      "text": "{user}君！",
      "startTime": 32.7,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "chs",
      "speakerName": "白石千紗",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-chisa.png",
      "voiceUrl": null,
      "text": "えへへ\n賑やかで楽しい新年だね",
      "startTime": 34.3666666667,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "chs",
      "speakerName": "白石千紗",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-chisa.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/eventStoryVoice/sud_vo_adv_event_2201_02_01/sud_vo_adv_event_2201_02_01-chs001.wav",
      "text": "私はみんなと\nいい年にしたいなぁ",
      "startTime": 38.5666666667,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "rei",
      "speakerName": "一ノ瀬怜",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-rei.png",
      "voiceUrl": null,
      "text": "そうね。今年も一緒に頂点を\n見据えて頑張りましょう",
      "startTime": 42.3333333333,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "rei",
      "speakerName": "一ノ瀬怜",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-rei.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/eventStoryVoice/sud_vo_adv_event_2201_02_01/sud_vo_adv_event_2201_02_01-rei001.wav",
      "text": "しっかりマネジメントを\nお願いしますね！",
      "startTime": 47.0333333333,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "skr",
      "speakerName": "川咲さくら",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-sakura.png",
      "voiceUrl": null,
      "text": "うんうん、トップアイドル\n目指して頑張ろー！！",
      "startTime": 49.8666666667,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "skr",
      "speakerName": "川咲さくら",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-sakura.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/eventStoryVoice/sud_vo_adv_event_2201_02_01/sud_vo_adv_event_2201_02_01-skr004.wav",
      "text": "それじゃ改めまして！",
      "startTime": 54.3174311738,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "skr",
      "speakerName": "川咲さくら",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-sakura.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/eventStoryVoice/sud_vo_adv_event_2201_02_01/sud_vo_adv_event_2201_02_01-skr005.wav",
      "text": "せーの！",
      "startTime": 56.6666666667,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "skr",
      "speakerName": "一同",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-sakura.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/eventStoryVoice/sud_vo_adv_event_2201_02_01/sud_vo_adv_event_2201_02_01-hrk004.wav",
      "text": "ハッピーニューイヤー！！！",
      "startTime": 58.3666666667,
      "sfxList": []
    }
  ]
}