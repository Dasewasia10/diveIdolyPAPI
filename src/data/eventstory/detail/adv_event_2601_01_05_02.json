      "bgName": "shrine-00-noon",
      "startTime": 121.2150081348
    },
    {
      "type": "dialogue",
      "speakerCode": "mhk",
      "speakerName": "miho",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-miho.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/eventStoryVoice/sud_vo_adv_event_2601_01_05_02/sud_vo_adv_event_2601_01_05-mhk008.wav",
      "text": "帰省か、もう少し遠出すれば良かった",
      "startTime": 127.2333379379,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_shrine-00-noon.webp",
      "bgName": "shrine-00-noon",
      "startTime": 130.7906601301
    },
    {
