{
  "id": "adv_event_2309_02_rei",
  "title": "Episode 2 Part Rei",
  "script": [
    {
      "type": "dialogue",
      "speakerCode": "rei",
      "speakerName": "一ノ瀬怜",
      "speakerNameEn": "Rei",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-rei.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/eventStoryVoice/sud_vo_adv_event_2309_02_rei/sud_vo_adv_event_2309_02_rei-rei001.m4a",
      "text": "私、遙子さんみたいに\n落ち着きを持ちたいんです",
      "translations": {
        "en": "I want to be as calm and\ncollected as you are‚\nHaruko-san.",
        "id": ""
      },
      "startTime": 0.8,
      "endTime": 5.9000001907,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "rei",
      "speakerName": "一ノ瀬怜",
      "speakerNameEn": "Rei",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-rei.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/eventStoryVoice/sud_vo_adv_event_2309_02_rei/sud_vo_adv_event_2309_02_rei-rei002.m4a",
      "text": "ネットでは、瞑想をすると\nいいと書いてあったんですが",
      "translations": {
        "en": "I read online that\nmeditation is good for\nthat‚ so I tried it",
        "id": ""
      },
      "startTime": 6.0866669337,
      "endTime": 11.3933788935,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "rei",
      "speakerName": "一ノ瀬怜",
      "speakerNameEn": "Rei",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-rei.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/eventStoryVoice/sud_vo_adv_event_2309_02_rei/sud_vo_adv_event_2309_02_rei-rei003.m4a",
      "text": "寮で試していたら、キッチン\nからカレーの匂いがしてきて",
      "translations": {
        "en": "in the dorm‚ but then the\nsmell of curry wafted in",
        "id": ""
      },
      "startTime": 11.5933788935,
      "endTime": 17.5702497164,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "rei",
      "speakerName": "一ノ瀬怜",
      "speakerNameEn": "Rei",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-rei.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/eventStoryVoice/sud_vo_adv_event_2309_02_rei/sud_vo_adv_event_2309_02_rei-rei004.m4a",
      "text": "落ち着くどころか気になって\n仕方ありませんでした",
      "translations": {
        "en": "and instead of calming\ndown‚ I couldn’t focus\non anything else.",
        "id": ""
      },
      "startTime": 17.7635829448,
      "endTime": 22.6635828494,
      "sfxList": []
    }
  ]
