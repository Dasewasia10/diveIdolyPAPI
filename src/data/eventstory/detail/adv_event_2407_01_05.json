      "endTime": 375.2254713695,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "rei",
      "speakerName": "一ノ瀬怜",
      "speakerNameEn": "Rei",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-rei.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/eventStoryVoice/sud_vo_adv_event_2407_01_05/sud_vo_adv_event_2407_01_05-rei015.m4a",
      "text": "ふふ……私も楽しみだわ\nちなみに、私と観たい映画ってどんな内容なの？",
      "translations": {
