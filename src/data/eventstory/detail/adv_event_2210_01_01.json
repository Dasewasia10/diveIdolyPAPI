    {
      "type": "dialogue",
      "speakerCode": "rio",
      "speakerName": "神崎莉央",
      "speakerNameEn": "Rio",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-rio.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/eventStoryVoice/sud_vo_adv_event_2210_01_01/sud_vo_adv_event_2210_01_01-rio001.m4a",
      "text": "……みなさん、今から一つ\n私のお願いを聞いてほしいんです",
      "translations": {
        "en": "…Everyone‚ could you please‚\ndo me a favor from now on?",
        "id": ""
      },
      "startTime": 7.5666666667,
      "endTime": 13.2630160968,
      "sfxList": []
    },
    {
      "type": "background",
