      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-rio.png",
      "voiceUrl": null,
      "text": "三年前の曲だけど……私の大好きな歌",
      "startTime": 23.8666666667,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "rio",
