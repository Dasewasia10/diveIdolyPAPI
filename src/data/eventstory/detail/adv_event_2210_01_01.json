    },
    {
      "type": "dialogue",
      "speakerCode": null,
      "speakerName": "",
      "speakerNameEn": "",
      "iconUrl": null,
      "voiceUrl": null,
      "text": "――四日前",
      "translations": {
        "en": "――4 days ago",
        "id": ""
      },
      "startTime": 41.6,
      "endTime": 43.3333333334,
      "sfxList": [
