      "speakerCode": "rio",
      "speakerName": "神崎莉央",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-rio.png",
      "voiceUrl": null,
      "text": "私はそんなキャラじゃないわよ",
      "startTime": 43.5783445358,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "rio",
