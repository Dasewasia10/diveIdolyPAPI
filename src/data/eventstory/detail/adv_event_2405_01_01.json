      "voiceUrl": "https://apiip.dasewasia.my.id/eventStoryVoice/sud_vo_adv_event_2405_01_01/sud_vo_adv_event_2405_01_01-kkr001.wav",
      "text": "そんな控えめな賛辞では全然足りませーん！",
      "startTime": 23.4999994278,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_dressingroom-00-noon.webp",
