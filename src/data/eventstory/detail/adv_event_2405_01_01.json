      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-kokoro.png",
      "voiceUrl": null,
      "text": "はぁ～。莉央さん、何言ってるんですか～？",
      "startTime": 19.5999994278,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "kkr",
      "speakerName": "赤崎こころ",
