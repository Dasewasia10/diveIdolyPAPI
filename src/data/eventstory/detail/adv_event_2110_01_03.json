    },
    {
      "type": "dialogue",
      "speakerCode": "skr",
      "speakerName": "川咲さくら",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-sakura.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/eventStoryVoice/sud_vo_adv_event_2110_01_03/sud_vo_adv_event_2110_01_03-skr013.m4a",
      "text": "走り続けてきたんじゃないですか",
      "startTime": 145.53333333333333,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "skr",
      "speakerName": "川咲さくら",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-sakura.png",
      "voiceUrl": null,
      "text": "それに、麻奈さんの誕生日なら、これから毎年",
      "startTime": 148.36666666666667,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "skr",
      "speakerName": "川咲さくら",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-sakura.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/eventStoryVoice/sud_vo_adv_event_2110_01_03/sud_vo_adv_event_2110_01_03-skr014.m4a",
      "text": "星見プロのみんなでお祝いすればいいんですよ",
      "startTime": 152.76666666666668,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "koh",
      "speakerName": "{user}",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-makino.png",
