      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-suzu.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/eventStoryVoice/sud_vo_adv_event_2112_01_01/sud_vo_adv_event_2112_01_01-suz003.m4a",
      "text": "成宮家では毎年大きなツリーを飾って\n盛大にパーティーをしていましたわ",
      "translations": {
        "en": "The Narumiya family decorates a big tree every year‚\nand throws a grand party.",
        "id": ""
      },
      "startTime": 144.3,
      "endTime": 150.4815488634,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "smr",
      "speakerName": "奥山すみれ",
      "speakerNameEn": "Sumire",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-sumire.png",
