      "type": "dialogue",
      "speakerCode": "kkr",
      "speakerName": "赤崎こころ",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-kokoro.png",
      "voiceUrl": null,
      "text": "莉央さん、葵さん……ありがとうございます",
