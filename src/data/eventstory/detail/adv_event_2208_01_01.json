      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "ai",
      "speakerName": "小美山愛",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-ai.png",
      "voiceUrl": null,
      "text": "（本当は、オフに先輩方と遊びたかったんだけど……）",
      "startTime": 132.0666666667,
      "sfxList": []
    },
    {
      "type": "dialogue",
