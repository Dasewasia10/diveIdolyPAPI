      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "kkr",
      "speakerName": "赤崎こころ",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-kokoro.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/eventStoryVoice/sud_vo_adv_event_2208_01_01/sud_vo_adv_event_2208_01_01-kkr006.wav",
