      "bgName": "ameapart-00-night",
      "startTime": 154.1936494826
    },
    {
      "type": "dialogue",
      "speakerCode": "mhk",
      "speakerName": "miho",
      "speakerNameEn": "miho",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-miho.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/eventStoryVoice/sud_vo_adv_event_2508_01_02/sud_vo_adv_event_2508_01_02-mhk007.m4a",
      "text": "……急に一体、なんなのよ\nそれに、葉ちゃんとの曲を貴方達と？　冗談言わないで",
      "translations": {
        "en": "……急に一体、なんなのよ\nそれに、葉ちゃんとの曲を貴方達と？　冗談言わないで",
