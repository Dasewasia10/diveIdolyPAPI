      "bgName": "ameapart-00-night",
      "startTime": 90.4936494826
    },
    {
      "type": "dialogue",
      "speakerCode": "kor",
      "speakerName": "fran",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-fran.png",
      "voiceUrl": null,
      "text": "はいこれ、kanaが飲んじゃったかわりのワイン",
      "startTime": 90.4936494826,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "kor",
      "speakerName": "fran",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-fran.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/eventStoryVoice/sud_vo_adv_event_2508_01_02/sud_vo_adv_event_2508_01_02-kor007.wav",
      "text": "味噌汁の分くらいは、先に飲んでいいわよ",
      "startTime": 94.1109530403,
      "sfxList": [
        {
          "src": "https://apiip.dasewasia.my.id/storyBgm/sud_se_adv_drink-01.m4a",
          "delay": 7259.900761899999
        }
      ]
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_ameapart-00-night.webp",
      "bgName": "ameapart-00-night",
      "startTime": 96.9603161493
    },
    {
      "type": "dialogue",
      "speakerCode": "mhk",
      "speakerName": "miho",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-miho.png",
      "voiceUrl": null,
      "text": "まさか、貴方に酒を奢られる日がくるなんて",
