      "speakerCode": "koh",
      "speakerName": "{user}",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-makino.png",
      "voiceUrl": null,
      "text": "俺も同席しましょうか？　二人だけじゃ不安……",
