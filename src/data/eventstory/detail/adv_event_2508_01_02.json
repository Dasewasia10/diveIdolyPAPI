      "startTime": 71.9999994914
    },
    {
      "type": "dialogue",
      "speakerCode": "kor",
      "speakerName": "fran",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-fran.png",
      "voiceUrl": null,
      "text": "ただいまー。まだ夕飯食べてないんだけど、何かある？",
      "startTime": 72.5936494826,
      "sfxList": []
    },
    {
      "type": "background",
