      "bgName": "ameapart-00-night",
      "startTime": 78.3269828159
    },
    {
      "type": "dialogue",
      "speakerCode": "kor",
      "speakerName": "fran",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-fran.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/eventStoryVoice/sud_vo_adv_event_2508_01_02/sud_vo_adv_event_2508_01_02-kor006.wav",
      "text": "あ、白いご飯と味噌汁！　久しぶりの日本の味！",
      "startTime": 78.3269828159,
      "sfxList": []
    },
    {
      "type": "background",
