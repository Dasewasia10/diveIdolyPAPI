      "text": "いえ、万が一の時の仲裁役ってことで",
      "startTime": 17.9,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "kor",
      "speakerName": "fran",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-fran.png",
      "voiceUrl": null,
      "text": "いや、別にいいです。って言うか、むしろ邪魔です",
