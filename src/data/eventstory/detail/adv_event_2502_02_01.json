      "voiceUrl": "https://apiip.dasewasia.my.id/eventStoryVoice/sud_vo_adv_event_2502_02_01/sud_vo_adv_event_2502_02_01-smr001.m4a",
      "text": "ええっ……！",
      "translations": {
        "en": "Ehh…!?",
        "id": ""
      },
      "startTime": 19.9333347321,
      "endTime": 20.9305229426,
      "sfxList": []
    },
