      "text": "私、こころと一緒に、アイドルを続けたい",
      "translations": {
        "en": "I want to continue being an idol with you‚ Kokoro.",
        "id": ""
      },
      "startTime": 365.5666666667,
      "endTime": 370.23467098879996,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "ai",
      "speakerName": "小美山愛",
      "speakerNameEn": "Ai",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-ai.png",
