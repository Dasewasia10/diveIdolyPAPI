      "speakerName": "川咲さくら",
      "speakerNameEn": "Sakura",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-sakura.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/eventStoryVoice/sud_vo_adv_event_2304_01_02/sud_vo_adv_event_2304_01_02-skr021.m4a",
      "text": "遙子ちゃんも、言いたくても言えないことがあるの？",
      "translations": {
        "en": "Haruka-chan‚ do you also have things you want to say but can't?",
        "id": ""
      },
