      "voiceUrl": "https://apiip.dasewasia.my.id/eventStoryVoice/sud_vo_adv_event_2304_01_02/sud_vo_adv_event_2304_01_02-koh002.m4a",
      "text": "ごめんごめん。ちゃんと説明するよ",
      "startTime": 15.4990700404,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "hrk",
