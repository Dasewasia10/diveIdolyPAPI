      "voiceUrl": "https://apiip.dasewasia.my.id/eventStoryVoice/sud_vo_adv_event_2304_01_02/sud_vo_adv_event_2304_01_02-szk002.m4a",
      "text": "遙子さん、しんみりしてた",
