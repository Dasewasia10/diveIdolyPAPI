      "text": "遙子ちゃん……",
      "translations": {
        "en": "Haruka-chan…",
        "id": ""
      },
      "startTime": 286.022276433,
      "endTime": 287.8521403866,
      "sfxList": []
    },
    {
      "type": "background",
