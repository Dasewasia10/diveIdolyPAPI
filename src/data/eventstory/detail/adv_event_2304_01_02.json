      "startTime": 50.6923120975,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "skr",
      "speakerName": "川咲さくら",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-sakura.png",
      "voiceUrl": null,
      "text": "いつか後輩が出来たら、って……",
      "startTime": 54.5977997464,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "skr",
