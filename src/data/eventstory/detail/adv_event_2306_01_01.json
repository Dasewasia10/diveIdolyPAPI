      "speakerNameEn": "Mana",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-mana.png",
      "voiceUrl": null,
      "text": "だって……改まって面と向かって「ありがとう」なんて",
      "translations": {
        "en": "Because… It's embarrassing to formally",
