      "startTime": 156.9666798909
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_xmasstage-00-night.webp",
      "bgName": "xmasstage-00-night",
      "startTime": 158.1000172933
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_xmasstage-00-night.webp",
      "bgName": "xmasstage-00-night",
      "startTime": 159.7000010173
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_xmasstage-00-night.webp",
      "bgName": "xmasstage-00-night",
      "startTime": 162.3769786515
    },
    {
      "type": "dialogue",
      "speakerCode": "unknown",
      "speakerName": "一同",
      "speakerNameEn": "",
      "iconUrl": null,
      "voiceUrl": null,
      "text": "メリークリスマス！",
      "translations": {
        "en": "",
        "id": ""
      },
      "startTime": 162.3769786515,
      "endTime": 164.4706541934,
      "sfxList": [
        {
          "src": "https://apiip.dasewasia.my.id/storyBgm/sud_se_adv_cheers-in-01.m4a",
          "delay": 689.6880152000051
        }
      ]
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_xmasstage-00-night.webp",
      "bgName": "xmasstage-00-night",
      "startTime": 164.6623546201
    },
    {
      "type": "dialogue",
      "speakerCode": "rui",
      "speakerName": "天動瑠依",
      "speakerNameEn": "Rui Tendo",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-rui.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/eventStoryVoice/sud_vo_adv_event_2512_01_03/sud_vo_adv_event_2512_01_03-rui006.m4a",
      "text": "今夜はグループの垣根を越えた\n私達五人のスペシャルライブです！",
      "translations": {
        "en": "",
        "id": ""
      },
      "startTime": 164.6623546201,
      "endTime": 169.7509035665,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_xmasstage-00-night.webp",
      "bgName": "xmasstage-00-night",
      "startTime": 169.9623546201
    },
    {
      "type": "dialogue",
      "speakerCode": "rio",
      "speakerName": "神崎莉央",
      "speakerNameEn": "Rio Kanzaki",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-rio.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/eventStoryVoice/sud_vo_adv_event_2512_01_03/sud_vo_adv_event_2512_01_03-rio005.m4a",
      "text": "素敵なクリスマスパーティーを過ごしましょう！\n一緒に最高の思い出を作るわよ！",
      "translations": {
        "en": "",
        "id": ""
      },
      "startTime": 169.9623546201,
      "endTime": 175.7951662618,
      "sfxList": [
        {
          "src": "https://apiip.dasewasia.my.id/storyBgm/sud_se_adv_cheers-in-01.m4a",
          "delay": 4704.354262199985
        }
      ]
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_xmasstage-00-night.webp",
      "bgName": "xmasstage-00-night",
      "startTime": 175.9868666886
    },
    {
      "type": "dialogue",
      "speakerCode": "momo",
      "speakerName": "モモ",
      "speakerNameEn": "",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-momo.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/eventStoryVoice/sud_vo_adv_event_2512_01_03/sud_vo_adv_event_2512_01_03-momo003.m4a",
      "text": "会場、凄く盛り上がってますね。これなら……\n古手川さん？　表情が硬いですよ。緊張してますか？",
      "translations": {
        "en": "",
        "id": ""
      },
      "startTime": 175.9868666886,
      "endTime": 186.2201981781,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "kyui",
