      "speakerNameEn": "Rio",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-rio.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_rio_11_03/sud_vo_adv_card_rio_11_03-rio022.m4a",
      "text": "私達がBIG4に辿り着くまでの道のりは\n険しくて、とても辛いものだったわ",
      "translations": {
        "en": "The road to reaching BIG4\nwas steep and extremely tough.",
        "id": ""
      },
      "startTime": 217.0247019133,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "rio",
      "speakerName": "神崎莉央",
      "speakerNameEn": "Rio",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-rio.png",
