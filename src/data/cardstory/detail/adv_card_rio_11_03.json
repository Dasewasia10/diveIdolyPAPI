      "text": "莉央さんらしい答えですね。強い覚悟を感じます",
      "translations": {
        "en": "That’s so Rio-san. I can feel your strong resolve.",
        "id": ""
      },
      "startTime": 202.2603816028,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "rio",
      "speakerName": "神崎莉央",
      "speakerNameEn": "Rio",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-rio.png",
