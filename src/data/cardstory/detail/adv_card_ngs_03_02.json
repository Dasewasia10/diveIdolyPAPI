      "text": "渚、何を読んでるんだ？",
      "translations": {
        "en": "What are you reading‚ Nagisa?",
        "id": ""
      },
      "startTime": 157.4333333333,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "ngs",
      "speakerName": "伊吹渚",
