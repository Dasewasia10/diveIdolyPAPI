      "text": "ごめんごめん\nでも、朝になるのも悪いことばかりじゃないだろ？",
      "startTime": 255.2333333333,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "suz",
      "speakerName": "成宮すず",
