      "speakerCode": "suz",
      "speakerName": "成宮すず",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-suzu.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_suz_06_03/sud_vo_adv_card_suz_06_03-suz032.m4a",
      "text": "次の楽しいことは、まだまだ沢山\nあるのかもしれませんわね",
      "startTime": 294.8666666667,
