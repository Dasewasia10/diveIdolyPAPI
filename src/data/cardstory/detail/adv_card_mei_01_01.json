      "bgName": "stage2",
      "startTime": 58.233333333333334
    },
    {
      "type": "dialogue",
      "speakerCode": "mei",
      "speakerName": "早坂芽衣",
      "speakerNameEn": "Mei",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-mei.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_mei_01_01/sud_vo_adv_card_mei_01_01-mei008.m4a",
      "text": "さっき『力になる』って言ってくれたでしょ？\nこのままじゃ、赤点になっちゃうよ～",
      "translations": {
        "en": "You said you’d help out!\nMy grades are crashing into the red!",
        "id": ""
      },
      "startTime": 62.63333333333333,
      "sfxList": []
    },
    {
      "type": "background",
