      "bgName": "stage2",
      "startTime": 84.36666666666666
    },
    {
      "type": "dialogue",
      "speakerCode": "koh",
      "speakerName": "{user}",
      "speakerNameEn": "{user}",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-makino.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_mei_01_01/sud_vo_adv_card_mei_01_01-koh005.m4a",
      "text": "そんなに面白い顔をしてるつもりはないんだが……\n仕方ない……教えるから、真面目にやるんだぞ？",
      "translations": {
        "en": "I’m not trying to make a funny face…\nBut okay‚ I’ll tutor you. So long as you take it seriously.",
        "id": ""
