      "text": "{user}さ～ん。勉強教えてよ～\nねーねー、教えてったら～",
      "translations": {
        "en": "{user}-san! Help me study!\nPlease‚ please! Teach me!",
        "id": ""
      },
      "startTime": 53.733333333333334,
      "sfxList": []
    },
    {
      "type": "background",
