      "text": "あぁ。花火を見ると夏だなーって感じるよ",
      "translations": {
        "en": "Yeah. Fireworks really make it feel like summer.",
        "id": ""
      },
      "startTime": 146.7402535279,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "koh",
      "speakerName": "{user}",
      "speakerNameEn": "{user}",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-makino.png",
