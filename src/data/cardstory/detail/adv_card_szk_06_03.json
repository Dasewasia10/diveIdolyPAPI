    {
      "type": "dialogue",
      "speakerCode": "koh",
      "speakerName": "{user}",
      "speakerNameEn": "{user}",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-makino.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_szk_06_03/sud_vo_adv_card_szk_06_03-koh008.m4a",
      "text": "そろそろ花火の時間だ\n人が多いからはぐれないようにな",
      "translations": {
        "en": "It's almost time for the fireworks.\nThere's a lot of people‚ so don't get separated.",
