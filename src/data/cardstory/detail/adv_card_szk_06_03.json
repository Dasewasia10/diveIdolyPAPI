      "text": "{user}さん、こそ……\nその、花火……見ない、の？",
      "translations": {
        "en": "{user}-san‚ aren't you…\nUm‚ aren't you going to watch the fireworks?",
        "id": ""
      },
      "startTime": 163.3309616884,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "koh",
      "speakerName": "{user}",
      "speakerNameEn": "{user}",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-makino.png",
