      "text": "花火、きれい……",
      "translations": {
        "en": "The fireworks are so beautiful…",
        "id": ""
      },
      "startTime": 143.5402637005,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "koh",
