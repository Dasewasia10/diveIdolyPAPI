      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-rei.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_rei_05_02/sud_vo_adv_card_rei_05_02-rei015.m4a",
      "text": "……え？　障害物競走への参加ですか？",
      "translations": {
        "en": "…Eh? Participating in an obstacle race?",
        "id": ""
      },
      "startTime": 153.1666666667,
      "sfxList": []
    },
    {
