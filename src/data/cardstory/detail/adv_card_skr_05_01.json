      "text": "どんなお仕事ですか？",
      "translations": {
        "en": "What kind of job is it?",
        "id": ""
      },
      "startTime": 75.6,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "koh",
      "speakerName": "{user}",
      "speakerNameEn": "{user}",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-makino.png",
