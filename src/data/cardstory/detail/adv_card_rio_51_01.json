      "speakerNameEn": "Rei",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-rei.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_rio_51_01/sud_vo_adv_card_rio_51_01-rei004.m4a",
      "text": "わがまま？",
      "translations": {
        "en": "Selfish?",
