      "text": "知力と体力をつけてテレビに売り込みをかけるの！？",
      "translations": {
        "en": "and you're trying to be on TV with both your intellect and your physical strength!?",
        "id": ""
      },
      "startTime": 48.5764437312,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_hoshireception-00-noon.webp",
      "bgName": "hoshireception-00-noon",
      "startTime": 51.8666718006
    },
    {
      "type": "dialogue",
      "speakerCode": "koh",
      "speakerName": "{user}",
      "speakerNameEn": "{user}",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-makino.png",
