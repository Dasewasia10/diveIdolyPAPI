      "speakerName": "長瀬麻奈",
      "speakerNameEn": "Mana Nagase",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-mana.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_hrk_14_01/sud_vo_adv_cmn_mna_surp-02.m4a",
      "text": "じゃあ、どうしてそんなに気合いが入ってるの？",
      "translations": {
        "en": "",
        "id": ""
      },
      "startTime": 180.8136707465,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "hrk",
      "speakerName": "佐伯遙子",
      "speakerNameEn": "Haruko Saeki",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-haruko.png",
