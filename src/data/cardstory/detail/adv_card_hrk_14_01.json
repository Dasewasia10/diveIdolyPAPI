        "en": "",
        "id": ""
      },
      "startTime": 263.3539643766,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "mna",
      "speakerName": "長瀬麻奈",
      "speakerNameEn": "Mana Nagase",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-mana.png",
      "voiceUrl": null,
      "text": "手伝えることがあればなんでも言ってね！",
      "translations": {
        "en": "",
        "id": ""
      },
      "startTime": 267.8999907178,
      "sfxList": []
    },
    {
