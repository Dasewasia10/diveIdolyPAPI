        "en": "",
        "id": ""
      },
      "startTime": 202.4999958039,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "hrk",
      "speakerName": "佐伯遙子",
      "speakerNameEn": "Haruko Saeki",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-haruko.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_hrk_14_01/sud_vo_adv_card_hrk_14_01-hrk022.m4a",
      "text": "だから、麻奈ちゃんがミュージカルの主人公に\n抜擢された時も、私には縁のない話だと思った……",
      "translations": {
        "en": "",
        "id": ""
      },
      "startTime": 207.1333291372,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "hrk",
      "speakerName": "佐伯遙子",
      "speakerNameEn": "Haruko Saeki",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-haruko.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_hrk_14_01/sud_vo_adv_card_hrk_14_01-hrk023.m4a",
      "text": "でも、主人公の親友役をオーディションで決めるって\n聞いて、「これだ！」って思ったのよ",
