      "translations": {
        "en": "",
        "id": ""
      },
      "startTime": 238.4945894242,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "mna",
      "speakerName": "長瀬麻奈",
      "speakerNameEn": "Mana Nagase",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-mana.png",
