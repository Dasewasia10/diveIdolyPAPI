      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-mana.png",
      "voiceUrl": null,
      "text": "お芝居の練習なら相手役がいた方がいいよね",
      "translations": {
        "en": "",
        "id": ""
      },
      "startTime": 279.666392565,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "mna",
      "speakerName": "長瀬麻奈",
