      "text": "頑張ってる遙子ちゃんを、私は信じてる！",
      "translations": {
        "en": "",
        "id": ""
      },
      "startTime": 320.6146651069,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "hrk",
      "speakerName": "佐伯遙子",
