      "text": "歌とダンスを人一倍頑張ってるじゃない",
      "translations": {
        "en": "",
        "id": ""
      },
      "startTime": 312.569135679,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "mna",
      "speakerName": "長瀬麻奈",
      "speakerNameEn": "Mana Nagase",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-mana.png",
      "voiceUrl": null,
      "text": "遙子ちゃんが頑張ってること、私はちゃんと知ってるよ",
      "translations": {
        "en": "",
        "id": ""
      },
      "startTime": 315.8705556713,
      "sfxList": []
    },
    {
