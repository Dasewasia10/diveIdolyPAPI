      "speakerCode": "mna",
      "speakerName": "長瀬麻奈",
      "speakerNameEn": "Mana Nagase",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-mana.png",
      "voiceUrl": null,
      "text": "私もいろいろ不安だったんだ",
      "translations": {
        "en": "",
        "id": ""
      },
      "startTime": 254.7434957296,
