      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-mana.png",
      "voiceUrl": null,
      "text": "こんなに頑張ってるの？",
      "translations": {
        "en": "",
        "id": ""
      },
      "startTime": 235.9767058131,
      "sfxList": []
    },
