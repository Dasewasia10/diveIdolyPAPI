    },
    {
      "type": "dialogue",
      "speakerCode": null,
      "speakerName": "",
      "speakerNameEn": "",
      "iconUrl": null,
      "voiceUrl": null,
      "text": "――新しい名刺が莉央に差し出される",
      "translations": {
        "en": "――and hand a new business card to Rio.",
        "id": ""
      },
      "startTime": 161.56666666666666,
      "sfxList": []
