      "speakerCode": null,
      "speakerName": "",
      "speakerNameEn": "",
      "iconUrl": null,
      "voiceUrl": null,
      "text": "――去り際、莉央は落とした名刺を拾った",
      "translations": {
        "en": "――As she leaves‚ Rio picks up the business card she dropped.",
        "id": ""
      },
