      "sfxList": [
        {
          "src": "https://apiip.dasewasia.my.id/storyBgm/sud_se_adv_walk-out-single-01.m4a",
          "delay": 5299.999999999997,
          "startTime": 93.9666666667
        }
      ]
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_shibuya-00-noon.webp",
      "bgName": "shibuya-00-noon",
      "startTime": 93.4386004555
    },
    {
      "type": "dialogue",
      "speakerCode": "rei",
      "speakerName": "一ノ瀬怜",
      "speakerNameEn": "一ノ瀬怜",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-rei.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_rei_12_02/sud_vo_adv_card_rei_12_02-rei009.m4a",
      "text": "車の走る音も、街に流れる音楽も、何も聞こえない……\n人がいない街って、気味が悪いですね……",
      "translations": {
        "en": "車の走る音も、街に流れる音楽も、何も聞こえない……\n人がいない街って、気味が悪いですね……",
        "id": ""
      },
      "startTime": 101.733337911,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "koh",
      "speakerName": "{user}",
      "speakerNameEn": "{user}",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-makino.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_rei_12_02/sud_vo_adv_card_rei_12_02-koh006.m4a",
      "text": "随分歩いたが、ここまで一人もすれ違わなかったな……\nいや、そもそも、駅ってこんなに遠かったか？",
      "translations": {
        "en": "随分歩いたが、ここまで一人もすれ違わなかったな……\nいや、そもそも、駅ってこんなに遠かったか？",
        "id": ""
      },
      "startTime": 110.6333333333,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_shibuya-00-noon.webp",
      "bgName": "shibuya-00-noon",
      "startTime": 116.0411243547
    },
    {
      "type": "dialogue",
      "speakerCode": "rei",
      "speakerName": "一ノ瀬怜",
      "speakerNameEn": "一ノ瀬怜",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-rei.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_rei_12_02/sud_vo_adv_card_rei_12_02-rei010.m4a",
      "text": "確かに、とっくに着いていいはずですが……\nあら？　あそこのお店、さっきも見ませんでしたか？",
      "translations": {
        "en": "確かに、とっくに着いていいはずですが……\nあら？　あそこのお店、さっきも見ませんでしたか？",
        "id": ""
      },
      "startTime": 122.0333333333,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_shibuya-00-noon.webp",
      "bgName": "shibuya-00-noon",
      "startTime": 127.4336869031
    },
    {
      "type": "dialogue",
      "speakerCode": "rei",
      "speakerName": "一ノ瀬怜",
      "speakerNameEn": "一ノ瀬怜",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-rei.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_rei_12_02/sud_vo_adv_card_rei_12_02-rei011.m4a",
      "text": "お店だけじゃない……ここの景色、見覚えがあります\nもしかして、同じ場所に戻って来た……？",
      "translations": {
        "en": "お店だけじゃない……ここの景色、見覚えがあります\nもしかして、同じ場所に戻って来た……？",
        "id": ""
      },
      "startTime": 134.7666666667,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "koh",
      "speakerName": "{user}",
      "speakerNameEn": "{user}",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-makino.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_rei_12_02/sud_vo_adv_card_rei_12_02-koh007.m4a",
      "text": "まさか、同じ所をぐるぐると歩き回っていたのか！？\n俺達は閉鎖された空間に閉じ込められている……？",
      "translations": {
        "en": "まさか、同じ所をぐるぐると歩き回っていたのか！？\n俺達は閉鎖された空間に閉じ込められている……？",
        "id": ""
      },
      "startTime": 143.2,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_shibuya-00-noon.webp",
      "bgName": "shibuya-00-noon",
      "startTime": 147.3369157584
    },
    {
      "type": "dialogue",
      "speakerCode": "rei",
      "speakerName": "一ノ瀬怜",
      "speakerNameEn": "一ノ瀬怜",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-rei.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_rei_12_02/sud_vo_adv_card_rei_12_02-rei012.m4a",
      "text": "閉鎖された空間って……どういうことですか！？\n私達、ここから出られないんですか？",
      "translations": {
        "en": "閉鎖された空間って……どういうことですか！？\n私達、ここから出られないんですか？",
        "id": ""
      },
      "startTime": 152.5,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_shibuya-00-noon.webp",
      "bgName": "shibuya-00-noon",
      "startTime": 158.3333323161
    },
    {
      "type": "dialogue",
      "speakerCode": "rei",
      "speakerName": "一ノ瀬怜",
      "speakerNameEn": "一ノ瀬怜",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-rei.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_rei_12_02/sud_vo_adv_card_rei_12_02-rei013.m4a",
      "text": "……ひょっとして、私のせい？\n私がハルヒにもう一度会いたいと願ったから……",
      "translations": {
        "en": "……ひょっとして、私のせい？\n私がハルヒにもう一度会いたいと願ったから……",
        "id": ""
      },
      "startTime": 162.9333323161,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "rei",
      "speakerName": "一ノ瀬怜",
      "speakerNameEn": "一ノ瀬怜",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-rei.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_rei_12_02/sud_vo_adv_card_rei_12_02-rei014.m4a",
      "text": "いるはずのないハルヒを追いかけたりしたから\nこんな場所に迷い込んでしまったんじゃ……",
      "translations": {
        "en": "いるはずのないハルヒを追いかけたりしたから\nこんな場所に迷い込んでしまったんじゃ……",
        "id": ""
      },
      "startTime": 169.9666697184,
      "sfxList": []
    },
    {
