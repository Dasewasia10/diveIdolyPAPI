      "startTime": 47.6999994914,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "rei",
      "speakerName": "一ノ瀬怜",
      "speakerNameEn": "一ノ瀬怜",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-rei.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_rei_12_02/sud_vo_adv_card_rei_12_02-rei006.m4a",
      "text": "周りを見て下さい、私達の他に誰も人がいません\nさっきまで沢山の人が歩いていたのに……",
      "translations": {
        "en": "周りを見て下さい、私達の他に誰も人がいません\nさっきまで沢山の人が歩いていたのに……",
        "id": ""
