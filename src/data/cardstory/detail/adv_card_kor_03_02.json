      "speakerCode": "koh",
      "speakerName": "{user}",
      "speakerNameEn": "{user}",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-makino.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_kor_03_02/sud_vo_adv_card_kor_03_02-koh014.m4a",
      "text": "どうも…………",
      "translations": {
        "en": "Thank you…",
