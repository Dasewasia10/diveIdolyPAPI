      "speakerName": "fran",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-fran.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_kor_03_03/sud_vo_adv_card_kor_03_03-kor020.m4a",
      "text": "あ、{user}さんはもういいです\n話長いから",
