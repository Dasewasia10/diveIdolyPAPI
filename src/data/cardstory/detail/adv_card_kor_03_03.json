      "text": "franさん\nそんなにサニピを買ってくれてたんですか",
      "startTime": 128.8666646321,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_antique-00-noon.webp",
      "bgName": "antique-00-noon",
      "startTime": 131.4999979655
    },
    {
