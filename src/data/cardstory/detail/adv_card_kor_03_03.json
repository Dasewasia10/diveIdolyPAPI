      "text": "それがなんだったのかは、少しだけ興味がわきました",
      "startTime": 164.7666656495,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "koh",
      "speakerName": "{user}",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-makino.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_kor_03_03/sud_vo_adv_card_kor_03_03-koh009.m4a",
      "text": "それなら……",
