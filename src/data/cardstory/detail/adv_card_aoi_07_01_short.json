{
  "id": "adv_card_aoi_07_01_short",
  "title": "井川葵 (Short)",
  "script": [
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_office-01-noon.webp",
      "bgName": "3d_way_noon",
