      "text": "そうですか……ふむふむ\n幽霊は苦手ですか？",
      "translations": {
        "en": "Okay. Hmmm.\nAre you scared of ghosts?",
        "id": ""
      },
      "startTime": 187.3,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "koh",
      "speakerName": "{user}",
      "speakerNameEn": "{user}",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-makino.png",
