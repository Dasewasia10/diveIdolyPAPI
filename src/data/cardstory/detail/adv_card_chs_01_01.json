      "text": "そうだな……特にこだわりはないかな",
      "translations": {
        "en": "Well… I’m fine with either.",
        "id": ""
      },
      "startTime": 180,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "chs",
      "speakerName": "白石千紗",
      "speakerNameEn": "Chisa",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-chisa.png",
