      "iconUrl": null,
      "voiceUrl": null,
      "text": "――仕事後の帰り道",
      "translations": {
        "en": "―― On the way home after work",
        "id": ""
      },
      "startTime": 0,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_tokyotown-00-night.webp",
      "bgName": "tokyotown-00-night",
