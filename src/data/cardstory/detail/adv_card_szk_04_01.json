      "startTime": 249.0666666667,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "szk",
      "speakerName": "兵藤雫",
      "speakerNameEn": "Shizuku",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-shizuku.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_szk_04_01/sud_vo_adv_card_szk_04_01-szk026.m4a",
      "text": "私には難しそう、だけど……やってみたい……",
      "translations": {
        "en": "It seems difficult for me‚ but… I want to give it a shot…",
        "id": ""
      },
      "startTime": 251.6,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "szk",
      "speakerName": "兵藤雫",
      "speakerNameEn": "Shizuku",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-shizuku.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_szk_04_01/sud_vo_adv_card_szk_04_01-szk027.m4a",
      "text": "スリクスやリズノワみたいな\nかっこいいアイドルに、挑戦してみたい……！",
      "translations": {
