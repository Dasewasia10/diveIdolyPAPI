      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "szk",
      "speakerName": "兵藤雫",
      "speakerNameEn": "Shizuku",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-shizuku.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_szk_04_01/sud_vo_adv_card_szk_04_01-szk028.m4a",
      "text": "今はまだ……\nスリクスに声を掛ける勇気はないけど……",
      "translations": {
