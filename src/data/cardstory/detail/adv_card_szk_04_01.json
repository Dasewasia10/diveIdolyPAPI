      "text": "スリクスやリズノワみたいな\nかっこいいアイドルに、挑戦してみたい……！",
      "startTime": 259.8333333333,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "szk",
      "speakerName": "兵藤雫",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-shizuku.png",
