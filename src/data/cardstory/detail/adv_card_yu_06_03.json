    {
      "type": "dialogue",
      "speakerCode": "yu",
      "speakerName": "鈴村優",
      "speakerNameEn": "Yu",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-yu.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_yu_06_03/sud_vo_adv_card_yu_06_03-yu014.m4a",
      "text": "もう楽屋入りやから、うちらは行きますね\n{user}さんもお仕事頑張ってなぁ",
      "translations": {
        "en": "Well‚ we're heading to the dressing room now.\n{user}-san‚ good luck with your work too.",
