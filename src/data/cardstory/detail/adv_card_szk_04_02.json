          "startTime": 120.8
        }
      ]
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_tokyoentrance-00-noon.webp",
      "bgName": "tokyoentrance-00-noon",
      "startTime": 120.8
    },
    {
      "type": "dialogue",
      "speakerCode": "koh",
      "speakerName": "{user}",
      "speakerNameEn": "{user}",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-makino.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_szk_04_02/sud_vo_adv_card_szk_04_02-koh008.m4a",
      "text": "これから出かけるみたいだな\nそして、三人の後ろをこそこそ歩いているのは……",
      "translations": {
        "en": "Seems like they're about to go somewhere.\nAnd the one sneaking behind the three…",
        "id": ""
      },
      "startTime": 123.3,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_tokyoentrance-00-noon.webp",
      "bgName": "tokyoentrance-00-noon",
      "startTime": 128.2333333333
    },
    {
      "type": "dialogue",
      "speakerCode": "szk",
      "speakerName": "兵藤雫",
      "speakerNameEn": "Shizuku",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-shizuku.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_szk_04_02/sud_vo_adv_card_szk_04_02-szk015.m4a",
      "text": "……はっ！　{user}さん……！",
      "translations": {
        "en": "…Ha! {user}-san…!",
        "id": ""
      },
      "startTime": 128.2333333333,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_tokyoentrance-00-noon.webp",
      "bgName": "tokyoentrance-00-noon",
      "startTime": 130.4666666667
    },
    {
      "type": "dialogue",
      "speakerCode": "koh",
      "speakerName": "{user}",
      "speakerNameEn": "{user}",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-makino.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_szk_04_02/sud_vo_adv_card_szk_04_02-koh009.m4a",
      "text": "雫？　そこで何をしているんだ？",
      "translations": {
        "en": "Shizuku? What are you doing there?",
        "id": ""
      },
      "startTime": 130.4666666667,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "szk",
      "speakerName": "兵藤雫",
      "speakerNameEn": "Shizuku",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-shizuku.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_szk_04_02/sud_vo_adv_card_szk_04_02-szk016.m4a",
      "text": "今は話し掛けないで……\n尾行してるのがバレる",
      "translations": {
        "en": "Please don't talk to me right now…\nThey'll notice I'm tailing them.",
        "id": ""
      },
      "startTime": 135.9666666667,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_tokyoentrance-00-noon.webp",
      "bgName": "tokyoentrance-00-noon",
      "startTime": 138.3666666667
    },
    {
      "type": "dialogue",
      "speakerCode": "szk",
      "speakerName": "兵藤雫",
      "speakerNameEn": "Shizuku",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-shizuku.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_szk_04_02/sud_vo_adv_card_szk_04_02-szk017.m4a",
      "text": "私はどうしても、かっこ良さの秘訣を知りたい\nだからスリクスを観察してる……",
      "translations": {
        "en": "I really want to know the secret of being cool.\nThat's why I'm observing IIIX…",
        "id": ""
      },
      "startTime": 142.5,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "koh",
      "speakerName": "{user}",
      "speakerNameEn": "{user}",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-makino.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_szk_04_02/sud_vo_adv_card_szk_04_02-koh010.m4a",
      "text": "それなら直接話を聞けばいいじゃないか",
      "translations": {
        "en": "If that's the case‚ why don't you just talk to them directly?",
        "id": ""
      },
      "startTime": 145.4,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_tokyoentrance-00-noon.webp",
      "bgName": "tokyoentrance-00-noon",
      "startTime": 148.6666666667
    },
    {
      "type": "dialogue",
      "speakerCode": "szk",
      "speakerName": "兵藤雫",
      "speakerNameEn": "Shizuku",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-shizuku.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_szk_04_02/sud_vo_adv_card_szk_04_02-szk018.m4a",
      "text": "無理。スリクスは憧れの存在……\n目が合っただけで緊張する……",
      "translations": {
        "en": "Impossible. IIIX is like an aspiration…\nI get nervous just from making eye contact…",
        "id": ""
      },
      "startTime": 151.8666666667,
      "sfxList": []
    },
    {
      "type": "background",
