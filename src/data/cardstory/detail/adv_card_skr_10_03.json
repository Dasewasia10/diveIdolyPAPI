      "text": "……え、クマと言うよりオオカミの遠吠え？\nた、確かに……！",
      "startTime": 105.7000035605,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "skr",
      "speakerName": "川咲さくら",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-sakura.png",
