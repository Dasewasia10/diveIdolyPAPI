    {
      "type": "dialogue",
      "speakerCode": "ktn",
      "speakerName": "長瀬琴乃",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-kotono.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_ktn_11_03/sud_vo_adv_card_ktn_11_03-ktn007.m4a",
      "text": "こ、このままだと{user}さんと\n一生繋がれたまま……ご飯の時も、ね、寝る時も！？",
      "startTime": 85.3023127556,
      "sfxList": [
        {
          "src": "https://apiip.dasewasia.my.id/storyBgm/sud_se_adv_handcuffs-01.m4a",
