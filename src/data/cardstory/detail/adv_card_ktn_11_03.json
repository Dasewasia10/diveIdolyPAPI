    {
      "type": "dialogue",
      "speakerCode": "ktn",
      "speakerName": "長瀬琴乃",
      "speakerNameEn": "Kotono",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-kotono.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_ktn_11_03/sud_vo_adv_card_ktn_11_03-ktn011.m4a",
      "text": "まさか、追いかけていたあなたに\n私が逆に捕まってしまうなんて……",
      "translations": {
        "en": "I can't believe I got caught by you‚\nthe person I was chasing…",
        "id": ""
      },
