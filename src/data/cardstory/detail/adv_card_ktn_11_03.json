      ]
    },
    {
      "type": "dialogue",
      "speakerCode": "koh",
      "speakerName": "{user}",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-makino.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_ktn_11_03/sud_vo_adv_card_ktn_11_03-koh005.m4a",
      "text": "いやいや、さすがにそうなったら鍵の業者を……？\nなぁ、今気付いたんだが、この手錠のボタンはなんだ？",
      "startTime": 96.6706137975,
      "sfxList": [
        {
          "src": "https://apiip.dasewasia.my.id/storyBgm/sud_se_adv_handcuffs-01.m4a",
