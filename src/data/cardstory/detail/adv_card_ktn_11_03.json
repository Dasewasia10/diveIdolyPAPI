      "bgName": "tokyoentrance-00-noon"
    },
    {
      "type": "dialogue",
      "speakerCode": "ktn",
      "speakerName": "長瀬琴乃",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-kotono.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_ktn_11_03/sud_vo_adv_card_ktn_11_03-ktn006.m4a",
      "text": "でも、助かりましたね。本当にひやひやしました\nただ、これだけ探しても鍵が見つからないなんて……",
      "startTime": 77.8023127556,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_tokyoentrance-00-noon.webp",
