      "text": "{user}さんが寂しくて泣いちゃうかも\nそう考えたら可哀想に思えて……",
      "startTime": 33.7666667383,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "koh",
      "speakerName": "{user}",
