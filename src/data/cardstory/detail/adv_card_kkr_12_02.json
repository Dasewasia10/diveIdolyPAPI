    },
    {
      "type": "dialogue",
      "speakerCode": "koh",
      "speakerName": "{user}",
      "speakerNameEn": "{user}",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-makino.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_kkr_12_02/sud_vo_adv_card_kkr_12_02-koh015.m4a",
      "text": "（こころ……ずっと愛を待っていたな……）\n（スタジオの隅で誰とも会話せずに……）",
      "translations": {
        "en": "（Kokoro… was waiting for Ai all this time…）\n（Without talking to anyone in the corner of the studio…）",
        "id": ""
