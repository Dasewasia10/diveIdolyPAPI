      "text": "待ち切れないのはこころの方だろう？\n撮影までまだ時間があるのに随分早く来たじゃないか",
      "startTime": 11.6333334049,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "koh",
      "speakerName": "{user}",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-makino.png",
