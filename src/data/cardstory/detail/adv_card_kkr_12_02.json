      "text": "俺は子供じゃないんだぞ……\nまぁ、ありがとう、待たせて悪かった",
      "startTime": 39.9641470463,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_tokyotown-00-noon.webp",
      "bgName": "tokyotown-00-noon"
    },
    {
      "type": "dialogue",
      "speakerCode": "kkr",
      "speakerName": "赤崎こころ",
