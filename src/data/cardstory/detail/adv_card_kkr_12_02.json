      "startTime": 292.0000077009,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_photostudio-00-noon.webp",
      "bgName": "photostudio-00-noon",
      "startTime": 297.0000077009
    },
    {
      "type": "dialogue",
      "speakerCode": "koh",
      "speakerName": "{user}",
      "speakerNameEn": "{user}",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-makino.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_kkr_12_02/sud_vo_adv_card_kkr_12_02-koh017.m4a",
