      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_kkr_12_02/sud_vo_adv_card_kkr_12_02-kkr004.m4a",
      "text": "感謝して下さいよ～？\nそれじゃお礼にオフショを撮って下さい！",
      "startTime": 45.9666667383,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "koh",
      "speakerName": "{user}",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-makino.png",
