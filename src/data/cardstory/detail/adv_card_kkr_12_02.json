      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_kkr_12_02/sud_vo_adv_card_kkr_12_02-kkr006.m4a",
      "text": "それに外での撮影の方がこの衣装は合うと思うんです\nいや、むしろ外で撮るべきです！　もったいないです！",
      "startTime": 67.9000000716,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "kkr",
      "speakerName": "赤崎こころ",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-kokoro.png",
