      "startTime": 265.3999954939
    },
    {
      "type": "dialogue",
      "speakerCode": "kkr",
      "speakerName": "赤崎こころ",
      "speakerNameEn": "Kokoro",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-kokoro.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_kkr_12_02/sud_vo_adv_card_kkr_12_02-kkr023.m4a",
      "text": "そう、ですか……愛ちゃん……\nやっぱり、来れないんだ……そっか……",
      "translations": {
        "en": "I see… Ai-chan…\nAfter all‚ she couldn't make it… I see…",
        "id": ""
