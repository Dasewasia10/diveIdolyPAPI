      "speakerCode": "kkr",
      "speakerName": "赤崎こころ",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-kokoro.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_kkr_12_02/sud_vo_adv_card_kkr_12_02-kkr002.m4a",
      "text": "その通りです。{user}さんがスタジオで\nこころを見つけられなかったら大変ですからね",
      "startTime": 27.2000000716,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_tokyotown-00-noon.webp",
