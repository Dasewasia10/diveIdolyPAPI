    {
      "type": "dialogue",
      "speakerCode": "chs",
      "speakerName": "白石千紗",
      "speakerNameEn": "白石千紗",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-chisa.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_chs_10_01/sud_vo_adv_card_chs_10_01-chs017.m4a",
      "text": "グレイ型にタコ型……宇宙人ってこんなにいるんだ……\n海外には宇宙人を管理する施設があるって本当なのかな",
      "translations": {
        "en": "グレイ型にタコ型……宇宙人ってこんなにいるんだ……\n海外には宇宙人を管理する施設があるって本当なのかな",
        "id": ""
      },
      "startTime": 182.3333379109,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "koh",
      "speakerName": "{user}",
      "speakerNameEn": "{user}",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-makino.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_chs_10_01/sud_vo_adv_card_chs_10_01-koh007.m4a",
      "text": "ち、千紗？　その机の上に積まれている大量の本は\n一体なんなんだ？",
      "translations": {
        "en": "ち、千紗？　その机の上に積まれている大量の本は\n一体なんなんだ？",
        "id": ""
      },
      "startTime": 193.1333379109,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "chs",
      "speakerName": "白石千紗",
      "speakerNameEn": "白石千紗",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-chisa.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_chs_10_01/sud_vo_adv_card_chs_10_01-chs018.m4a",
      "text": "あ、{user}さん！\nすみません、勝手に本を持ち込んでしまって",
      "translations": {
        "en": "あ、{user}さん！\nすみません、勝手に本を持ち込んでしまって",
        "id": ""
      },
      "startTime": 197.3666712443,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "chs",
      "speakerName": "白石千紗",
      "speakerNameEn": "白石千紗",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-chisa.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_chs_10_01/sud_vo_adv_card_chs_10_01-chs019.m4a",
      "text": "これはですね、宇宙人についてまとめられた資料を\n図書館で沢山借りてきたんです",
      "translations": {
