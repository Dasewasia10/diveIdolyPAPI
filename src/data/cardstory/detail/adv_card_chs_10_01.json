      "startTime": 146.0999984741,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "chs",
      "speakerName": "白石千紗",
      "speakerNameEn": "白石千紗",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-chisa.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_chs_10_01/sud_vo_adv_card_chs_10_01-chs014.m4a",
      "text": "確かに、ちょっと不思議な部分は多いんですけど\nあんまり夢っぽさは感じなかったんですよね",
      "translations": {
        "en": "確かに、ちょっと不思議な部分は多いんですけど\nあんまり夢っぽさは感じなかったんですよね",
        "id": ""
      },
      "startTime": 154.0333368937,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "chs",
      "speakerName": "白石千紗",
      "speakerNameEn": "白石千紗",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-chisa.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_chs_10_01/sud_vo_adv_card_chs_10_01-chs015.m4a",
      "text": "むしろすっごくリアリティがあったんです\n何があったのかも鮮明に覚えていますし……",
      "translations": {
        "en": "むしろすっごくリアリティがあったんです\n何があったのかも鮮明に覚えていますし……",
        "id": ""
