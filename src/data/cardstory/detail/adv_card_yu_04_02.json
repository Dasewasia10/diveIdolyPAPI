      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_yu_04_02/sud_vo_adv_card_yu_04_02-koh006.m4a",
      "text": "（いつのまにか、俺も時々カメラに映ってる……）\n（スタッフいじりは勘弁してほしいな……）",
      "startTime": 145.4150255839,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_kyoto-00-noon.webp",
