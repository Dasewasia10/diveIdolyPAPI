    {
      "type": "dialogue",
      "speakerCode": "yu",
      "speakerName": "鈴村優",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-yu.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_yu_10_03/sud_vo_adv_card_yu_10_03-yu015.m4a",
      "text": "ほなうちが、じっくりたっぷり介抱してあげますね\nこれも演技の練習ですから、ほらほら",
      "startTime": 272.5000008265,
      "sfxList": []
