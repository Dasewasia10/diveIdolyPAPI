      "startTime": 216.8333422978,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "koh",
      "speakerName": "{user}",
      "speakerNameEn": "{user}",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-makino.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_yu_10_03/sud_vo_adv_card_yu_10_03-koh008.m4a",
      "text": "優が人一倍周りに気を遣っていることも\nどこかで息抜きしたいんだってことも分かってるさ",
      "translations": {
        "en": "I know that you're more considerate of others than most‚\nand that you want to relax somewhere.",
        "id": ""
      },
      "startTime": 223.4666756312,
      "sfxList": []
    },
    {
      "type": "background",
