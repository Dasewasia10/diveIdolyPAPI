      "text": "ええっ……！？\nええっ……！？",
      "startTime": 26.5666670481,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": null,
      "speakerName": "",
      "iconUrl": null,
      "voiceUrl": null,
      "text": "――星見プロ誕生日慰安旅行in山梨",
      "startTime": 28.6287578619,
