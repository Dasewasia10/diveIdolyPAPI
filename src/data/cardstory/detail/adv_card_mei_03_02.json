      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_mei_03_02/sud_vo_adv_card_mei_03_02-mei001.m4a",
      "text": "やっぱり！　見て見てあそこのモニター！\nサニピの映像だ！",
      "startTime": 6.1666666684,
      "sfxList": []
    },
    {
      "type": "background",
