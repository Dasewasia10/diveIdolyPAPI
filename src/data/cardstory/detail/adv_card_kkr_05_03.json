      "text": "ああ、分かった。それじゃあいくぞ、はい、チーズ",
      "startTime": 216.8666666667,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "kkr",
      "speakerName": "赤崎こころ",
