      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-makino.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_suz_03_02/sud_vo_adv_card_suz_03_02-koh014.m4a",
      "text": "すず？　さっきから何をぶつぶつ言ってるんだ？",
      "startTime": 342.6666666667,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "suz",
