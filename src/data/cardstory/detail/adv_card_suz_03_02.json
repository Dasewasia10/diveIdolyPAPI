      "text": "もちろんやりますわ！",
      "startTime": 260.4333333333,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "suz",
      "speakerName": "成宮すず",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-suzu.png",
