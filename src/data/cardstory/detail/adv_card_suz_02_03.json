          "delay": 1633.3333333333328,
          "startTime": 14
        }
      ]
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_okinawabeach-00-noon.webp",
      "bgName": "summerfes-00-noon",
      "startTime": 15.6666666666667
    },
    {
      "type": "dialogue",
      "speakerCode": "koh",
      "speakerName": "{user}",
      "speakerNameEn": "{user}",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-makino.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_suz_02_03/sud_vo_adv_card_suz_02_03-koh002.m4a",
      "text": "えっ、海から声が？\nもしかして沖に流されてるのか！？　大変だ！",
      "translations": {
        "en": "Eh? She’s calling from the sea?\nDid she get swept out to sea? This is terrible!",
        "id": ""
      },
      "startTime": 18.8,
      "sfxList": [
        {
          "src": "https://apiip.dasewasia.my.id/storyBgm/sud_se_adv_run-coast-single-01.m4a",
          "delay": 1866.6666666666672,
          "startTime": 20.666666666666668
        },
        {
          "src": "https://apiip.dasewasia.my.id/storyBgm/sud_se_adv_water-pacha-01.m4a",
          "delay": 3300.000000000001,
          "startTime": 22.1
        },
        {
          "src": "https://apiip.dasewasia.my.id/storyBgm/sud_se_adv_water-pacha-01.m4a",
          "delay": 3300.000000000001,
          "startTime": 22.1
        },
        {
          "src": "https://apiip.dasewasia.my.id/storyBgm/sud_se_adv_water-pacha-01.m4a",
          "delay": 3300.000000000001,
          "startTime": 22.1
        }
      ]
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_okinawabeach-00-noon.webp",
      "bgName": "summerfes-00-noon",
      "startTime": 23.9333333333333
    },
    {
      "type": "dialogue",
      "speakerCode": "suz",
      "speakerName": "成宮すず",
      "speakerNameEn": "Suzu",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-suzu.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_suz_02_03/sud_vo_adv_card_suz_02_03-suz002.m4a",
      "text": "はぁ、はぁ……やっと岸に戻れましたわ\n浮き輪で遊んでたら急に波にさらわれて驚きましたわ",
      "translations": {
        "en": "*huff* I finally made it back to shore.\nI was playing with the pool float and I got surprised by a sudden wave.",
        "id": ""
      },
      "startTime": 31.966666666666665,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_okinawabeach-00-noon.webp",
      "bgName": "summerfes-00-noon",
      "startTime": 37.4
    },
    {
      "type": "dialogue",
      "speakerCode": "koh",
      "speakerName": "{user}",
      "speakerNameEn": "{user}",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-makino.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_suz_02_03/sud_vo_adv_card_suz_02_03-koh003.m4a",
      "text": "はぁ、はぁ……驚いたのはこっちだ\nすずがどんどん遠くなっていくから焦ったぞ",
      "translations": {
        "en": "*huff* I’m the one who was surprised.\nI was panicking because you kept getting further away.",
        "id": ""
      },
      "startTime": 42.46666666666667,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "suz",
      "speakerName": "成宮すず",
      "speakerNameEn": "Suzu",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-suzu.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_suz_02_03/sud_vo_adv_card_suz_02_03-suz003.m4a",
      "text": "大袈裟ですわね",
      "translations": {
        "en": "You’re making this a bigger deal than it is.",
        "id": ""
      },
      "startTime": 46.53333333333333,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_okinawabeach-00-noon.webp",
      "bgName": "summerfes-00-noon",
      "startTime": 48.7666666666667
    },
    {
      "type": "dialogue",
      "speakerCode": "suz",
      "speakerName": "成宮すず",
      "speakerNameEn": "Suzu",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-suzu.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_suz_02_03/sud_vo_adv_card_suz_02_03-suz004.m4a",
      "text": "私を見つけるなり海に飛び込むなんて\n慌て過ぎじゃないかしら",
      "translations": {
        "en": "Jumping into the sea as soon as you saw me‚\nwas maybe a little too frantic.",
        "id": ""
      },
      "startTime": 51.733333333333334,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_okinawabeach-00-noon.webp",
      "bgName": "summerfes-00-noon",
      "startTime": 54
    },
    {
      "type": "dialogue",
      "speakerCode": "suz",
      "speakerName": "成宮すず",
      "speakerNameEn": "Suzu",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-suzu.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_suz_02_03/sud_vo_adv_card_suz_02_03-suz005.m4a",
      "text": "そんなに焦らなくても自力で泳いで戻れましたわよ",
      "translations": {
        "en": "I could have swam back on my own without all that fuss.",
        "id": ""
      },
      "startTime": 54,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "koh",
      "speakerName": "{user}",
      "speakerNameEn": "{user}",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-makino.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_suz_02_03/sud_vo_adv_card_suz_02_03-koh004.m4a",
      "text": "そうだとしても、万が一ってことがあるだろ\n頼むから俺の目の届く範囲からいなくならないでくれ",
      "translations": {
        "en": "Even so‚ something bad might have happened.\nPlease‚ just stay where I can see you.",
        "id": ""
      },
      "startTime": 62.2,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_okinawabeach-00-noon.webp",
      "bgName": "summerfes-00-noon",
      "startTime": 66.2
    },
    {
      "type": "dialogue",
      "speakerCode": "suz",
      "speakerName": "成宮すず",
      "speakerNameEn": "Suzu",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-suzu.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_suz_02_03/sud_vo_adv_card_suz_02_03-suz006.m4a",
      "text": "そんなに私のことを……",
      "translations": {
        "en": "You’re that worried about me…",
        "id": ""
      },
      "startTime": 66.2,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_okinawabeach-00-noon.webp",
      "bgName": "summerfes-00-noon",
      "startTime": 69.66666666666667
    },
    {
      "type": "dialogue",
      "speakerCode": "suz",
      "speakerName": "成宮すず",
      "speakerNameEn": "Suzu",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-suzu.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_suz_02_03/sud_vo_adv_card_suz_02_03-suz007.m4a",
      "text": "そ、そうですわね……\n心配させてしまって……そ、その……",
      "translations": {
        "en": "I-I guess so.\nWorrying you like that‚ I…",
        "id": ""
      },
      "startTime": 72.53333333333333,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_okinawabeach-00-noon.webp",
      "bgName": "summerfes-00-noon",
      "startTime": 77.26666666666667
    },
    {
      "type": "dialogue",
      "speakerCode": "koh",
      "speakerName": "{user}",
      "speakerNameEn": "{user}",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-makino.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_suz_02_03/sud_vo_adv_card_suz_02_03-koh005.m4a",
      "text": "反省してるならそれでいいんだ\nすずが無事でよかったよ",
      "translations": {
        "en": "If you understand what you did‚ that’s good enough.\nI’m just glad you’re alright‚ Suzu.",
        "id": ""
      },
      "startTime": 80,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "suz",
      "speakerName": "成宮すず",
      "speakerNameEn": "Suzu",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-suzu.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_suz_02_03/sud_vo_adv_card_suz_02_03-suz008.m4a",
      "text": "……{user}さんって\nたまにとても頼りになりますわね",
      "translations": {
        "en": "Sometimes‚ {user}-san‚\nyou’re really dependable.",
        "id": ""
      },
      "startTime": 84.56666666666666,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_okinawabeach-00-noon.webp",
      "bgName": "summerfes-00-noon",
      "startTime": 87.93333333333334
    },
    {
      "type": "dialogue",
      "speakerCode": "suz",
      "speakerName": "成宮すず",
      "speakerNameEn": "Suzu",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-suzu.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_suz_02_03/sud_vo_adv_card_suz_02_03-suz009.m4a",
      "text": "ちょっとだけ見直しましたわ",
      "translations": {
        "en": "I’m seeing you in a new light‚ just a little.",
        "id": ""
      },
      "startTime": 87.93333333333334,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_okinawabeach-00-noon.webp",
      "bgName": "summerfes-00-noon",
      "startTime": 90.4
    },
    {
      "type": "dialogue",
      "speakerCode": "koh",
      "speakerName": "{user}",
      "speakerNameEn": "{user}",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-makino.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_suz_02_03/sud_vo_adv_card_suz_02_03-koh006.m4a",
      "text": "たまにというのが気になるが……まぁいいか\nそれよりそろそろ帰る時間だ。みんなも待ってるぞ",
      "translations": {
        "en": "You could have left the “sometimes” out… but it’ll do.\nAnyway‚ it’s time to head home. Everyone’s waiting.",
        "id": ""
      },
      "startTime": 95.13333333333334,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_okinawabeach-00-noon.webp",
      "bgName": "summerfes-00-noon",
      "startTime": 99.3
    },
    {
      "type": "dialogue",
      "speakerCode": "suz",
      "speakerName": "成宮すず",
      "speakerNameEn": "Suzu",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-suzu.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_suz_02_03/sud_vo_adv_card_suz_02_03-suz010.m4a",
      "text": "そうですわね……",
      "translations": {
        "en": "Yeah‚ I guess so…",
        "id": ""
      },
      "startTime": 99.3,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "koh",
      "speakerName": "{user}",
      "speakerNameEn": "{user}",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-makino.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_suz_02_03/sud_vo_adv_card_suz_02_03-koh007.m4a",
      "text": "どうしたんだ？　何か気になることでもあるのか？",
      "translations": {
        "en": "What is it? Something on your mind?",
        "id": ""
      },
      "startTime": 101.46666666666667,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_okinawabeach-00-noon.webp",
      "bgName": "summerfes-00-noon",
      "startTime": 105.46666666666667
    },
    {
      "type": "dialogue",
      "speakerCode": "suz",
      "speakerName": "成宮すず",
      "speakerNameEn": "Suzu",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-suzu.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_suz_02_03/sud_vo_adv_card_suz_02_03-suz011.m4a",
      "text": "気になると言うか……\n帰る前にちゃんと謝っておきたくて",
      "translations": {
        "en": "Well…\nI want to apologize properly before we go back.",
        "id": ""
      },
      "startTime": 108,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_okinawabeach-00-noon.webp",
      "bgName": "summerfes-00-noon",
      "startTime": 111.16666666666667
    },
    {
      "type": "dialogue",
      "speakerCode": "suz",
      "speakerName": "成宮すず",
      "speakerNameEn": "Suzu",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-suzu.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_suz_02_03/sud_vo_adv_card_suz_02_03-suz012.m4a",
      "text": "海で遊びたいとわがままを言ったせいで\n迷惑をかけましたわよね",
      "translations": {
        "en": "I was being selfish because I wanted to have fun at the beach.\nI’m sorry for bothering you.",
        "id": ""
      },
      "startTime": 114.1,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "suz",
      "speakerName": "成宮すず",
      "speakerNameEn": "Suzu",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-suzu.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_suz_02_03/sud_vo_adv_card_suz_02_03-suz013.m4a",
      "text": "私のために無理をしてくれたのに\n私は自分のことしか考えてなかった",
      "translations": {
        "en": "You went out of your way for me‚\nand I was only thinking about myself.",
        "id": ""
      },
      "startTime": 119.3,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_okinawabeach-00-noon.webp",
      "bgName": "summerfes-00-noon",
      "startTime": 122.83333333333333
    },
    {
      "type": "dialogue",
      "speakerCode": "suz",
      "speakerName": "成宮すず",
      "speakerNameEn": "Suzu",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-suzu.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_suz_02_03/sud_vo_adv_card_suz_02_03-suz014.m4a",
      "text": "わがままばかり言って大人げなかったのですわ\nごめんなさい……",
      "translations": {
        "en": "Being selfish all the time was really immature.\nI’m sorry…",
        "id": ""
      },
      "startTime": 126.96666666666667,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_okinawabeach-00-noon.webp",
      "bgName": "summerfes-00-noon",
      "startTime": 126.96666666666667
    },
    {
      "type": "dialogue",
      "speakerCode": "koh",
      "speakerName": "{user}",
      "speakerNameEn": "{user}",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-makino.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_suz_02_03/sud_vo_adv_card_suz_02_03-koh008.m4a",
      "text": "それを言うなら俺の方こそ謝らないと\n毎日忙しくて息が詰まってたんだよな",
      "translations": {
        "en": "Come to that‚ I’m the one who should apologize.\nEvery day‚ you were too busy to catch a breath.",
        "id": ""
      },
      "startTime": 133.03333333333333,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "koh",
      "speakerName": "{user}",
      "speakerNameEn": "{user}",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-makino.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_suz_02_03/sud_vo_adv_card_suz_02_03-koh009.m4a",
      "text": "すずはまだ中学生なのに、いろいろなことを我慢させて\nすまなかった。気をつけるよ",
      "translations": {
        "en": "You’re still in middle school‚ but you’ve had to put up with a lot‚ Suzu.\nSorry. I’ll be more careful.",
        "id": ""
      },
      "startTime": 140.56666666666666,
      "sfxList": []
    },
    {
      "type": "background",
