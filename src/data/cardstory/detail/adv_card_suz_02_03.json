    },
    {
      "type": "dialogue",
      "speakerCode": "koh",
      "speakerName": "{user}",
      "speakerNameEn": "{user}",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-makino.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_suz_02_03/sud_vo_adv_card_suz_02_03-koh001.m4a",
      "text": "おーい、すず！　どこにいるんだ！\nおかしいな、さっきまでここにいたはずなのに",
      "translations": {
        "en": "Hey Suzu! Where are you!\nThat’s odd. She was here just a minute ago.",
        "id": ""
      },
      "startTime": 8.066666666666666,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "suz",
      "speakerName": "成宮すず",
      "speakerNameEn": "Suzu",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-suzu.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_suz_02_03/sud_vo_adv_card_suz_02_03-suz001.m4a",
      "text": "{user}さん、こっちですわ～！",
      "translations": {
        "en": "{user}-san‚ I’m over here!",
        "id": ""
      },
      "startTime": 12.366666666666667,
      "sfxList": [
        {
          "src": "https://apiip.dasewasia.my.id/storyBgm/sud_se_adv_water-pacha-01.m4a",
