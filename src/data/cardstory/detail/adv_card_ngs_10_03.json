      "speakerName": "伊吹渚",
      "speakerNameEn": "Nagisa",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-nagisa.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_ngs_10_03/sud_vo_adv_card_ngs_10_03-ngs018.m4a",
      "text": "{user}さんもよかったら\nお一つどうですか？",
      "translations": {
        "en": "Would you like some\n{user}-san?",
