      "speakerName": "川咲さくら",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-sakura.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_skr_06_01/sud_vo_adv_card_skr_06_01-skr005.m4a",
      "text": "はい！　今度のイベントで麻奈さんの曲を歌うことが\n決まって、気持ちがどんどん高まってます",
      "startTime": 47.3333381494,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "skr",
      "speakerName": "川咲さくら",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-sakura.png",
