      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_mhk_07_03/sud_vo_adv_card_mhk_07_03-mhk002.m4a",
      "text": "あ、やっと来た\n{user}さ……ん……？",
      "startTime": 10.8,
      "sfxList": [
        {
          "src": "https://apiip.dasewasia.my.id/storyBgm/sud_se_adv_walk-in-single-02.m4a",
