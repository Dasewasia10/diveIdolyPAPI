          "delay": 3713.1841897,
          "startTime": 14.5131841897
        }
      ]
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_photostudio-00-noon.webp",
      "bgName": "photostudio-00-noon"
    },
    {
      "type": "dialogue",
      "speakerCode": "koh",
      "speakerName": "{user}",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-makino.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_mhk_07_03/sud_vo_adv_card_mhk_07_03-koh001.m4a",
      "text": "えぇ、ちょ、mihoさん？\n突然引っ張ってどこに……！？",
      "startTime": 17.5814049403,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_dressingroom-00-noon.webp",
      "bgName": "dressingroom-00-noon"
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_dressingroom-00-noon.webp",
      "bgName": "dressingroom-00-noon"
    },
    {
      "type": "dialogue",
      "speakerCode": "mhk",
      "speakerName": "miho",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-miho.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_mhk_07_03/sud_vo_adv_card_mhk_07_03-mhk003.m4a",
      "text": "{user}さん、その頭……\n一体どういうことですか",
      "startTime": 25.7999995549,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "koh",
      "speakerName": "{user}",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-makino.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_mhk_07_03/sud_vo_adv_card_mhk_07_03-koh002.m4a",
      "text": "mihoさんに言われた通りセットして来ました\nどうですか？　結構いい感じに……",
      "startTime": 30.9666662216,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_dressingroom-00-noon.webp",
      "bgName": "dressingroom-00-noon"
    },
    {
      "type": "dialogue",
      "speakerCode": "mhk",
      "speakerName": "miho",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-miho.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_mhk_07_03/sud_vo_adv_card_mhk_07_03-mhk004.m4a",
      "text": "……どうして角刈りになっているのかって\n聞いてるのよ！",
      "startTime": 36.4999995549,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "koh",
      "speakerName": "{user}",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-makino.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_mhk_07_03/sud_vo_adv_card_mhk_07_03-koh003.m4a",
      "text": "えぇっ！？　さすがにちょっと攻め過ぎましたかね？\n少し冒険しちゃったかなとは思ってたんですが",
      "startTime": 41.5999995549,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_dressingroom-00-noon.webp",
      "bgName": "dressingroom-00-noon"
    },
    {
      "type": "dialogue",
      "speakerCode": "mhk",
      "speakerName": "miho",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-miho.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_mhk_07_03/sud_vo_adv_card_mhk_07_03-mhk005.m4a",
      "text": "違います。あんなオシャレな美容院で\nどうやったら角刈りになるんですか！？",
      "startTime": 48.1666680018,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "mhk",
      "speakerName": "miho",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-miho.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_mhk_07_03/sud_vo_adv_card_mhk_07_03-mhk006.m4a",
      "text": "角刈りって……\nよりによって角刈りって……",
      "startTime": 52.5999995549,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_dressingroom-00-noon.webp",
      "bgName": "dressingroom-00-noon"
    },
    {
      "type": "dialogue",
      "speakerCode": "mhk",
      "speakerName": "miho",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-miho.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_mhk_07_03/sud_vo_adv_card_mhk_07_03-mhk007.m4a",
      "text": "こんなに角刈りが似合わない人、初めて見ました\n全国の角刈りの人に謝ってきて下さい",
      "startTime": 59.1666662216,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "koh",
      "speakerName": "{user}",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-makino.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_mhk_07_03/sud_vo_adv_card_mhk_07_03-koh004.m4a",
      "text": "そ、そんな無茶な……",
      "startTime": 62.1333350021,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_dressingroom-00-noon.webp",
      "bgName": "dressingroom-00-noon"
    },
    {
      "type": "dialogue",
      "speakerCode": "mhk",
      "speakerName": "miho",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-miho.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_mhk_07_03/sud_vo_adv_card_mhk_07_03-mhk008.m4a",
      "text": "そもそも、セットしてくるだけって言ってましたよね？\nそれがどうしてこうなったんですか？",
      "startTime": 68.5666644414,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_dressingroom-00-noon.webp",
      "bgName": "dressingroom-00-noon"
    },
    {
      "type": "dialogue",
      "speakerCode": "koh",
      "speakerName": "{user}",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-makino.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_mhk_07_03/sud_vo_adv_card_mhk_07_03-koh005.m4a",
      "text": "俺でもセット出来るような髪型に整えてもらっていたら\nこの髪型になったんです",
      "startTime": 74.1333311081,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "mhk",
      "speakerName": "miho",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-miho.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_mhk_07_03/sud_vo_adv_card_mhk_07_03-mhk009.m4a",
      "text": "……意味が分かりません\nまったく……一人で美容院もろくに行けないなんて",
      "startTime": 79.2000003179,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_dressingroom-00-noon.webp",
      "bgName": "dressingroom-00-noon"
    },
    {
      "type": "dialogue",
      "speakerCode": "koh",
      "speakerName": "{user}",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-makino.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_mhk_07_03/sud_vo_adv_card_mhk_07_03-koh006.m4a",
      "text": "そんなにダメですかね……\n俺としてはこの髪型も結構……",
      "startTime": 86.5333336513,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_dressingroom-00-noon.webp",
      "bgName": "dressingroom-00-noon"
    },
    {
      "type": "dialogue",
      "speakerCode": "mhk",
      "speakerName": "miho",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-miho.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_mhk_07_03/sud_vo_adv_card_mhk_07_03-mhk010.m4a",
      "text": "黙って下さい\n仕方ありません、もう撮影が始まってしまいます",
      "startTime": 90.9666669846,
      "sfxList": [
        {
          "src": "https://apiip.dasewasia.my.id/storyBgm/sud_se_adv_gasa-02.m4a",
          "delay": 5866.666668400001,
          "startTime": 96.833333653
        }
      ]
    },
    {
      "type": "dialogue",
      "speakerCode": "mhk",
      "speakerName": "miho",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-miho.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_mhk_07_03/sud_vo_adv_card_mhk_07_03-mhk011.m4a",
      "text": "とにかく、撮影の間はずっと\nこの帽子を被っていて下さい",
      "startTime": 96.8000003179,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_dressingroom-00-noon.webp",
      "bgName": "dressingroom-00-noon"
    },
    {
      "type": "dialogue",
      "speakerCode": "koh",
      "speakerName": "{user}",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-makino.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_mhk_07_03/sud_vo_adv_card_mhk_07_03-koh007.m4a",
      "text": "これ、mihoさんの日よけ帽子じゃ……\nスーツに帽子って、変じゃないですか……？",
      "startTime": 102.5000003179,
      "sfxList": [
        {
          "src": "https://apiip.dasewasia.my.id/storyBgm/sud_se_adv_clipper-01.m4a",
          "delay": 8766.66666669999,
          "startTime": 111.2666669846
        }
      ]
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_dressingroom-00-noon.webp",
      "bgName": "dressingroom-00-noon"
    },
    {
      "type": "dialogue",
      "speakerCode": "mhk",
      "speakerName": "miho",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-miho.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_mhk_07_03/sud_vo_adv_card_mhk_07_03-mhk012.m4a",
      "text": "その頭をさらすよりマシでしょう\nそれとも……本当にこのバリカンで刈られたいですか？",
      "startTime": 108.4000003179,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "koh",
      "speakerName": "{user}",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-makino.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_mhk_07_03/sud_vo_adv_card_mhk_07_03-koh008.m4a",
      "text": "そ、それいつも持っているんですか……？",
      "startTime": 113.1666645208,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_dressingroom-00-noon.webp",
      "bgName": "dressingroom-00-noon"
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_dressingroom-00-noon.webp",
      "bgName": "dressingroom-00-noon"
    },
    {
      "type": "dialogue",
      "speakerCode": "mhk",
      "speakerName": "miho",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-miho.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_mhk_07_03/sud_vo_adv_card_mhk_07_03-mhk013.m4a",
      "text": "撮影が終わるまで帽子は取らないで下さいね\nぜっっったいに",
      "startTime": 119.1666669846,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_photostudio-00-noon.webp",
      "bgName": "photostudio-00-noon"
    },
    {
      "type": "dialogue",
      "speakerCode": null,
      "speakerName": "",
      "iconUrl": null,
      "voiceUrl": null,
      "text": "――撮影後",
      "startTime": 121.8666690985,
      "sfxList": [
        {
          "src": "https://apiip.dasewasia.my.id/storyBgm/sud_se_adv_walk-in-single-02.m4a",
          "delay": 1266.669211500002,
          "startTime": 123.13333831
        }
      ]
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_photostudio-00-noon.webp",
      "bgName": "photostudio-00-noon"
    },
    {
      "type": "dialogue",
      "speakerCode": "koh",
      "speakerName": "{user}",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-makino.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_mhk_07_03/sud_vo_adv_card_mhk_07_03-koh009.m4a",
      "text": "mihoさん、撮影お疲れ様でした！\n凄く良かったと先方も大喜びですよ",
      "startTime": 126.7862201704,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "koh",
      "speakerName": "{user}",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-makino.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_mhk_07_03/sud_vo_adv_card_mhk_07_03-koh010.m4a",
      "text": "それで、追加でオフショットとインタビューもしたいと\n言ってくれているんですが……",
      "startTime": 133.3333397548,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_photostudio-00-noon.webp",
      "bgName": "photostudio-00-noon"
    },
    {
      "type": "dialogue",
      "speakerCode": "mhk",
      "speakerName": "miho",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-miho.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_mhk_07_03/sud_vo_adv_card_mhk_07_03-mhk014.m4a",
      "text": "そうですか。私は大丈夫ですよ\n長めに時間を空けておいて良かったです",
      "startTime": 138.7666730881,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "koh",
      "speakerName": "{user}",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-makino.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_mhk_07_03/sud_vo_adv_card_mhk_07_03-koh011.m4a",
      "text": "ありがとうございます。じゃあ、休憩を挟んだら\n撮影再開しましょう。いや～、さすがmihoさん――",
      "startTime": 144.5000064214,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_photostudio-00-noon.webp",
      "bgName": "photostudio-00-noon"
    },
    {
      "type": "dialogue",
      "speakerCode": "mhk",
      "speakerName": "miho",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-miho.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_mhk_07_03/sud_vo_adv_card_mhk_07_03-mhk015.m4a",
      "text": "ちょっと！　今帽子を脱ごうとしましたよね？\n撮影が終わるまで取るなと言ったはずですが",
      "startTime": 153.0666730881,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_photostudio-00-noon.webp",
      "bgName": "photostudio-00-noon"
    },
    {
      "type": "dialogue",
      "speakerCode": "koh",
      "speakerName": "{user}",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-makino.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_mhk_07_03/sud_vo_adv_card_mhk_07_03-koh012.m4a",
      "text": "す、すみません……ただ、この帽子を被っていると\nスタッフさんに変な目で見られるんですよ",
      "startTime": 160.8666730881,
      "sfxList": []
