{
  "id": "adv_card_hrk_08_01_short",
  "title": "佐伯遙子 (Short)",
  "script": [
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_office-00-noon.webp",
      "bgName": "3d_toffice_noon",
