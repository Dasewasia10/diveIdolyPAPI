      "bgName": "themepark-00-night",
      "startTime": 267.4000426768
    },
    {
      "type": "dialogue",
      "speakerCode": "hrk",
      "speakerName": "佐伯遙子",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-haruko.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_hrk_11_02/sud_vo_adv_card_hrk_11_02-hrk023.m4a",
      "text": "麻奈ちゃんは、きっと分かっていたのね\n私が悩んでいたことも、全部……",
      "startTime": 272.8666737873,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_themepark-00-night.webp",
