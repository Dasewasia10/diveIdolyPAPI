      "speakerName": "{user}",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-makino.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_hrk_11_02/sud_vo_adv_card_hrk_11_02-koh010.m4a",
      "text": "あの曲は、急に制作を決めたんですよ。遙子さんが\nバースデーライブの準備をしたって知った後、すぐに",
      "startTime": 255.633340454,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "koh",
      "speakerName": "{user}",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-makino.png",
