      "text": "ステージの上で\n麻奈ちゃんに、おめでとうって伝えたい",
      "startTime": 313.7000071207,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "hrk",
      "speakerName": "佐伯遙子",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-haruko.png",
