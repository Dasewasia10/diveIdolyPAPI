      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_rui_03_03/sud_vo_adv_card_rui_03_03-rui014.m4a",
      "text": "ええ、最高のクリスマスライブをファンに届けます\n{user}さんも受け取って下さいね",
      "startTime": 131.4666666667,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "koh",
      "speakerName": "{user}",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-makino.png",
