      "bgName": "countdownstage_oosaka"
    },
    {
      "type": "dialogue",
      "speakerCode": "kkr",
      "speakerName": "赤崎こころ",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-kokoro.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_kkr_05_01/sud_vo_adv_card_kkr_05_01-kkr002.m4a",
      "text": "私のセンターがとっても良かった～っていう人は\nSNSでバンバン広げちゃって下さ～い！",
      "startTime": 12.614762052,
      "sfxList": [
