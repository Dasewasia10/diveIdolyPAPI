      "speakerName": "長瀬琴乃",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-kotono.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_ktn_09_01/sud_vo_adv_card_ktn_09_01-ktn020.m4a",
      "text": "忙しいのはありがたいんですけど……お姉ちゃんの\nお墓参りが出来てないのがちょっと気掛かりなんです",
      "startTime": 247.2000038783,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "koh",
      "speakerName": "{user}",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-makino.png",
