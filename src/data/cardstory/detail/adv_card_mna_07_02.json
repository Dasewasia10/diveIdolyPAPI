    },
    {
      "type": "dialogue",
      "speakerCode": "mna",
      "speakerName": "長瀬麻奈",
      "speakerNameEn": "Mana",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-mana.png",
      "voiceUrl": null,
      "text": "分からないなら、私も一緒に探してあげるからさ",
      "translations": {
        "en": "If you don’t know‚ I’ll look together with you.",
        "id": ""
      },
      "startTime": 43.3095378714,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "mna",
      "speakerName": "長瀬麻奈",
