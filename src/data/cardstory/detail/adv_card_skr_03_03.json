      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_tvrooftop-00-evening.webp",
      "bgName": "stage03",
      "startTime": 203.9
    },
    {
      "type": "dialogue",
      "speakerCode": "koh",
      "speakerName": "{user}",
      "speakerNameEn": "{user}",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-makino.png",
