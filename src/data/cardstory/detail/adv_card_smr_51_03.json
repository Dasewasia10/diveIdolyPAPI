      "bgName": "yamagatastage-00-noon",
      "startTime": 309.0699554021
    },
    {
      "type": "dialogue",
      "speakerCode": "kkr",
      "speakerName": "赤崎こころ",
      "speakerNameEn": "Kokoro",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-kokoro.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_smr_51_03/sud_vo_adv_card_smr_51_03-kkr014.m4a",
      "text": "これからすみれちゃんに監修してもらって、近日発売\n予定でーす。みなさん、一人十缶は買って下さいね！",
      "translations": {
        "en": "We’ll have Sumire-chan supervise it‚ and it’s scheduled to\nbe released soon~. Everyone‚ please buy at least ten cans each!",
        "id": ""
      },
      "startTime": 312.7333384196,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_yamagatastage-00-noon.webp",
