      "text": "怜のお父さんは……\n芸能活動のことをよく思ってないみたいだな",
      "startTime": 27.333333333333332,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "mei",
      "speakerName": "早坂芽衣",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-mei.png",
