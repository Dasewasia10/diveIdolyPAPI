      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "koh",
      "speakerName": "{user}",
      "speakerNameEn": "{user}",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-makino.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_ngs_01_03/sud_vo_adv_card_ngs_01_03-koh016.m4a",
      "text": "（ライブは盛況のうちに終わった）\n（みんな力を出しきったのか、床に座り込んでいる）",
      "translations": {
        "en": "(The live is a rousing success.)\n(Afterward‚ everyone sits on the ground‚ exhausted.)",
        "id": ""
      },
      "startTime": 173.56666666666666,
