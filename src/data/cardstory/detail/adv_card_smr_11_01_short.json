      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_smr_11_01_short/sud_vo_adv_card_smr_11_01-koh001.m4a",
      "text": "すみれ？\nいい匂いだが、一体何を食べているんだ？",
      "translations": {
        "en": "Sumire?\nIt smells good—what are you eating?",
        "id": ""
      },
      "startTime": 14.8,
      "sfxList": []
    },
    {
      "type": "background",
