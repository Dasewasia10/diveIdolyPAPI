      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_smr_11_01_short/sud_vo_adv_card_smr_11_01-smr003.m4a",
      "text": "おうどんのCMの撮影に向けて美味しく食べる練習を\nしてました。でも、本当に美味しいから困っちゃいます",
      "startTime": 27.4666666667,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_tokyoconference-00-noon.webp",
      "bgName": "tokyoconference-00-noon",
      "startTime": 32.740181923
    },
    {
      "type": "dialogue",
      "speakerCode": "koh",
      "speakerName": "{user}",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-makino.png",
