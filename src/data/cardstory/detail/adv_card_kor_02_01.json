      "text": "へぇ……、めずらしい成分が入ってる\nこれは試してみる価値あるかも",
      "startTime": 176.9381891172,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "koh",
      "speakerName": "{user}",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-makino.png",
