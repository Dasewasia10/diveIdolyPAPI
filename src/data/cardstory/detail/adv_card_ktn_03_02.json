      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-kotono.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_ktn_03_02/sud_vo_adv_card_ktn_03_02-ktn010.m4a",
      "text": "だ、だからなんでニヤニヤしてるんですか、もうっ！",
      "startTime": 85.1333333333,
      "sfxList": [
        {
          "src": "https://apiip.dasewasia.my.id/storyBgm/sud_se_adv_walk-out-single-01.m4a",
