      "text": "参拝の列、凄く長いですね\nしばらく並びそうかな……",
      "startTime": 97.1666666667,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_shrine-00-noon.webp",
      "bgName": "stage01",
      "startTime": 99.6333333333
    },
    {
      "type": "dialogue",
      "speakerCode": "ktn",
      "speakerName": "長瀬琴乃",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-kotono.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_ktn_03_02/sud_vo_adv_card_ktn_03_02-ktn012.m4a",
      "text": "{user}さん\nちょっと……話を聞いてもらってもいいですか？",
      "startTime": 101.6,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_shrine-00-noon.webp",
      "bgName": "stage01",
      "startTime": 105.7
    },
    {
      "type": "dialogue",
      "speakerCode": "koh",
      "speakerName": "{user}",
