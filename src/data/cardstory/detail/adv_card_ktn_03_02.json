    },
    {
      "type": "dialogue",
      "speakerCode": "ktn",
      "speakerName": "長瀬琴乃",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-kotono.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_ktn_03_02/sud_vo_adv_card_ktn_03_02-ktn021.m4a",
      "text": "私が成長すれば大丈夫、って考えたこともありました\nでも、成長するとみんなの力がよく見えるようになって",
      "startTime": 178.7666666667,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_shrine-00-noon.webp",
      "bgName": "stage01",
      "startTime": 184.6
    },
    {
      "type": "dialogue",
      "speakerCode": "ktn",
      "speakerName": "長瀬琴乃",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-kotono.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_ktn_03_02/sud_vo_adv_card_ktn_03_02-ktn022.m4a",
      "text": "こんなことが出来るんだ……とか",
      "startTime": 184.6,
      "sfxList": []
    },
    {
      "type": "dialogue",
