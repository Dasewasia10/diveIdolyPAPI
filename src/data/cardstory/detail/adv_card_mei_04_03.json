      "bgName": "stage02",
      "startTime": 151.5
    },
    {
      "type": "dialogue",
      "speakerCode": "koh",
      "speakerName": "{user}",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-makino.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_mei_04_03/sud_vo_adv_card_mei_04_03-koh011.m4a",
      "text": "それにしても……やっぱり練習で\n負荷がかかり過ぎてたのかもな。見抜けなくてすまない",
      "startTime": 154.5333333333,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "mei",
      "speakerName": "早坂芽衣",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-mei.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_mei_04_03/sud_vo_adv_card_mei_04_03-mei019.m4a",
      "text": "ううん、謝んなくていいよ",
      "startTime": 159.4666666667,
      "sfxList": []
    },
    {
      "type": "background",
