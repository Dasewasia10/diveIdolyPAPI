      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_ktn_04_03/sud_vo_adv_card_ktn_04_03-ktn029.m4a",
      "text": "はい、私もびっくりしてます\n雑誌でもあんなに大々的に取り上げていただいて……",
      "startTime": 252.7,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "koh",
      "speakerName": "{user}",
