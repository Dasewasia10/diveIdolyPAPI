      "text": "……はぁ\nでも……ありがとうございます\nとっても嬉しいです",
      "startTime": 234.0666666667,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "koh",
      "speakerName": "{user}",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-makino.png",
