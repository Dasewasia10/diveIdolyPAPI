      "text": "ありがとうございます。うまくいくか不安でしたけど\nしっかり出来て良かったです",
      "startTime": 203,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "koh",
      "speakerName": "{user}",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-makino.png",
