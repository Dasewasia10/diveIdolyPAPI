    },
    {
      "type": "dialogue",
      "speakerCode": "koh",
      "speakerName": "{user}",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-makino.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_ktn_04_03/sud_vo_adv_card_ktn_04_03-koh010.m4a",
      "text": "え？　いや……撮影の時は忙しかっただろ？\nちゃんと言うタイミングがなかったなって",
      "startTime": 217.7666666667,
      "sfxList": []
    },
    {
      "type": "background",
