      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_mku_02_02/sud_vo_adv_card_mku_02_02-mku002.m4a",
      "text": "ねぇ、自由研究ってどんな宿題なの？",
      "startTime": 45.0666653951,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "ktn",
