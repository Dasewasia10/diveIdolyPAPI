      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_smr_01_01/sud_vo_adv_card_smr_01_01-smr003.m4a",
      "text": "星見プロの{user}さん！？\nもう～っ！　ビックリしたっちゃ～",
      "startTime": 26.6,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "koh",
