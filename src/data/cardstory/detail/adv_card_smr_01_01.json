      "voiceUrl": null,
      "text": "…………えっと",
      "translations": {
        "en": "…Erm.",
        "id": ""
      },
      "startTime": 30.333333333333332,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "smr",
      "speakerName": "奥山すみれ",
      "speakerNameEn": "Sumire",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-sumire.png",
