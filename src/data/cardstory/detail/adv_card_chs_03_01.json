      "text": "{user}さん……\n昨日のことで提案があるんですけど……",
      "startTime": 258.3666666667,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "chs",
      "speakerName": "白石千紗",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-chisa.png",
