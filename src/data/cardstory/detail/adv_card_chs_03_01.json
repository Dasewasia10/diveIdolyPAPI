      },
      "startTime": 324.8333333333,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "chs",
      "speakerName": "白石千紗",
      "speakerNameEn": "Chisa",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-chisa.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_chs_03_01/sud_vo_adv_card_chs_03_01-chs032.m4a",
