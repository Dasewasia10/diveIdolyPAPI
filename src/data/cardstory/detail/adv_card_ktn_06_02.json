      "startTime": 100.7333309175
    },
    {
      "type": "dialogue",
      "speakerCode": "koh",
      "speakerName": "{user}",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-makino.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_ktn_06_02/sud_vo_adv_card_ktn_06_02-koh007.m4a",
      "text": "もしもし……琴乃？　どうした！？\nダメだ……通話が切れてる",
      "startTime": 105.8666637422,
      "sfxList": [
        {
          "src": "https://apiip.dasewasia.my.id/storyBgm/sud_se_adv_phone-tap-01.m4a",
