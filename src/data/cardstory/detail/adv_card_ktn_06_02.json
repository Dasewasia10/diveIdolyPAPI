      "text": "みんなに心配をかけて申し訳ないです\nでも、どうしたらいいか分からなくて",
      "startTime": 60.4673526765,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "ktn",
      "speakerName": "長瀬琴乃",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-kotono.png",
