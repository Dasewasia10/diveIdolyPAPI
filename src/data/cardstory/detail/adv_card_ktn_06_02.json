      "text": "それで……みんなに何も言わずに\n自分の部屋に戻ってきちゃったんです",
      "startTime": 43.308909464,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "koh",
      "speakerName": "{user}",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-makino.png",
