      "startTime": 48.1006814322
    },
    {
      "type": "dialogue",
      "speakerCode": "ktn",
      "speakerName": "長瀬琴乃",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-kotono.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_ktn_06_02/sud_vo_adv_card_ktn_06_02-ktn004.m4a",
      "text": "さっきよりは大丈夫ですけど……\nでも、まだ……胸がキュッと締め付けられてます",
      "startTime": 51.4006814322,
      "sfxList": []
    },
    {
      "type": "background",
