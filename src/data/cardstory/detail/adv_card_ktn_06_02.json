      "speakerName": "長瀬琴乃",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-kotono.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_ktn_06_02/sud_vo_adv_card_ktn_06_02-ktn010.m4a",
      "text": "あ、ちょ、さくら――きゃあっ！？",
      "startTime": 96.7193198046,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_office-01-night.webp",
