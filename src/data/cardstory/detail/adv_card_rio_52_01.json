      "iconUrl": null,
      "voiceUrl": null,
      "text": "――星見プロ誕生日慰安旅行in沖縄",
      "translations": {
        "en": "Hoshimi Pro Birthday Recreational Trip in Okinawa",
        "id": ""
      },
      "startTime": 27.1707422891,
      "sfxList": [
        {
