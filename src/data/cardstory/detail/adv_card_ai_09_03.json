      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_ai_09_03/sud_vo_adv_card_ai_09_03-koh011.m4a",
      "text": "……そうだな。急に筋肉とか言い出すから\n少し驚いたけど……その意気だ",
      "startTime": 262.1666681926,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "koh",
      "speakerName": "{user}",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-makino.png",
