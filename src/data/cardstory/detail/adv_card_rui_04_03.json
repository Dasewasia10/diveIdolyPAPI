{
  "id": "adv_card_rui_04_03",
  "title": "天動瑠依 3話 一世一代のウォーキング",
  "script": [
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_stagesleeves-00-noon.webp",
      "bgName": "stagesleeves-00-noon",
      "startTime": 0
    },
    {
      "type": "dialogue",
      "speakerCode": null,
      "speakerName": "",
