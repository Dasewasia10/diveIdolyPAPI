      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_livecorridor-00-noon.webp",
      "bgName": "livecorridor-00-noon",
      "startTime": 281.6666666667
    },
    {
      "type": "dialogue",
      "speakerCode": "rei",
      "speakerName": "一ノ瀬怜",
      "speakerNameEn": "Rei",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-rei.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_rei_06_01/sud_vo_adv_card_rei_06_01-rei023.m4a",
      "text": "私達のことを何も知らずに……勝手なこと言わないで！",
      "translations": {
        "en": "Don't make baseless claims about us!",
        "id": ""
      },
      "startTime": 281.6666666667,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_stagesleeves-00-noon.webp",
      "bgName": "stagesleeves-00-noon",
