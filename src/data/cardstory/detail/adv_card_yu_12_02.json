      "speakerNameEn": "{user}",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-makino.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_yu_12_02/sud_vo_adv_card_yu_12_02-koh009.m4a",
      "text": "……分かった。そういうことなら俺も協力するよ\nまずは、ダイエットの専門家に相談しよう",
      "translations": {
        "en": "…Alright. Then I’ll help too.\nLet’s consult a diet specialist first.",
        "id": ""
      },
      "startTime": 245.5333265941,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "koh",
      "speakerName": "{user}",
      "speakerNameEn": "{user}",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-makino.png",
