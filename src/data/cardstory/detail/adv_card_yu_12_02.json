      "speakerCode": "yu",
      "speakerName": "鈴村優",
      "speakerNameEn": "Yu",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-yu.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_yu_12_02/sud_vo_adv_card_yu_12_02-yu022.m4a",
      "text": "……分かりました。{user}さんには\nうちの恥ずかしいとこ、全部知られてもうたし……",
      "translations": {
        "en": "…Alright. You already know\nall my embarrassing sides anyway…",
        "id": ""
      },
      "startTime": 260.6333265941,
      "sfxList": []
    },
    {
