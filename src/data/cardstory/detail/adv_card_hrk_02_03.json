      "text": "だから彼を信じて\nついて行きなさいって",
      "translations": {
        "en": "That she just has to believe in you\nand follow your lead‚ and it’ll be okay.",
        "id": ""
      },
      "startTime": 172.13333333333333,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_okinawabeach-00-night.webp",
      "bgName": "s2",
      "startTime": 174.23333333333332
    },
    {
      "type": "dialogue",
      "speakerCode": "hrk",
      "speakerName": "佐伯遙子",
