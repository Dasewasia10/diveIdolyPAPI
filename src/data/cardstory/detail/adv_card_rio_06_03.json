      "speakerCode": "koh",
      "speakerName": "{user}",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-makino.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_rio_06_03/sud_vo_adv_card_rio_06_03-koh012.m4a",
      "text": "本当にすみません",
      "startTime": 188.0333333333,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "riomam",
      "speakerName": "莉央の母",
      "iconUrl": null,
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_rio_06_03/sud_vo_adv_card_rio_06_03-riomom003.m4a",
      "text": "仕事があるのはいいことだから\n莉央、頑張って貴方の夢を叶えなさい",
      "startTime": 192.5666666667,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_station-00-noon.webp",
      "bgName": "station-00-noon",
      "startTime": 196.1333333333
    },
    {
      "type": "dialogue",
      "speakerCode": "rio",
      "speakerName": "神崎莉央",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-rio.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_rio_06_03/sud_vo_adv_card_rio_06_03-rio020.m4a",
      "text": "……ありがとう。お母さんも健康に気を付けてね\n私、頑張って夢を叶えてみせるわ",
      "startTime": 200.8333333333,
      "sfxList": []
    },
    {
