      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_rio_06_03/sud_vo_adv_card_rio_06_03-riomom002.m4a",
      "text": "もっといてほしかったけど\n楽しい時間はあっと言う間に過ぎるものね",
      "startTime": 179.8333333333,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_station-00-noon.webp",
