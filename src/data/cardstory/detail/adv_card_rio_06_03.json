      "startTime": 182.7333333333
    },
    {
      "type": "dialogue",
      "speakerCode": "rio",
      "speakerName": "神崎莉央",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-rio.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_rio_06_03/sud_vo_adv_card_rio_06_03-rio019.m4a",
      "text": "ごめんなさい、お母さん\n次に帰る時は、もっとゆっくりしていくから",
      "startTime": 184.7333333333,
      "sfxList": []
    },
    {
      "type": "background",
