{
  "id": "adv_card_ai_03_01_short",
  "title": "小美山愛 1話 親友の本音 (Short)",
  "script": [
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_lesson-01-noon.webp",
      "bgName": "stage01",
