      "startTime": 148.5666666667,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "koh",
      "speakerName": "{user}",
      "speakerNameEn": "{user}",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-makino.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_rio_03_02/sud_vo_adv_card_rio_03_02-koh013.m4a",
      "text": "以前は、話し掛けるのもためらうほど怖かったですし",
      "translations": {
        "en": "Before‚ I was hesitant even to talk to you.",
        "id": ""
      },
      "startTime": 150.6,
