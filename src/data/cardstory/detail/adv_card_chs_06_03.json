      "iconUrl": null,
      "voiceUrl": null,
      "text": "――ライブ終了後の夜",
      "startTime": 0,
      "sfxList": [
        {
          "src": "https://apiip.dasewasia.my.id/storyBgm/sud_se_adv_phone-call-01.m4a",
          "delay": 2099.9999761999998,
          "startTime": 2.0999999762
        },
        {
