      "startTime": 300.1666666667,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "koh",
      "speakerName": "{user}",
      "speakerNameEn": "{user}",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-makino.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_rui_04_02/sud_vo_adv_card_rui_04_02-koh014.m4a",
      "text": "（だが、そのせいでこんなに思い詰めて……天動さんに）\n（似合うと思って安易に引き受けた俺の責任だ……）",
