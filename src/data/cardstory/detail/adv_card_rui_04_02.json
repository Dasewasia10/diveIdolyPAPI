      "text": "おいおい、変に取らないでくれ",
      "startTime": 365.4333333333,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "koh",
      "speakerName": "{user}",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-makino.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_rui_04_02/sud_vo_adv_card_rui_04_02-koh020.m4a",
      "text": "とにかく、俺も出来る限りサポートするから\nファッションショーを必ず成功させよう！",
