    },
    {
      "type": "dialogue",
      "speakerCode": "yu",
      "speakerName": "鈴村優",
      "speakerNameEn": "Yu",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-yu.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_yu_12_01_short/sud_vo_adv_card_yu_12_01-yu005.m4a",
      "text": "ほんならうちの仕事は、大好きな極烙拉麺を食べて\n美味しさをアピールするって訳やんな？　最高やん！",
      "translations": {
        "en": "So my job is to eat my beloved Gokuraku Ramen\nand show everyone how delicious it is‚ right? That’s the best!",
        "id": ""
      },
      "startTime": 62.4000007629,
      "sfxList": []
