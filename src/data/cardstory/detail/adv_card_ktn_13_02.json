      "bgName": "osaka-00-night",
      "startTime": 37.3656676928
    },
    {
      "type": "dialogue",
      "speakerCode": "koh",
      "speakerName": "{user}",
      "speakerNameEn": "{user}",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-makino.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_ktn_13_02/sud_vo_adv_card_ktn_13_02-koh004.m4a",
      "text": "それにまぁ、すずとは祭りに行ったから\n他のみんなにもお土産を買って帰れば大丈夫だろう",
      "translations": {
        "en": "",
        "id": ""
      },
      "startTime": 40.4990012169,
      "sfxList": []
    },
