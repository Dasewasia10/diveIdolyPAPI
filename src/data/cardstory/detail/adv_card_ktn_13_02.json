      "text": "あ……そうだ、{user}さん\n昨日の用事って、なんだったんですか？",
      "translations": {
        "en": "",
        "id": ""
      },
      "startTime": 146.8333333333,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "ktn",
      "speakerName": "長瀬琴乃",
      "speakerNameEn": "Kotono Nagase",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-kotono.png",
