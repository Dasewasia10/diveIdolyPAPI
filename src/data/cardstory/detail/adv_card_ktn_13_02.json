      "text": "……あ、ホテルに着きましたね\nじゃあ、私はもう部屋に戻りますね",
      "translations": {
        "en": "",
        "id": ""
      },
      "startTime": 68.3,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "koh",
