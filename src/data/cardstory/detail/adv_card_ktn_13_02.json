      "text": "すずもお祭り凄く楽しかったって言ってました\nあ、お土産と言えばこの間、芽衣が大喜びしてましたね",
      "translations": {
        "en": "",
        "id": ""
      },
      "startTime": 48.0666666667,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "ktn",
      "speakerName": "長瀬琴乃",
      "speakerNameEn": "Kotono Nagase",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-kotono.png",
