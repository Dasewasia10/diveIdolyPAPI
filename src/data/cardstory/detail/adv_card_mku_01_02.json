      "text": "いややわぁ、冗談やんか\n今時そんなこと言いませんから",
      "translations": {
        "en": "Oh‚ no‚ just kidding.\nThey don't say things like that nowadays.",
        "id": ""
      },
      "startTime": 130.5,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "koh",
      "speakerName": "{user}",
      "speakerNameEn": "{user}",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-makino.png",
