      "text": "すみれちゃんに、山形から通うのは\n大変じゃないかって聞いたの",
      "translations": {
        "en": "I asked Sumire-chan if it's tough\nto commute from Yamagata.",
        "id": ""
      },
      "startTime": 70.5,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_tokyokissa-00-noon.webp",
      "bgName": "tokyokissa-00-noon",
      "startTime": 73.0666666667
    },
    {
      "type": "dialogue",
      "speakerCode": "mku",
      "speakerName": "初音ミク",
      "speakerNameEn": "Hatsune",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-mku.png",
