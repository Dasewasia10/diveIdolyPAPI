      "text": "奥山さんは本当に元気だな",
      "translations": {
        "en": "Okuyama-san is really energetic.",
        "id": ""
      },
      "startTime": 78.4,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "mku",
      "speakerName": "初音ミク",
      "speakerNameEn": "Hatsune",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-mku.png",
