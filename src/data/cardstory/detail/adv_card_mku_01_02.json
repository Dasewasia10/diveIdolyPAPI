      "text": "そしたら、「新幹線でいっぱい寝るから平気だよ」って",
      "startTime": 73.0666666667,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_tokyokissa-00-noon.webp",
      "bgName": "tokyokissa-00-noon"
    },
    {
      "type": "dialogue",
      "speakerCode": "koh",
      "speakerName": "{user}",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-makino.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_mku_01_02/sud_vo_adv_card_mku_01_02-koh007.m4a",
      "text": "奥山さんは本当に元気だな",
      "startTime": 78.4,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "mku",
      "speakerName": "初音ミク",
