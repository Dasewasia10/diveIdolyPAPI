      "text": "いややわぁ、冗談やんか\n今時そんなこと言いませんから",
      "startTime": 130.5,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "koh",
      "speakerName": "{user}",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-makino.png",
