    },
    {
      "type": "dialogue",
      "speakerCode": "koh",
      "speakerName": "{user}",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-makino.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_mku_01_02/sud_vo_adv_card_mku_01_02-koh008.m4a",
      "text": "天動さんの味覚は独特だからな……",
      "startTime": 97.9333333333,
