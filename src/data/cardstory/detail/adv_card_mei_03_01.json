      "text": "怜ちゃん……お父さん……話し合い……むむむ",
      "startTime": 185.1333333333,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "mei",
      "speakerName": "早坂芽衣",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-mei.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_mei_03_01/sud_vo_adv_card_mei_03_01-mei025.m4a",
      "text": "あ！　猫ちゃん発見！\nえへへ、可愛いにゃー。どこから来たにゃー？",
      "startTime": 197.3333333333,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_shoppingspot-00-noon.webp",
