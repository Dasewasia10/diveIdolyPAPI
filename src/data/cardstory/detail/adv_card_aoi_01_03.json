    {
      "type": "dialogue",
      "speakerCode": "koh",
      "speakerName": "{user}",
      "speakerNameEn": "{user}",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-makino.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_aoi_01_03/sud_vo_adv_card_aoi_01_03-koh001.m4a",
      "text": "さすがLizNoirのライブ……凄い盛り上がりだ\nそれにしても、いきなり過ぎたよな……",
      "translations": {
        "en": "LizNoir knows how to put on an incredible live!\nBut still this was all so sudden.",
        "id": ""
      },
      "startTime": 8.433333333333334,
      "sfxList": [
        {
          "src": "https://apiip.dasewasia.my.id/storyBgm/sud_se_adv_cheers-in-01.m4a",
