      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-mei.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_mku_03_02/sud_vo_adv_card_mku_03_02-mei002.m4a",
      "text": "でもミクちゃん、カラオケ知ってるんだね\nもしかして、行ったことあったりする？",
      "startTime": 38.1424512224,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "koh",
