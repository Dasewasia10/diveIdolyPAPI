    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_hoshimifes-03-night.webp",
      "bgName": "hoshimifes-01-night"
    },
    {
      "type": "dialogue",
