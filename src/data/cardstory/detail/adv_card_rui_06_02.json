          "startTime": 169.5333333333
        }
      ]
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_office-01-night.webp",
      "bgName": "3d_toffice_night",
      "startTime": 168.8333333333
    },
    {
      "type": "dialogue",
      "speakerCode": "koh",
      "speakerName": "{user}",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-makino.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_rui_06_02/sud_vo_adv_card_rui_06_02-koh011.m4a",
      "text": "ふぅ……うわ！？　瑠依！？\nど、どうしたんだ、そんな真剣な顔をして……？",
      "startTime": 172.8,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "rui",
      "speakerName": "天動瑠依",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-rui.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_rui_06_02/sud_vo_adv_card_rui_06_02-rui021.m4a",
      "text": "{user}さん\nあなたにお話があります",
      "startTime": 178.4,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "koh",
      "speakerName": "{user}",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-makino.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_rui_06_02/sud_vo_adv_card_rui_06_02-koh012.m4a",
      "text": "俺に話……？　それは問題ないんだが\n優とすみれはどうしたんだ？",
      "startTime": 185.0666666667,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "rui",
      "speakerName": "天動瑠依",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-rui.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_rui_06_02/sud_vo_adv_card_rui_06_02-rui022.m4a",
      "text": "二人には先に帰ってもらいました",
      "startTime": 187.7,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "rui",
