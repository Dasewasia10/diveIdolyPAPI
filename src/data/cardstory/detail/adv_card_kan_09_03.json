      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_kan_09_03/sud_vo_adv_card_kan_09_03-koh005.m4a",
      "text": "（す、凄いサーブだ！？　コロ子さん）\n（あまりの速さに固まることしか出来ない！）",
      "startTime": 104.2666666667,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "kan",
      "speakerName": "kana",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-kana.png",
