      "bgName": "s1"
    },
    {
      "type": "dialogue",
      "speakerCode": "kan",
      "speakerName": "kana",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-kana.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_kan_09_03/sud_vo_adv_card_kan_09_03-kan004.m4a",
      "text": "すっご～い、コロ子ちゃん、上手～！！\n今までテニスやったことなかったの？　信じらんない！",
      "startTime": 50.2106351215,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "koh",
      "speakerName": "{user}",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-makino.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_kan_09_03/sud_vo_adv_card_kan_09_03-koh003.m4a",
      "text": "（もしかしてあの人、テニス経験者なのを黙って）\n（この仕事を請けたんじゃないか？）",
      "startTime": 58.4666666667,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_tenniscourt-00-noon.webp",
