      "text": "ちょっ、コロ子ちゃん、大丈夫！？\nもしかして、サーブが当たっちゃったとか！？",
      "startTime": 109.2333333333,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_tenniscourt-00-noon.webp",
      "bgName": "s1"
    },
    {
      "type": "dialogue",
