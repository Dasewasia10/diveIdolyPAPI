      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_ngs_01_01/sud_vo_adv_card_ngs_01_01-koh003.m4a",
      "text": "やはり見られている気が……",
      "translations": {
        "en": "No‚ someone’s definitely watching me…",
        "id": ""
      },
      "startTime": 16.7,
      "sfxList": [
