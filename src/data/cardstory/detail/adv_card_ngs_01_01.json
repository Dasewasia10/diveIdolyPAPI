      "text": "{user}さんは\n琴乃ちゃんのマネージャーですから",
      "translations": {
        "en": "After all‚\nyou’re also Kotono-chan’s manager.",
        "id": ""
      },
      "startTime": 121.96666666666667,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_hoshicorridor-00-noon.webp",
      "bgName": "s３",
      "startTime": 124.3
    },
    {
      "type": "dialogue",
      "speakerCode": "ngs",
      "speakerName": "伊吹渚",
      "speakerNameEn": "Nagisa",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-nagisa.png",
