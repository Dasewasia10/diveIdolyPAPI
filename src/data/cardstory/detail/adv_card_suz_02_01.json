      "text": "そんなことより\n早く荷物を部屋まで運んで下さいまし",
      "startTime": 108.5,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "koh",
      "speakerName": "{user}",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-makino.png",
