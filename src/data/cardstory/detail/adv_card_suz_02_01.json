      "translations": {
        "en": "It’s not a swimsuit.\nThis is the outfit I’m going to wear for the shoot tomorrow.",
        "id": ""
      },
      "startTime": 16.633333333333333,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "suz",
