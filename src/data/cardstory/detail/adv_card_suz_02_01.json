      "text": "こんなにはしゃぐなんて\nまるで遠足を楽しみにしている子供だな",
      "startTime": 72.96666666666667,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "suz",
      "speakerName": "成宮すず",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-suzu.png",
