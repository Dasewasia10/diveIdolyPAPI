      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_suz_02_01/sud_vo_adv_card_suz_02_01-koh001.m4a",
      "text": "おーい、すず！　ちょっと来てくれないか！",
      "startTime": 0.8,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "suz",
      "speakerName": "成宮すず",
