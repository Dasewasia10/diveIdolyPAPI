      "text": "そうそう、事務所にすず宛ての荷物が届いてたから\n持って来たんだ",
      "startTime": 87.96666666666667,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "suz",
      "speakerName": "成宮すず",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-suzu.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_suz_02_01/sud_vo_adv_card_suz_02_01-suz012.m4a",
      "text": "やっと届きましたわね！　待っていましたわよ！",
      "startTime": 89.16666666666667,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_tokyodormcorridor-00-noon.webp",
