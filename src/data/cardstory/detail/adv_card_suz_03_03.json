    {
      "type": "dialogue",
      "speakerCode": "suz",
      "speakerName": "成宮すず",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-suzu.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_suz_03_03/sud_vo_adv_card_suz_03_03-suz001.m4a",
      "text": "いよいよドッキリが始まりますわね\n今もどこかから隠しカメラで撮影しているはず……",
      "startTime": 8.233333333333333,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_photostudio-00-noon.webp",
      "bgName": "photostudio-00-noon"
    },
    {
