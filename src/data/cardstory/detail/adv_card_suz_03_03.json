      "speakerCode": "suz",
      "speakerName": "成宮すず",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-suzu.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_suz_03_03/sud_vo_adv_card_suz_03_03-suz005.m4a",
      "text": "……分かりました\n必ずみなさんの期待に応えてみせますわ！",
      "startTime": 53.7,
      "sfxList": [
        {
          "src": "https://apiip.dasewasia.my.id/storyBgm/sud_se_adv_camera-01.m4a",
