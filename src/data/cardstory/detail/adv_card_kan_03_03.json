      "text": "そんな相談者さんのこと\nkanaは可愛いな～って思いますけどね",
      "translations": {
        "en": "Regarding such questioners‚\nkana think they're cute~",
        "id": ""
      },
      "startTime": 68.4000031948,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_bar-00-night.webp",
      "bgName": "bar-00-night",
      "startTime": 72.1000032266
    },
    {
      "type": "dialogue",
      "speakerCode": "kan",
      "speakerName": "kana",
      "speakerNameEn": "kana",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-kana.png",
