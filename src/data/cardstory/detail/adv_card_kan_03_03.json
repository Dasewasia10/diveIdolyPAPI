      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-kana.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_kan_03_03/sud_vo_adv_card_kan_03_03-kan018.m4a",
      "text": "それともいつものkanaのインタビューが\n悪いって言いたい？",
      "translations": {
        "en": "Or do you want to blame\nthe usual interviews with me?",
        "id": ""
      },
      "startTime": 158.6000184535,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "koh",
      "speakerName": "{user}",
      "speakerNameEn": "{user}",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-makino.png",
