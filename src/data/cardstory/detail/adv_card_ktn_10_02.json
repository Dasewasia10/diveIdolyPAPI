      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_ktn_10_02/sud_vo_adv_card_ktn_10_02-koh017.m4a",
      "text": "それは甘んじて受けるべきだな",
      "translations": {
        "en": "That's something you should accept.",
        "id": ""
      },
      "startTime": 379.3084594396,
      "sfxList": []
