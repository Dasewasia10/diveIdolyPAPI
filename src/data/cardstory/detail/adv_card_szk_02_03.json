      "text": "雫、緊張してる？",
      "translations": {
        "en": "Shizuku‚ are you nervous?",
        "id": ""
      },
      "startTime": 3.5,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "szk",
      "speakerName": "兵藤雫",
