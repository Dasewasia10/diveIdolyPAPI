      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-makino.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_ktn_02_02/sud_vo_adv_card_ktn_02_02-koh015.m4a",
      "text": "誤解だって\n琴乃が元気になって嬉しいんだよ",
