      "startTime": 301.53333333333336,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "rui",
      "speakerName": "天動瑠依",
      "speakerNameEn": "Rui",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-rui.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_rui_02_01/sud_vo_adv_card_rui_02_01-rui029.m4a",
      "text": "いえ、星見プロでの初の単独仕事ですから",
      "translations": {
        "en": "This is my first solo offer with Hoshimi Productions.",
