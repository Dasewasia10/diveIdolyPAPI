      "text": "…………待って下さい\n私、やります",
      "translations": {
        "en": "…One moment.\nI’ll do it.",
        "id": ""
      },
      "startTime": 267.2,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "koh",
      "speakerName": "{user}",
      "speakerNameEn": "{user}",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-makino.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_rui_02_01/sud_vo_adv_card_rui_02_01-koh020.m4a",
      "text": "えっ？　な……なんで？",
      "translations": {
        "en": "Eh? Wh-why?",
        "id": ""
      },
      "startTime": 269.9,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "rui",
      "speakerName": "天動瑠依",
      "speakerNameEn": "Rui",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-rui.png",
