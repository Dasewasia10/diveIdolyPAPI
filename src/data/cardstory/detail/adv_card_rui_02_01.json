      "text": "――はい？",
      "translations": {
        "en": "…What?",
        "id": ""
      },
      "startTime": 232.26666666666668,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "koh",
      "speakerName": "{user}",
      "speakerNameEn": "{user}",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-makino.png",
