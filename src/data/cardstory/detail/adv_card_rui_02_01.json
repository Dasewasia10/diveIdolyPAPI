      "text": "してません！\n……でも、絶対、現場にはついて来てほしいです",
      "startTime": 293.73333333333335,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "koh",
      "speakerName": "{user}",
