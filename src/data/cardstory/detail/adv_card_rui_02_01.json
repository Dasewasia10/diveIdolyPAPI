      },
      "startTime": 281.3333333333333,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "rui",
      "speakerName": "天動瑠依",
      "speakerNameEn": "Rui",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-rui.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_rui_02_01/sud_vo_adv_card_rui_02_01-rui027.m4a",
      "text": "――私、水着グラビアを解禁します！",
