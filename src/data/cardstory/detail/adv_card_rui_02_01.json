      },
      "startTime": 305.2,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "rui",
      "speakerName": "天動瑠依",
      "speakerNameEn": "Rui",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-rui.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_rui_02_01/sud_vo_adv_card_rui_02_01-rui030.m4a",
      "text": "{user}さんに私の仕事ぶりを\nしっかり確認していただきたいんです",
      "translations": {
