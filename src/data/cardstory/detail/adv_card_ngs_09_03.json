      "text": "ただ、ステージで琴乃ちゃんが私に手を伸ばして……",
      "translations": {
        "en": "However‚ Kotono reached out her hand to me on stage…",
        "id": ""
      },
      "startTime": 170.9999942777,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "ngs",
      "speakerName": "伊吹渚",
      "speakerNameEn": "Nagisa",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-nagisa.png",
