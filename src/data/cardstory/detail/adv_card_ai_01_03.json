      "text": "愛がもしいなかったら、莉央とこころの面倒を\n僕一人で見るの？　それは勘弁してほしい",
      "translations": {
        "en": "Or are you going to leave me to take care\nof Rio and Kokoro on my own? Seriously?",
        "id": ""
      },
      "startTime": 222.9,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_stagesleeves-00-noon.webp",
      "bgName": "stagesleeves-00-noon",
      "startTime": 227.5
    },
    {
      "type": "dialogue",
      "speakerCode": "ai",
      "speakerName": "小美山愛",
      "speakerNameEn": "Ai",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-ai.png",
