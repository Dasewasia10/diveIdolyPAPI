      "bgName": "stagesleeves-00-noon",
      "startTime": 379.6666666666667
    },
    {
      "type": "dialogue",
      "speakerCode": "koh",
      "speakerName": "{user}",
      "speakerNameEn": "{user}",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-makino.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_ai_01_03/sud_vo_adv_card_ai_01_03-koh019.m4a",
      "text": "ああ、みんなにはちゃんと続けるって言っとくんだぞ",
      "translations": {
        "en": "Good! Make sure you let everyone know you’re not quitting.",
        "id": ""
      },
      "startTime": 379.6666666666667,
