      "text": "……葵さん、こんなに私のこと……",
      "translations": {
        "en": "I had no idea Aoi-san felt this way about me.",
        "id": ""
      },
      "startTime": 245.16666666666666,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "koh",
