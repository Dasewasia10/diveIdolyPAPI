      "text": "……莉央さん……",
      "translations": {
        "en": "Oh‚ Rio-san….",
        "id": ""
      },
      "startTime": 200.16666666666666,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "koh",
