      "speakerCode": "smr",
      "speakerName": "奥山すみれ",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-sumire.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_smr_10_01_short/sud_vo_adv_card_smr_10_01-smr001.m4a",
      "text": "ふーん、ふふーん……\nあ！　{user}さん、お疲れ様です！",
      "startTime": 15.1666666667,
      "sfxList": [
        {
          "src": "https://apiip.dasewasia.my.id/storyBgm/sud_se_adv_walk-in-single-02.m4a",
