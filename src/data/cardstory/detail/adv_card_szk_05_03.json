          "startTime": 1.4666666667
        }
      ]
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_stagesleeves-00-noon.webp",
      "bgName": "stagesleeves-00-noon",
      "startTime": 0
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_stagesleeves-00-noon.webp",
      "bgName": "stagesleeves-00-noon",
      "startTime": 1.466666786
    },
    {
      "type": "dialogue",
      "speakerCode": "koh",
      "speakerName": "{user}",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-makino.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_szk_05_03/sud_vo_adv_card_szk_05_03-koh001.m4a",
      "text": "雫、お疲れ様。いいステージだったよ\nお客さん達も、盛り上がっていたぞ",
      "startTime": 6.4666666429,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "szk",
      "speakerName": "兵藤雫",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-shizuku.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_szk_05_03/sud_vo_adv_card_szk_05_03-szk001.m4a",
      "text": "ふふ……あれから、意見を出し合ったり……\nみんなでいっぱい、頑張った、から……",
      "startTime": 13.3333333095,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_stagesleeves-00-noon.webp",
      "bgName": "stagesleeves-00-noon",
      "startTime": 16.3999999762
    },
    {
      "type": "dialogue",
      "speakerCode": "szk",
      "speakerName": "兵藤雫",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-shizuku.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_szk_05_03/sud_vo_adv_card_szk_05_03-szk002.m4a",
      "text": "合宿では、話が脱線したり、してたけど……\nそれが、良さでもあった、みたい……",
      "startTime": 21.1333333095,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "szk",
      "speakerName": "兵藤雫",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-shizuku.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_szk_05_03/sud_vo_adv_card_szk_05_03-szk003.m4a",
      "text": "なんでも、いつでも、全力で楽しんで……\n凄いエネルギーを、生み出して……",
      "startTime": 28.7666661342,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_stagesleeves-00-noon.webp",
      "bgName": "stagesleeves-00-noon",
      "startTime": 31.6666661342
    },
    {
      "type": "dialogue",
      "speakerCode": "szk",
      "speakerName": "兵藤雫",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-shizuku.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_szk_05_03/sud_vo_adv_card_szk_05_03-szk004.m4a",
      "text": "そのエネルギーが、今はこうして……\nファンのみんなも巻き込んで、最高のライブになった",
      "startTime": 35.2666661342,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_stagesleeves-00-noon.webp",
      "bgName": "stagesleeves-00-noon",
      "startTime": 39.7666656256
    },
    {
      "type": "dialogue",
      "speakerCode": "szk",
      "speakerName": "兵藤雫",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-shizuku.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_szk_05_03/sud_vo_adv_card_szk_05_03-szk005.m4a",
      "text": "ファンのみんなも、一緒に楽しんでくれたから……\n私達まで、エネルギーをもらえた気がする……",
      "startTime": 43.9666656256,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "szk",
      "speakerName": "兵藤雫",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-shizuku.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_szk_05_03/sud_vo_adv_card_szk_05_03-szk006.m4a",
      "text": "まるで、ファンのみんなも、全員で……\nパジャマパーティーした気分……",
      "startTime": 52.2333322923,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_stagesleeves-00-noon.webp",
      "bgName": "stagesleeves-00-noon",
      "startTime": 54.699997433
    },
    {
      "type": "dialogue",
      "speakerCode": "koh",
      "speakerName": "{user}",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-makino.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_szk_05_03/sud_vo_adv_card_szk_05_03-koh002.m4a",
      "text": "俺も沢山エネルギーをもらったよ\nいいユニットだな",
      "startTime": 57.5666640997,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "szk",
      "speakerName": "兵藤雫",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-shizuku.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_szk_05_03/sud_vo_adv_card_szk_05_03-szk007.m4a",
      "text": "ん……！　すみれちゃんと、こころちゃんと\nすずちゃんと、千紗ちゃんと……",
      "startTime": 63.8999979417,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_stagesleeves-00-noon.webp",
      "bgName": "stagesleeves-00-noon",
      "startTime": 67.1999979417
    },
    {
      "type": "dialogue",
      "speakerCode": "szk",
      "speakerName": "兵藤雫",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-shizuku.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_szk_05_03/sud_vo_adv_card_szk_05_03-szk008.m4a",
      "text": "五人でステージに立てて\n本当に……良かった",
      "startTime": 69.6999979417,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_stagesleeves-00-noon.webp",
      "bgName": "stagesleeves-00-noon",
      "startTime": 72.1999953985
    },
    {
      "type": "dialogue",
      "speakerCode": "koh",
      "speakerName": "{user}",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-makino.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_szk_05_03/sud_vo_adv_card_szk_05_03-koh003.m4a",
      "text": "……ん？\n雫、あっちですみれが呼んでるぞ",
      "startTime": 73.2999953985,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "szk",
      "speakerName": "兵藤雫",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-shizuku.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_szk_05_03/sud_vo_adv_card_szk_05_03-szk009.m4a",
      "text": "あ、うん\nこの後は、みんなで打ち上げ……",
      "startTime": 78.2333287318,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_stagesleeves-00-noon.webp",
      "bgName": "stagesleeves-00-noon",
      "startTime": 81.3333236456
    },
    {
      "type": "dialogue",
      "speakerCode": "szk",
      "speakerName": "兵藤雫",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-shizuku.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_szk_05_03/sud_vo_adv_card_szk_05_03-szk010.m4a",
      "text": "寮でね……\nパジャマパーティー……する……",
      "startTime": 82.6999903123,
      "sfxList": [
        {
          "src": "https://apiip.dasewasia.my.id/storyBgm/sud_se_adv_walk-in-single-02.m4a",
          "delay": 7460.004601400002,
          "startTime": 90.1599949137
        }
      ]
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_stagesleeves-00-noon.webp",
      "bgName": "stagesleeves-00-noon",
      "startTime": 85.0333236456
    },
    {
      "type": "dialogue",
      "speakerCode": "szk",
      "speakerName": "兵藤雫",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-shizuku.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_szk_05_03/sud_vo_adv_card_szk_05_03-szk011.m4a",
      "text": "呼んでるから、行くね……\nお疲れ様です、{user}さん……！",
      "startTime": 87.4333236456,
      "sfxList": [
        {
          "src": "https://apiip.dasewasia.my.id/storyBgm/sud_se_adv_message-01.m4a",
          "delay": 9800.009687699998,
          "startTime": 97.2333333333
        },
        {
          "src": "https://apiip.dasewasia.my.id/storyBgm/sud_se_adv_phone-tap-01.m4a",
          "delay": 11473.3221436,
          "startTime": 98.9066457892
        }
      ]
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_office-01-night.webp",
      "bgName": "3d_toffice_night",
      "startTime": 92.6833124559
    },
    {
      "type": "dialogue",
      "speakerCode": "koh",
      "speakerName": "{user}",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-makino.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_szk_05_03/sud_vo_adv_card_szk_05_03-koh004.m4a",
      "text": "今頃、パジャマパーティーは\n盛り上がってるんだろうな……ん？",
      "startTime": 95.4333124559,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "koh",
      "speakerName": "{user}",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-makino.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_szk_05_03/sud_vo_adv_card_szk_05_03-koh005.m4a",
      "text": "メッセージ……雫からか……\n画像もついてるな……",
      "startTime": 102.9666417201,
      "sfxList": [
        {
          "src": "https://apiip.dasewasia.my.id/storyBgm/sud_se_adv_phone-tap-01.m4a",
          "delay": 4883.352685000005,
          "startTime": 104.3166610718
        }
      ]
    },
    {
      "type": "dialogue",
      "speakerCode": "szk",
      "speakerName": "兵藤雫",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-shizuku.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_szk_05_03/sud_vo_adv_card_szk_05_03-szk012.m4a",
      "text": "「パジャマパーティー、楽しんでます\nオフショ、送るね」",
      "startTime": 108.4178066516,
      "sfxList": [
        {
          "src": "https://apiip.dasewasia.my.id/storyBgm/sud_se_adv_phone-call-01.m4a",
          "delay": 4248.845749599994,
          "startTime": 112.6666524012
        },
        {
          "src": "https://apiip.dasewasia.my.id/storyBgm/sud_se_adv_phone-tap-01.m4a",
          "delay": 7705.512416299996,
          "startTime": 116.1233190679
        }
      ]
    },
    {
      "type": "dialogue",
      "speakerCode": "koh",
      "speakerName": "{user}",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-makino.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_szk_05_03/sud_vo_adv_card_szk_05_03-koh006.m4a",
      "text": "すっかりリラックスしてるな\nっと、今度は電話……？　もしもし",
      "startTime": 113.6999857346,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "szk",
      "speakerName": "兵藤雫",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-shizuku.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_szk_05_03/sud_vo_adv_card_szk_05_03-szk013.m4a",
      "text": "{user}さん……\nオフショ、見た……？",
      "startTime": 121.699989295,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "koh",
      "speakerName": "{user}",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-makino.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_szk_05_03/sud_vo_adv_card_szk_05_03-koh007.m4a",
      "text": "あぁ、見たよ\n今返事をしようと……",
      "startTime": 124.8666559617,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "szk",
      "speakerName": "兵藤雫",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-shizuku.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_szk_05_03/sud_vo_adv_card_szk_05_03-szk014.m4a",
      "text": "みんな今日は、特に……可愛い……！",
      "startTime": 126.2133267212,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "szk",
      "speakerName": "兵藤雫",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-shizuku.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_szk_05_03/sud_vo_adv_card_szk_05_03-szk015.m4a",
      "text": "もう、ステージじゃないから\n写真……撮り放題……！",
      "startTime": 130.6000025194,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "szk",
      "speakerName": "兵藤雫",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-shizuku.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_szk_05_03/sud_vo_adv_card_szk_05_03-szk016.m4a",
      "text": "ファンサが手厚い……最高のイベント……！\n尊過ぎて、さとみさんと撮りまくってる……！",
      "startTime": 134.9666752896,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "koh",
      "speakerName": "{user}",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-makino.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_szk_05_03/sud_vo_adv_card_szk_05_03-koh008.m4a",
      "text": "同じユニットの打ち上げだろ……\nドルオタのスイッチが入ってるぞ",
      "startTime": 140.8666752896,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "szk",
      "speakerName": "兵藤雫",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-shizuku.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_szk_05_03/sud_vo_adv_card_szk_05_03-szk017.m4a",
      "text": "入って当然……！\n{user}さんも、来れば分かる……！",
      "startTime": 144.933328732,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "koh",
      "speakerName": "{user}",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-makino.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_szk_05_03/sud_vo_adv_card_szk_05_03-koh009.m4a",
      "text": "俺は遠慮しておくよ\nみんなで楽しんでくれ",
      "startTime": 149.4333236458,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "szk",
      "speakerName": "兵藤雫",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-shizuku.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_szk_05_03/sud_vo_adv_card_szk_05_03-szk018.m4a",
      "text": "そっか……じゃあ\nせめて、オフショ楽しんで……",
      "startTime": 153.6333226285,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "szk",
      "speakerName": "兵藤雫",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-shizuku.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_szk_05_03/sud_vo_adv_card_szk_05_03-szk019.m4a",
      "text": "{user}さんのおかげで\nみんなと一つになれたから、おすそ分け……",
      "startTime": 158.1333236458,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "szk",
      "speakerName": "兵藤雫",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-shizuku.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_szk_05_03/sud_vo_adv_card_szk_05_03-szk020.m4a",
      "text": "本当に……ありがとう\nじゃあ、お休みなさい……",
      "startTime": 164.9666488411,
      "sfxList": []
    },
