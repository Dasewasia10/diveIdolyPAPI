    },
    {
      "type": "dialogue",
      "speakerCode": "szk",
      "speakerName": "兵藤雫",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-shizuku.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_szk_51_01_short/sud_vo_adv_card_szk_51_01-szk003.m4a",
      "text": "これは、推しを拝めるチャンス……！\nドルオタダッシュで向かわなきゃ……！",
      "startTime": 20.4666662852,
      "sfxList": []
    },
    {
