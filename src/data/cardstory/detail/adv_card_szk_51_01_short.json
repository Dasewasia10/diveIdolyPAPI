      "speakerName": "kana",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-kana.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_szk_51_01_short/sud_vo_adv_card_szk_51_01-kan001.m4a",
      "text": "ねぇ、さくら\n昨日やってたドラマなんだけどさー",
      "startTime": 27.0333335876,
      "sfxList": [
        {
          "src": "https://apiip.dasewasia.my.id/storyBgm/sud_se_adv_run-in-single-02.m4a",
          "delay": 3099.998982799999,
