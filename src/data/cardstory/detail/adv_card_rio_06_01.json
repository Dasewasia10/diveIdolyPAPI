      "speakerName": "",
      "iconUrl": null,
      "voiceUrl": null,
      "text": "――大阪、合同カウントダウンライブ",
      "startTime": 0,
      "sfxList": [
        {
          "src": "https://apiip.dasewasia.my.id/storyBgm/sud_se_adv_cheers-in-01.m4a",
          "delay": 1866.6666667,
