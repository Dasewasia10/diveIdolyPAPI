    {
      "type": "sfx",
      "src": "https://apiip.dasewasia.my.id/storyBgm/sud_se_adv_walk-in-single-01.m4a",
      "startTime": 0.2666666667
    },
    {
      "type": "dialogue",
      "speakerCode": "szk",
      "speakerName": "兵藤雫",
      "speakerNameEn": "兵藤雫",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-shizuku.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_szk_09_02/sud_vo_adv_card_szk_09_02-szk001.m4a",
      "text": "あれ……{user}さん？\nレッスンスタジオで何してるの？　……仕事？",
      "translations": {
        "en": "あれ……{user}さん？\nレッスンスタジオで何してるの？　……仕事？",
        "id": ""
      },
      "startTime": 4.0666666667,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "szk",
      "speakerName": "兵藤雫",
      "speakerNameEn": "兵藤雫",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-shizuku.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_szk_09_02/sud_vo_adv_card_szk_09_02-szk002.m4a",
      "text": "お手伝い出来ることなら、言って？\n手伝うから。……荷物運びとか",
      "translations": {
        "en": "お手伝い出来ることなら、言って？\n手伝うから。……荷物運びとか",
        "id": ""
      },
      "startTime": 10.3,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "koh",
      "speakerName": "{user}",
      "speakerNameEn": "{user}",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-makino.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_szk_09_02/sud_vo_adv_card_szk_09_02-koh001.m4a",
      "text": "いや、仕事じゃなくて、練習したいことがあってな……\n俺はもう行くから、雫が使ってくれ",
      "translations": {
        "en": "いや、仕事じゃなくて、練習したいことがあってな……\n俺はもう行くから、雫が使ってくれ",
        "id": ""
      },
      "startTime": 17.2333333333,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "szk",
      "speakerName": "兵藤雫",
      "speakerNameEn": "兵藤雫",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-shizuku.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_szk_09_02/sud_vo_adv_card_szk_09_02-szk003.m4a",
      "text": "私は自主練しに来ただけだから、大丈夫\n……{user}さんは、なんの練習？",
      "translations": {
        "en": "私は自主練しに来ただけだから、大丈夫\n……{user}さんは、なんの練習？",
        "id": ""
      },
      "startTime": 24.644580555,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "koh",
      "speakerName": "{user}",
      "speakerNameEn": "{user}",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-makino.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_szk_09_02/sud_vo_adv_card_szk_09_02-koh002.m4a",
      "text": "俺は、星見プロの忘年会でやる、余興の練習だよ\nたまたまここが空いてたから、ちょっと借りてたんだ",
      "translations": {
        "en": "俺は、星見プロの忘年会でやる、余興の練習だよ\nたまたまここが空いてたから、ちょっと借りてたんだ",
        "id": ""
      },
      "startTime": 31.7333333333,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "szk",
      "speakerName": "兵藤雫",
      "speakerNameEn": "兵藤雫",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-shizuku.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_szk_09_02/sud_vo_adv_card_szk_09_02-szk004.m4a",
      "text": "忘年会の余興……？\n何するのか、聞いてもいい？",
      "translations": {
        "en": "忘年会の余興……？\n何するのか、聞いてもいい？",
        "id": ""
      },
      "startTime": 37.6532429378,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "koh",
      "speakerName": "{user}",
      "speakerNameEn": "{user}",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-makino.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_szk_09_02/sud_vo_adv_card_szk_09_02-koh003.m4a",
      "text": "その、実は……一曲歌う予定なんだ\n現役アイドルの前で歌うから、練習しておきたくてな",
      "translations": {
        "en": "その、実は……一曲歌う予定なんだ\n現役アイドルの前で歌うから、練習しておきたくてな",
        "id": ""
      },
      "startTime": 45.5,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "szk",
      "speakerName": "兵藤雫",
      "speakerNameEn": "兵藤雫",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-shizuku.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_szk_09_02/sud_vo_adv_card_szk_09_02-szk005.m4a",
      "text": "えっ、{user}さんが歌うの……！？\n楽しそう……。良かったら、レッスンしてみる？",
      "translations": {
        "en": "えっ、{user}さんが歌うの……！？\n楽しそう……。良かったら、レッスンしてみる？",
        "id": ""
      },
      "startTime": 53.2817676544,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "koh",
      "speakerName": "{user}",
      "speakerNameEn": "{user}",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-makino.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_szk_09_02/sud_vo_adv_card_szk_09_02-koh004.m4a",
      "text": "レッスン？　……待ってくれ\nまさか雫が俺に、歌のレッスンをするってことか！？",
      "translations": {
        "en": "レッスン？　……待ってくれ\nまさか雫が俺に、歌のレッスンをするってことか！？",
        "id": ""
      },
      "startTime": 60.5333333333,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "szk",
      "speakerName": "兵藤雫",
      "speakerNameEn": "兵藤雫",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-shizuku.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_szk_09_02/sud_vo_adv_card_szk_09_02-szk006.m4a",
      "text": "うん。木組みの街でも、ココアちゃん達に教えてあげた\n私、教えるの、意外と得意かも",
      "translations": {
        "en": "うん。木組みの街でも、ココアちゃん達に教えてあげた\n私、教えるの、意外と得意かも",
        "id": ""
      },
      "startTime": 69.9777993838,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "koh",
      "speakerName": "{user}",
      "speakerNameEn": "{user}",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-makino.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_szk_09_02/sud_vo_adv_card_szk_09_02-koh005.m4a",
      "text": "クリスマスライブにゲストで出てもらった時か\nあっ、そうか、雫達が教えたんだな",
      "translations": {
        "en": "クリスマスライブにゲストで出てもらった時か\nそうか、雫達が教えたんだな",
        "id": ""
      },
      "startTime": 77.3666666667,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "koh",
      "speakerName": "{user}",
      "speakerNameEn": "{user}",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-makino.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_szk_09_02/sud_vo_adv_card_szk_09_02-koh006.m4a",
      "text": "直接話す機会はなかったが、ステージは観たよ\nみんな、よく歌えていたな",
      "translations": {
        "en": "直接話す機会はなかったが、ステージは観たよ\nみんな、よく歌えていたな",
        "id": ""
      },
      "startTime": 85.0333333333,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "szk",
      "speakerName": "兵藤雫",
      "speakerNameEn": "兵藤雫",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-shizuku.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_szk_09_02/sud_vo_adv_card_szk_09_02-szk007.m4a",
      "text": "ココアちゃん達が、一生懸命やってくれたから\nいいステージに出来た",
      "translations": {
        "en": "ココアちゃん達が、一生懸命やってくれたから\nいいステージに出来た",
        "id": ""
      },
      "startTime": 91.3622207005,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "szk",
      "speakerName": "兵藤雫",
      "speakerNameEn": "兵藤雫",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-shizuku.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_szk_09_02/sud_vo_adv_card_szk_09_02-szk008.m4a",
      "text": "{user}さんも、せっかくなら……\n忘年会でみんなをビックリさせたく、ない？",
      "translations": {
        "en": "{user}さんも、せっかくなら……\n忘年会でみんなをビックリさせたく、ない？",
        "id": ""
      },
      "startTime": 95.6955540339,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "koh",
      "speakerName": "{user}",
      "speakerNameEn": "{user}",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-makino.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_szk_09_02/sud_vo_adv_card_szk_09_02-koh007.m4a",
      "text": "確かに、下手だなって思われるよりは\nそこそこ聴けるな、とは思われたいけど……",
      "translations": {
        "en": "確かに、下手だなって思われるよりは\nそこそこ聴けるな、とは思われたいけど……",
        "id": ""
      },
      "startTime": 103.4333333333,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "szk",
      "speakerName": "兵藤雫",
      "speakerNameEn": "兵藤雫",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-shizuku.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_szk_09_02/sud_vo_adv_card_szk_09_02-szk009.m4a",
      "text": "じゃあ、まずは一回、歌ってみせて\n改善点があれば、伝えるから",
      "translations": {
        "en": "じゃあ、まずは一回、歌ってみせて\n改善点があれば、伝えるから",
        "id": ""
      },
      "startTime": 110.4181840579,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "koh",
      "speakerName": "{user}",
      "speakerNameEn": "{user}",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-makino.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_szk_09_02/sud_vo_adv_card_szk_09_02-koh008.m4a",
      "text": "そうだな……うん、それじゃあちょっと恥ずかしいけど\nお手柔らかに頼むよ、雫先生。…………よし",
      "translations": {
        "en": "そうだな……うん、それじゃあちょっと恥ずかしいけど\nお手柔らかに頼むよ、雫先生。…………よし",
        "id": ""
      },
      "startTime": 120,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "koh",
      "speakerName": "{user}",
      "speakerNameEn": "{user}",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-makino.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_szk_09_02/sud_vo_adv_card_szk_09_02-koh009.m4a",
      "text": "出会いがあって、別れがあって、始まった物語♪\n嬉しくって、悔しくって、強くなった、それでも♪",
      "translations": {
        "en": "出会いがあって、別れがあって、始まった物語♪\n嬉しくって、悔しくって、強くなった、それでも♪",
        "id": ""
      },
      "startTime": 132.4333333333,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "szk",
      "speakerName": "兵藤雫",
      "speakerNameEn": "兵藤雫",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-shizuku.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_szk_09_02/sud_vo_adv_card_szk_09_02-szk010.m4a",
      "text": "えぇっっ！？　ど、どど、どういうことっ！？\n{user}さん、アイドルやってた……！？",
      "translations": {
        "en": "えぇっっ！？　ど、どど、どういうことっ！？\n{user}さん、アイドルやってた……！？",
        "id": ""
      },
      "startTime": 142.4537263552,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "szk",
      "speakerName": "兵藤雫",
      "speakerNameEn": "兵藤雫",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-shizuku.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_szk_09_02/sud_vo_adv_card_szk_09_02-szk011.m4a",
      "text": "か、歌唱力があり過ぎる。ボイストレーニングしたり\nCDの一、二枚出してないと、普通こんなに歌えない！",
      "translations": {
        "en": "か、歌唱力があり過ぎる。ボイストレーニングしたり\nCDの一、二枚出してないと、普通こんなに歌えない！",
        "id": ""
      },
      "startTime": 149.1203920046,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "koh",
      "speakerName": "{user}",
      "speakerNameEn": "{user}",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-makino.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_szk_09_02/sud_vo_adv_card_szk_09_02-koh010.m4a",
      "text": "し、雫、落ち着いてくれ。褒め過ぎだし\nアイドルをやってたことなんて一度もないから",
      "translations": {
        "en": "し、雫、落ち着いてくれ。褒め過ぎだし\nアイドルをやってたことなんて一度もないから",
        "id": ""
      },
      "startTime": 156.683818372,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "koh",
      "speakerName": "{user}",
      "speakerNameEn": "{user}",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-makino.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_szk_09_02/sud_vo_adv_card_szk_09_02-koh011.m4a",
      "text": "しいていえば、昔、カラオケが好きなやつに\n何度も連れて行かれてたからかな",
      "translations": {
        "en": "しいていえば、昔、カラオケが好きなやつに\n何度も連れて行かれてたからかな",
        "id": ""
      },
      "startTime": 163.9171517054,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "szk",
      "speakerName": "兵藤雫",
      "speakerNameEn": "兵藤雫",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-shizuku.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_szk_09_02/sud_vo_adv_card_szk_09_02-szk012.m4a",
      "text": "そういうレベルじゃない。いつステージに立っても\n大丈夫。……一応聞くけど……レッスン、必要……？",
      "translations": {
        "en": "そういうレベルじゃない。いつステージに立っても\n大丈夫。……一応聞くけど……レッスン、必要……？",
        "id": ""
      },
      "startTime": 170.0554059664,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "koh",
      "speakerName": "{user}",
      "speakerNameEn": "{user}",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-makino.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_szk_09_02/sud_vo_adv_card_szk_09_02-koh012.m4a",
      "text": "いやいや、必要だ\nせっかくだし、アドバイスしてほしいな",
      "translations": {
        "en": "いやいや、必要だ\nせっかくだし、アドバイスしてほしいな",
        "id": ""
      },
      "startTime": 178.4838122685,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "szk",
      "speakerName": "兵藤雫",
      "speakerNameEn": "兵藤雫",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-shizuku.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_szk_09_02/sud_vo_adv_card_szk_09_02-szk013.m4a",
      "text": "そっか……。より高みを目指すなら……うーん\n長音のところが、自信ないのか揺れてたから……そこと",
      "translations": {
        "en": "そっか……。より高みを目指すなら……うーん\n長音のところが、自信ないのか揺れてたから……そこと",
        "id": ""
      },
      "startTime": 188.4325202941,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "szk",
      "speakerName": "兵藤雫",
      "speakerNameEn": "兵藤雫",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-shizuku.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_szk_09_02/sud_vo_adv_card_szk_09_02-szk014.m4a",
      "text": "強調する音のところを……\nもっと、はっきり区切ってあげてもいいと思う……",
      "translations": {
        "en": "強調する音のところを……\nもっと、はっきり区切ってあげてもいいと思う……",
        "id": ""
      },
      "startTime": 196.9991869608,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "szk",
      "speakerName": "兵藤雫",
      "speakerNameEn": "兵藤雫",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-shizuku.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_szk_09_02/sud_vo_adv_card_szk_09_02-szk015.m4a",
      "text": "音程は、完璧……！\nリズムは少し、走り気味、かも……",
