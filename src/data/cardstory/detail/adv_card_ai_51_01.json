      "startTime": 289.3666403453,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "ai",
      "speakerName": "小美山愛",
      "speakerNameEn": "Ai",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-ai.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_ai_51_01/sud_vo_adv_card_ai_51_01-ai019.m4a",
      "text": "はぁ……ちょっとだけ心配だけど……\nとりあえず、お父さんに連絡しておこっと……",
      "translations": {
        "en": "Haa… I’m a little worried…\nBut for now‚ I’ll contact my dad…",
