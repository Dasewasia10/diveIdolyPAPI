      "startTime": 269.5999818166,
      "sfxList": [
        {
          "src": "https://apiip.dasewasia.my.id/storyBgm/sud_se_adv_gasa-01.m4a",
          "delay": 4366.689936300019,
          "startTime": 273.9666717529
        }
      ]
    },
    {
      "type": "dialogue",
      "speakerCode": "aoi",
      "speakerName": "井川葵",
      "speakerNameEn": "Aoi",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-aoi.png",
