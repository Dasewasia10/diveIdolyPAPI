      "text": "……うん。その気持ち、きっとお父さんに届くと思うよ",
      "translations": {
        "en": "…Yeah. I think your feelings will definitely reach your dad.",
        "id": ""
      },
      "startTime": 329.266618983,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "chs",
      "speakerName": "白石千紗",
      "speakerNameEn": "Chisa",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-chisa.png",
