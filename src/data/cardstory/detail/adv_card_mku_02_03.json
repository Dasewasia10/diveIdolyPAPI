      "text": "ミクを……自由研究のテーマに？",
      "translations": {
        "en": "N―nothing! Let's get something to eat!\nMiku‚ do you have any recommendations?",
        "id": ""
      },
      "startTime": 100.6451864243,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_okinawabeach-00-noon.webp",
