      "text": "今のお二人にとって過酷過ぎるのでは……！？",
      "startTime": 272.7334117255,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "ai",
      "speakerName": "小美山愛",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-ai.png",
