      "translations": {
        "en": "No‚ no‚ no‚ I didn’t say such a thing!\nChisa-san’s smile just looked a little ominous‚ that’s all.",
        "id": ""
      },
      "startTime": 218.3000234605,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "chs",
      "speakerName": "白石千紗",
      "speakerNameEn": "Chisa",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-chisa.png",
