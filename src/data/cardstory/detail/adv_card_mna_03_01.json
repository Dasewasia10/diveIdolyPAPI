      "text": "……ふぅーん。そうなんですかー",
      "startTime": 86.0999981163,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "mna",
      "speakerName": "長瀬麻奈",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-mana.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_mna_03_01/sud_vo_adv_cmn_mna_mean-01.m4a",
      "text": "それは良かったですねー",
      "startTime": 89.2999920128,
      "sfxList": []
    },
    {
      "type": "background",
