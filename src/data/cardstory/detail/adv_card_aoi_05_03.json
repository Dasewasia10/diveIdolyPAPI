      "text": "うん。それじゃあ――行ってくるよ",
      "translations": {
        "en": "Yeah. Well then‚ I'm off.",
        "id": ""
      },
      "startTime": 238.9666853269,
      "sfxList": [
        {
          "src": "https://apiip.dasewasia.my.id/storyBgm/sud_se_adv_walk-in-single-02.m4a",
          "delay": 3133.314673099989,
          "startTime": 242.1
        }
      ]
    },
    {
      "type": "background",
