      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_ski_06_01/sud_vo_adv_card_ski_06_01-ski026.m4a",
      "text": "気楽に喋れと言われても何を話せばいいのか……",
      "startTime": 229,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "koh",
      "speakerName": "{user}",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-makino.png",
