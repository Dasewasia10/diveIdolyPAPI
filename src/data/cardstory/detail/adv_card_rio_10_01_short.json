      "bgName": "dressingroom-01-noon",
      "startTime": 32.7989566645
    },
    {
      "type": "dialogue",
      "speakerCode": "koh",
      "speakerName": "{user}",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-makino.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_rio_10_01_short/sud_vo_adv_card_rio_10_01-koh003.m4a",
      "text": "ちょ、ちょっと待って下さい、莉央さん\n速過ぎます、追いつけませんから！",
      "startTime": 35.0000011444,
      "sfxList": []
    },
    {
