          "startTime": 116.966666158
        }
      ]
    },
    {
      "type": "dialogue",
      "speakerCode": "mhk",
      "speakerName": "miho",
      "speakerNameEn": "miho",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-miho.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_mhk_09_02/sud_vo_adv_card_mhk_09_02-mhk011.m4a",
      "text": "こころが？　……まぁいいでしょう、いただきます\nっぐ！？　……っ、なんなんですか、これ！？",
      "translations": {
        "en": "こころが？　……まぁいいでしょう、いただきます\nっぐ！？　……っ、なんなんですか、これ！？",
        "id": ""
      },
      "startTime": 128.4114279112,
      "sfxList": [
        {
          "src": "https://apiip.dasewasia.my.id/storyBgm/sud_se_adv_gasa-02.m4a",
          "delay": 4621.9054221,
          "startTime": 126.4
        }
      ]
    },
    {
      "type": "dialogue",
      "speakerCode": "koh",
      "speakerName": "{user}",
      "speakerNameEn": "{user}",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-makino.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_mhk_09_02/sud_vo_adv_card_mhk_09_02-koh009.m4a",
      "text": "え、何か変なものでも入って…………\nうわ、わさびクリームだこれ！？　なんて古典的な！？",
      "translations": {
        "en": "え、何か変なものでも入って…………\nうわ、わさびクリームだこれ！？　なんて古典的な！？",
        "id": ""
      },
      "startTime": 136.466666158,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "mhk",
      "speakerName": "miho",
      "speakerNameEn": "miho",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-miho.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_mhk_09_02/sud_vo_adv_card_mhk_09_02-mhk012.m4a",
      "text": "……騙し討ちでこんな物を食べさせて\n星見プロを辞めてほしいなら、素直に言ったらどうです",
      "translations": {
        "en": "……騙し討ちでこんな物を食べさせて\n星見プロを辞めてほしいなら、素直に言ったらどうです",
        "id": ""
      },
      "startTime": 144.8999994914,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "koh",
      "speakerName": "{user}",
      "speakerNameEn": "{user}",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-makino.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_mhk_09_02/sud_vo_adv_card_mhk_09_02-koh010.m4a",
      "text": "ち、違います！　さっきkanaさん達と会った時に\nmihoさんにかわりに渡しておいてと言われて……",
      "translations": {
        "en": "ち、違います！　さっきkanaさん達と会った時に\nmihoさんにかわりに渡しておいてと言われて……",
        "id": ""
      },
      "startTime": 152.0333328247,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "mhk",
      "speakerName": "miho",
      "speakerNameEn": "miho",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-miho.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_mhk_09_02/sud_vo_adv_card_mhk_09_02-mhk013.m4a",
      "text": "またkanaに騙されてるじゃないですか！\nあの子がタダでそんな親切する訳ないでしょう",
      "translations": {
        "en": "またkanaに騙されてるじゃないですか！\nあの子がタダでそんな親切する訳ないでしょう",
        "id": ""
      },
      "startTime": 157.7772820476,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "mhk",
      "speakerName": "miho",
      "speakerNameEn": "miho",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-miho.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_mhk_09_02/sud_vo_adv_card_mhk_09_02-mhk014.m4a",
      "text": "昨日今日、私達のマネージャーになった訳でも\nないのに。そろそろ学習して下さい",
      "translations": {
        "en": "昨日今日、私達のマネージャーになった訳でも\nないのに。そろそろ学習して下さい",
        "id": ""
      },
      "startTime": 163.5106153809,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "koh",
      "speakerName": "{user}",
      "speakerNameEn": "{user}",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-makino.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_mhk_09_02/sud_vo_adv_card_mhk_09_02-koh011.m4a",
      "text": "そんなこともない……と思うんですけど……\nいえ引っかかった俺が悪かったです、すみません！！",
      "translations": {
        "en": "そんなこともない……と思うんですけど……\nいえ引っかかった俺が悪かったです、すみません！！",
        "id": ""
      },
      "startTime": 171.2999994914,
      "sfxList": []
    },
