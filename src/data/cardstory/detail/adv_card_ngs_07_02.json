      "text": "本当ですか！？　いやでも、今は琴乃ちゃんが……\nあー！　いない！",
      "startTime": 133.4769861857,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_mall-00-noon.webp",
      "bgName": "mall-00-noon",
      "startTime": 135.7769861857
    },
    {
      "type": "dialogue",
