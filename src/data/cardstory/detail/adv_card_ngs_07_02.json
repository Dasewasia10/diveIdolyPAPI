      "text": "琴乃ちゃんを見る時だけは視力が上がるんです、私！",
      "startTime": 67.9600496609,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "koh",
      "speakerName": "{user}",
