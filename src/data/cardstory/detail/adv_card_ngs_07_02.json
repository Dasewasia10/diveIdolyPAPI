    },
    {
      "type": "dialogue",
      "speakerCode": "koh",
      "speakerName": "{user}",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-makino.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_ngs_07_02/sud_vo_adv_card_ngs_07_02-koh006.m4a",
      "text": "あ！　渚、あそこのカフェを見てくれ！　桃入り\nパンケーキが限定販売されてるぞ！　今が旬だもんな！",
      "startTime": 125.578258166,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_mall-00-noon.webp",
      "bgName": "mall-00-noon",
