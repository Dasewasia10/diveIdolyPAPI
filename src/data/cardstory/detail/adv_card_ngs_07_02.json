      "text": "も～、{user}さんのせいで\n見失っちゃったじゃないですか～！",
      "startTime": 137.910319519,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "koh",
      "speakerName": "{user}",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-makino.png",
