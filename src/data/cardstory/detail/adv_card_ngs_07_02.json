    {
      "type": "dialogue",
      "speakerCode": "ngs",
      "speakerName": "伊吹渚",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-nagisa.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_ngs_07_02/sud_vo_adv_card_ngs_07_02-ngs017.m4a",
      "text": "はぁ、はぁ……あれ？　琴乃ちゃんに、沙季ちゃん？\n二人で待ち合わせして何を……？",
      "startTime": 115.0851960182,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "ngs",
