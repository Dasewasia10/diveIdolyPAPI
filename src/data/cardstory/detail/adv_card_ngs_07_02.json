      "speakerCode": "ngs",
      "speakerName": "伊吹渚",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-nagisa.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_ngs_07_02/sud_vo_adv_card_ngs_07_02-ngs015.m4a",
      "text": "無意識に出ちゃうクセの数々……はぁぁ、可愛いな～",
