      "speakerName": "赤崎こころ",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-kokoro.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_kkr_01_02/sud_vo_adv_card_kkr_01_02-kkr031.m4a",
      "text": "{user}さん\n早く次のポーズの練習を始めましょう！",
      "startTime": 305.2666666666667,
      "sfxList": []
    },
    {
