      "text": "それは、そうなんですけど……",
      "translations": {
        "en": "That's true‚ but…",
        "id": ""
      },
      "startTime": 291.6333333333,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "ski",
      "speakerName": "白石沙季",
      "speakerNameEn": "Saki",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-saki.png",
