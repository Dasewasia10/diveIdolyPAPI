      "text": "とても反抗した一日だったな……\nこれはこれで癖になっちゃうかも",
      "startTime": 252.2,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "koh",
      "speakerName": "{user}",
