      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-saki.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_ski_03_01/sud_vo_adv_card_ski_03_01-ski031.m4a",
      "text": "アイドルは体調管理も仕事のうちなのに\n私、反抗的です！！",
      "startTime": 270.6666666667,
      "sfxList": []
    },
    {
      "type": "dialogue",
