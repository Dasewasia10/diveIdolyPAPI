      "speakerNameEn": "Saki",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-saki.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_ski_03_01/sud_vo_adv_card_ski_03_01-ski027.m4a",
      "text": "しかも……福神漬けすら用意しなかった！",
      "translations": {
        "en": "And I didn't even prepare side dishes!",
        "id": ""
      },
      "startTime": 244.9333333333,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "ski",
