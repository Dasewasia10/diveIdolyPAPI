      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_ski_03_01/sud_vo_adv_card_ski_03_01-koh012.m4a",
      "text": "そ、そうだな……間違ってはいないけど……",
      "translations": {
        "en": "Y-Yeah… you're not wrong‚ but…",
        "id": ""
      },
      "startTime": 197.1,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "ski",
