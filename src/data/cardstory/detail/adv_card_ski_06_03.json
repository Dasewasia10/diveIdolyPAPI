      "text": "私をこんなに喜ばせて、どういうつもりですか？",
      "translations": {
        "en": "Why are you making me so happy?",
        "id": ""
      },
      "startTime": 181.5,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "ski",
      "speakerName": "白石沙季",
      "speakerNameEn": "Saki",
