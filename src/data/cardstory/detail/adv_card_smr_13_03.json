    },
    {
      "type": "dialogue",
      "speakerCode": "smr",
      "speakerName": "奥山すみれ",
      "speakerNameEn": "奥山すみれ",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-sumire.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_smr_13_03/sud_vo_adv_card_smr_13_03-smr006.m4a",
      "text": "行こう行こう！　実は串カツも食べてみたいって\n思ってたんだよね！",
      "translations": {
        "en": "行こう行こう！　実は串カツも食べてみたいって\n思ってたんだよね！",
        "id": ""
      },
      "startTime": 130.2666666667,
      "sfxList": []
    },
    {
      "type": "background",
