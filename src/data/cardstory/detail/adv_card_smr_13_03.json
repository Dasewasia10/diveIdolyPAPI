    {
      "type": "dialogue",
      "speakerCode": "smr",
      "speakerName": "奥山すみれ",
      "speakerNameEn": "奥山すみれ",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-sumire.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_smr_13_03/sud_vo_adv_card_smr_13_03-smr003.m4a",
      "text": "いいんですか？　やったー！\nありがとうございます、{user}さん！",
      "translations": {
        "en": "いいんですか？　やったー！\nありがとうございます、{user}さん！",
        "id": ""
      },
      "startTime": 82.8333333333,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_onsenlobby-00-noon.webp",
