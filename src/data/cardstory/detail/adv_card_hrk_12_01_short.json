      "text": "佐伯遙子でっす、はるぴって呼んでね！\nバイブス爆アゲでいっくよー！",
      "startTime": 40.9,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "hrk",
      "speakerName": "佐伯遙子",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-haruko.png",
