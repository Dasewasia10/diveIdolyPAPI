      "bgName": "s1",
      "startTime": 24.7906119664
    },
    {
      "type": "dialogue",
      "speakerCode": "unknown",
      "speakerName": "？？？",
      "speakerNameEn": "",
      "iconUrl": null,
      "voiceUrl": null,
      "text": "すずにゃん……すずにゃーん……",
      "translations": {
        "en": "",
        "id": ""
      },
      "startTime": 24.7906119664,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_hauntedhouse-00-noon.webp",
      "bgName": "s1",
