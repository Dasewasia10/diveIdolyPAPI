        }
      ]
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_hauntedhouse-00-noon.webp",
      "bgName": "s1",
      "startTime": 12.7815869014
    },
    {
      "type": "dialogue",
      "speakerCode": "suz",
      "speakerName": "成宮すず",
      "speakerNameEn": "Suzu Narumiya",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-suzu.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_suz_13_03/sud_vo_adv_card_suz_13_03-suz002.m4a",
      "text": "え……そんなっ！？　扉がなくなっている！？\nひっ、気配があちこちから……来ないでくださいまし！",
      "translations": {
        "en": "",
        "id": ""
      },
      "startTime": 18.5666666667,
      "sfxList": []
    },
    {
      "type": "background",
