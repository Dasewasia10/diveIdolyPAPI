      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-makino.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_mhk_02_01/sud_vo_adv_card_mhk_02_01-koh015.m4a",
      "text": "ところで、さっきから気になってたんですけど\nmihoさん、顔色悪くありませんか？",
      "translations": {
        "en": "By the way‚ I've been meaning to ask‚\nYou're looking a little pale‚ miho-san. You alright?",
        "id": ""
      },
      "startTime": 183.2333333333,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_onsenlobby-00-noon.webp",
      "bgName": "onsenlobby-00-noon",
      "startTime": 186.2
    },
    {
      "type": "dialogue",
      "speakerCode": "mhk",
      "speakerName": "miho",
      "speakerNameEn": "miho",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-miho.png",
