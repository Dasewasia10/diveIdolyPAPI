      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-miho.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_mhk_02_01/sud_vo_adv_card_mhk_02_01-mhk021.m4a",
      "text": "……だって\nあんなに沢山、お酒を飲んだことなかったんです",
      "translations": {
        "en": "…But\nI've never drunk so much before.",
        "id": ""
      },
      "startTime": 204.2666666667,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_onsenlobby-00-noon.webp",
      "bgName": "onsenlobby-00-noon",
      "startTime": 207.2
    },
    {
      "type": "dialogue",
      "speakerCode": "mhk",
      "speakerName": "miho",
      "speakerNameEn": "miho",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-miho.png",
