      "speakerName": "白石沙季",
      "speakerNameEn": "Saki",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-saki.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_chs_51_03/sud_vo_adv_card_chs_51_03-ski012.m4a",
      "text": "ええ、千紗なら出来ると思っていたわ\n千紗は立派なアイドルで……私の、自慢の妹だもの",
      "translations": {
        "en": "Yes‚ I knew you could do it‚ Chisa.\nYou’re a fine idol… and my prideful little sister.",
        "id": ""
      },
      "startTime": 351.9115274585,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_hoshistage-00-night.webp",
      "bgName": "hoshistage-00-night",
      "startTime": 357.7915388029
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_hoshistage-00-night.webp",
      "bgName": "hoshistage-00-night",
      "startTime": 363.16664594
    },
    {
      "type": "dialogue",
      "speakerCode": "ski",
      "speakerName": "白石沙季",
      "speakerNameEn": "Saki",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-saki.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_chs_51_03/sud_vo_adv_card_chs_51_03-ski014.m4a",
