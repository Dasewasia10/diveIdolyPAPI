      "bgName": "hoshistage-00-night",
      "startTime": 333.4889600039
    },
    {
      "type": "dialogue",
      "speakerCode": "ski",
      "speakerName": "白石沙季",
      "speakerNameEn": "Saki",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-saki.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_chs_51_03/sud_vo_adv_card_chs_51_03-ski011.m4a",
      "text": "頑張ったわね、千紗\n千紗の温かい気持ちが、沢山伝わってきたわ",
      "translations": {
        "en": "You did well‚ Chisa.\nI could feel all of your warm feelings.",
        "id": ""
      },
      "startTime": 335.5666968027,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_hoshistage-00-night.webp",
      "bgName": "hoshistage-00-night",
      "startTime": 339.3389804998
    },
    {
      "type": "dialogue",
      "speakerCode": "chs",
      "speakerName": "白石千紗",
      "speakerNameEn": "Chisa",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-chisa.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_chs_51_03/sud_vo_adv_card_chs_51_03-chs025.m4a",
      "text": "おねえ……ちゃん……っ……\nうんっ……頑張ったよ……一人でも……私……！",
      "translations": {
        "en": "Saki… chan…\nY-yeah… I did my best… even by myself… me…!",
