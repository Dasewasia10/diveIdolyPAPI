      "bgName": "osaka-00-night",
      "startTime": 158.0482698597
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_osaka-00-night.webp",
      "bgName": "osaka-00-night",
      "startTime": 158.0482698597
    },
    {
      "type": "dialogue",
      "speakerCode": "skr",
      "speakerName": "川咲さくら",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-sakura.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_skr_08_02/sud_vo_adv_card_skr_08_02-skr014.m4a",
      "text": "練習に付き合ってくれて、本当に助かりました！\nおかげで、明日は安心して始球式に臨めます",
      "startTime": 164.4316042103,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_osaka-00-night.webp",
      "bgName": "osaka-00-night",
      "startTime": 164.4316042103
    },
    {
      "type": "dialogue",
      "speakerCode": "koh",
