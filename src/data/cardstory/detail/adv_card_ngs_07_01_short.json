      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "koh",
      "speakerName": "{user}",
      "speakerNameEn": "{user}",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-makino.png",
      "voiceUrl": null,
      "text": "夏のライブイベントの準備はどうだ？",
      "translations": {
        "en": "How are the preparations for the summer live event going?",
        "id": ""
      },
      "startTime": 3.8333332141,
