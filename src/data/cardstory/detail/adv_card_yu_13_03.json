      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_schoolgymstage-00-noon.webp",
      "bgName": "schoolgymstage-01-noon",
      "startTime": 319.8400580087
    },
    {
      "type": "dialogue",
