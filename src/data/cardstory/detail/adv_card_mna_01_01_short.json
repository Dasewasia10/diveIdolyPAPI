    },
    {
      "type": "dialogue",
      "speakerCode": "mna",
      "speakerName": "長瀬麻奈",
      "speakerNameEn": "Mana",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-mana.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_mna_01_01_short/sud_vo_adv_card_mna_01_01-mna002.m4a",
      "text": "今日は油断して二度寝しちゃった～\n琴乃もお母さんも、起こしてくれないんだもん",
      "translations": {
        "en": "I let my guard down and overslept!\nKotono and mom didn’t wake me up…",
        "id": ""
      },
      "startTime": 26.5,
      "sfxList": []
    },
    {
