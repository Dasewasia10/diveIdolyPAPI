      "bgName": "stage1",
      "startTime": 15.969818401336703
    },
    {
      "type": "dialogue",
      "speakerCode": "koh",
      "speakerName": "{user}",
      "speakerNameEn": "{user}",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-makino.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_rui_01_03/sud_vo_adv_card_rui_01_03-koh003.m4a",
      "text": "お疲れ様です。今日は見学と挨拶回りで伺いました\n天動さんはリハーサル終わりですか？",
      "translations": {
        "en": "Hello. I came to observe and say hello.\nDid you just get out of a rehearsal?",
        "id": ""
      },
      "startTime": 23.089929705858236,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_livecorridor-00-noon.webp",
      "bgName": "stage1",
      "startTime": 25.657096914450364
    },
    {
      "type": "dialogue",
      "speakerCode": "rui",
      "speakerName": "天動瑠依",
      "speakerNameEn": "Rui",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-rui.png",
