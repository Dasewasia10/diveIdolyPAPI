      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_tokyokkrroom-00-night.webp",
      "bgName": "tokyokkrroom-00-night"
    },
    {
      "type": "dialogue",
      "speakerCode": "kkr",
      "speakerName": "赤崎こころ",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-kokoro.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_rio_53_02/sud_vo_adv_card_rio_53_02-kkr010.m4a",
      "text": "今の私達があるのは、間違いなく莉央さんのおかげです\n前に、自信をなくしてた時もあったみたいですが……",
      "startTime": 132.3333404541,
      "sfxList": []
    },
