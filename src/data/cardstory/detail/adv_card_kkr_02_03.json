      "text": "……なあ、少し気負い過ぎてるんじゃないか？",
      "translations": {
        "en": "…Hey. Are you sure you’re not overthinking this?",
        "id": ""
      },
      "startTime": 158.86666666666667,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "kkr",
      "speakerName": "赤崎こころ",
      "speakerNameEn": "Kokoro",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-kokoro.png",
