{
  "id": "adv_card_mhk_08_02",
  "title": "miho",
  "script": [
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_tokyocorridor-00-noon.webp",
      "bgName": "s1",
      "startTime": 0
    },
    {
      "type": "dialogue",
      "speakerCode": "koh",
