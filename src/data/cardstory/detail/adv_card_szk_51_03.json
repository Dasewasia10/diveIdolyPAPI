      "speakerNameEn": "kana",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-kana.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_szk_51_03/sud_vo_adv_card_szk_51_03-kan013.m4a",
      "text": "趣味悪いんじゃないの？",
      "translations": {
