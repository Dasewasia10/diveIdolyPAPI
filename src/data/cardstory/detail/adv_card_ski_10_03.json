      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_ski_10_03/sud_vo_adv_card_ski_10_03-koh009.m4a",
      "text": "そうか。まぁ、ゆっくり出来ているなら何よりだ",
      "translations": {
        "en": "I see. Well‚ as long as you’re relaxed‚ that’s what matters.",
        "id": ""
      },
      "startTime": 193.9999976319,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "ski",
      "speakerName": "白石沙季",
      "speakerNameEn": "Saki",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-saki.png",
