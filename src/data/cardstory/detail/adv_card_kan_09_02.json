      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_kan_09_02/sud_vo_adv_card_kan_09_02-kan012.m4a",
      "text": "ん、誰か来た？\n……ちっ、向こうからお出ましか",
      "startTime": 119.6451014521,
      "sfxList": [
        {
          "src": "https://apiip.dasewasia.my.id/storyBgm/sud_se_adv_run-in-single-02.m4a",
