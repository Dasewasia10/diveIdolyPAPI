      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_kan_09_02/sud_vo_adv_card_kan_09_02-koh001.m4a",
      "text": "（事前に用意してたネタを、そのまま使われたからな）\n（kanaさんは、どう答えるんだ……！？）",
      "startTime": 5.4666666667,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_press-00-noon.webp",
