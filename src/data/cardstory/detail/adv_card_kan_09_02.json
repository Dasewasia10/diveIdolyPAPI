    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_livecorridor-00-noon.webp",
      "bgName": "livecorridor-00-noon"
    },
    {
      "type": "dialogue",
      "speakerCode": "kan",
      "speakerName": "kana",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-kana.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_kan_09_02/sud_vo_adv_card_kan_09_02-kan013.m4a",
      "text": "あ、コロ子ちゃん！　さっきはお疲れ～！\n次の撮影……って、いきなり泣き出してどうしたの！？",
      "startTime": 126.4784307165,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "kan",
      "speakerName": "kana",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-kana.png",
