      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-kana.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_kan_09_02/sud_vo_adv_card_kan_09_02-kan018.m4a",
      "text": "ん？　また、誰か来たみたい\n……あ、社長！　今日はありがとうございます！",
      "startTime": 177.3812241716,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "koh",
      "speakerName": "{user}",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-makino.png",
