      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_mhk_52_03/sud_vo_adv_card_mhk_52_03-mhk019.m4a",
      "text": "すみません、こちらに大根サラダのお代わりと\n赤ワインをボトルでお願いします",
      "translations": {
        "en": "Excuse me‚ another serving of radish salad‚\nand another bottle of red wine‚ please.",
        "id": ""
      },
      "startTime": 191.2999984742,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_pub-00-night.webp",
      "bgName": "pub-00-night",
