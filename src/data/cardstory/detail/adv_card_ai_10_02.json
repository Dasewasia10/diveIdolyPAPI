      "startTime": 226.9666732788,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "ai",
      "speakerName": "小美山愛",
      "speakerNameEn": "Ai",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-ai.png",
