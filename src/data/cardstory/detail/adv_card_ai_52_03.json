          "startTime": 171.7110293071
        }
      ]
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_jungle-00-noon.webp",
      "bgName": "jungle-00-noon",
      "startTime": 171.5443603515
    },
    {
      "type": "dialogue",
      "speakerCode": "koh",
      "speakerName": "{user}",
      "speakerNameEn": "{user}",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-makino.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_ai_52_03/sud_vo_adv_card_ai_52_03-koh006.m4a",
      "text": "あ、あぁ……看板が……見えてきた……\nあれが、幻のラーメン屋さん……！",
      "translations": {
        "en": "Ah‚ ahh… can see… the sign…\nThat's‚ the legendary ramen shop…!",
        "id": ""
      },
      "startTime": 178.9666638691,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_jungle-00-noon.webp",
