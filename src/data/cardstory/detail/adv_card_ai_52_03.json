    },
    {
      "type": "dialogue",
      "speakerCode": "ai",
      "speakerName": "小美山愛",
      "speakerNameEn": "Ai",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-ai.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_ai_52_03/sud_vo_adv_card_ai_52_03-ai016.m4a",
      "text": "やった！　私達、ついに探し当てたんです！\n『DENSETSU』は、本当にあったんです！！",
      "translations": {
        "en": "Hooray! We finally arrived it!\n\"DENSETSU\"‚ really existed!!",
        "id": ""
