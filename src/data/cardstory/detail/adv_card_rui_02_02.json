      "text": "そんなこと……\nもっと自信を持って下さい",
      "translations": {
        "en": "That’s not…\nYou should be more confident in yourself.",
        "id": ""
      },
      "startTime": 220.33333333333334,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_tokyocorridor-00-noon.webp",
      "bgName": "tokyocorridor-00-noon",
      "startTime": 222.93333333333334
    },
    {
      "type": "dialogue",
      "speakerCode": "rui",
      "speakerName": "天動瑠依",
      "speakerNameEn": "Rui",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-rui.png",
