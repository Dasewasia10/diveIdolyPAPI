      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_rik_01_02/sud_vo_adv_card_rik_01_02-rik001.m4a",
      "text": "ふぅ……見つからずに済んで良かった\nありがとう、雫ちゃん",
      "startTime": 4.4666666667,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "szk",
      "speakerName": "兵藤雫",
