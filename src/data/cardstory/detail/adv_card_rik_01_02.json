      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_rik_01_02/sud_vo_adv_card_rik_01_02-szk001.m4a",
      "text": "気にしないで。気持ち、分かるから\nのんびり、お散歩しながら行くのも、悪くないし",
      "startTime": 10.4333333333,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_tokyopark-00-noon.webp",
