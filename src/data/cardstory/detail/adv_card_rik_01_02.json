      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-rik.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_rik_01_02/sud_vo_adv_card_rik_01_02-rik002.m4a",
      "text": "……ふふ、雫ちゃんって、とっても優しいのね",
      "startTime": 14.4689115524,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_tokyopark-00-noon.webp",
