      "text": "はぁ、はぁ、はぁ……\n今度は……ショッピングモール？",
      "startTime": 51.5050559361,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "szk",
      "speakerName": "兵藤雫",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-shizuku.png",
