      "text": "受け取ってくれて……\nありがとうございます",
      "translations": {
        "en": "You accepted my gift.\nThank you.",
        "id": ""
      },
      "startTime": 221.43333333333334,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "chs",
      "speakerName": "白石千紗",
      "speakerNameEn": "Chisa",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-chisa.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_chs_01_03/sud_vo_adv_card_chs_01_03-chs027.m4a",
      "text": "おかげで私、なんだか今日は\nいつもより自信が持てる気がします",
      "translations": {
