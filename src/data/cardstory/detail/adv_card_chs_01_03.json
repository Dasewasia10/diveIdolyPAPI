      "text": "そうか……もちろん嬉しいんだけど\nなんで俺に？",
      "translations": {
        "en": "I see… That makes me happy‚ sure‚\nbut why for me?",
        "id": ""
      },
      "startTime": 178.03333333333333,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "chs",
      "speakerName": "白石千紗",
      "speakerNameEn": "Chisa",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-chisa.png",
