      "bgName": "okinawastage-00-noon",
      "startTime": 96.7932538585
    },
    {
      "type": "dialogue",
      "speakerCode": "ngs",
      "speakerName": "伊吹渚",
      "speakerNameEn": "Nagisa",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-nagisa.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_ngs_07_03/sud_vo_adv_card_ngs_07_03-ngs010.m4a",
      "text": "本当に……本っ当に、ありがとうございます！",
