      "text": "はい！　行ってきますね！",
      "translations": {
        "en": "Okay! I’m off!",
        "id": ""
      },
      "startTime": 29.6266679046,
      "sfxList": [
        {
          "src": "https://apiip.dasewasia.my.id/storyBgm/sud_se_adv_popper-01.m4a",
