    },
    {
      "type": "dialogue",
      "speakerCode": "ngs",
      "speakerName": "伊吹渚",
      "speakerNameEn": "Nagisa",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-nagisa.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_ngs_07_03/sud_vo_adv_card_ngs_07_03-ngs001.m4a",
      "text": "えへへ、ありがとうございます\nこの衣装、とっても可愛いですよね！",
      "translations": {
        "en": "Ehehe‚ thank you.\nThis outfit is so cute!",
        "id": ""
      },
      "startTime": 8.1966661372,
      "sfxList": []
    },
    {
      "type": "background",
