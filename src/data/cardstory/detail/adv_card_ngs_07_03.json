    },
    {
      "type": "dialogue",
      "speakerCode": "ngs",
      "speakerName": "伊吹渚",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-nagisa.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_ngs_07_03/sud_vo_adv_card_ngs_07_03-ngs011.m4a",
      "text": "ライブ、無事に終わって良かったです",
      "startTime": 105.8599098439,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "koh",
      "speakerName": "{user}",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-makino.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_ngs_07_03/sud_vo_adv_card_ngs_07_03-koh005.m4a",
      "text": "渚へのサプライズも成功して良かったよ",
      "startTime": 108.8599098439,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_okinawabeach-00-night.webp",
      "bgName": "okinawabeach-00-night"
    },
    {
      "type": "dialogue",
