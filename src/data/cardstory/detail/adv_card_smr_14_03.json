      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-sumire.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_smr_14_03/sud_vo_adv_card_smr_14_03-smr012.m4a",
      "text": "……と、後悔はここまでです\nそろそろリハの時間ですし、行きましょう！",
      "startTime": 176.1307048478,
      "sfxList": [
        {
          "src": "https://apiip.dasewasia.my.id/storyBgm/sud_se_adv_door-open-01.m4a",
