      "speakerName": "{user}",
      "speakerNameEn": "{user}",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-makino.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_hrk_01_01/sud_vo_adv_card_hrk_01_01-koh011.m4a",
      "text": "大丈夫です\n今日まで一緒にやってきた俺を、信じて下さい",
      "translations": {
        "en": "You bet.\nWe’ve come this far together. You can trust me.",
        "id": ""
