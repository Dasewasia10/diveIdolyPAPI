      "startTime": 216.53333333333333,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "hrk",
      "speakerName": "佐伯遙子",
      "speakerNameEn": "Haruko",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-haruko.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_hrk_01_01/sud_vo_adv_card_hrk_01_01-hrk027.m4a",
      "text": "もう……本当に大丈夫かなぁ？",
      "translations": {
        "en": "Are you really up for this?",
        "id": ""
      },
      "startTime": 220.8,
      "sfxList": []
    },
    {
      "type": "dialogue",
