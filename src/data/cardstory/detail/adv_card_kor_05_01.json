      "bgName": "env_adv_2d_tokyoentrance-00-noon"
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_tokyoentrance-00-noon.webp",
      "bgName": "env_adv_2d_tokyoentrance-00-noon"
    },
    {
      "type": "dialogue",
      "speakerCode": "kor",
      "speakerName": "fran",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-fran.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_kor_05_01/sud_vo_adv_card_kor_05_01-kor022.m4a",
      "text": "あ、{user}さん、おはようございます\n今日は早いですね",
      "startTime": 204.1666309994,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "koh",
      "speakerName": "{user}",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-makino.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_kor_05_01/sud_vo_adv_card_kor_05_01-koh009.m4a",
      "text": "おはようございます、franさんも早いですね\n……あの、玄関で何をやってらっしゃるんですか？",
      "startTime": 209.5999643327,
      "sfxList": []
    },
