      "text": "新年早々、二つも夢が叶っちゃいました",
      "startTime": 185.3333333333,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_dressingroom-00-noon.webp",
      "bgName": "stage02",
      "startTime": 189.1666666667
    },
    {
      "type": "dialogue",
      "speakerCode": "koh",
      "speakerName": "{user}",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-makino.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_skr_03_02/sud_vo_adv_card_skr_03_02-koh010.m4a",
      "text": "そうか……\nさくらはいい正月を過ごせたみたいだな",
