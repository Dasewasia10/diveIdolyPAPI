      "speakerNameEn": "Everyone",
      "iconUrl": null,
      "voiceUrl": null,
      "text": "テーマパーク！！",
      "translations": {
        "en": "Theme park!!",
        "id": ""
      },
      "startTime": 159.1370286546,
      "sfxList": []
    },
    {
      "type": "background",
