      "speakerName": "白石沙季",
      "speakerNameEn": "Saki",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-saki.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_ski_02_03/sud_vo_adv_card_ski_02_03-ski022.m4a",
      "text": "ふぅ……なんとかなった、のかな",
      "translations": {
        "en": "Phew… I did it.",
        "id": ""
      },
      "startTime": 167.33333333333334,
      "sfxList": [
        {
          "src": "https://apiip.dasewasia.my.id/storyBgm/sud_se_adv_walk-in-single-02.m4a",
