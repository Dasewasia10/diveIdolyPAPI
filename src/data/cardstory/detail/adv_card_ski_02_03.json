      "text": "これも、{user}さんの\nアドバイスのおかげです",
      "translations": {
        "en": "It’s all thanks\nto {user}-san's advice.",
        "id": ""
      },
      "startTime": 234.074448003372,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_stagesleeves-00-noon.webp",
      "bgName": "stage03",
      "startTime": 237.2
    },
    {
      "type": "dialogue",
