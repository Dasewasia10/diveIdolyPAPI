      "startTime": 229.633336385,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "koh",
      "speakerName": "{user}",
      "speakerNameEn": "{user}",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-makino.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_yu_09_03/sud_vo_adv_card_yu_09_03-koh010.m4a",
      "text": "来年も特番をやることになったら\nぜひMCを引き受けていただきたいです、だそうだ",
