    },
    {
      "type": "dialogue",
      "speakerCode": "koh",
      "speakerName": "{user}",
      "speakerNameEn": "{user}",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-makino.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_yu_09_03/sud_vo_adv_card_yu_09_03-koh012.m4a",
      "text": "あんまり一人で無理はしないようにな",
      "translations": {
        "en": "Don’t overwork yourself.",
