      "startTime": 220.2666697184,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "yu",
      "speakerName": "鈴村優",
      "speakerNameEn": "Yu",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-yu.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_yu_09_03/sud_vo_adv_card_yu_09_03-yu025.m4a",
      "text": "ふふ、相変わらず謙虚なお人やなぁ",
