      },
      "startTime": 214.4666697184,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "koh",
      "speakerName": "{user}",
      "speakerNameEn": "{user}",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-makino.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_yu_09_03/sud_vo_adv_card_yu_09_03-koh008.m4a",
      "text": "俺はマネージャーとして当たり前のことをしただけだよ\n優達の頑張りがあったからこそだ",
      "translations": {
