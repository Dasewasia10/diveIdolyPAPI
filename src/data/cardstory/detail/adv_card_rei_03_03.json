      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_livecorridor-00-noon.webp",
      "bgName": "livecorridor-00-noon"
    },
    {
      "type": "dialogue",
      "speakerCode": "rei",
      "speakerName": "一ノ瀬怜",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-rei.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_rei_03_03/sud_vo_adv_card_rei_03_03-rei009.m4a",
      "text": "くっ、まだまだ……！　ああああっ……！",
      "startTime": 93.9333333333,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "rei",
      "speakerName": "一ノ瀬怜",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-rei.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_rei_03_03/sud_vo_adv_card_rei_03_03-rei010.m4a",
      "text": "くうううううううっ……！",
      "startTime": 101.8,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_livecorridor-00-noon.webp",
      "bgName": "livecorridor-00-noon"
    },
    {
      "type": "dialogue",
      "speakerCode": "koh",
      "speakerName": "{user}",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-makino.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_rei_03_03/sud_vo_adv_card_rei_03_03-koh008.m4a",
      "text": "（凄い声だ……怜のあんな声、初めて聞いたぞ）\n（ダメか？　俺にはもう祈ることしか出来ない……）",
      "startTime": 112.1,
      "sfxList": [
        {
          "src": "https://apiip.dasewasia.my.id/storyBgm/sud_se_adv_door-open-01.m4a",
