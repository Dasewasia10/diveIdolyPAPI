      "text": "でも忙しいのはいいことですよね！\nこの後のお仕事も頑張りますよ～！",
      "startTime": 36.5333350976,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "koh",
      "speakerName": "{user}",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-makino.png",
