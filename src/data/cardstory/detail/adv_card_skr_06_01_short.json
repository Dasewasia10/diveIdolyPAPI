      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-makino.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_skr_06_01_short/sud_vo_adv_card_skr_06_01-koh001.m4a",
      "text": "ニヤニヤしてどうしたんだ？",
      "translations": {
        "en": "Why the big smile?",
        "id": ""
      },
      "startTime": 6.9052384653,
      "sfxList": []
    },
    {
      "type": "background",
