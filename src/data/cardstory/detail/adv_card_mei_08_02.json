      "speakerName": "{user}",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-makino.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_mei_08_02/sud_vo_adv_card_mei_08_02-koh001.m4a",
      "text": "芽衣とすずは、大会でも頑張っていたからな\nたまにはいいかと思ったんだよ",
      "startTime": 14.1666666667,
      "sfxList": []
    },
    {
      "type": "background",
