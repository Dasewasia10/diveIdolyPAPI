      "text": "え～？\n{user}さんとも繋ぎたかったのにな～",
      "startTime": 29.8333332697,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_mall-00-noon.webp",
      "bgName": "mall-00-noon",
      "startTime": 33.4000017165
    },
    {
      "type": "dialogue",
      "speakerCode": "mei",
      "speakerName": "早坂芽衣",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-mei.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_mei_08_02/sud_vo_adv_card_mei_08_02-mei005.m4a",
      "text": "あ……そういえばここのショッピングモール\n麻奈ちゃんと遊びに来たことがあるよ",
      "startTime": 38.2333350498,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "koh",
      "speakerName": "{user}",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-makino.png",
