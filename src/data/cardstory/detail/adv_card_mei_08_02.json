      "bgName": "mall-00-noon",
      "startTime": 138.1333164852
    },
    {
      "type": "dialogue",
      "speakerCode": "mei",
      "speakerName": "早坂芽衣",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-mei.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_mei_08_02/sud_vo_adv_card_mei_08_02-mei016.m4a",
      "text": "……あれ？\n麻奈ちゃん、なんか照れてる？",
      "startTime": 139.4999831518,
