      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_mei_08_02/sud_vo_adv_card_mei_08_02-mei021.m4a",
      "text": "あはは、{user}さんてば\n麻奈ちゃんとおんなじ反応してる",
      "startTime": 190.5666426994,
      "sfxList": []
    },
    {
      "type": "background",
