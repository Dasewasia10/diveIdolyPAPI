      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_mei_08_02/sud_vo_adv_card_mei_08_02-koh005.m4a",
      "text": "俺は犬に似てるのか……？",
      "startTime": 108.8666447323,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "mei",
      "speakerName": "早坂芽衣",
