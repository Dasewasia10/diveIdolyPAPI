      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-makino.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_suz_06_01/sud_vo_adv_card_suz_06_01-koh014.m4a",
      "text": "やっぱり浮かれてるな……\n張り切り過ぎて反動がこなければいいが……",
      "translations": {
        "en": "She's definitely Christmas high……\nI hope she doesn't crash afterward…",
        "id": ""
      },
      "startTime": 307.7666666667,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_dressingroom-00-noon.webp",
      "bgName": "dressingroom-00-noon",
