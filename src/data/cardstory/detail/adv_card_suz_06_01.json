      "speakerCode": "koh",
      "speakerName": "{user}",
      "speakerNameEn": "{user}",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-makino.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_suz_06_01/sud_vo_adv_card_suz_06_01-koh013.m4a",
      "text": "行くってどこへ？",
      "translations": {
        "en": "Where are we going?",
        "id": ""
      },
      "startTime": 288.7,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "suz",
      "speakerName": "成宮すず",
      "speakerNameEn": "Suzu",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-suzu.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_suz_06_01/sud_vo_adv_card_suz_06_01-suz034.m4a",
      "text": "{user}さんと一緒に、この近くにある\n大きなクリスマスツリーを見に行きたいのです",
      "translations": {
        "en": "I'd like to go with {user}-san to see\nthe big Christmas tree nearby.",
        "id": ""
      },
      "startTime": 293.6666666667,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_dressingroom-00-noon.webp",
      "bgName": "dressingroom-00-noon",
      "startTime": 297.1333333333
    },
    {
      "type": "dialogue",
      "speakerCode": "suz",
      "speakerName": "成宮すず",
      "speakerNameEn": "Suzu",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-suzu.png",
