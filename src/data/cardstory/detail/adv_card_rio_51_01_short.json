      "startTime": 28.715895756,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "aoi",
      "speakerName": "井川葵",
      "speakerNameEn": "Aoi",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-aoi.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_rio_51_01_short/sud_vo_adv_card_rio_51_01-aoi002.m4a",
      "text": "とっくに終わったよ。今は休憩中なんだ\nこれを読んでたところ",
      "translations": {
        "en": "I finished a while ago. I'm on break now.\nI was reading this.",
        "id": ""
      },
      "startTime": 35.0333334445,
      "sfxList": [
