      "startTime": 104.3948859773
    },
    {
      "type": "dialogue",
      "speakerCode": "kkr",
      "speakerName": "赤崎こころ",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-kokoro.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_ymk_01_02/sud_vo_adv_card_ymk_01_02-kkr005.m4a",
      "text": "くぅ……こころ、完全に火が付きましたよ！\nリベンジです～！",
      "startTime": 108.8282106639,
      "sfxList": []
    },
