      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-rio.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_ymk_01_02/sud_vo_adv_card_ymk_01_02-rio015.m4a",
      "text": "ありがとう、ミク……！\nせっかくだし、お願いしようかしら。いいわよね？",
      "startTime": 231.8269264699,
      "sfxList": []
    },
    {
      "type": "background",
