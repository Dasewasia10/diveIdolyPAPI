      "text": "ふふっ、そうだね！",
      "startTime": 101.7666671753,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_karaokeroom-00-noon.webp",
