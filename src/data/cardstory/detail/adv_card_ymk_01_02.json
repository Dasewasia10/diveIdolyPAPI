      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_karaokeroom-00-noon.webp",
      "bgName": "karaokeroom-00-noon",
      "startTime": 90.1260830167
    },
    {
      "type": "dialogue",
      "speakerCode": "kkr",
      "speakerName": "赤崎こころ",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-kokoro.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_ymk_01_02/sud_vo_adv_card_ymk_01_02-kkr004.m4a",
      "text": "きゅ……98点！？\nしかも、初めてのデュエットなのに……！",
      "startTime": 92.8594077033,
      "sfxList": []
    },
    {
      "type": "background",
