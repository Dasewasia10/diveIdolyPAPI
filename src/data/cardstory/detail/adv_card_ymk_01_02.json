      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_karaokeroom-00-noon.webp",
      "bgName": "karaokeroom-00-noon",
      "startTime": 111.4948773306
    },
    {
      "type": "dialogue",
      "speakerCode": "koh",
      "speakerName": "{user}",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-makino.png",
