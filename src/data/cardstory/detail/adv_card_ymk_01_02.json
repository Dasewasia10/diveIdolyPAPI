      "bgName": "hokkatown-00-noon",
      "startTime": 252.8196312512
    },
    {
      "type": "dialogue",
      "speakerCode": "rio",
      "speakerName": "神崎莉央",
      "speakerNameEn": "Rio",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-rio.png",
