      "bgName": "karaokeroom-00-noon",
      "startTime": 95.65941635
    },
    {
      "type": "dialogue",
      "speakerCode": "rio",
      "speakerName": "神崎莉央",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-rio.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_ymk_01_02/sud_vo_adv_card_ymk_01_02-rio006.m4a",
      "text": "このぐらい当然でしょ、私とミクが歌ったんだから\nねぇ、ミク！",
      "startTime": 99.6989028075,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "ymk",
