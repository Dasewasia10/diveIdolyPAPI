      "speakerName": "初音ミク",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-ymk.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_ymk_01_02/sud_vo_adv_card_ymk_01_02-ymk007.m4a",
      "text": "平気！　案内もアンバサダーの役目だからね",
      "startTime": 224.6718446338,
