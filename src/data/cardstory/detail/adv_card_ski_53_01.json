    {
      "type": "dialogue",
      "speakerCode": "kor",
      "speakerName": "fran",
      "speakerNameEn": "fran",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-fran.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_ski_53_01/sud_vo_adv_card_ski_53_01-kor002.m4a",
      "text": "まぁいつものことか……。っていうか沙季、何それ\nプレゼント？　なんか机の上にいろいろあるけど",
      "translations": {
        "en": "まぁいつものことか……。っていうか沙季、何それ\nプレゼント？　なんか机の上にいろいろあるけど",
        "id": ""
      },
      "startTime": 29.1,
      "sfxList": [
        {
          "src": "https://apiip.dasewasia.my.id/storyBgm/sud_se_adv_gasa-02.m4a",
          "delay": 3933.3330790999953,
          "startTime": 33.0333330791
        }
      ]
    },
    {
      "type": "dialogue",
      "speakerCode": "ski",
      "speakerName": "白石沙季",
      "speakerNameEn": "白石沙季",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-saki.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_ski_53_01/sud_vo_adv_card_ski_53_01-ski004.m4a",
      "text": "はい。実は私、今日が誕生日なんです。ここにあるのは\n寮で皆さんにいただいた、プレゼントの一部ですね",
      "translations": {
        "en": "はい。実は私、今日が誕生日なんです。ここにあるのは\n寮で皆さんにいただいた、プレゼントの一部ですね",
        "id": ""
      },
      "startTime": 39.4,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "ski",
      "speakerName": "白石沙季",
      "speakerNameEn": "白石沙季",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-saki.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_ski_53_01/sud_vo_adv_card_ski_53_01-ski005.m4a",
      "text": "出来るだけ早く確認して、お礼の品を用意したいので\nこうして持って来てしまいました",
      "translations": {
        "en": "出来るだけ早く確認して、お礼の品を用意したいので\nこうして持って来てしまいました",
        "id": ""
      },
