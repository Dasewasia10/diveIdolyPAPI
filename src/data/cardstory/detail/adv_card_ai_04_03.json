    },
    {
      "type": "dialogue",
      "speakerCode": "ai",
      "speakerName": "小美山愛",
      "speakerNameEn": "Ai",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-ai.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_ai_04_03/sud_vo_adv_card_ai_04_03-ai004.m4a",
      "text": "み、見つめないで下さい！\nこの衣装、結構恥ずかしいんですよ？",
      "translations": {
        "en": "Please don't stare!\nThis outfit is quite embarrassing‚ you know?",
        "id": ""
      },
      "startTime": 38.1,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "koh",
