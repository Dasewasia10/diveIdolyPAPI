      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_mhk_05_01/sud_vo_adv_card_mhk_05_01-koh002.m4a",
      "text": "……あの、mihoさん？",
      "startTime": 7.0168477695,
      "sfxList": [
