    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_shoppingspot-00-noon.webp",
      "bgName": "shoppingspot-00-noon",
      "startTime": 197.3617604417
    },
    {
      "type": "dialogue",
      "speakerCode": "koh",
      "speakerName": "{user}",
      "speakerNameEn": "{user}",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-makino.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_rei_12_01/sud_vo_adv_card_rei_12_01-koh008.m4a",
      "text": "今日の仕事はこれで終わりだ\n俺は事務所に戻るが、怜はこの後どうするんだ？",
      "translations": {
        "en": "今日の仕事はこれで終わりだ\n俺は事務所に戻るが、怜はこの後どうするんだ？",
        "id": ""
      },
      "startTime": 200.7,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "rei",
      "speakerName": "一ノ瀬怜",
      "speakerNameEn": "一ノ瀬怜",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-rei.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_rei_12_01/sud_vo_adv_card_rei_12_01-rei018.m4a",
