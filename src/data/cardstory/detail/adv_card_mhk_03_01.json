      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_mhk_03_01/sud_vo_adv_card_mhk_03_01-mhk013.m4a",
      "text": "私も息抜きです\n普段、お酒はあまり飲まないようにしてるんですけど",
      "startTime": 154.1333400407,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "koh",
      "speakerName": "{user}",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-makino.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_mhk_03_01/sud_vo_adv_card_mhk_03_01-koh015.m4a",
      "text": "前に旅館でもいろいろありましたしね",
      "startTime": 157.3333410579,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_pub-00-night.webp",
