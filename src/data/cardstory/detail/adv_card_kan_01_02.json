          "delay": 1033.3333332999998,
          "startTime": 1.8333333333
        }
      ]
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_tokyoentrance-00-noon.webp",
      "bgName": "tokyoentrance-00-noon"
    },
    {
      "type": "dialogue",
      "speakerCode": "kan",
      "speakerName": "kana",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-kana.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_kan_01_02/sud_vo_adv_card_kan_01_02-kan002.m4a",
      "text": "でもな～、最近フォロワー数の伸びがイマイチ……\nやっぱ弱小事務所に移ったのがマズかったかな～",
      "startTime": 12.1333333333,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "kan",
      "speakerName": "kana",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-kana.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_kan_01_02/sud_vo_adv_card_kan_01_02-kan003.m4a",
      "text": "いや、ここは逆に弱小事務所の実態を暴いてみるか……\nアイドルのブラック労働ぶりを……",
      "startTime": 21.3333333333,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_tokyoentrance-00-noon.webp",
      "bgName": "tokyoentrance-00-noon"
    },
    {
      "type": "dialogue",
      "speakerCode": "kan",
      "speakerName": "kana",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-kana.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_kan_01_02/sud_vo_adv_card_kan_01_02-kan004.m4a",
      "text": "あれ、{user}じゃん、いたんだ",
      "startTime": 24.5,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "koh",
      "speakerName": "{user}",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-makino.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_kan_01_02/sud_vo_adv_card_kan_01_02-koh001.m4a",
      "text": "さっきからいましたよ……",
      "startTime": 27.7,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_tokyoentrance-00-noon.webp",
      "bgName": "tokyoentrance-00-noon"
    },
    {
      "type": "dialogue",
      "speakerCode": "kan",
      "speakerName": "kana",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-kana.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_kan_01_02/sud_vo_adv_card_kan_01_02-kan005.m4a",
      "text": "それでさ～、なんか面白いネタない？\n投稿サボるとすぐにフォロワー数減るからさぁ",
      "startTime": 33.4666666667,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "koh",
      "speakerName": "{user}",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-makino.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_kan_01_02/sud_vo_adv_card_kan_01_02-koh002.m4a",
      "text": "いや、面白いことと言われても\nそんなすぐには思いつきませんよ",
      "startTime": 39.5333333333,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_tokyoentrance-00-noon.webp",
      "bgName": "tokyoentrance-00-noon"
    },
    {
      "type": "dialogue",
      "speakerCode": "kan",
      "speakerName": "kana",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-kana.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_kan_01_02/sud_vo_adv_card_kan_01_02-kan006.m4a",
      "text": "ちっ\nマネージャーのくせに、ほんと使えないよね～",
      "startTime": 43.2333333333,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "koh",
      "speakerName": "{user}",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-makino.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_kan_01_02/sud_vo_adv_card_kan_01_02-koh003.m4a",
      "text": "ところで……いや、SNSも大事なのは知ってますけど\nそろそろ、ライブバトルに向けて練習をですね……",
      "startTime": 51.6,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_tokyoentrance-00-noon.webp",
      "bgName": "tokyoentrance-00-noon"
    },
    {
      "type": "dialogue",
      "speakerCode": "kan",
      "speakerName": "kana",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-kana.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_kan_01_02/sud_vo_adv_card_kan_01_02-kan007.m4a",
      "text": "は？\nそんなのkanaに必要ないし",
      "startTime": 56,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "koh",
      "speakerName": "{user}",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-makino.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_kan_01_02/sud_vo_adv_card_kan_01_02-koh004.m4a",
      "text": "いやでも、『マイペースでかたじけない』を倒すって\n凄い張り切ってたじゃないですか",
      "startTime": 62.1,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_tokyoentrance-00-noon.webp",
      "bgName": "tokyoentrance-00-noon"
    },
    {
      "type": "dialogue",
      "speakerCode": "kan",
      "speakerName": "kana",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-kana.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_kan_01_02/sud_vo_adv_card_kan_01_02-kan008.m4a",
      "text": "だから～、マイかたはぶっ潰すってば\n相変わらずkanaの真似しててウザいし",
      "startTime": 68.9,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "kan",
      "speakerName": "kana",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-kana.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_kan_01_02/sud_vo_adv_card_kan_01_02-kan009.m4a",
      "text": "でもそれとレッスンは関係ないじゃん",
      "startTime": 71.9666666667,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_tokyoentrance-00-noon.webp",
      "bgName": "tokyoentrance-00-noon"
    },
    {
      "type": "dialogue",
      "speakerCode": "koh",
      "speakerName": "{user}",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-makino.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_kan_01_02/sud_vo_adv_card_kan_01_02-koh005.m4a",
      "text": "いや、関係ないことはないでしょう\nむしろ要と言ってもいいくらい……",
      "startTime": 77.2,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "kan",
      "speakerName": "kana",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-kana.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_kan_01_02/sud_vo_adv_card_kan_01_02-kan010.m4a",
      "text": "あ～もう、うるさいうるさい\nkanaに説教するとか、あんた何様？",
      "startTime": 83.2,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_tokyoentrance-00-noon.webp",
      "bgName": "tokyoentrance-00-noon"
    },
    {
      "type": "dialogue",
      "speakerCode": "kan",
      "speakerName": "kana",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-kana.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_kan_01_02/sud_vo_adv_card_kan_01_02-kan011.m4a",
      "text": "いくらマネージャーでも、あんまりウザいようなら\nぶっ飛ばすからね",
      "startTime": 89.8,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_tokyoentrance-00-noon.webp",
      "bgName": "tokyoentrance-00-noon"
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_tokyoentrance-00-noon.webp",
      "bgName": "tokyoentrance-00-noon"
    },
    {
      "type": "dialogue",
      "speakerCode": "kan",
      "speakerName": "kana",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-kana.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_kan_01_02/sud_vo_adv_card_kan_01_02-kan012.m4a",
      "text": "あ、あそこのコスメの新作、個数限定だ\nネタに出来るのはいいけど、人に頼むのめんどいなー",
      "startTime": 96.5,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "kan",
      "speakerName": "kana",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-kana.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_kan_01_02/sud_vo_adv_card_kan_01_02-kan013.m4a",
      "text": "って言うか、なんでkanaにPRの依頼来ないんだろ\nこんな一流インフルエンサーがいるのにおかしくない？",
      "startTime": 105.7333333333,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_tokyoentrance-00-noon.webp",
      "bgName": "tokyoentrance-00-noon"
    },
    {
      "type": "dialogue",
      "speakerCode": "koh",
      "speakerName": "{user}",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-makino.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_kan_01_02/sud_vo_adv_card_kan_01_02-koh006.m4a",
      "text": "（あんなにライブバトルに燃えてたのに）\n（kanaさん、一体何があったんだろう……？）",
      "startTime": 112.1666666667,
      "sfxList": []
    },
    {
