      "speakerName": "",
      "iconUrl": null,
      "voiceUrl": null,
      "text": "――星見プロが東京に進出してしばらく経った頃",
      "startTime": 0.03333333333333333,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_tokyocorridor-00-noon.webp",
      "bgName": "stage01",
