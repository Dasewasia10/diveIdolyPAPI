      "speakerNameEn": "{user}",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-makino.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_mei_10_02/sud_vo_adv_card_mei_10_02-koh012.m4a",
      "text": "お手本になれるアイドルに、っていうのも良かったが\nこっちの言い方の方が、より芽衣らしいよ",
