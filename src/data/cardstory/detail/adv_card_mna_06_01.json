        "id": ""
      },
      "startTime": 151.0780240288,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "mna",
      "speakerName": "長瀬麻奈",
      "speakerNameEn": "Mana",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-mana.png",
