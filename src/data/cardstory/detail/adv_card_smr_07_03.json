      "bgName": "summerfes-00-noon",
      "startTime": 131.985398269
    },
    {
      "type": "dialogue",
      "speakerCode": "smr",
      "speakerName": "奥山すみれ",
      "speakerNameEn": "Sumire",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-sumire.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_smr_07_03/sud_vo_adv_card_smr_07_03-smr015.m4a",
      "text": "分かりました！\n……準備して、一時間後に合流するそうです！",
      "translations": {
        "en": "Understood!\n…She said to get ready and meet up in an hour!",
        "id": ""
      },
      "startTime": 133.7520588282,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "koh",
      "speakerName": "{user}",
      "speakerNameEn": "{user}",
