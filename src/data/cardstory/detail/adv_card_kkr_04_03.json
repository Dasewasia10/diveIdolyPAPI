      "bgName": "stage02",
      "startTime": 147.7
    },
    {
      "type": "dialogue",
      "speakerCode": "kkr",
      "speakerName": "赤崎こころ",
      "speakerNameEn": "Kokoro",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-kokoro.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_kkr_04_03/sud_vo_adv_card_kkr_04_03-kkr015.m4a",
      "text": "ほら見て下さい、屋台が沢山ありますよ～\nこの間のお礼にこころがなんでもおごっちゃいます！",
      "translations": {
        "en": "Look‚ there are plenty of food stalls here~\nAs a thank you for the other day‚ Kokoro will treat you to anything you want!",
        "id": ""
      },
      "startTime": 152.3,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_summerfes-00-noon.webp",
      "bgName": "stage02",
