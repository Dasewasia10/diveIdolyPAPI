      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_aoi_04_01/sud_vo_adv_card_aoi_04_01-koh013.m4a",
      "text": "聞いてくれ、俺はストーカーでも覗き魔でもないし\n合宿について行ったのも葵達のことが心配で……",
      "startTime": 231.7,
      "sfxList": []
    },
