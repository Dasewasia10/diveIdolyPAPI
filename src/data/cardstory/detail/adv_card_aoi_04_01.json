      "text": "間違いじゃないが語弊があり過ぎる！",
      "startTime": 225.8,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_tokyokissa-00-noon.webp",
      "bgName": "tokyocafe-00-noon"
    },
    {
      "type": "dialogue",
