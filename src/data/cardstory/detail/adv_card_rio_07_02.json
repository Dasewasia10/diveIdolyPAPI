      "text": "答えは「親密なコミュニケーション」でしたよね？",
      "translations": {
        "en": "Your answer was \"intimate communication‚\" right?",
        "id": ""
      },
      "startTime": 236.6000268379,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "rio",
      "speakerName": "神崎莉央",
      "speakerNameEn": "Rio",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-rio.png",
