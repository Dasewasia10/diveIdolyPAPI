      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-rio.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_rio_07_02/sud_vo_adv_card_rio_07_02-rio029.m4a",
      "text": "……って、何を言わせるのよ！？",
      "translations": {
        "en": "…W-why are you making me say this!?",
