    },
    {
      "type": "dialogue",
      "speakerCode": "suz",
      "speakerName": "成宮すず",
      "speakerNameEn": "Suzu",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-suzu.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_suz_08_02/sud_vo_adv_card_suz_08_02-suz031.m4a",
      "text": "私は……芽衣と一緒に楽しく歌いたい\nそのために私は、芽衣とユニットを組んだのですわ",
      "translations": {
        "en": "I… I want to sing happily with Mei.\nThat’s why I formed a unit with Mei.",
        "id": ""
      },
      "startTime": 331.9333309177,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_famires-00-night.webp",
      "bgName": "famires-00-night",
      "startTime": 336.1666637423
    },
    {
      "type": "dialogue",
      "speakerCode": "koh",
      "speakerName": "{user}",
      "speakerNameEn": "{user}",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-makino.png",
