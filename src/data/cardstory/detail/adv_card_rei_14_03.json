        }
      ]
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_ricefield-00-noon.webp",
      "bgName": "ricefield-00-noon",
      "startTime": 2.999999849
    },
    {
      "type": "dialogue",
      "speakerCode": "koh",
      "speakerName": "{user}",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-makino.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_rei_14_03/sud_vo_adv_card_rei_14_03-koh001.m4a",
      "text": "もうすぐ、もうすぐだぞ、怜……！　うおおおお！\nマネージャーのど根性舐めんなあああああ！",
      "startTime": 8.0666666667,
      "sfxList": [
        {
          "src": "https://apiip.dasewasia.my.id/storyBgm/sud_se_adv_walk-out-single-01.m4a",
          "delay": 5933.3336909,
          "startTime": 14.0000003576
        }
      ]
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_ricefield-00-noon.webp",
      "bgName": "ricefield-00-noon",
      "startTime": 13.799999849
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_ricefield-00-noon.webp",
      "bgName": "ricefield-00-noon",
      "startTime": 13.799999849
    },
    {
      "type": "dialogue",
      "speakerCode": "koh",
      "speakerName": "{user}",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-makino.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_rei_14_03/sud_vo_adv_card_rei_14_03-koh002.m4a",
      "text": "ぜぇっ、ぜぇっ……はぁっ、はぁっ……！\nお、お待たせ、怜……具合は、どうだ……？",
      "startTime": 18.4666666667,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_ricefield-00-noon.webp",
      "bgName": "ricefield-00-noon",
      "startTime": 22.5333335638
    },
    {
      "type": "dialogue",
      "speakerCode": "rei",
      "speakerName": "一ノ瀬怜",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-rei.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_rei_14_03/sud_vo_adv_card_rei_14_03-rei001.m4a",
      "text": "あ、お帰りなさい！　おかげさまで、少し休んだら\nだいぶ良く、ってなんでそんなに疲れてるんですか！？",
      "startTime": 26.3333332062,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_ricefield-00-noon.webp",
      "bgName": "ricefield-00-noon",
      "startTime": 31.4666668971
    },
    {
      "type": "dialogue",
      "speakerCode": "rei",
      "speakerName": "一ノ瀬怜",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-rei.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_rei_14_03/sud_vo_adv_card_rei_14_03-rei002.m4a",
      "text": "あと、その自転車どうしたんですか！？\n行く時は乗ってませんでしたよね！？",
      "startTime": 34.2333332062,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "koh",
      "speakerName": "{user}",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-makino.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_rei_14_03/sud_vo_adv_card_rei_14_03-koh003.m4a",
      "text": "こ、コンビニで事情を話したら……\n店員さんが貸してくれたんだ……げっほげっほ！",
      "startTime": 38.9978065788,
      "sfxList": [
        {
          "src": "https://apiip.dasewasia.my.id/storyBgm/sud_se_adv_gasa-02.m4a",
          "delay": 5202.193421200001,
          "startTime": 44.2
        }
      ]
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_ricefield-00-noon.webp",
      "bgName": "ricefield-00-noon",
      "startTime": 42.9333335638
    },
    {
      "type": "dialogue",
      "speakerCode": "koh",
      "speakerName": "{user}",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-makino.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_rei_14_03/sud_vo_adv_card_rei_14_03-koh004.m4a",
      "text": "そ、そんなことより、スポドリを……\nジェルシートとアイスも、買ってきたぞ……",
      "startTime": 45.9999998729,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_ricefield-00-noon.webp",
      "bgName": "ricefield-00-noon",
      "startTime": 52.2993968241
    },
    {
      "type": "dialogue",
      "speakerCode": "rei",
      "speakerName": "一ノ瀬怜",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-rei.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_rei_14_03/sud_vo_adv_card_rei_14_03-rei003.m4a",
      "text": "あ、ありがとうございます……って\n買い過ぎじゃないですか！？　袋パンパンですよ！",
      "startTime": 52.7846284062,
      "sfxList": [
        {
          "src": "https://apiip.dasewasia.my.id/storyBgm/sud_se_adv_gasa-02.m4a",
          "delay": 4348.704927100001,
          "startTime": 57.1333333333
        },
        {
          "src": "https://apiip.dasewasia.my.id/storyBgm/sud_se_adv_book-01.m4a",
          "delay": 6795.371593799999,
          "startTime": 59.58
        }
      ]
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_ricefield-00-noon.webp",
      "bgName": "ricefield-00-noon",
      "startTime": 56.8666674296
    },
    {
      "type": "dialogue",
      "speakerCode": "rei",
      "speakerName": "一ノ瀬怜",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-rei.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_rei_14_03/sud_vo_adv_card_rei_14_03-rei004.m4a",
      "text": "ん？　これは、雑誌？　『背筋も凍る心霊大特集』……\nいや、冷やすってそっちの意味ですか！？",
      "startTime": 66.7333357493,
      "sfxList": [
        {
          "src": "https://apiip.dasewasia.my.id/storyBgm/sud_se_adv_down-01.m4a",
          "delay": 12366.664250699998,
          "startTime": 79.1
        }
      ]
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_ricefield-00-noon.webp",
      "bgName": "ricefield-00-noon",
      "startTime": 69.2666694402
    },
    {
      "type": "dialogue",
      "speakerCode": "koh",
      "speakerName": "{user}",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-makino.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_rei_14_03/sud_vo_adv_card_rei_14_03-koh005.m4a",
      "text": "す、すまない、必死に選ぶあまり……間違えて……\nでも、これで当分は大丈夫、だろう……がくり",
      "startTime": 73.6654900722,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_ricefield-00-noon.webp",
      "bgName": "ricefield-00-noon",
      "startTime": 80.3666689316
    },
    {
      "type": "dialogue",
      "speakerCode": "rei",
      "speakerName": "一ノ瀬怜",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-rei.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_rei_14_03/sud_vo_adv_card_rei_14_03-rei005.m4a",
      "text": "{user}さーん！？\n大丈夫ですか、目を覚まして下さーい！",
      "startTime": 81.766668574,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_ricefield-00-noon.webp",
      "bgName": "ricefield-00-noon",
      "startTime": 86.9333311717
    },
    {
      "type": "dialogue",
      "speakerCode": "rei",
      "speakerName": "一ノ瀬怜",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-rei.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_rei_14_03/sud_vo_adv_card_rei_14_03-rei006.m4a",
      "text": "何してるんですか、もう！\nいきなり倒れて……心配したんですからね！？",
      "startTime": 90.3999978383,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "koh",
      "speakerName": "{user}",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-makino.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_rei_14_03/sud_vo_adv_card_rei_14_03-koh006.m4a",
      "text": "す、すまない。戻ってきたら気が抜けて\nそのまま倒れてしまった。もう大丈夫だ",
      "startTime": 97.6999978383,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_ricefield-00-noon.webp",
      "bgName": "ricefield-00-noon",
      "startTime": 101.9666658799
    },
    {
      "type": "dialogue",
      "speakerCode": "rei",
      "speakerName": "一ノ瀬怜",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-rei.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_rei_14_03/sud_vo_adv_card_rei_14_03-rei007.m4a",
      "text": "はぁ……相変わらず心配性ですし\n妙なところがズレてるっていうか……",
      "startTime": 106.5333311717,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_ricefield-00-noon.webp",
      "bgName": "ricefield-00-noon",
      "startTime": 109.8333325465
    },
    {
      "type": "dialogue",
      "speakerCode": "rei",
      "speakerName": "一ノ瀬怜",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-rei.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_rei_14_03/sud_vo_adv_card_rei_14_03-rei008.m4a",
      "text": "……でも、ありがとうございます。買ってきてくれた\n飲み物や休憩のおかげで、体調もだいぶ回復しました",
      "startTime": 115.0999978383,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "rei",
      "speakerName": "一ノ瀬怜",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-rei.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_rei_14_03/sud_vo_adv_card_rei_14_03-rei009.m4a",
      "text": "これなら撮影を再開出来ると思います\nご心配をお掛けしました",
      "startTime": 122.6999978383,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_ricefield-00-noon.webp",
      "bgName": "ricefield-00-noon",
      "startTime": 124.8333325465
    },
    {
      "type": "dialogue",
      "speakerCode": "koh",
      "speakerName": "{user}",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-makino.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_rei_14_03/sud_vo_adv_card_rei_14_03-koh007.m4a",
      "text": "本当に大丈夫か？　さっきより涼しくはなってきたが\nもう少し休んだ方が……",
      "startTime": 129.3333311717,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "rei",
      "speakerName": "一ノ瀬怜",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-rei.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_rei_14_03/sud_vo_adv_card_rei_14_03-rei010.m4a",
      "text": "さっきみたいな無理は絶対にしません\n無理そうだったら、ちゃんと言いますから",
      "startTime": 134.5999978383,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_ricefield-00-noon.webp",
      "bgName": "ricefield-00-noon",
      "startTime": 137.7333233912
    },
    {
      "type": "dialogue",
      "speakerCode": "rei",
      "speakerName": "一ノ瀬怜",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-rei.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_rei_14_03/sud_vo_adv_card_rei_14_03-rei011.m4a",
      "text": "だから、撮影を続けさせて下さい\n最後まで、仕事をきっちりやり遂げたいんです",
      "startTime": 140.599988683,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_ricefield-00-noon.webp",
      "bgName": "ricefield-00-noon",
      "startTime": 144.1999900579
    },
    {
      "type": "dialogue",
      "speakerCode": "koh",
      "speakerName": "{user}",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-makino.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_rei_14_03/sud_vo_adv_card_rei_14_03-koh008.m4a",
      "text": "分かった。じゃあ、撮影を再開させてほしいって\nスタッフさん達に伝えてくるよ",
      "startTime": 147.6666553497,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_ricefield-00-noon.webp",
      "bgName": "ricefield-00-noon",
      "startTime": 149.8999900579
    },
    {
      "type": "dialogue",
      "speakerCode": "rei",
      "speakerName": "一ノ瀬怜",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-rei.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_rei_14_03/sud_vo_adv_card_rei_14_03-rei012.m4a",
      "text": "ありがとうございます！\n今度こそ、最高の仕事をしてみせますね！",
      "startTime": 152.1666553497,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": null,
      "speakerName": "",
      "iconUrl": null,
      "voiceUrl": null,
      "text": "――撮影終了後",
      "startTime": 156.0333203395,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_ricefield-00-noon.webp",
      "bgName": "ricefield-00-noon",
      "startTime": 157.1466486057
    },
    {
      "type": "dialogue",
      "speakerCode": "rei",
      "speakerName": "一ノ瀬怜",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-rei.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_rei_14_03/sud_vo_adv_card_rei_14_03-rei013.m4a",
      "text": "お疲れ様です。撤収の時間まで\nまだもう少しだけ余裕ありますよね？",
      "startTime": 161.899988683,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "koh",
      "speakerName": "{user}",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-makino.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_rei_14_03/sud_vo_adv_card_rei_14_03-koh009.m4a",
      "text": "そうだな。機材の片付けもあるし\n十五分ぐらいは掛かりそうだ",
      "startTime": 168.3333220164,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_ricefield-00-noon.webp",
      "bgName": "ricefield-00-noon",
      "startTime": 170.4666455348
    },
    {
      "type": "dialogue",
      "speakerCode": "rei",
      "speakerName": "一ノ瀬怜",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-rei.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_rei_14_03/sud_vo_adv_card_rei_14_03-rei014.m4a",
      "text": "それなら、ひまわり畑、もう少しだけ\n見ていってもいいでしょうか？",
      "startTime": 173.399988683,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "koh",
      "speakerName": "{user}",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-makino.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_rei_14_03/sud_vo_adv_card_rei_14_03-koh010.m4a",
      "text": "構わないよ。せっかくここまで来たんだ\n満足するまで見てくるといい",
      "startTime": 178.899988683,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_ricefield-00-noon.webp",
      "bgName": "ricefield-00-noon",
      "startTime": 181.1666455348
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_ricefield-00-noon.webp",
      "bgName": "ricefield-00-noon",
      "startTime": 185.5333220164
    },
    {
      "type": "dialogue",
      "speakerCode": "rei",
      "speakerName": "一ノ瀬怜",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-rei.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_rei_14_03/sud_vo_adv_card_rei_14_03-rei015.m4a",
      "text": "ありがとうございます！　ふふっ\n{user}さんも一緒に行きましょう！",
      "startTime": 185.5333220164,
      "sfxList": [
