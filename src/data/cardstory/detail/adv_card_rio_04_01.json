      "text": "クールでスタイリッシュな主人公を\nケイティは体を張って熱演して――",
      "translations": {
        "en": "She threw herself into playing the cool and\nstylish lead with all her might—",
        "id": ""
      },
      "startTime": 211.1,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "koh",
      "speakerName": "{user}",
      "speakerNameEn": "{user}",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-makino.png",
