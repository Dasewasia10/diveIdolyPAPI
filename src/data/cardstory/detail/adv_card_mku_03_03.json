      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_mku_03_03/sud_vo_adv_card_mku_03_03-ngs002.m4a",
      "text": "ライブで月ストの衣装をミクちゃんに着てもらったけど\n逆に、私達がミクちゃんの衣装を着るのもいいかもね",
      "startTime": 25.433332932,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_feststage-00-night.webp",
      "bgName": "s1"
    },
    {
      "type": "dialogue",
