      "speakerName": "ダンスコーチB",
      "speakerNameEn": "Dance",
      "iconUrl": null,
      "voiceUrl": null,
      "text": "実は私、怜の……",
      "translations": {
        "en": "I’m Rei’s…",
        "id": ""
      },
      "startTime": 89.88170576964811,
      "sfxList": []
    },
