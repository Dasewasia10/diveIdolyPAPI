      "text": "みんなで意見をぶつけ合って\n悩んで、海で遊んで……",
      "startTime": 58.5,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "mei",
      "speakerName": "早坂芽衣",
