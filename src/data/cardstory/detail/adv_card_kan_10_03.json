      "text": "いったぁい\nこころの角を引っ張らないで下さい～！",
      "translations": {
        "en": "",
        "id": ""
      },
      "startTime": 170.5666730244,
      "sfxList": [
        {
          "src": "https://apiip.dasewasia.my.id/storyBgm/sud_se_adv_rope-02.m4a",
          "delay": 138.02755630001684,
          "startTime": 168.5000063578
        }
      ]
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_dressingroom-00-noon.webp",
      "bgName": "dressingroom-00-noon",
