      "speakerName": "奥山すみれ",
      "speakerNameEn": "Sumire Okuyama",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-sumire.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_smr_14_01/sud_vo_adv_card_smr_14_01-smr022.m4a",
      "text": "彼女が出来たんですよ、きっと！\n酷い！　お兄ちゃんの彼女なら、私も会いたいのに！",
      "translations": {
        "en": "",
        "id": ""
      },
      "startTime": 305.9492665178,
      "sfxList": []
    },
    {
