    },
    {
      "type": "dialogue",
      "speakerCode": "koh",
      "speakerName": "{user}",
      "speakerNameEn": "{user}",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-makino.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_mei_06_02/sud_vo_adv_card_mei_06_02-koh017.m4a",
      "text": "……琴乃、来ないな",
      "translations": {
        "en": "…Kotono hasn't come.",
        "id": ""
      },
      "startTime": 302.9333333333,
      "sfxList": []
