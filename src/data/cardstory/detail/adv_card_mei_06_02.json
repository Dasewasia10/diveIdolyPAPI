      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_mei_06_02/sud_vo_adv_card_mei_06_02-mei034.m4a",
      "text": "それじゃ、また後でね、{user}さん！",
      "translations": {
        "en": "Well then‚ see you later‚ {user}-san!",
