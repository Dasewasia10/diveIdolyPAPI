      "text": "うん、いろいろありがとう\n{user}さん！",
      "startTime": 327.2,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "mei",
      "speakerName": "早坂芽衣",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-mei.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_mei_06_02/sud_vo_adv_card_mei_06_02-mei031.m4a",
      "text": "……今日のことは、芽衣と{user}さん\n二人だけの秘密だね",
      "startTime": 332.1666666667,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "koh",
