      "text": "私は……\nやっぱりお姉ちゃんほど強くないんだと思います",
      "startTime": 233.6433333333,
      "sfxList": []
    },
    {
      "type": "bgm",
      "action": "play",
      "src": "https://apiip.dasewasia.my.id/storyBgm/sud_bgm_adv_achieve-01.m4a"
    },
    {
      "type": "dialogue",
      "speakerCode": "ktn",
