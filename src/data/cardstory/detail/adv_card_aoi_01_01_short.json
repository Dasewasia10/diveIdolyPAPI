      "text": "肩書きなんてどうでもいいよ\nレッスン場使わせてもらうよ",
      "startTime": 17.433333333333334,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "koh",
      "speakerName": "{user}",
