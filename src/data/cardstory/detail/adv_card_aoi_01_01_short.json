      "text": "隅っこで勝手にやってるから\n気にしないでいいよ",
      "startTime": 23.5,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "koh",
      "speakerName": "{user}",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-makino.png",
