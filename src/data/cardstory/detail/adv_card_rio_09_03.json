      "text": "周囲に配慮はしてるくせに、しっかり我を通すところ",
      "startTime": 236.6475447575,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "koh",
      "speakerName": "{user}",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-makino.png",
