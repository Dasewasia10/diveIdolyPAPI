      "text": "そうですか……いえ、そうですよね\n莉央さんがいれば、LizNoirは安心です",
      "startTime": 220.4000040688,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "rio",
      "speakerName": "神崎莉央",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-rio.png",
