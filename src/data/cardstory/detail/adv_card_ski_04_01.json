      "text": "やります！　頑張って特訓しますから！",
      "translations": {
        "en": "I'll do it! I'll work hard and train for it!",
        "id": ""
      },
      "startTime": 354.2,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "koh",
      "speakerName": "{user}",
      "speakerNameEn": "{user}",
