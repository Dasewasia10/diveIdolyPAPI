      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_ski_04_01/sud_vo_adv_card_ski_04_01-koh019.m4a",
      "text": "え！？　い、いや、正直……かなり厳しいと思うぞ？",
      "translations": {
        "en": "Huh!? Well‚ honestly… I think it's quite challenging.",
        "id": ""
      },
      "startTime": 358.2666666667,
      "sfxList": []
