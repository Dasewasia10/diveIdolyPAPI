      "startTime": 254.8666636149,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "kkr",
      "speakerName": "赤崎こころ",
      "speakerNameEn": "Kokoro",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-kokoro.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_kkr_11_03/sud_vo_adv_card_kkr_11_03-kkr025.m4a",
      "text": "見守っていて下さい、これまで通りに。……こころが\n成長したところをっ！　存分に見せつけてあげますから",
      "translations": {
