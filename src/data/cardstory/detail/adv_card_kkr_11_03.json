    },
    {
      "type": "dialogue",
      "speakerCode": "kkr",
      "speakerName": "赤崎こころ",
      "speakerNameEn": "Kokoro",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-kokoro.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_kkr_11_03/sud_vo_adv_card_kkr_11_03-kkr020.m4a",
      "text": "本当に、ありがとうございます",
      "translations": {
        "en": "Truly‚ thank you so much.",
        "id": ""
      },
      "startTime": 213.52129577,
      "sfxList": []
    },
    {
      "type": "background",
