      "text": "{user}さんこそ……\n誰よりもずっと諦めずにいてくれたじゃないですか",
      "translations": {
        "en": "You’re the one…\nwho never gave up more than anyone else.",
        "id": ""
      },
      "startTime": 195.1709243548,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "kkr",
      "speakerName": "赤崎こころ",
      "speakerNameEn": "Kokoro",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-kokoro.png",
