      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "koh",
      "speakerName": "{user}",
      "speakerNameEn": "{user}",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-makino.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_ktn_08_03/sud_vo_adv_card_ktn_08_03-koh013.m4a",
      "text": "ありがとう……って、凄い数だな。えぇと……\n健康祈願に交通安全、それに商売繁盛",
