      "startTime": 276.7999797823,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "ktn",
      "speakerName": "長瀬琴乃",
      "speakerNameEn": "Kotono",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-kotono.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_ktn_08_03/sud_vo_adv_card_ktn_08_03-ktn028.m4a",
      "text": "まだありますよ。お年玉のお礼も兼ねて\n沢山いただいてきましたから",
      "translations": {
