      },
      "startTime": 308.2333415987,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "koh",
      "speakerName": "{user}",
      "speakerNameEn": "{user}",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-makino.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_ktn_08_03/sud_vo_adv_card_ktn_08_03-koh015.m4a",
      "text": "なるほど……ちゃんと考えてくれた訳か",
      "translations": {
        "en": "I see… You put a lot of thought into it.",
        "id": ""
      },
      "startTime": 310.4000082654,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "ktn",
      "speakerName": "長瀬琴乃",
      "speakerNameEn": "Kotono",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-kotono.png",
