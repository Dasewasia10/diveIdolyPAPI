      "text": "ほら……言わんこっちゃない\n横になろう、いま胃薬持ってくるから",
      "startTime": 189.0054979398,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": null,
      "speakerName": "",
      "iconUrl": null,
      "voiceUrl": null,
