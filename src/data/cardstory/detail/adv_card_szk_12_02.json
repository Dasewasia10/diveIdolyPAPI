    },
    {
      "type": "dialogue",
      "speakerCode": "szk",
      "speakerName": "兵藤雫",
      "speakerNameEn": "Shizuku Hyodo",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-shizuku.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_szk_12_02/sud_vo_adv_card_szk_12_02-szk009.m4a",
      "text": "むしろ夜遅くまで付き合ってくれて、ありがとう\nまた時間を見つけて、一緒に考えよう？",
      "translations": {
        "en": "",
        "id": ""
      },
      "startTime": 133.6666652361,
      "sfxList": [
        {
          "src": "https://apiip.dasewasia.my.id/storyBgm/sud_se_adv_walk-living-single-01.m4a",
