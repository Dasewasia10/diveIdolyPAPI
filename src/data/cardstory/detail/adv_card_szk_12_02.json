      ]
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_tokyoszkroom-00-noon.webp",
      "bgName": "tokyoszkroom-00-noon",
      "startTime": 137.0147303904
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_tokyoszkroom-00-noon.webp",
      "bgName": "tokyoszkroom-00-noon",
      "startTime": 142.0999924659
    },
    {
      "type": "dialogue",
      "speakerCode": "chs",
      "speakerName": "白石千紗",
      "speakerNameEn": "Chisa Shiraishi",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-chisa.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_szk_12_02/sud_vo_adv_card_szk_12_02-chs009.m4a",
      "text": "うん、ありがとう。じゃあ、私は部屋に戻るね\nおやすみなさい、雫ちゃん。また明日",
      "translations": {
        "en": "",
        "id": ""
      },
      "startTime": 142.0999924659,
      "sfxList": [
        {
          "src": "https://apiip.dasewasia.my.id/storyBgm/sud_se_adv_door-close-01.m4a",
          "delay": 7760.001430599999,
