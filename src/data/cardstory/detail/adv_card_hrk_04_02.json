    },
    {
      "type": "dialogue",
      "speakerCode": "hrk",
      "speakerName": "佐伯遙子",
      "speakerNameEn": "Haruko",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-haruko.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_hrk_04_02/sud_vo_adv_card_hrk_04_02-hrk001.m4a",
      "text": "うふふ……今日はいいお天気だから\n公園へ散歩にでも行こうかし……ら……",
      "translations": {
        "en": "Hehe… The weather is nice today‚\nMaybe I should go for a walk in the park… or…",
        "id": ""
      },
      "startTime": 14.7333333333,
      "sfxList": [
        {
          "src": "https://apiip.dasewasia.my.id/storyBgm/sud_se_adv_walk-living-single-01.m4a",
          "delay": 166.66666659999942,
