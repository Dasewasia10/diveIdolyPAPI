      "bgName": "tokyocorridor-00-noon",
      "startTime": 117.6333333333
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_tokyocorridor-00-noon.webp",
      "bgName": "tokyocorridor-00-noon",
      "startTime": 117.6333333333
    },
    {
      "type": "dialogue",
      "speakerCode": "koh",
      "speakerName": "{user}",
      "speakerNameEn": "{user}",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-makino.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_hrk_04_02/sud_vo_adv_card_hrk_04_02-koh008.m4a",
      "text": "仕事も一段落したし、遙子さんの様子を見に行くか\nこの時間は事務所にいるはずだけど……",
      "translations": {
        "en": "Work has settled down‚ so I thought I'd check on Haruko-san's condition.\nShe should be at the office at this time‚ though…",
        "id": ""
      },
      "startTime": 123.4333333333,
      "sfxList": [
        {
          "src": "https://apiip.dasewasia.my.id/storyBgm/sud_se_adv_walk-in-single-02.m4a",
