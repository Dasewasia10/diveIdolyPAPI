      "startTime": 93.7666666667
    },
    {
      "type": "dialogue",
      "speakerCode": "koh",
      "speakerName": "{user}",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-makino.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_hrk_04_02/sud_vo_adv_card_hrk_04_02-koh006.m4a",
      "text": "それを聞いて安心しました。でも普段着にするのは\nやめて下さい。破れたりしたら大変ですから",
      "startTime": 98.0333333333,
      "sfxList": []
