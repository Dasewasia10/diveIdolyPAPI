      "speakerCode": "koh",
      "speakerName": "{user}",
      "speakerNameEn": "{user}",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-makino.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_rei_15_01/sud_vo_adv_card_rei_15_01-koh010.m4a",
      "text": "発明品以外にも、モモさんの植物もあるしな\nあの時は、俺も大変な目に遭ったよ……",
      "translations": {
        "en": "",
        "id": ""
      },
      "startTime": 186.8999888103,
      "sfxList": []
    },
    {
      "type": "dialogue",
