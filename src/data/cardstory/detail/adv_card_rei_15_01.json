        "en": "",
        "id": ""
      },
      "startTime": 104.2333221436,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "rei",
      "speakerName": "一ノ瀬怜",
      "speakerNameEn": "Rei Ichinose",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-rei.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_rei_15_01/sud_vo_adv_card_rei_15_01-rei008.m4a",
      "text": "そうでしょうか？　スマホの形をした\nハレンチアイテムという可能性も……",
      "translations": {
        "en": "",
        "id": ""
      },
      "startTime": 109.9234370234,
      "sfxList": []
    },
