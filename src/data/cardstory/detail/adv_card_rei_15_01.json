      "speakerCode": "koh",
      "speakerName": "{user}",
      "speakerNameEn": "{user}",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-makino.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_rei_15_01/sud_vo_adv_card_rei_15_01-koh011.m4a",
      "text": "そ、それは確かに……目のやり場に困りそうだ\n寮は共同生活だから気遣いは大切だしな",
      "translations": {
        "en": "",
        "id": ""
      },
      "startTime": 208.9848474712,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "rei",
      "speakerName": "一ノ瀬怜",
      "speakerNameEn": "Rei Ichinose",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-rei.png",
