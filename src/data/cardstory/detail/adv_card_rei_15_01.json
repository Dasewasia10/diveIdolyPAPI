      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-makino.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_rei_15_01/sud_vo_adv_card_rei_15_01-koh013.m4a",
      "text": "それをなんとかしようと\nみんなのために、怜が頑張ってくれている訳か",
      "translations": {
        "en": "",
        "id": ""
      },
      "startTime": 234.6999704997,
      "sfxList": []
    },
    {
      "type": "dialogue",
