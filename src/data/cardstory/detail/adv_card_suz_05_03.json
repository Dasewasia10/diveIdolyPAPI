      "text": "はぁ……。全然ダメですわ……\nさすがの私もへこみますわ",
      "startTime": 35.5987395922,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "koh",
      "speakerName": "{user}",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-makino.png",
