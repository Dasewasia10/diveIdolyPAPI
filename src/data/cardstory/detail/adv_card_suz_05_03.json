      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-suzu.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_suz_05_03/sud_vo_adv_card_suz_05_03-suz004.m4a",
      "text": "練習の時は、{user}さんだけでしたから\n意識しなかったんですけど",
      "startTime": 49.3987395922,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "suz",
      "speakerName": "成宮すず",
