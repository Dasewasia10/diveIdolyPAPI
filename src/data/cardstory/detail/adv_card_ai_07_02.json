      "text": "でも……もっとこころを分かりたい……\nお互いを理解して、より良いものを生み出したい",
      "translations": {
        "en": "But… I want to understand Kokoro more…\nI want us to understand each other and create something better…",
        "id": ""
      },
      "startTime": 293.5201988773,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "ai",
      "speakerName": "小美山愛",
      "speakerNameEn": "Ai",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-ai.png",
