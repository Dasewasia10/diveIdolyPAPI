      "text": "……私にうまく出来るか分かりません\n自信もないですし……",
      "translations": {
        "en": "…I'm not sure if I can do it well.\nI'm not confident…",
        "id": ""
      },
      "startTime": 286.8627535567,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "ai",
      "speakerName": "小美山愛",
      "speakerNameEn": "Ai",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-ai.png",
