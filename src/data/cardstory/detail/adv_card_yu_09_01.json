      "speakerName": "",
      "iconUrl": null,
      "voiceUrl": null,
      "text": "――ある日のレッスンの休憩中",
      "startTime": 0,
      "sfxList": [
        {
          "src": "https://apiip.dasewasia.my.id/storyBgm/sud_se_adv_phone-tap-01.m4a",
          "delay": 4680,
