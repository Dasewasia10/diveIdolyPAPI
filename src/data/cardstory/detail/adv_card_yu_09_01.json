          "startTime": 5.07
        }
      ]
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_dancestudiocorridor-00-noon.webp",
      "bgName": "dancestudiocorridor-00-noon",
      "startTime": 0
    },
    {
      "type": "dialogue",
      "speakerCode": "yu",
      "speakerName": "鈴村優",
      "speakerNameEn": "Yu",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-yu.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_yu_09_01/sud_vo_adv_card_yu_09_01-yu001.m4a",
      "text": "……ふふ、懐かしいわぁ",
      "translations": {
        "en": "…Fufu‚ it brings back memories~.",
        "id": ""
      },
      "startTime": 2.1666667025,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "koh",
      "speakerName": "{user}",
      "speakerNameEn": "{user}",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-makino.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_yu_09_01/sud_vo_adv_card_yu_09_01-koh001.m4a",
      "text": "レッスンお疲れ様\n何を見ているんだ？",
      "translations": {
        "en": "Good work on the lesson.\nWhat are you watching?",
        "id": ""
      },
      "startTime": 8.2666666667,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_dancestudiocorridor-00-noon.webp",
      "bgName": "dancestudiocorridor-00-noon",
      "startTime": 10.0796822111
    },
    {
      "type": "dialogue",
      "speakerCode": "yu",
      "speakerName": "鈴村優",
      "speakerNameEn": "Yu",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-yu.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_yu_09_01/sud_vo_adv_card_yu_09_01-yu002.m4a",
      "text": "昔出演した、音楽番組の動画です\nちょっと見返したくなってなぁ",
      "translations": {
        "en": "It’s a video of a music program I appeared on a while ago.\nI just felt like watching it again~.",
        "id": ""
      },
      "startTime": 13.8333333333,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "koh",
      "speakerName": "{user}",
      "speakerNameEn": "{user}",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-makino.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_yu_09_01/sud_vo_adv_card_yu_09_01-koh002.m4a",
      "text": "出演したって……優個人でか？",
      "translations": {
        "en": "You appeared on it… alone?",
        "id": ""
      },
      "startTime": 16.4565304954,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_dancestudiocorridor-00-noon.webp",
      "bgName": "dancestudiocorridor-00-noon",
      "startTime": 20.2581404567
    },
    {
      "type": "dialogue",
      "speakerCode": "yu",
      "speakerName": "鈴村優",
      "speakerNameEn": "Yu",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-yu.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_yu_09_01/sud_vo_adv_card_yu_09_01-yu003.m4a",
      "text": "トリエルの三人に決まってるやんか\nうちらはデビューした時から三人一緒や",
      "translations": {
        "en": "Of course‚ it’s the three of us in TRINITYAiLE.\nSince our debut‚ the three of us have always been together.",
        "id": ""
      },
      "startTime": 23.4,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "yu",
      "speakerName": "鈴村優",
      "speakerNameEn": "Yu",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-yu.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_yu_09_01/sud_vo_adv_card_yu_09_01-yu004.m4a",
      "text": "こん時のうちらは、まだまだ甘ちゃんやってん\n笑顔もトークもぎこちなくてなぁ",
      "translations": {
        "en": "We were still newbies back then.\nOur smiles and talks were awkward~.",
        "id": ""
      },
      "startTime": 30.1333333333,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_dancestudiocorridor-00-noon.webp",
      "bgName": "dancestudiocorridor-00-noon",
      "startTime": 33.2982532381
    },
    {
      "type": "dialogue",
      "speakerCode": "yu",
      "speakerName": "鈴村優",
      "speakerNameEn": "Yu",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-yu.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_yu_09_01/sud_vo_adv_card_yu_09_01-yu005.m4a",
      "text": "ほら、今、うちがセリフを盛大に噛んだやろ？\nこういう失敗を二度とせんように時々見返してるんよ",
      "translations": {
        "en": "Look‚ I messed up my lines big time.\nI sometimes rewatch it so I don’t make these kinds of mistakes again.",
        "id": ""
      },
      "startTime": 37.8,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_dancestudiocorridor-00-noon.webp",
      "bgName": "dancestudiocorridor-00-noon",
      "startTime": 42.8397273897
    },
    {
      "type": "dialogue",
      "speakerCode": "koh",
      "speakerName": "{user}",
      "speakerNameEn": "{user}",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-makino.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_yu_09_01/sud_vo_adv_card_yu_09_01-koh003.m4a",
      "text": "そうか。なら、ちょうど良かったかもな",
      "translations": {
        "en": "I see. Then it might have been good timing.",
        "id": ""
      },
      "startTime": 42.8397273897,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "koh",
      "speakerName": "{user}",
      "speakerNameEn": "{user}",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-makino.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_yu_09_01/sud_vo_adv_card_yu_09_01-koh004.m4a",
      "text": "優が見てた関東ローカルの音楽番組なんだが\n実は、終了することが決定したそうだ",
      "translations": {
        "en": "It's about that Kanto local music program you were watching.\nIn fact‚ it's been decided to end.",
        "id": ""
      },
      "startTime": 50.0701812115,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_dancestudiocorridor-00-noon.webp",
      "bgName": "dancestudiocorridor-00-noon",
      "startTime": 53.37761873
    },
    {
      "type": "dialogue",
      "speakerCode": "yu",
      "speakerName": "鈴村優",
      "speakerNameEn": "Yu",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-yu.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_yu_09_01/sud_vo_adv_card_yu_09_01-yu006.m4a",
      "text": "え、それほんまなん！？\n初めて出演した番組やから、ちょっと寂しいなぁ……",
      "translations": {
        "en": "What‚ seriously!?\nIt’s a bit sad… since it was the first program we appeared on…",
        "id": ""
      },
      "startTime": 56.0666666667,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_dancestudiocorridor-00-noon.webp",
      "bgName": "dancestudiocorridor-00-noon",
      "startTime": 61.3851245283
    },
    {
      "type": "dialogue",
      "speakerCode": "koh",
      "speakerName": "{user}",
      "speakerNameEn": "{user}",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-makino.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_yu_09_01/sud_vo_adv_card_yu_09_01-koh005.m4a",
      "text": "実はその番組から、トリエルに出演オファーが\nきているんだが、どうする？",
      "translations": {
        "en": "Actually‚ we received an offer from that program\nto have TRINITYAiLE appear‚ what do you think?",
        "id": ""
      },
      "startTime": 64.5441368669,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "yu",
      "speakerName": "鈴村優",
      "speakerNameEn": "Yu",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-yu.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_yu_09_01/sud_vo_adv_card_yu_09_01-yu007.m4a",
      "text": "もちろん受けさせてもらいます",
      "translations": {
        "en": "Of course‚ we’ll accept it!",
        "id": ""
      },
      "startTime": 67.0333100358,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_dancestudiocorridor-00-noon.webp",
      "bgName": "dancestudiocorridor-00-noon",
      "startTime": 69.5978224952
    },
    {
      "type": "dialogue",
      "speakerCode": "yu",
      "speakerName": "鈴村優",
      "speakerNameEn": "Yu",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-yu.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_yu_09_01/sud_vo_adv_card_yu_09_01-yu008.m4a",
      "text": "……いや、うちだけじゃ決められへんけど\nきっと他の二人も出たいって言うはずや",
      "translations": {
        "en": "…Well‚ I can’t decide on my own…\nbut I’m sure the others will want to appear too.",
        "id": ""
      },
      "startTime": 73.0666666667,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "yu",
      "speakerName": "鈴村優",
      "speakerNameEn": "Yu",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-yu.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_yu_09_01/sud_vo_adv_card_yu_09_01-yu009.m4a",
      "text": "うちらにとって、この番組はトリエルの\n地上波初出演という特別なもの",
      "translations": {
        "en": "For us‚ this program is special because it was\nTRINITYAiLE’s first terrestrial broadcast appearance.",
        "id": ""
      },
      "startTime": 79.6,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_dancestudiocorridor-00-noon.webp",
      "bgName": "dancestudiocorridor-00-noon",
      "startTime": 83.5976867239
    },
    {
      "type": "dialogue",
      "speakerCode": "yu",
      "speakerName": "鈴村優",
      "speakerNameEn": "Yu",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-yu.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_yu_09_01/sud_vo_adv_card_yu_09_01-yu010.m4a",
      "text": "この番組に出るために毎日スタジオに残って\n遅くまで練習してたんよ",
      "translations": {
        "en": "We used to stay in the studio every day and\npractice until late to appear on it.",
        "id": ""
      },
      "startTime": 87.8666666667,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "yu",
      "speakerName": "鈴村優",
      "speakerNameEn": "Yu",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-yu.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_yu_09_01/sud_vo_adv_card_yu_09_01-yu011.m4a",
      "text": "瑠依ちゃんなんか、気合いを入れ過ぎたせいで\nいつもスタジオで寝落ちしとったわ",
      "translations": {
        "en": "Rui would always fall asleep in the studio\nbecause she was so fired up.",
        "id": ""
      },
      "startTime": 93.999233984,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_dancestudiocorridor-00-noon.webp",
      "bgName": "dancestudiocorridor-00-noon",
      "startTime": 97.0641493361
    },
    {
      "type": "dialogue",
      "speakerCode": "koh",
      "speakerName": "{user}",
      "speakerNameEn": "{user}",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-makino.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_yu_09_01/sud_vo_adv_card_yu_09_01-koh006.m4a",
      "text": "寝てしまうまで頑張るなんて、瑠依らしいな",
      "translations": {
        "en": "It’s like Rui to work hard until she falls asleep.",
        "id": ""
      },
      "startTime": 97.0641493361,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "yu",
      "speakerName": "鈴村優",
      "speakerNameEn": "Yu",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-yu.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_yu_09_01/sud_vo_adv_card_yu_09_01-yu012.m4a",
      "text": "可愛いのはええけど、うちとすみれちゃんでくすぐって\n無理やり起こして連れ帰ったりして、苦労したんやで？",
      "translations": {
        "en": "She’s cute‚ but Sumire-chan and I had a hard time\ntickling her awake and taking her home‚ you know?",
        "id": ""
      },
      "startTime": 105.0376186412,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_dancestudiocorridor-00-noon.webp",
      "bgName": "dancestudiocorridor-00-noon",
      "startTime": 109.708457474
    },
    {
      "type": "dialogue",
      "speakerCode": "yu",
      "speakerName": "鈴村優",
      "speakerNameEn": "Yu",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-yu.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_yu_09_01/sud_vo_adv_card_yu_09_01-yu013.m4a",
      "text": "それからも、何度か出させてもらうことがあってな\n沢山思い出がある番組なんや",
      "translations": {
        "en": "We’ve appeared on the program a few times since then‚\nso we have a lot of memories of it.",
        "id": ""
      },
      "startTime": 114.1,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "yu",
      "speakerName": "鈴村優",
      "speakerNameEn": "Yu",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-yu.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_yu_09_01/sud_vo_adv_card_yu_09_01-yu014.m4a",
      "text": "その最終回のゲストに選ばれるなんて\nこないに光栄なことはありません",
      "translations": {
        "en": "And we've been chosen as guests for its final episode…\nthere’s no greater honor.",
        "id": ""
      },
      "startTime": 120.5,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_dancestudiocorridor-00-noon.webp",
      "bgName": "dancestudiocorridor-00-noon",
      "startTime": 123.3121762315
    },
    {
      "type": "dialogue",
      "speakerCode": "koh",
      "speakerName": "{user}",
      "speakerNameEn": "{user}",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-makino.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_yu_09_01/sud_vo_adv_card_yu_09_01-koh007.m4a",
      "text": "じゃあ、ちゃんと準備しないとな",
      "translations": {
        "en": "Then‚ we have to prepare properly.",
        "id": ""
      },
      "startTime": 123.3121762315,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "yu",
      "speakerName": "鈴村優",
      "speakerNameEn": "Yu",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-yu.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_yu_09_01/sud_vo_adv_card_yu_09_01-yu015.m4a",
      "text": "せやね。成長したうちらの姿を\nお世話になったみなさんに見せるいいチャンスや",
      "translations": {
        "en": "Right. It’s a good chance to show\neveryone who supported us how much we’ve grown.",
        "id": ""
      },
      "startTime": 129.9333333333,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_dancestudiocorridor-00-noon.webp",
      "bgName": "dancestudiocorridor-00-noon",
      "startTime": 133.5864619135
    },
    {
      "type": "dialogue",
      "speakerCode": "yu",
      "speakerName": "鈴村優",
      "speakerNameEn": "Yu",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-yu.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_yu_09_01/sud_vo_adv_card_yu_09_01-yu016.m4a",
      "text": "恩返しのつもりで、うちらが番組の最後を\n大いに盛り上げてみせます",
      "translations": {
        "en": "We’ll liven up the final episode of the program\nas a way of showing our gratitude.",
        "id": ""
      },
      "startTime": 136.9666666667,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": null,
      "speakerName": "",
      "speakerNameEn": "",
      "iconUrl": null,
      "voiceUrl": null,
      "text": "――数日後",
      "translations": {
        "en": "――A few days later",
        "id": ""
      },
      "startTime": 140.0183911521,
      "sfxList": [
        {
          "src": "https://apiip.dasewasia.my.id/storyBgm/sud_se_adv_walk-in-single-02.m4a",
          "delay": 1348.2755146000045,
          "startTime": 141.3666666667
        }
      ]
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_office-01-evening.webp",
      "bgName": "office-01-000-evening",
      "startTime": 141.0183911521
    },
    {
      "type": "dialogue",
      "speakerCode": "yu",
      "speakerName": "鈴村優",
      "speakerNameEn": "Yu",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-yu.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_yu_09_01/sud_vo_adv_card_yu_09_01-yu017.m4a",
      "text": "あ、{user}さん\nお疲れ様です～",
      "translations": {
        "en": "Ah‚ {user}-san~.\nGood work~.",
        "id": ""
      },
      "startTime": 144.9482765318,
      "sfxList": []
    },
    {
      "type": "dialogue",
