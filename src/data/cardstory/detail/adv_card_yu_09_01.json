      "speakerName": "",
      "speakerNameEn": "",
      "iconUrl": null,
      "voiceUrl": null,
      "text": "――ある日のレッスンの休憩中",
      "translations": {
        "en": "――During a lesson break one day",
        "id": ""
      },
      "startTime": 0,
      "sfxList": [
        {
