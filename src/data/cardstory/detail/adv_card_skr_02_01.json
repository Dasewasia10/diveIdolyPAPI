      "translations": {
        "en": "They said it got so much buzz it was on the news.",
        "id": ""
      },
      "startTime": 103.2,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_hospital-02-noon.webp",
      "bgName": "stage01",
      "startTime": 112.2
    },
    {
      "type": "dialogue",
      "speakerCode": "skr",
      "speakerName": "川咲さくら",
      "speakerNameEn": "Sakura",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-sakura.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_skr_02_01/sud_vo_adv_card_skr_02_01-skr014.m4a",
      "text": "その会場に麻奈さんと縁のある私が出演することで\n注目が集まっているらしいんです",
      "translations": {
        "en": "The fact that I’m connected to Mana-san and will be performing at the\nsame venue is already attracting attention.",
        "id": ""
      },
      "startTime": 112.2,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_hospital-02-noon.webp",
      "bgName": "stage01",
      "startTime": 115.13333333333334
    },
    {
      "type": "dialogue",
      "speakerCode": "skr",
      "speakerName": "川咲さくら",
      "speakerNameEn": "Sakura",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-sakura.png",
