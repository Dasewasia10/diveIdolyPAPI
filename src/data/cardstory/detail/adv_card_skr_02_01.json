      "speakerCode": "skr",
      "speakerName": "川咲さくら",
      "speakerNameEn": "Sakura",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-sakura.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_skr_02_01/sud_vo_adv_card_skr_02_01-skr004.m4a",
      "text": "普段の私を一番よく知ってるのは\n{user}さんだから……",
      "translations": {
        "en": "{user}-san‚ you’re the person who knows\neveryday me the best…",
        "id": ""
      },
      "startTime": 25.633333333333333,
      "sfxList": []
    },
    {
      "type": "background",
