      "bgName": "stage01",
      "startTime": 27.3
    },
    {
      "type": "dialogue",
      "speakerCode": "koh",
      "speakerName": "{user}",
      "speakerNameEn": "{user}",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-makino.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_skr_02_01/sud_vo_adv_card_skr_02_01-koh002.m4a",
      "text": "検査の結果も異常がなくて安心したよ",
      "translations": {
        "en": "It’s a relief that the test results are normal.",
        "id": ""
      },
      "startTime": 27.3,
      "sfxList": []
    },
    {
      "type": "background",
