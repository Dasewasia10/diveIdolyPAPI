      "text": "芽衣はまだ猫と遊んでいるようだが……",
      "startTime": 62.8333267688,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_photostudio-00-noon.webp",
      "bgName": "photostudio-00-noon"
    },
    {
      "type": "dialogue",
      "speakerCode": "suz",
      "speakerName": "成宮すず",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-suzu.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_suz_08_03/sud_vo_adv_card_suz_08_03-suz009.m4a",
      "text": "好きにさせておけばいいのですわ\nもう止めるのも疲れました",
      "startTime": 68.9666622798,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "suz",
      "speakerName": "成宮すず",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-suzu.png",
