      "text": "ふふ、褒めてるんですよ",
      "translations": {
        "en": "huhu‚ I mean that as a compliment.",
        "id": ""
      },
      "startTime": 76.3333333333,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "kor",
      "speakerName": "fran",
      "speakerNameEn": "fran",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-fran.png",
