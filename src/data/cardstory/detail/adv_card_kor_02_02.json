        {
          "src": "https://apiip.dasewasia.my.id/storyBgm/sud_se_adv_sisiodoshi-01.m4a",
          "delay": 10000,
          "startTime": 52.5333333333
        }
      ]
    },
    {
      "type": "dialogue",
      "speakerCode": "kor",
      "speakerName": "fran",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-fran.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_kor_02_02/sud_vo_adv_card_kor_02_02-kor004.m4a",
      "text": "はぁぁ～……気ん持ちいぃ～～……\n柚子の香りもすっごくいい感じぃ～……",
      "startTime": 52.4666666667,
      "sfxList": [
        {
          "src": "https://apiip.dasewasia.my.id/storyBgm/sud_se_adv_water-02.m4a",
