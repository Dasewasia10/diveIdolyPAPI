      "text": "私達がやるしかないのは分かりますけど……",
      "translations": {
        "en": "so we just have to do it‚ but…",
        "id": ""
      },
      "startTime": 180.7,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "smr",
      "speakerName": "奥山すみれ",
