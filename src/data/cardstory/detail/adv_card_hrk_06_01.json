      "text": "スリクスさんがあんなに仲悪いなんて\n聞いてないわよ～！",
      "translations": {
        "en": "I didn't know IIIX members had\nsuch poor relations.",
        "id": ""
      },
      "startTime": 252.6719441731,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_onsenroom-00-noon.webp",
      "bgName": "onsenroom-00-noon",
      "startTime": 254.6719441731
    },
    {
      "type": "dialogue",
      "speakerCode": "hrk",
      "speakerName": "佐伯遙子",
      "speakerNameEn": "Haruko",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-haruko.png",
