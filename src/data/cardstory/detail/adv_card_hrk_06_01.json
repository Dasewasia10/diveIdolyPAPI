      "text": "褒めておけばごまかせると思ってるでしょ\n付き合いが長いとそういうことも分かるんだからね",
      "translations": {
        "en": "You think you can trick me with flattery?\nI know these tricks‚ we've known each other too long.",
        "id": ""
      },
      "startTime": 273.4052775065,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_onsenroom-00-noon.webp",
      "bgName": "onsenroom-00-noon",
      "startTime": 277.0719441731
    },
    {
      "type": "dialogue",
      "speakerCode": "hrk",
      "speakerName": "佐伯遙子",
      "speakerNameEn": "Haruko",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-haruko.png",
