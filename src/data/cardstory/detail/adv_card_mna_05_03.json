      "text": "一年の最後、大晦日に一緒に過ごせるなんて",
      "startTime": 89.8999954068,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "mna",
      "speakerName": "長瀬麻奈",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-mana.png",
