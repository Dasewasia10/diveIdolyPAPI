      "text": "昔から観ていた舞台に立てて、夢みたい",
      "startTime": 95.7666717373,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "mna",
      "speakerName": "長瀬麻奈",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-mana.png",
      "voiceUrl": null,
      "text": "これも、みんなが応援してくれたおかげだよ",
      "startTime": 99.0489672153,
      "sfxList": [
        {
          "src": "https://apiip.dasewasia.my.id/storyBgm/sud_se_adv_cheers-in-01.m4a",
