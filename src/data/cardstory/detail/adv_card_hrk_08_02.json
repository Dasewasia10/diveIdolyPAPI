      "text": "{user}君も\n私がトップアイドルになる方法を一緒に探してくれる？",
      "translations": {
        "en": "{user}…\nWould you help me find the path to becoming a top idol?",
        "id": ""
      },
      "startTime": 163.5687356138,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_hoshiarcade-00-noon.webp",
      "bgName": "hoshiarcade-00-noon",
