    },
    {
      "type": "dialogue",
      "speakerCode": null,
      "speakerName": "",
      "speakerNameEn": "",
      "iconUrl": null,
      "voiceUrl": null,
      "text": "――数日後",
      "translations": {
        "en": "――A few days later",
        "id": ""
      },
      "startTime": 182.733298556,
      "sfxList": []
    },
    {
      "type": "background",
