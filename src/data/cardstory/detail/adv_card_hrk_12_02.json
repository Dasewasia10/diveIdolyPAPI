    {
      "type": "dialogue",
      "speakerCode": "koh",
      "speakerName": "{user}",
      "speakerNameEn": "{user}",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-makino.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_hrk_12_02/sud_vo_adv_card_hrk_12_02-koh010.m4a",
      "text": "あれ、遙子さん……ど、どうしました？\nなんで泣いて……何があったんですか！？",
      "translations": {
        "en": "Oh‚ Haruko-san… w-what’s wrong?\nWhy are you crying…? What happened!?",
        "id": ""
      },
      "startTime": 193.3,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_hoshicorridor-00-noon.webp",
