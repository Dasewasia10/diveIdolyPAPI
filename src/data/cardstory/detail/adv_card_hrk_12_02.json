    },
    {
      "type": "dialogue",
      "speakerCode": "hrk",
      "speakerName": "佐伯遙子",
      "speakerNameEn": "Haruko",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-haruko.png",
      "voiceUrl": null,
      "text": "{user}君……ううん、なんでもないの",
      "translations": {
        "en": "{user}-kun… no‚ it’s nothing.",
        "id": ""
      },
      "startTime": 197.2,
