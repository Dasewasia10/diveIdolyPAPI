          "startTime": 138.6459172727
        }
      ]
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_kawasakiliving-00-noon.webp",
      "bgName": "kawasakiliving-00-noon",
      "startTime": 127.7792463821
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_kawasakiliving-00-noon.webp",
      "bgName": "kawasakiliving-00-noon",
      "startTime": 133.3792428216
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_kawasakiliving-00-noon.webp",
      "bgName": "kawasakiliving-00-noon",
      "startTime": 137.812576155
    },
    {
      "type": "dialogue",
      "speakerCode": "skr",
      "speakerName": "川咲さくら",
      "speakerNameEn": "Sakura",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-sakura.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_skr_51_03/sud_vo_adv_card_skr_51_03-skr005.m4a",
      "text": "なんでやねんっ！　もういいぜっ！\nどうも、ありがとうございましたー！",
      "translations": {
        "en": "No way! I’ve had enough!\nThank you very much~!",
        "id": ""
      },
      "startTime": 137.812576155,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "skr",
      "speakerName": "川咲さくら",
      "speakerNameEn": "Sakura",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-sakura.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_skr_51_03/sud_vo_adv_card_skr_51_03-skr006.m4a",
      "text": "えへへ、スタッフさん達も\n拍手ありがとうございま～す！",
      "translations": {
        "en": "Ehehe‚ thank you\nfor the applause‚ staff~!",
        "id": ""
      },
      "startTime": 144.212576155,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_kawasakiliving-00-noon.webp",
      "bgName": "kawasakiliving-00-noon",
      "startTime": 147.0459135574
    },
    {
      "type": "dialogue",
      "speakerCode": "ktn",
      "speakerName": "長瀬琴乃",
      "speakerNameEn": "Kotono",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-kotono.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_skr_51_03/sud_vo_adv_card_skr_51_03-ktn007.m4a",
      "text": "あはは……結局、最後までツッコミが早かったけど……\nでは、次のコーナーです。さくら",
      "translations": {
        "en": "Ahaha… Your punchline was too early until the very end‚ though…\nWell then‚ it’s time for the next segment. Sakura‚",
        "id": ""
      },
      "startTime": 156.6792468907,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_kawasakiliving-00-noon.webp",
      "bgName": "kawasakiliving-00-noon",
      "startTime": 156.6792468907
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_kawasakiliving-00-noon.webp",
      "bgName": "kawasakiliving-00-noon",
      "startTime": 160.6792468907
    },
    {
      "type": "dialogue",
      "speakerCode": "skr",
      "speakerName": "川咲さくら",
      "speakerNameEn": "Sakura",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-sakura.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_skr_51_03/sud_vo_adv_card_skr_51_03-skr007.m4a",
      "text": "うん。次はお父さんとお母さんに\n私の小さい頃の話を聞いちゃうよ！",
      "translations": {
        "en": "Okay. Next‚ Mom and Dad are going to\ntell us stories about my childhood!",
        "id": ""
      },
      "startTime": 164.7459135574,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": null,
