      "text": "遙子さん、しー……",
      "startTime": 14.4391149402,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_tokyocorridor-00-noon.webp",
      "bgName": "env_adv_2d_tokyodormcorridor-00-noon",
      "startTime": 18.3391149402
    },
    {
      "type": "dialogue",
      "speakerCode": "hrk",
      "speakerName": "佐伯遙子",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-haruko.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_skr_51_03/sud_vo_adv_card_skr_51_03-hrk002.m4a",
      "text": "えっ、琴乃ちゃん？\nしー、って……レッスン室に誰かいるの？",
      "startTime": 20.9666659673,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_lesson-01-noon.webp",
