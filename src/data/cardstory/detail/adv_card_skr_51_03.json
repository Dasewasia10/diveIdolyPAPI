      "startTime": 83.3341050824
    },
    {
      "type": "dialogue",
      "speakerCode": null,
      "speakerName": "",
      "speakerNameEn": "",
      "iconUrl": null,
      "voiceUrl": null,
      "text": "――撮影当日",
      "translations": {
        "en": "――The day of the shoot.",
        "id": ""
