      "text": "私はね、ファンのみんなが、私の歌で元気になって",
      "startTime": 159.7876813248,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "mna",
      "speakerName": "長瀬麻奈",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-mana.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_mna_52_03/sud_vo_adv_cmn_mna_glad-04.m4a",
