      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-mana.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_mna_52_03/sud_vo_adv_cmn_mna_hey-04.m4a",
      "text": "この胸の想いを、今度は私が、みんなに届けるよ",
      "startTime": 88.2093192889,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "mna",
