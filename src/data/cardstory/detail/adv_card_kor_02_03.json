{
  "id": "adv_card_kor_02_03",
  "title": "fran 3話 秘密ですからね？",
  "script": [
    {
      "type": "dialogue",
      "speakerCode": null,
      "speakerName": "",
      "speakerNameEn": "",
      "iconUrl": null,
      "voiceUrl": null,
      "text": "――翌朝",
      "translations": {
        "en": "――The next morning",
        "id": ""
      },
      "startTime": 0,
      "sfxList": []
    },
    {
      "type": "background",
