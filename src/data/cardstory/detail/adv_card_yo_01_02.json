      "startTime": 5.0333333452
    },
    {
      "type": "dialogue",
      "speakerCode": "yo",
      "speakerName": "渡辺曜",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-yo.png",
