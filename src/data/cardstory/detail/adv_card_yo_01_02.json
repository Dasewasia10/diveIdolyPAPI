          "delay": 7433.3333214,
          "startTime": 12.4666666666
        }
      ]
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_uchiurabeach-00-noon.webp",
      "bgName": "uchiurabeach-00-noon",
      "startTime": 12.4666666786
    },
    {
      "type": "dialogue",
      "speakerCode": "yo",
      "speakerName": "渡辺曜",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-yo.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_yo_01_02/sud_vo_adv_card_yo_01_02-yo003.m4a",
      "text": "わわっ、どんどん質問がきちゃった！\nしかもどれもすっごく細かい質問だ……",
      "startTime": 15.1000000119,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_uchiurabeach-00-noon.webp",
      "bgName": "uchiurabeach-00-noon",
      "startTime": 19.3666666786
    },
    {
      "type": "dialogue",
      "speakerCode": "yo",
      "speakerName": "渡辺曜",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-yo.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_yo_01_02/sud_vo_adv_card_yo_01_02-yo004.m4a",
      "text": "……なるほどね。千紗ちゃんは分かりやすいなぁ",
      "startTime": 19.3666666786,
      "sfxList": [
        {
          "src": "https://apiip.dasewasia.my.id/storyBgm/sud_se_adv_phone-call-01.m4a",
          "delay": 13166.666654699999,
          "startTime": 32.5333333333
        },
        {
          "src": "https://apiip.dasewasia.my.id/storyBgm/sud_se_adv_phone-call-01.m4a",
          "delay": 17385.314675199996,
          "startTime": 36.7519813538
        },
        {
          "src": "https://apiip.dasewasia.my.id/storyBgm/sud_se_adv_phone-tap-02.m4a",
          "delay": 9563.333321399998,
          "startTime": 28.93
        }
      ]
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_living-01-noon.webp",
      "bgName": "env_adv_3d_living-01-000-noon",
      "startTime": 25.3333333452
    },
    {
      "type": "dialogue",
      "speakerCode": "chs",
      "speakerName": "白石千紗",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-chisa.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_yo_01_02/sud_vo_adv_card_yo_01_02-chs001.m4a",
      "text": "一杯送っちゃった……\nでも、この間の感じなら、バレてないよね……？",
      "startTime": 29.066664644,
      "sfxList": [
        {
          "src": "https://apiip.dasewasia.my.id/storyBgm/sud_se_adv_phone-tap-01.m4a",
          "delay": 8166.666666700003,
          "startTime": 37.2333313107
        }
      ]
    },
    {
      "type": "dialogue",
      "speakerCode": "chs",
      "speakerName": "白石千紗",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-chisa.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_yo_01_02/sud_vo_adv_card_yo_01_02-chs002.m4a",
      "text": "わっ、曜ちゃんから電話？\n……はい、もしもし",
      "startTime": 37.2333313107,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "yo",
      "speakerName": "渡辺曜",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-yo.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_yo_01_02/sud_vo_adv_card_yo_01_02-yo005.m4a",
      "text": "千紗ちゃん、大丈夫？\n一人で作るのは大変じゃない？",
      "startTime": 41.5666666667,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "chs",
      "speakerName": "白石千紗",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-chisa.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_yo_01_02/sud_vo_adv_card_yo_01_02-chs003.m4a",
      "text": "え？　あ、うん……そうなんだ\n思った以上に難しくて……って、あ、あれ？",
      "startTime": 47.9999987404,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_uchiurabeach-00-noon.webp",
      "bgName": "uchiurabeach-00-noon",
      "startTime": 54.7000007749
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_uchiurabeach-00-noon.webp",
      "bgName": "uchiurabeach-00-noon",
      "startTime": 54.7000007749
    },
    {
      "type": "dialogue",
      "speakerCode": "yo",
      "speakerName": "渡辺曜",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-yo.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_yo_01_02/sud_vo_adv_card_yo_01_02-yo006.m4a",
      "text": "あはは、もうバレバレだよー",
      "startTime": 55.8333343625,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "chs",
      "speakerName": "白石千紗",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-chisa.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_yo_01_02/sud_vo_adv_card_yo_01_02-chs004.m4a",
      "text": "えぇ！？　あ、え、う、嘘……なんで分かったの？",
      "startTime": 59.3000050982,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_uchiurabeach-00-noon.webp",
      "bgName": "uchiurabeach-00-noon",
      "startTime": 65.4000050982
    },
    {
      "type": "dialogue",
      "speakerCode": "yo",
      "speakerName": "渡辺曜",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-yo.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_yo_01_02/sud_vo_adv_card_yo_01_02-yo007.m4a",
      "text": "だって、千紗ちゃんてばずっとふわふわしてたでしょ？\nこの間も妙に熱心に撮影してたし",
      "startTime": 69.3666717649,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "yo",
      "speakerName": "渡辺曜",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-yo.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_yo_01_02/sud_vo_adv_card_yo_01_02-yo008.m4a",
      "text": "それで、もしかしたら……って思ったんだよね",
      "startTime": 72.7333343626,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_uchiurabeach-00-noon.webp",
      "bgName": "uchiurabeach-00-noon",
      "startTime": 76.8666743081
    },
    {
      "type": "dialogue",
      "speakerCode": "chs",
      "speakerName": "白石千紗",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-chisa.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_yo_01_02/sud_vo_adv_card_yo_01_02-chs005.m4a",
      "text": "うん、本当は驚かせるつもりだったんだけど……\n今度のライブでお揃いの衣装を着たくて",
      "startTime": 81.7333409747,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_uchiurabeach-00-noon.webp",
      "bgName": "uchiurabeach-00-noon",
      "startTime": 85.4333404661
    },
    {
      "type": "dialogue",
      "speakerCode": "yo",
      "speakerName": "渡辺曜",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-yo.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_yo_01_02/sud_vo_adv_card_yo_01_02-yo009.m4a",
      "text": "え、サニピが私達の衣装を着てくれるの！？\nはぁぁ～……嬉し過ぎる～！",
      "startTime": 89.8666737994,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_uchiurabeach-00-noon.webp",
      "bgName": "uchiurabeach-00-noon",
      "startTime": 93.6666737994
    },
    {
      "type": "dialogue",
      "speakerCode": "chs",
      "speakerName": "白石千紗",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-chisa.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_yo_01_02/sud_vo_adv_card_yo_01_02-chs006.m4a",
      "text": "でも私、衣装のデザインをしたことはあるけど\n一人で作ったことはないから、なかなか進まなくて……",
      "startTime": 98.0000071328,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_uchiurabeach-00-noon.webp",
      "bgName": "uchiurabeach-00-noon",
      "startTime": 102.9666793944
    },
    {
      "type": "dialogue",
      "speakerCode": "yo",
      "speakerName": "渡辺曜",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-yo.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_yo_01_02/sud_vo_adv_card_yo_01_02-yo010.m4a",
      "text": "それなら私に手伝わせて！",
      "startTime": 102.9666793944,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_youroom-00-noon.webp",
      "bgName": "youroom-00-noon",
      "startTime": 106.7500127277
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_youroom-00-noon.webp",
      "bgName": "youroom-00-noon",
      "startTime": 106.7500127277
    },
    {
      "type": "dialogue",
      "speakerCode": "chs",
      "speakerName": "白石千紗",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-chisa.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_yo_01_02/sud_vo_adv_card_yo_01_02-chs007.m4a",
      "text": "曜ちゃん、ごめんね……？　ほんとにありがとう",
      "startTime": 107.8000127277,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_youroom-00-noon.webp",
      "bgName": "youroom-00-noon",
      "startTime": 112.0000127277
    },
    {
      "type": "dialogue",
      "speakerCode": "yo",
      "speakerName": "渡辺曜",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-yo.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_yo_01_02/sud_vo_adv_card_yo_01_02-yo011.m4a",
      "text": "そんなのこちらこそだよ！　サニピが\nAqoursの衣装を着てくれるなんて最っ高だよ！",
      "startTime": 114.8333460611,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_youroom-00-noon.webp",
      "bgName": "youroom-00-noon",
      "startTime": 118.6333430094
    },
    {
      "type": "dialogue",
      "speakerCode": "yo",
      "speakerName": "渡辺曜",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-yo.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_yo_01_02/sud_vo_adv_card_yo_01_02-yo012.m4a",
      "text": "よーし、二人で頑張って作ってみよう！",
      "startTime": 118.6333430094,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_youroom-00-noon.webp",
      "bgName": "youroom-00-noon",
      "startTime": 123.5000094218
    },
    {
      "type": "dialogue",
      "speakerCode": "yo",
      "speakerName": "渡辺曜",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-yo.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_yo_01_02/sud_vo_adv_card_yo_01_02-yo013.m4a",
      "text": "……ふぅ。結構進んだね～",
      "startTime": 124.6333506388,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_youroom-00-noon.webp",
      "bgName": "youroom-00-noon",
      "startTime": 128.3333506388
    },
    {
      "type": "dialogue",
      "speakerCode": "chs",
      "speakerName": "白石千紗",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-chisa.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_yo_01_02/sud_vo_adv_card_yo_01_02-chs008.m4a",
      "text": "うん。曜ちゃんに手伝ってもらったおかげで\n一気に進んだよ……ありがとう",
      "startTime": 131.8666839721,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_youroom-00-noon.webp",
      "bgName": "youroom-00-noon",
      "startTime": 135.0666839721
    },
    {
      "type": "dialogue",
      "speakerCode": "yo",
      "speakerName": "渡辺曜",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-yo.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_yo_01_02/sud_vo_adv_card_yo_01_02-yo014.m4a",
      "text": "ふふ、どういたしまして！　この調子で残りも\n頑張っちゃおう！　全速前進、ヨーソロー！",
      "startTime": 138.9333506388,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_youroom-00-noon.webp",
      "bgName": "youroom-00-noon",
      "startTime": 144.0333343628
    },
    {
      "type": "dialogue",
      "speakerCode": "chs",
      "speakerName": "白石千紗",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-chisa.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_yo_01_02/sud_vo_adv_card_yo_01_02-chs009.m4a",
      "text": "よ、ヨーソロー！",
      "startTime": 144.0333343628,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_youroom-00-noon.webp",
      "bgName": "youroom-00-noon",
      "startTime": 146.4999918742
    },
    {
      "type": "dialogue",
      "speakerCode": "yo",
      "speakerName": "渡辺曜",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-yo.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_yo_01_02/sud_vo_adv_card_yo_01_02-yo015.m4a",
      "text": "お、いいねいいね！",
      "startTime": 146.4999918742,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_youroom-00-noon.webp",
      "bgName": "youroom-00-noon",
      "startTime": 149.0666687134
    },
    {
      "type": "dialogue",
      "speakerCode": "chs",
      "speakerName": "白石千紗",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-chisa.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_yo_01_02/sud_vo_adv_card_yo_01_02-chs010.m4a",
      "text": "曜ちゃんみたいな元気のいい挨拶に憧れてて……\nで、出来てるかな……？",
      "startTime": 154.2333353801,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_youroom-00-noon.webp",
      "bgName": "youroom-00-noon",
      "startTime": 156.8000020467
    },
    {
      "type": "dialogue",
      "speakerCode": "yo",
      "speakerName": "渡辺曜",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-yo.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_yo_01_02/sud_vo_adv_card_yo_01_02-yo016.m4a",
      "text": "うんうん、バッチリだよ！　とっても可愛い！\nそうだ、せっかくだから一緒に写真撮ろうよ！",
      "startTime": 160.6000020467,
      "sfxList": [
        {
          "src": "https://apiip.dasewasia.my.id/storyBgm/sud_se_adv_phone-camera-01.m4a",
          "delay": 12566.650378399998,
          "startTime": 173.1666524251
        }
      ]
    },
