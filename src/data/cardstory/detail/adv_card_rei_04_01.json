      "text": "睨んでません！　ただ、ちゃんと話せなかったから\n二人のことが気になって……",
      "startTime": 259.7,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "rei",
      "speakerName": "一ノ瀬怜",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-rei.png",
