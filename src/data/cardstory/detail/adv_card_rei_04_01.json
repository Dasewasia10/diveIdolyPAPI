      "text": "怜は怖い顔で千紗達を睨んでいたのか？",
      "startTime": 251.9,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "rei",
      "speakerName": "一ノ瀬怜",
