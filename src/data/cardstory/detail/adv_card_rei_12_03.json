      "startTime": 164.7448203239,
      "sfxList": [
        {
          "src": "https://apiip.dasewasia.my.id/storyBgm/sud_se_adv_cat-01.m4a",
          "delay": 0,
          "startTime": 164.5448228671
        }
      ]
    },
    {
      "type": "dialogue",
