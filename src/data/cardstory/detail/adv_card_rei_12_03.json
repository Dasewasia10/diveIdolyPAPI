      "text": "……え？　ここは……",
      "startTime": 174.7140377038,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "koh",
      "speakerName": "{user}",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-makino.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_rei_12_03/sud_vo_adv_card_rei_12_03-koh005.m4a",
      "text": "見ろ、人が沢山いるぞ\nさっきまで誰もいなかったのに……",
      "startTime": 181.2333307899,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_shoppingspot-00-noon.webp",
