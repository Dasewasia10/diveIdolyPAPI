      "bgName": "stage1",
      "startTime": 16.485963273048363
    },
    {
      "type": "dialogue",
      "speakerCode": "koh",
      "speakerName": "{user}",
      "speakerNameEn": "{user}",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-makino.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_suz_01_02/sud_vo_adv_card_suz_01_02-koh003.m4a",
      "text": "そんなことより、急にどうしたんだ\n楽屋に閉じこもるなんて",
      "translations": {
        "en": "Never mind that. What’s the matter all of a sudden?\nStaying slience in your waiting room…",
        "id": ""
      },
      "startTime": 19.866666666666667,
      "sfxList": []
    },
    {
      "type": "background",
