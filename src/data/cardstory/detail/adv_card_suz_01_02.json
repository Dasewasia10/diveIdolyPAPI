      "bgName": "stage1",
      "startTime": 21.749296593666077
    },
    {
      "type": "dialogue",
      "speakerCode": "suz",
      "speakerName": "成宮すず",
      "speakerNameEn": "Suzu",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-suzu.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_suz_01_02/sud_vo_adv_card_suz_01_02-suz003.m4a",
      "text": "いえ、私はいつも通りですわよ？",
      "translations": {
        "en": "No‚ I’m the same as ever.",
        "id": ""
      },
      "startTime": 21.74929659366608,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "suz",
      "speakerName": "成宮すず",
      "speakerNameEn": "Suzu",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-suzu.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_suz_01_02/sud_vo_adv_card_suz_01_02-suz004.m4a",
      "text": "星見市が生んだ可憐な宝石、成宮すずですの",
      "translations": {
        "en": "I’m Suzu Narumiya‚ the cute jewel from Hoshimi City.",
        "id": ""
      },
      "startTime": 24.932244467735295,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_livecorridor-00-noon.webp",
      "bgName": "stage1",
      "startTime": 29.12074797153476
    },
    {
      "type": "dialogue",
      "speakerCode": "koh",
      "speakerName": "{user}",
      "speakerNameEn": "{user}",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-makino.png",
