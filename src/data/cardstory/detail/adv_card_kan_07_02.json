      "text": "こころがこっそり、こーんな危ない物を持ってたと\nあの保護者連中が知ったら……ふふふ",
      "startTime": 255.1076034707,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "koh",
      "speakerName": "{user}",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-makino.png",
