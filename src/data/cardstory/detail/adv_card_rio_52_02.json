      "speakerCode": "koh",
      "speakerName": "{user}",
      "speakerNameEn": "{user}",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-makino.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_rio_52_02/sud_vo_adv_card_rio_52_02-koh009.m4a",
      "text": "もちろんです。マネージャーとして出来ることなら\nなんでも言って下さい",
      "translations": {
