      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-rik.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_rik_01_01/sud_vo_adv_card_rik_01_01-rik006.m4a",
      "text": "わぁっ！？　し、雫ちゃん！？\nど、どど、どうしてここに？",
      "startTime": 55.2130135377,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "szk",
      "speakerName": "兵藤雫",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-shizuku.png",
