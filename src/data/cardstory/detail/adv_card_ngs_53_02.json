{
  "id": "adv_card_ngs_53_02",
  "title": "伊吹渚",
  "script": [
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_liveslope-00-noon.webp",
      "bgName": "env_adv_3d_liveslope-00-000-noon",
