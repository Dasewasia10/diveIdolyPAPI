        {
          "src": "https://apiip.dasewasia.my.id/storyBgm/sud_se_adv_horror-voice-01.m4a",
          "delay": 5366.6666665999965,
          "startTime": 179.8666615804
        }
      ]
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_hauntedhouse-00-noon.webp",
      "bgName": "hauntedhouse-00-noon"
