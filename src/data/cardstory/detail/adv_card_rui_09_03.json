      "speakerName": "{user}",
      "speakerNameEn": "{user}",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-makino.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_rui_09_03/sud_vo_adv_card_rui_09_03-koh012.m4a",
      "text": "変なこと？",
      "translations": {
