      "startTime": 220.8
    },
    {
      "type": "dialogue",
      "speakerCode": "rui",
      "speakerName": "天動瑠依",
      "speakerNameEn": "Rui",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-rui.png",
