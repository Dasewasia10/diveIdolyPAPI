      "speakerCode": "unknown",
      "speakerName": "男子生徒",
      "speakerNameEn": "",
      "iconUrl": null,
      "voiceUrl": null,
      "text": "ちょうど予備を持っているので。どうぞ",
      "translations": {
        "en": "",
        "id": ""
      },
