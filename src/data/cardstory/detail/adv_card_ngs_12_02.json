      "iconUrl": null,
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_ngs_12_02/sud_vo_adv_card_ngs_12_02-koh017.m4a",
      "text": "あはは……見ての通りガラガラですから\n少しぐらい離れても大丈夫ですよ",
      "translations": {
        "en": "",
        "id": ""
      },
      "startTime": 329.8666646321,
      "sfxList": []
    },
    {
