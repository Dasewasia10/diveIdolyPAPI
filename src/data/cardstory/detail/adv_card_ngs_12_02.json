      "text": "何かあったんですか？　話してみて下さい",
      "translations": {
        "en": "",
        "id": ""
      },
      "startTime": 287.5232309343,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "unknown",
      "speakerName": "男子生徒",
      "speakerNameEn": "",
      "iconUrl": null,
      "voiceUrl": null,
      "text": "俺で良かったら、力になりますよ",
      "translations": {
        "en": "",
        "id": ""
      },
      "startTime": 291.1666585286,
      "sfxList": []
    },
    {
