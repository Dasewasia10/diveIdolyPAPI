      "iconUrl": null,
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_ngs_12_02/sud_vo_adv_card_ngs_12_02-koh013.m4a",
      "text": "あ、そこの方、見て行きませんか？\nきっと気に入る写真があるはずですよ",
      "translations": {
        "en": "",
        "id": ""
      },
