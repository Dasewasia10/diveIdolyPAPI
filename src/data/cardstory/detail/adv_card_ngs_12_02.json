      "iconUrl": null,
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_ngs_12_02/sud_vo_adv_card_ngs_12_02-koh016.m4a",
      "text": "行きたい場所があるなら、お教えしますよ",
      "translations": {
        "en": "",
        "id": ""
      },
      "startTime": 312.3898752214,
      "sfxList": []
    },
