      "speakerCode": "unknown",
      "speakerName": "男子生徒",
      "speakerNameEn": "",
      "iconUrl": null,
      "voiceUrl": null,
      "text": "あ、良かったら案内しましょうか？",
      "translations": {
        "en": "",
        "id": ""
      },
      "startTime": 315.3666483561,
      "sfxList": []
    },
    {
      "type": "background",
