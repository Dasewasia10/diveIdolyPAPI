      "text": "いや、今のはフリじゃないからな……？",
      "startTime": 77.4204758347,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": null,
      "speakerName": "",
      "iconUrl": null,
      "voiceUrl": null,
