      "speakerCode": "kkr",
      "speakerName": "赤崎こころ",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-kokoro.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_kkr_09_02/sud_vo_adv_card_kkr_09_02-kkr008.m4a",
      "text": "さてさて、しばらく愛ちゃんが一人で撮影ということ\nなので、こころ達は一休みするとしましょうか～",
      "startTime": 94.6991365217,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "koh",
      "speakerName": "{user}",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-makino.png",
