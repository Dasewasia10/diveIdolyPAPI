      "text": "えいっ",
      "startTime": 44.6376416844,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "koh",
      "speakerName": "{user}",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-makino.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_kkr_09_02/sud_vo_adv_card_kkr_09_02-koh003.m4a",
      "text": "ぶはっっ！？　げほっ、げほっ、けほっ……\nこ、こら、こころ！　いきなり脇腹をつつくな……！",
      "startTime": 47.6333340328,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_bigpool-00-noon.webp",
