      "text": "ちょっとー！　失礼なんですけどー",
      "startTime": 35.6666690189,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "mna",
      "speakerName": "長瀬麻奈",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-mana.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_mna_05_01/sud_vo_adv_cmn_mna_laughter-05.m4a",
      "text": "あはは、でもなんだか緊張ほぐれてきたかも",
      "startTime": 38.3042185252,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "koh",
      "speakerName": "{user}",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-makino.png",
