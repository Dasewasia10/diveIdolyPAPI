      "text": "そっか。んー……\nなら、ほしいものとかない？",
      "translations": {
        "en": "I see. Hmm…\nWell‚ is there anything you want?",
        "id": ""
      },
      "startTime": 79.5666662335,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "ktn",
      "speakerName": "長瀬琴乃",
      "speakerNameEn": "Kotono",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-kotono.png",
