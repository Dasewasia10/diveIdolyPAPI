      "text": "渚？　お弁当食べないの？",
      "translations": {
        "en": "Nagisa? Aren't you going to eat your lunch?",
        "id": ""
      },
      "startTime": 47.8632644774,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "ngs",
      "speakerName": "伊吹渚",
      "speakerNameEn": "Nagisa",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-nagisa.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_ngs_51_01/sud_vo_adv_card_ngs_51_01-ngs005.m4a",
      "text": "あ、ごめん、ちょっと考えごとしちゃってた",
      "translations": {
        "en": "Oh‚ sorry‚ I was just thinking about something.",
        "id": ""
      },
      "startTime": 51.1774366659,
      "sfxList": []
    },
    {
      "type": "background",
