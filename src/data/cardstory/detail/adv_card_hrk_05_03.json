      "text": "……そっか、この向こうにいるんだね\n私達を待ってくれているファンの人達が……",
      "translations": {
        "en": "…I see‚ they're over there.\nThe fans who are waiting for us…",
        "id": ""
      },
      "startTime": 286.2,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "koh",
      "speakerName": "{user}",
      "speakerNameEn": "{user}",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-makino.png",
