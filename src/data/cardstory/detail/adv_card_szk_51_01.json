        "en": "Ugh…\nGoodbye… My… Birthday…",
        "id": ""
      },
      "startTime": 186.561073653,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "skr",
      "speakerName": "川咲さくら",
