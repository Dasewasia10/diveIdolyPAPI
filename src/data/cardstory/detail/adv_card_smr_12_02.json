    },
    {
      "type": "dialogue",
      "speakerCode": "smr",
      "speakerName": "奥山すみれ",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-sumire.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_smr_12_02/sud_vo_adv_card_smr_12_02-smr001.m4a",
      "text": "{user}さん、ちょうどいいところに！\nエールトゥインクル～くるくるぽーん！",
      "startTime": 9.8333333333,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "koh",
      "speakerName": "{user}",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-makino.png",
