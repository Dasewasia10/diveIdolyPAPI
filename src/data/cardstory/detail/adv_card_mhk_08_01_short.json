          "delay": 3670.0523642,
          "startTime": 8.4999999999
        }
      ]
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_office-01-night.webp",
      "bgName": "env_adv_3d_office-01-000-night"
    },
    {
      "type": "dialogue",
      "speakerCode": "mhk",
      "speakerName": "miho",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-miho.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_mhk_08_01_short/sud_vo_adv_card_mhk_08_01-mhk001.m4a",
      "text": "お疲れ様です。今掃除中で邪魔なので\nさっさとどいていただけると助かります",
      "startTime": 14.8333333333,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "koh",
      "speakerName": "{user}",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-makino.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_mhk_08_01_short/sud_vo_adv_card_mhk_08_01-koh002.m4a",
      "text": "し、失礼しました……あれ、mihoさんが\n事務所の掃除をしてくれてたんですか？",
      "startTime": 21.3666666667,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "mhk",
      "speakerName": "miho",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-miho.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_mhk_08_01_short/sud_vo_adv_card_mhk_08_01-mhk002.m4a",
      "text": "いつも沙季が整頓してくれているようですが\n子供にばかりやらせるのも大人として情けないですし",
      "startTime": 27.3,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "mhk",
      "speakerName": "miho",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-miho.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_mhk_08_01_short/sud_vo_adv_card_mhk_08_01-mhk003.m4a",
      "text": "いくら片付けても、いつの間にかまた散らかって……\n今日なんて、雑誌が読み散らかされていましたね",
      "startTime": 35.7666666667,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "koh",
      "speakerName": "{user}",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-makino.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_mhk_08_01_short/sud_vo_adv_card_mhk_08_01-koh003.m4a",
      "text": "すみません……その雑誌、俺が読んでたやつです……\n以後整理整頓を徹底いたします、はい",
      "startTime": 44,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "mhk",
      "speakerName": "miho",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-miho.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_mhk_08_01_short/sud_vo_adv_card_mhk_08_01-mhk004.m4a",
      "text": "アイドル達の模範となるべきマネージャーが\n率先して堕落していてどうするんですか",
      "startTime": 51,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "mhk",
      "speakerName": "miho",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-miho.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_mhk_08_01_short/sud_vo_adv_card_mhk_08_01-mhk005.m4a",
      "text": "それにアイドル誌に混じって車の雑誌もありましたけど\n業務中に何をやっていたんですか、まったく",
      "startTime": 57.8666666667,
      "sfxList": []
    }
  ]
}