      "translations": {
        "en": "Ah‚ sorry.\nBut can I really pull off something so mature?",
        "id": ""
      },
      "startTime": 272.2666666667,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "koh",
      "speakerName": "{user}",
      "speakerNameEn": "{user}",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-makino.png",
