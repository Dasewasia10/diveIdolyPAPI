      "translations": {
        "en": "I know that you prioritize LizNoir.\nBut your own success will also benefit LizNoir.",
        "id": ""
      },
      "startTime": 219.0521257482,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "ai",
      "speakerName": "小美山愛",
      "speakerNameEn": "Ai",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-ai.png",
