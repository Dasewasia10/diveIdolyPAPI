      "text": "でも、{user}さんになら話せるかも……\n聞いてもらっても、いい？",
      "translations": {
        "en": "but maybe I can tell you‚ {user}-san…\nWould you listen?",
        "id": ""
      },
      "startTime": 278.7813845094,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "koh",
      "speakerName": "{user}",
