    {
      "type": "dialogue",
      "speakerCode": "ktn",
      "speakerName": "長瀬琴乃",
      "speakerNameEn": "Kotono",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-kotono.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_ktn_05_02/sud_vo_adv_card_ktn_05_02-ktn023.m4a",
      "text": "それと、お姉ちゃんは{user}さんの\nことをよく、頑固者だーって言ってましたよ",
      "translations": {
        "en": "Also‚ big sis told me that you‚\n{user}-san‚ are quite stubborn too.",
