      "startTime": 41.4518018722
    },
    {
      "type": "dialogue",
      "speakerCode": "cca",
      "speakerName": "ココア",
      "speakerNameEn": "ココア",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-cca.png",
