      "startTime": 55.5299117088,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_woodentownstreet-00-noon.webp",
      "bgName": "s1",
      "startTime": 57.8512046654
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_woodentownstreet-00-noon.webp",
      "bgName": "s1",
