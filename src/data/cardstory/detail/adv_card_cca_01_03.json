      "text": "うん、でもココアちゃんにはチノちゃんがいるし\nあんまり甘えちゃうのは悪いかな",
      "translations": {
        "en": "うん、でもココアちゃんにはチノちゃんがいるし\nあんまり甘えちゃうのは悪いかな",
        "id": ""
      },
      "startTime": 115.0666666667,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "chs",
      "speakerName": "白石千紗",
      "speakerNameEn": "白石千紗",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-chisa.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_cca_01_03/sud_vo_adv_card_cca_01_03-chs011.m4a",
      "text": "もしお姉ちゃんが取られちゃったら\nチノちゃんも寂しくなっちゃうと思うから",
      "translations": {
        "en": "もしお姉ちゃんが取られちゃったら\nチノちゃんも寂しくなっちゃうと思うから",
        "id": ""
      },
      "startTime": 120.5,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_woodentownstreet-00-noon.webp",
      "bgName": "s1",
      "startTime": 123.6239019235
    },
    {
      "type": "dialogue",
      "speakerCode": "cca",
      "speakerName": "ココア",
      "speakerNameEn": "ココア",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-cca.png",
