      "text": "私のお姉ちゃんとは、また違う感じだけど\nココアちゃんがお姉ちゃんだったら、素敵かも",
      "translations": {
        "en": "私のお姉ちゃんとは、また違う感じだけど\nココアちゃんがお姉ちゃんだったら、素敵かも",
        "id": ""
      },
      "startTime": 92.6666666667,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_woodentownstreet-00-noon.webp",
      "bgName": "s1",
      "startTime": 95.9634322008
    },
    {
      "type": "dialogue",
      "speakerCode": "chs",
      "speakerName": "白石千紗",
      "speakerNameEn": "白石千紗",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-chisa.png",
