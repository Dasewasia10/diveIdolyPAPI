      "startTime": 32.0589977423,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_woodentownstreet-00-noon.webp",
      "bgName": "s1",
      "startTime": 35.9091235001
    },
    {
      "type": "dialogue",
      "speakerCode": "chs",
      "speakerName": "白石千紗",
      "speakerNameEn": "白石千紗",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-chisa.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_cca_01_03/sud_vo_adv_card_cca_01_03-chs004.m4a",
      "text": "うさぎさんに言葉は通じないような……\nだ、大丈夫かな……",
      "translations": {
        "en": "うさぎさんに言葉は通じないような……\nだ、大丈夫かな……",
        "id": ""
