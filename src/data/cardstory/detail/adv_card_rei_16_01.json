        },
        {
          "src": "https://apiip.dasewasia.my.id/storyBgm/sud_se_adv_car-02.m4a",
          "delay": 13699.995422400008,
          "startTime": 190.4
        }
      ]
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_tokyotown-00-noon.webp",
      "bgName": "tokyotown-00-noon"
    },
    {
      "type": "dialogue",
      "speakerCode": "koh",
      "speakerName": "{user}",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-makino.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_rei_16_01/sud_vo_adv_card_rei_16_01-koh009.m4a",
      "text": "（VENUSプログラムに登録していない野良アイドルが）\n（夜な夜な集い、争う『アイドル地下闘技場』）",
      "startTime": 184.7333379109,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "koh",
      "speakerName": "{user}",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-makino.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_rei_16_01/sud_vo_adv_card_rei_16_01-koh010.m4a",
      "text": "（身バレのリスクも考えると正直参加してほしくはない）\n（でも芽衣曰く、みんなやる気みたいだし……）",
      "startTime": 193.2000045776,
      "sfxList": []
    },
