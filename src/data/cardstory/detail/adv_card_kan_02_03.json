      },
      "startTime": 109.4294871886,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "koh",
      "speakerName": "{user}",
      "speakerNameEn": "{user}",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-makino.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_kan_02_03/sud_vo_adv_card_kan_02_03-koh005.m4a",
      "text": "（……なんだかんだ言って）\n（メンバーのことは認めてるんだな……）",
      "translations": {
        "en": "(……You admit to the members‚)\n(don't you? ……)",
