      },
      "startTime": 77.3961538553,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "kan",
      "speakerName": "kana",
      "speakerNameEn": "kana",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-kana.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_kan_02_03/sud_vo_adv_card_kan_02_03-kan010.m4a",
      "text": "だからkanaはスリクスを続けてるの",
      "translations": {
        "en": "So That's why kana keeps doing ⅢX.",
        "id": ""
      },
      "startTime": 82.0294871886,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_dressingroom-00-noon.webp",
      "bgName": "dressingroom-00-noon",
