    },
    {
      "type": "dialogue",
      "speakerCode": "kan",
      "speakerName": "kana",
      "speakerNameEn": "kana",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-kana.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_kan_02_03/sud_vo_adv_card_kan_02_03-kan014.m4a",
      "text": "ほんっとうに、ぜんっぜん、好きじゃないけど",
      "translations": {
        "en": "I really don't like them at all.",
        "id": ""
      },
      "startTime": 118.062820522,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_dressingroom-00-noon.webp",
      "bgName": "dressingroom-00-noon",
      "startTime": 122.962820522
    },
    {
      "type": "dialogue",
      "speakerCode": "koh",
      "speakerName": "{user}",
      "speakerNameEn": "{user}",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-makino.png",
