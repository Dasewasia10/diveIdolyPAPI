    {
      "type": "dialogue",
      "speakerCode": "koh",
      "speakerName": "{user}",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-makino.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_ngs_52_02/sud_vo_adv_card_ngs_52_02-koh008.m4a",
      "text": "そ、そうか……？\n俺の記憶だとそこまで似てない気もするんだが……",
      "startTime": 184.8666727275,
      "sfxList": []
    },
    {
      "type": "dialogue",
