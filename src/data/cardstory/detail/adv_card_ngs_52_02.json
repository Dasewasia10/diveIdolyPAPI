      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "ngs",
      "speakerName": "伊吹渚",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-nagisa.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_ngs_52_02/sud_vo_adv_card_ngs_52_02-ngs015.m4a",
      "text": "あの二人も制服着てるし、きっとそうですよね？\nしかも髪型と背格好まで映画とよく似てる……",
      "startTime": 177.9333444804,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_okinawabeach-00-noon.webp",
