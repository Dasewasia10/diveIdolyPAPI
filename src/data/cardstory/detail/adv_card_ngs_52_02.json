      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "ngs",
      "speakerName": "伊吹渚",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-nagisa.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_ngs_52_02/sud_vo_adv_card_ngs_52_02-ngs005.m4a",
      "text": "そこをどうしても見てみたいな～って。自由時間の内に\nちゃんと帰って来ますから……行ってもいいですか？",
      "startTime": 52.9175941183,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_summerfes-00-noon.webp",
      "bgName": "summerfes-00-noon"
    },
    {
