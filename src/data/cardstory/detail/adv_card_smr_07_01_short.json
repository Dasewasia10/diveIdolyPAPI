      "text": "同人誌即売会っていうのにも初めて行ったし\nステージも全力を出し切ったし",
      "translations": {
        "en": "It was my first time at a fanzine convention‚\nand I gave my all on stage.",
        "id": ""
      },
      "startTime": 33.2676866674,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "smr",
      "speakerName": "奥山すみれ",
      "speakerNameEn": "Sumire",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-sumire.png",
