      "text": "一緒にどうかな？\n美味しい紅茶もあるし、ゆっくりしてこー！",
      "translations": {
        "en": "一緒にどうかな？\n美味しい紅茶もあるし、ゆっくりしてこー！",
        "id": ""
      },
      "startTime": 29.8666666667,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "koh",
      "speakerName": "{user}",
      "speakerNameEn": "{user}",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-makino.png",
