      "text": "ハルヒちゃんが教えてくれたんだよ\nウェイトレスはおもてなしをするものだって",
      "translations": {
        "en": "ハルヒちゃんが教えてくれたんだよ\nウェイトレスはおもてなしをするものだって",
        "id": ""
      },
      "startTime": 113.9333353679,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "mei",
      "speakerName": "早坂芽衣",
      "speakerNameEn": "早坂芽衣",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-mei.png",
