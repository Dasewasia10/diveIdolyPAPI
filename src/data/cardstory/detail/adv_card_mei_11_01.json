      "text": "あれれ？　{user}さん、早いね\n打ち合わせの時間、まだまだ先だよー？",
      "translations": {
        "en": "あれれ？　{user}さん、早いね\n打ち合わせの時間、まだまだ先だよー？",
        "id": ""
      },
      "startTime": 7.9666666667,
      "sfxList": [
        {
          "src": "https://apiip.dasewasia.my.id/storyBgm/sud_se_adv_walk-living-single-01.m4a",
          "delay": 0,
          "startTime": 4.9706349214
        }
      ]
    },
    {
      "type": "dialogue",
      "speakerCode": "koh",
      "speakerName": "{user}",
      "speakerNameEn": "{user}",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-makino.png",
