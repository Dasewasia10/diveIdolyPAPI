      "text": "はい！　ありがとうございます！",
      "translations": {
        "en": "Okay! Thank you very much!",
        "id": ""
      },
      "startTime": 239.1781562637,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "koh",
      "speakerName": "{user}",
      "speakerNameEn": "{user}",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-makino.png",
