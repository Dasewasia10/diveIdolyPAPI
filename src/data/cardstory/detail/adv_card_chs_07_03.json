      "text": "はい、{user}さんに\nついていきます",
      "translations": {
        "en": "Yes‚ I'll follow you‚\n{user}-san.",
        "id": ""
      },
      "startTime": 210.7384102813,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "chs",
      "speakerName": "白石千紗",
      "speakerNameEn": "Chisa",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-chisa.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_chs_07_03/sud_vo_adv_card_chs_07_03-chs024.m4a",
      "text": "……こうしてると、本当にお父さんみたいですね\nあっ、あそこにりんご飴の屋台がありますよ",
      "translations": {
        "en": "…It really feels like being with my dad like this.\nOh‚ look! There's a candy apple stall over there!",
        "id": ""
      },
      "startTime": 216.6717395456,
      "sfxList": []
    },
    {
      "type": "background",
