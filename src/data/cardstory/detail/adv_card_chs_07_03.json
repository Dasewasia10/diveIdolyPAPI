      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-makino.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_chs_07_03/sud_vo_adv_card_chs_07_03-koh016.m4a",
      "text": "……仕方ないな。寄って行こう",
      "translations": {
        "en": "…Alright‚ let's go over there.",
        "id": ""
      },
      "startTime": 236.2035532625,
      "sfxList": []
    },
    {
