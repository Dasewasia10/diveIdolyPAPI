      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": null,
      "speakerName": "",
      "speakerNameEn": "",
      "iconUrl": null,
      "voiceUrl": null,
      "text": "――そして、年明けの神社にて",
      "translations": {
        "en": "――And then‚ at the shrine after the new year.",
        "id": ""
      },
      "startTime": 204.299999706,
      "sfxList": []
    },
    {
      "type": "background",
