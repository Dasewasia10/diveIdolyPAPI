      "translations": {
        "en": "I'm sorry for saying strange things.",
        "id": ""
      },
      "startTime": 277.0333333333,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "rei",
      "speakerName": "一ノ瀬怜",
      "speakerNameEn": "Rei",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-rei.png",
