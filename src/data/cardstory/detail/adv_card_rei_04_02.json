      "translations": {
        "en": "(That's not what I meant…)\n(Your overly stoic personality might be working against you.)",
        "id": ""
      },
      "startTime": 272.8,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "rei",
