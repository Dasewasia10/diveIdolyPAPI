      "text": "あっ！　そうでした、ついうっかり",
      "translations": {
        "en": "Ah! You’re right‚ I slipped up.",
        "id": ""
      },
      "startTime": 28.4684366227,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "koh",
      "speakerName": "{user}",
