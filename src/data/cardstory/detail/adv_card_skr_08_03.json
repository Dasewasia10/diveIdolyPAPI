      "text": "あっ！　そうでした、ついうっかり",
      "startTime": 28.4684366227,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "koh",
      "speakerName": "{user}",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-makino.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_skr_08_03/sud_vo_adv_card_skr_08_03-koh004.m4a",
      "text": "それと、ふわっと投げるんだ。練習を思い出してくれ",
      "startTime": 32.1351027807,
      "sfxList": [
        {
          "src": "https://apiip.dasewasia.my.id/storyBgm/sud_se_adv_futon-01.m4a",
          "delay": 11431.563886,
          "startTime": 43.5666666667
        },
        {
          "src": "https://apiip.dasewasia.my.id/storyBgm/sud_se_adv_ball-02.m4a",
          "delay": 12464.897219299999,
          "startTime": 44.6
        },
        {
          "src": "https://apiip.dasewasia.my.id/storyBgm/sud_se_adv_bang-01.m4a",
          "delay": 12631.563885900001,
          "startTime": 44.7666666666
        }
      ]
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_schoolyard-00-noon.webp",
