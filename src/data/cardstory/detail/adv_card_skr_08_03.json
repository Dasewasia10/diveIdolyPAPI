      "text": "お陰で、緊張なんて吹っ飛んじゃいました",
      "translations": {
        "en": "Thanks to them‚ my nervousness has completely disappeared!",
        "id": ""
      },
      "startTime": 215.4406731288,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_dressingroom-00-noon.webp",
      "bgName": "dressingroom-00-noon",
