      "speakerName": "川咲さくら",
      "speakerNameEn": "Sakura",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-sakura.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_skr_08_03/sud_vo_adv_card_skr_08_03-skr013.m4a",
      "text": "あれ？　相手チームのみんなからの\nメッセージもありますよ？",
      "translations": {
        "en": "Oh? There are messages\nfrom the other team‚ too?",
        "id": ""
      },
      "startTime": 154.9018812656,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_dressingroom-00-noon.webp",
