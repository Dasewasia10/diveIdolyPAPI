        "id": ""
      },
      "startTime": 238.0975446224,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "skr",
      "speakerName": "川咲さくら",
      "speakerNameEn": "Sakura",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-sakura.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_skr_08_03/sud_vo_adv_card_skr_08_03-skr024.m4a",
      "text": "私達は、こうしてステージに立って\nファンのみなさんに元気を届けているつもりでした",
      "translations": {
        "en": "We thought we were on stage\nto give energy to all the fans here.",
        "id": ""
      },
      "startTime": 246.8308728695,
      "sfxList": []
    },
    {
      "type": "background",
