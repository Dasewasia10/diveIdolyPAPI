      "text": "このお礼は、ステージでしてこないとな",
      "translations": {
        "en": "You have to repay them with a great performance.",
        "id": ""
      },
      "startTime": 219.00734183,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "skr",
      "speakerName": "川咲さくら",
      "speakerNameEn": "Sakura",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-sakura.png",
