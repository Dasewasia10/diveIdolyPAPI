      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_festivalseat-00-noon.webp",
      "bgName": "festivalseat-00-noon",
      "startTime": 313.5
    },
    {
      "type": "dialogue",
      "speakerCode": "skr",
      "speakerName": "川咲さくら",
      "speakerNameEn": "Sakura",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-sakura.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_skr_04_02/sud_vo_adv_card_skr_04_02-skr029.m4a",
      "text": "I-UNITYで私達が歌った会場です\nあの日の光景は今でも目に焼き付いてます",
      "translations": {
        "en": "It's where we performed on I-UNITY.\nThe sight of that day is still unforgettable in my mind.",
        "id": ""
      },
      "startTime": 316.6333333333,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_festivalseat-00-noon.webp",
      "bgName": "festivalseat-00-noon",
      "startTime": 320.4
    },
    {
      "type": "dialogue",
      "speakerCode": "skr",
      "speakerName": "川咲さくら",
      "speakerNameEn": "Sakura",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-sakura.png",
