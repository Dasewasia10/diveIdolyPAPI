      "text": "聞くまでもなかったですね",
      "translations": {
        "en": "Dumb question‚ I guess.",
        "id": ""
      },
      "startTime": 181.63333333333333,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "rio",
      "speakerName": "神崎莉央",
      "speakerNameEn": "Rio",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-rio.png",
