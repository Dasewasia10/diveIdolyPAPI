      "bgName": "stagesleeves-00-noon",
      "startTime": 248.9666775385
    },
    {
      "type": "dialogue",
      "speakerCode": "yu",
      "speakerName": "鈴村優",
      "speakerNameEn": "Yu",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-yu.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_yu_11_03/sud_vo_adv_card_yu_11_03-yu021.m4a",
      "text": "そうやんな。SNSとかでもめっちゃ話題になってるし\n事務所のみんなも絶賛してたし……",
      "translations": {
        "en": "Right? It’s going viral on social media too.\nEveryone at the agency praised it too…",
        "id": ""
      },
      "startTime": 253.9666687012,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "yu",
      "speakerName": "鈴村優",
      "speakerNameEn": "Yu",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-yu.png",
