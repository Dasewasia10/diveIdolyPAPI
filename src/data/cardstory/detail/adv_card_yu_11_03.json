    },
    {
      "type": "dialogue",
      "speakerCode": "yu",
      "speakerName": "鈴村優",
      "speakerNameEn": "Yu",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-yu.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_yu_11_03/sud_vo_adv_card_yu_11_03-yu020.m4a",
      "text": "会場に集まってくれてるファンのみんなも\nビックリし過ぎて気絶するんちゃう？　……なんて",
      "translations": {
        "en": "All the fans gathered here\nmight faint from shock‚ you know? …maybe.",
