      "bgName": "designoffice-00-noon",
      "startTime": 159.3577441219
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_designoffice-00-noon.webp",
      "bgName": "designoffice-00-noon",
      "startTime": 159.3577441219
    },
    {
      "type": "dialogue",
      "speakerCode": "ktn",
      "speakerName": "長瀬琴乃",
      "speakerNameEn": "Kotono",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-kotono.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_ktn_07_01/sud_vo_adv_card_ktn_07_01-ktn014.m4a",
      "text": "これが台本ですか……わぁ……",
      "translations": {
        "en": "Is this the script…? Wow…",
        "id": ""
      },
      "startTime": 160.2577512427,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_designoffice-00-noon.webp",
