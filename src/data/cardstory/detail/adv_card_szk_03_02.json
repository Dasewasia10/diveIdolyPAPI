        "id": ""
      },
      "startTime": 319,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "koh",
      "speakerName": "{user}",
      "speakerNameEn": "{user}",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-makino.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_szk_03_02/sud_vo_adv_card_szk_03_02-koh016.m4a",
      "text": "……なぁ、雫？\n雫にとって天動さんはどういう存在なんだ？",
      "translations": {
        "en": "Hey‚ Shizuku?\nWhat does Tendo-san mean to you?",
        "id": ""
      },
      "startTime": 326.1,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "szk",
      "speakerName": "兵藤雫",
      "speakerNameEn": "Shizuku",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-shizuku.png",
