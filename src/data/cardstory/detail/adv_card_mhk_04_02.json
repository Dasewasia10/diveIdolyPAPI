      "bgName": "summerfes-00-noon",
      "startTime": 95.9225824758
    },
    {
      "type": "dialogue",
      "speakerCode": "mhk",
      "speakerName": "miho",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-miho.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_mhk_04_02/sud_vo_adv_card_mhk_04_02-mhk012.m4a",
      "text": "人が増えてきましたね……",
      "startTime": 97.689226827,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_summerfes-00-noon.webp",
