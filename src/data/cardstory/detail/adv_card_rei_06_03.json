      "startTime": 195.1,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "rei",
      "speakerName": "一ノ瀬怜",
      "speakerNameEn": "Rei",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-rei.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_rei_06_03/sud_vo_adv_card_rei_06_03-rei019.m4a",
      "text": "格好いいのも、セクシーで可愛いのも、元気なのも……\nどんなダンスも素敵で、そこに上下なんかないって",
      "translations": {
        "en": "Whether it's cool‚ sexy‚ cute‚ or energetic…\nEvery dance is wonderful‚ and there's no hierarchy in it.",
        "id": ""
      },
      "startTime": 204.1666666667,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "rei",
