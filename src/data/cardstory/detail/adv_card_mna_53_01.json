    {
      "type": "dialogue",
      "speakerCode": "ktn",
      "speakerName": "長瀬琴乃",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-kotono.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_mna_53_01/sud_vo_adv_card_mna_53_01-ktn001.m4a",
      "text": "（う～ん……全然いい歌詞が思いつかない。お姉ちゃんは）\n（私へのどんな思いを込めて書いてくれたのかな……）",
      "startTime": 11.3333333333,
      "sfxList": [
        {
          "src": "https://apiip.dasewasia.my.id/storyBgm/sud_se_adv_gasa-02.m4a",
