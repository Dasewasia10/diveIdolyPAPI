        }
      ]
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_fessmall-01-evening.webp",
      "bgName": "fessmall-01-evening",
      "startTime": 5.7666666667
    },
    {
      "type": "dialogue",
      "speakerCode": "suz",
      "speakerName": "成宮すず",
      "speakerNameEn": "Suzu Narumiya",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-suzu.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_suz_14_03/sud_vo_adv_card_suz_14_03-suz001.m4a",
      "text": "みなさま、星見市の春祭りへようこそ！\nお祭り、楽しんでいらっしゃいますかー？",
      "translations": {
        "en": "",
        "id": ""
      },
      "startTime": 10.0333333333,
      "sfxList": [
        {
          "src": "https://apiip.dasewasia.my.id/storyBgm/sud_se_adv_cheers-out-01.m4a",
          "delay": 6166.6666666,
          "startTime": 11.9333333333
        },
        {
          "src": "https://apiip.dasewasia.my.id/storyBgm/sud_se_adv_cheers-out-01.m4a",
          "delay": 9566.6666667,
          "startTime": 19.6
        }
      ]
    },
    {
      "type": "dialogue",
      "speakerCode": "suz",
      "speakerName": "成宮すず",
      "speakerNameEn": "Suzu Narumiya",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-suzu.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_suz_14_03/sud_vo_adv_card_suz_14_03-suz002.m4a",
      "text": "月のテンペストのセンターである私が、このライブの\nトップバッターを務めさせていただきますわ！",
      "translations": {
        "en": "",
        "id": ""
      },
      "startTime": 17.7666668574,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_fessmall-01-evening.webp",
      "bgName": "fessmall-01-evening",
      "startTime": 21.3000000636
    },
    {
      "type": "dialogue",
      "speakerCode": "suz",
      "speakerName": "成宮すず",
      "speakerNameEn": "Suzu Narumiya",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-suzu.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_suz_14_03/sud_vo_adv_card_suz_14_03-suz003.m4a",
      "text": "きっと……急な雨でみなさま不安なことでしょう\nですが、どうか安心してくださいまし",
      "translations": {
        "en": "",
        "id": ""
      },
      "startTime": 26.5333333969,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_fessmall-01-evening.webp",
      "bgName": "fessmall-01-evening",
      "startTime": 30.4000000636
    },
    {
      "type": "dialogue",
      "speakerCode": "suz",
      "speakerName": "成宮すず",
      "speakerNameEn": "Suzu Narumiya",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-suzu.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_suz_14_03/sud_vo_adv_card_suz_14_03-suz004.m4a",
      "text": "『二代目星降る奇跡』たる私、成宮すずが！\n必ず、この歌で雨を晴らしてみせますから！",
      "translations": {
        "en": "",
        "id": ""
      },
      "startTime": 35.2999998729,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "suz",
      "speakerName": "成宮すず",
      "speakerNameEn": "Suzu Narumiya",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-suzu.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_suz_14_03/sud_vo_adv_card_suz_14_03-suz005.m4a",
      "text": "聴いて下さいまし\n『星の海の記憶』……！",
      "translations": {
        "en": "",
        "id": ""
      },
      "startTime": 42.1000000636,
      "sfxList": [
        {
          "src": "https://apiip.dasewasia.my.id/storyBgm/sud_se_adv_cheers-out-01.m4a",
          "delay": 1533.3332379000026,
          "startTime": 43.6333333015
        }
      ]
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_fessmall-01-evening.webp",
      "bgName": "fessmall-01-evening",
      "startTime": 44.3666669845
    },
    {
      "type": "dialogue",
      "speakerCode": "koh",
      "speakerName": "{user}",
      "speakerNameEn": "{user}",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-makino.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_suz_14_03/sud_vo_adv_card_suz_14_03-koh002.m4a",
      "text": "（心配はいらなかったか。リハーサルなしの飛び入り）\n（参加でこのパフォーマンス……本当に成長したな）",
      "translations": {
        "en": "",
        "id": ""
      },
      "startTime": 48.9000003178,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_fessmall-01-evening.webp",
      "bgName": "fessmall-01-evening",
      "startTime": 52.8333336512
    },
    {
      "type": "dialogue",
      "speakerCode": "koh",
      "speakerName": "{user}",
      "speakerNameEn": "{user}",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-makino.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_suz_14_03/sud_vo_adv_card_suz_14_03-koh003.m4a",
      "text": "（会場のみんなも、すずに夢中になっているみたいだ）\n（……ん？　雨が……）",
      "translations": {
        "en": "",
        "id": ""
      },
      "startTime": 57,
      "sfxList": [
        {
          "src": "https://apiip.dasewasia.my.id/storyBgm/sud_se_adv_cheers-out-01.m4a",
          "delay": 4033.3336512000033,
          "startTime": 61.0333336512
        }
      ]
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_fessmall-00-evening.webp",
      "bgName": "fessmall-00-evening",
      "startTime": 60.7833336512
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_fessmall-00-evening.webp",
      "bgName": "fessmall-00-evening",
      "startTime": 60.7833336512
    },
    {
      "type": "dialogue",
      "speakerCode": "suz",
      "speakerName": "成宮すず",
      "speakerNameEn": "Suzu Narumiya",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-suzu.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_suz_14_03/sud_vo_adv_card_suz_14_03-suz006.m4a",
      "text": "ありがとうございました！　ふふふ！\nみなさま、空を見てくださいまし！",
      "translations": {
        "en": "",
        "id": ""
      },
      "startTime": 65.1666667938,
      "sfxList": [
        {
          "src": "https://apiip.dasewasia.my.id/storyBgm/sud_se_adv_cheers-in-04.m4a",
          "delay": 10733.333142599995,
          "startTime": 72.5666667938
        }
      ]
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_fessmall-00-evening.webp",
      "bgName": "fessmall-00-evening",
      "startTime": 69.0000003178
    },
    {
      "type": "dialogue",
      "speakerCode": "suz",
      "speakerName": "成宮すず",
      "speakerNameEn": "Suzu Narumiya",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-suzu.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_suz_14_03/sud_vo_adv_card_suz_14_03-suz007.m4a",
      "text": "雨雲一つ残さず、消し飛ばしてやりましたわ！\nさぁ舞台は整えましたわよ！",
      "translations": {
        "en": "",
        "id": ""
      },
      "startTime": 73.6666669845,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "suz",
      "speakerName": "成宮すず",
      "speakerNameEn": "Suzu Narumiya",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-suzu.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_suz_14_03/sud_vo_adv_card_suz_14_03-suz008.m4a",
      "text": "私の未来のライバル達！\n存分に今日という日を楽しんでくださいまし！",
      "translations": {
        "en": "",
        "id": ""
      },
      "startTime": 80.2333336512,
      "sfxList": [
        {
          "src": "https://apiip.dasewasia.my.id/storyBgm/sud_se_adv_cheers-out-01.m4a",
          "delay": 5728.172111500001,
          "startTime": 83.0281724293
        }
      ]
    },
    {
      "type": "dialogue",
      "speakerCode": null,
      "speakerName": "",
      "speakerNameEn": "",
      "iconUrl": null,
      "voiceUrl": null,
      "text": "――ミニライブ後",
      "translations": {
        "en": "",
        "id": ""
      },
      "startTime": 85.1000003178,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_hillpark-00-evening.webp",
      "bgName": "hillpark-00-evening",
      "startTime": 86.2000003178
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_hillpark-00-evening.webp",
      "bgName": "hillpark-00-evening",
      "startTime": 86.2000003178
    },
    {
      "type": "dialogue",
      "speakerCode": "suz",
      "speakerName": "成宮すず",
      "speakerNameEn": "Suzu Narumiya",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-suzu.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_suz_14_03/sud_vo_adv_card_suz_14_03-suz009.m4a",
      "text": "ふふ、最高のライブでしたわね。どのパフォーマンスも\n荒削りながら凄まじい熱意がこもっていましたわ",
      "translations": {
        "en": "",
        "id": ""
      },
      "startTime": 92.4333336512,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_hillpark-00-evening.webp",
      "bgName": "hillpark-00-evening",
      "startTime": 96.4999987919
    },
    {
      "type": "dialogue",
      "speakerCode": "koh",
      "speakerName": "{user}",
      "speakerNameEn": "{user}",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-makino.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_suz_14_03/sud_vo_adv_card_suz_14_03-koh004.m4a",
      "text": "ああ、最初はすずが出たらみんな萎縮するんじゃないか\nって考えていたんだが……杞憂だったな",
      "translations": {
        "en": "",
        "id": ""
      },
      "startTime": 100.1666669845,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "koh",
      "speakerName": "{user}",
      "speakerNameEn": "{user}",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-makino.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_suz_14_03/sud_vo_adv_card_suz_14_03-koh005.m4a",
      "text": "むしろすずのおかげでみんな、さらに燃えたみたいだ\nミニライブとは思えないほどの盛り上がりだったな",
      "translations": {
        "en": "",
        "id": ""
      },
      "startTime": 108.0666644413,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_hillpark-00-evening.webp",
      "bgName": "hillpark-00-evening",
      "startTime": 111.3333295821
    },
    {
      "type": "dialogue",
      "speakerCode": "suz",
      "speakerName": "成宮すず",
      "speakerNameEn": "Suzu Narumiya",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-suzu.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_suz_14_03/sud_vo_adv_card_suz_14_03-suz010.m4a",
      "text": "私が奇跡を起こしたおかげですわね！　麻奈様のように\n星を降らせられなかったのは悔しいですが……",
      "translations": {
        "en": "",
        "id": ""
      },
      "startTime": 116.7666644413,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "koh",
      "speakerName": "{user}",
      "speakerNameEn": "{user}",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-makino.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_suz_14_03/sud_vo_adv_card_suz_14_03-koh006.m4a",
      "text": "ええと……実はそれなんだがな……\nこれ、見てくれるか？",
      "translations": {
        "en": "",
        "id": ""
      },
      "startTime": 125.0999977747,
      "sfxList": [
        {
          "src": "https://apiip.dasewasia.my.id/storyBgm/sud_se_adv_gasa-02.m4a",
          "delay": 3766.6681926000083,
          "startTime": 124.4999977747
        },
        {
          "src": "https://apiip.dasewasia.my.id/storyBgm/sud_se_adv_phone-tap-01.m4a",
          "delay": 4366.668192600002,
          "startTime": 125.0999977747
        }
      ]
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_hillpark-00-evening.webp",
      "bgName": "hillpark-00-evening",
      "startTime": 127.5666659672
    },
    {
      "type": "dialogue",
      "speakerCode": "suz",
      "speakerName": "成宮すず",
      "speakerNameEn": "Suzu Narumiya",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-suzu.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_suz_14_03/sud_vo_adv_card_suz_14_03-suz011.m4a",
      "text": "お天気アプリ……？　ええと、星見市に\n十五分程度の通り雨の予報……え？　ま、まさか……",
      "translations": {
        "en": "",
        "id": ""
      },
      "startTime": 132.9000008265,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_hillpark-00-evening.webp",
      "bgName": "hillpark-00-evening",
      "startTime": 140.9999993006
    },
    {
      "type": "dialogue",
      "speakerCode": "suz",
      "speakerName": "成宮すず",
      "speakerNameEn": "Suzu Narumiya",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-suzu.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_suz_14_03/sud_vo_adv_card_suz_14_03-suz012.m4a",
      "text": "あの雨が止んだのは奇跡でもなんでもなく\n通り雨だったからですの……？",
      "translations": {
        "en": "",
        "id": ""
      },
      "startTime": 144.5333341598,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "koh",
      "speakerName": "{user}",
      "speakerNameEn": "{user}",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-makino.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_suz_14_03/sud_vo_adv_card_suz_14_03-koh007.m4a",
      "text": "あ、ああ。言い辛いがそうなるな……\nすずの出演を交渉した時に判明したんだ",
      "translations": {
        "en": "",
        "id": ""
      },
      "startTime": 150.8333077113,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "koh",
      "speakerName": "{user}",
      "speakerNameEn": "{user}",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-makino.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_suz_14_03/sud_vo_adv_card_suz_14_03-koh008.m4a",
      "text": "言うべきかどうか悩んだんだが……ライブ前に\n余計なことを言わない方がいいと思って……",
      "translations": {
        "en": "",
        "id": ""
      },
      "startTime": 157.2333056767,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_hillpark-00-evening.webp",
      "bgName": "hillpark-00-evening",
      "startTime": 160.0999708175
    },
    {
      "type": "dialogue",
      "speakerCode": "suz",
      "speakerName": "成宮すず",
      "speakerNameEn": "Suzu Narumiya",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-suzu.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_suz_14_03/sud_vo_adv_card_suz_14_03-suz013.m4a",
      "text": "そ、そんなぁ……じゃあそもそもお祭りも中止になんか\nならなかったんですのね……徒労でしたわ……",
      "translations": {
        "en": "",
        "id": ""
      },
      "startTime": 166.2666402181,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_hillpark-00-evening.webp",
      "bgName": "hillpark-00-evening",
      "startTime": 171.5666374842
    },
    {
      "type": "dialogue",
      "speakerCode": "koh",
      "speakerName": "{user}",
      "speakerNameEn": "{user}",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-makino.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_suz_14_03/sud_vo_adv_card_suz_14_03-koh009.m4a",
      "text": "で、でもな？　仮に予報がずっと雨だったとしても\n今日のすずなら奇跡を起こせていたさ",
      "translations": {
        "en": "",
        "id": ""
      },
      "startTime": 175.8333056767,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "koh",
