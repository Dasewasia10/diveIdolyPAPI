      "text": "来年『も』だろ？　今年も沢山挑戦をしたじゃないか",
      "translations": {
        "en": "“Next year too‚” right? You challenged yourselves a lot this year.",
        "id": ""
      },
      "startTime": 244.046480465,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "rui",
      "speakerName": "天動瑠依",
      "speakerNameEn": "Rui",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-rui.png",
