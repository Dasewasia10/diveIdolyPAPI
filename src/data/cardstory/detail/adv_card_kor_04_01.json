      "text": "こういう番組の打ち上げなら\nmihoとkanaがいるじゃないですか",
      "startTime": 95.9666514079,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_okinawabeach-00-noon.webp",
      "bgName": "beach",
      "startTime": 98.423498384
    },
    {
      "type": "dialogue",
      "speakerCode": "kor",
      "speakerName": "fran",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-fran.png",
