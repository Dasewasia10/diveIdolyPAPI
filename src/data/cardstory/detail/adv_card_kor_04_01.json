      "speakerName": "fran",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-fran.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_kor_04_01/sud_vo_adv_card_kor_04_01-kor016.m4a",
      "text": "こういう場所に少し興味があったんです\nそれだけですよ",
      "startTime": 171.1666559856,
