      "text": "あ、見て下さいよ、あの植物\n都内じゃ絶対見かけないですよ",
      "startTime": 153.4999893189,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_okinawabeach-00-noon.webp",
      "bgName": "beach",
      "startTime": 156.3792230287
    },
