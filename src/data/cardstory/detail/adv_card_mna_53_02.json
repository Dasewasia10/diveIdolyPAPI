      "speakerName": "長瀬麻奈",
      "speakerNameEn": "Mana Nagase",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-mana.png",
      "voiceUrl": null,
      "text": "ほら、こっちにおいで。お姉ちゃんがやってあげる！",
      "translations": {
        "en": "",
        "id": ""
      },
      "startTime": 66.0131446379,
