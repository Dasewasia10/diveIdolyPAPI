      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-mana.png",
      "voiceUrl": null,
      "text": "したいの！　いいでしょ？　お願い！　私誕生日だし！",
      "translations": {
        "en": "",
        "id": ""
      },
      "startTime": 91.0294256719,
