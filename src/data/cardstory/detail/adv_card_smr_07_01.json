    },
    {
      "type": "dialogue",
      "speakerCode": "smr",
      "speakerName": "奥山すみれ",
      "speakerNameEn": "Sumire",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-sumire.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_smr_07_01/sud_vo_adv_card_smr_07_01-smr001.m4a",
      "text": "今日、みなさんと会えて嬉しいです！\n最高の夏になりました、ありがとうございました！",
      "translations": {
        "en": "I'm so happy to meet everyone today!\nThis has been the best summer ever‚ thank you so much!",
        "id": ""
      },
      "startTime": 6.766666522,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_summerfesstage-00-night.webp",
      "bgName": "summerfesstage-00-night",
      "startTime": 11.2666665299
    },
    {
      "type": "dialogue",
      "speakerCode": "koh",
      "speakerName": "{user}",
      "speakerNameEn": "{user}",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-makino.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_smr_07_01/sud_vo_adv_card_smr_07_01-koh001.m4a",
      "text": "（凄い熱気だ……夏フェス、無事成功だな）",
      "translations": {
        "en": "（What an incredible energy… The summer festival was a success.）",
        "id": ""
      },
      "startTime": 11.2666665299,
      "sfxList": [
