      "text": "お疲れ様。星見音楽フェスの準備は進んでるか？",
      "startTime": 6.4026303928,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "kkr",
      "speakerName": "赤崎こころ",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-kokoro.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_kkr_06_01_short/sud_vo_adv_card_kkr_06_01-kkr002.m4a",
      "text": "問題なく進んでますよ～",
      "startTime": 10.4857150396,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_tokyocorridor-00-noon.webp",
      "bgName": "tokyocorridor-00-noon",
      "startTime": 12.9385495584
    },
    {
      "type": "dialogue",
      "speakerCode": "kkr",
      "speakerName": "赤崎こころ",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-kokoro.png",
