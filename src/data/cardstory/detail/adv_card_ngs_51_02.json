      "speakerNameEn": "",
      "iconUrl": null,
      "voiceUrl": null,
      "text": "―― 一方その頃",
      "translations": {
        "en": "―― Meanwhile",
        "id": ""
      },
      "startTime": 117.4036223365,
      "sfxList": []
    },
    {
