      "startTime": 75.2
    },
    {
      "type": "dialogue",
      "speakerCode": "smr",
      "speakerName": "奥山すみれ",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-sumire.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_smr_03_02/sud_vo_adv_card_smr_03_02-smr009.m4a",
      "text": "謝っても許してあげません",
      "startTime": 75.2,
      "sfxList": []
    },
    {
      "type": "background",
