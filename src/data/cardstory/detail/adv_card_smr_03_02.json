      "startTime": 133.9333333333
    },
    {
      "type": "dialogue",
      "speakerCode": "koh",
      "speakerName": "{user}",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-makino.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_smr_03_02/sud_vo_adv_card_smr_03_02-koh011.m4a",
      "text": "やっと笑顔を見せてくれたな\n奥山さんに無視されるのは辛かったよ",
      "startTime": 137.1,
      "sfxList": []
    },
    {
      "type": "background",
