      "startTime": 94
    },
    {
      "type": "dialogue",
      "speakerCode": "smr",
      "speakerName": "奥山すみれ",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-sumire.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_smr_03_02/sud_vo_adv_card_smr_03_02-smr011.m4a",
      "text": "あ、それは……",
      "startTime": 94,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_sancha-00-noon.webp",
      "bgName": "sancha-00-noon",
      "startTime": 96.4333333333
    },
    {
      "type": "dialogue",
      "speakerCode": "koh",
      "speakerName": "{user}",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-makino.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_smr_03_02/sud_vo_adv_card_smr_03_02-koh009.m4a",
      "text": "前に奥山さんにオススメされたことがあっただろ？\nあれ以来、たまに無性に飲みたくなるんだよな",
      "startTime": 99.9666666667,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_sancha-00-noon.webp",
      "bgName": "sancha-00-noon",
      "startTime": 103.6666666667
    },
    {
      "type": "dialogue",
      "speakerCode": "smr",
      "speakerName": "奥山すみれ",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-sumire.png",
