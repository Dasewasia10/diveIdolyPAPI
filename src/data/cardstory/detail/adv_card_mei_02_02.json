      "text": "ありがとう！",
      "translations": {
        "en": "Thank you!",
        "id": ""
      },
      "startTime": 0.8,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "mei",
      "speakerName": "早坂芽衣",
      "speakerNameEn": "Mei",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-mei.png",
      "voiceUrl": null,
      "text": "みんな大好きーっ！",
      "translations": {
        "en": "I love you all!",
        "id": ""
      },
      "startTime": 2.533333333333333,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "mei",
      "speakerName": "早坂芽衣",
      "speakerNameEn": "Mei",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-mei.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_mei_02_02/sud_vo_adv_card_mei_02_02-mei002.m4a",
      "text": "残りの夏も満喫してね～！",
      "translations": {
        "en": "Enjoy the rest of your summer!",
        "id": ""
      },
      "startTime": 4.833333333333333,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_summerfesstage-00-night.webp",
      "bgName": "summer_fes-stage",
      "startTime": 8.7
    },
    {
      "type": "dialogue",
      "speakerCode": "koh",
      "speakerName": "{user}",
      "speakerNameEn": "{user}",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-makino.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_mei_02_02/sud_vo_adv_card_mei_02_02-koh001.m4a",
      "text": "（なんだかんだでライブは大成功だったな）\n（新曲の反応も上々で本当によかった）",
      "translations": {
        "en": "（In the end‚ the concert was a big success.）\n（The response to the new song was good too.）",
        "id": ""
      },
      "startTime": 12.633333333333333,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_dressingroom-00-noon.webp",
      "bgName": "dressingroom-00-noon",
