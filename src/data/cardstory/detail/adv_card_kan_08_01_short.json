        }
      ]
    },
    {
      "type": "dialogue",
      "speakerCode": "koh",
      "speakerName": "{user}",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-makino.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_kan_08_01_short/sud_vo_adv_card_kan_08_01-koh003.m4a",
      "text": "その……三枝さんからこんなものが送られてきまして\n来週、週刊誌に載る予定の記事らしいんですけど……",
      "startTime": 37.9000000954,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_preconference-00-noon.webp",
