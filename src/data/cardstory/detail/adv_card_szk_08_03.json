      "text": "雫。この間のインタビューとポスター\nかなり好評みたいだな",
      "startTime": 222.6000183105,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "szk",
      "speakerName": "兵藤雫",
