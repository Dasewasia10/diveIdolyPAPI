      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_szk_08_03/sud_vo_adv_card_szk_08_03-szk024.m4a",
      "text": "そう……みたい。星見プロのみんなにも\n一杯褒めてもらった……照れる",
      "startTime": 228.4666697184,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "szk",
      "speakerName": "兵藤雫",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-shizuku.png",
