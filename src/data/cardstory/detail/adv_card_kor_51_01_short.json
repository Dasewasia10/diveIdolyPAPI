    {
      "type": "dialogue",
      "speakerCode": "suz",
      "speakerName": "成宮すず",
      "speakerNameEn": "Suzu",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-suzu.png",
      "voiceUrl": null,
      "text": "franさ～ん。聞きましたわよ！",
      "translations": {
        "en": "Fran-san~. I heard!",
        "id": ""
      },
      "startTime": 1.6999999166,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "suz",
      "speakerName": "成宮すず",
      "speakerNameEn": "Suzu",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-suzu.png",
      "voiceUrl": null,
      "text": "もうすぐ、franさんのお誕生日……あら？",
      "translations": {
        "en": "Your birthday is coming up soon… Huh?",
        "id": ""
      },
      "startTime": 4.7666665833,
      "sfxList": [
        {
          "src": "https://apiip.dasewasia.my.id/storyBgm/sud_se_adv_letter-01.m4a",
          "delay": 4833.333416699999,
          "startTime": 9.6
        }
      ]
    },
    {
      "type": "dialogue",
      "speakerCode": "kor",
      "speakerName": "fran",
      "speakerNameEn": "fran",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-fran.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_kor_51_01_short/sud_vo_adv_card_kor_51_01-kor001.m4a",
      "text": "この先生も違う……こっちの先生もイメージとは……\nはぁ……この調子で誕生日までに間に合うのかしら……",
      "translations": {
        "en": "This artist isn’t right either… And this one isn’t what I imagined…\nSigh… I wonder if I can make it in time for my birthday like this…",
        "id": ""
      },
      "startTime": 16.2333332499,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "suz",
      "speakerName": "成宮すず",
      "speakerNameEn": "Suzu",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-suzu.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_kor_51_01_short/sud_vo_adv_card_kor_51_01-suz002.m4a",
      "text": "何か悩み事ですの？　って……まぁ！\n漫画の本がこんなに沢山。一体どうしたんですの？",
      "translations": {
        "en": "What’s bothering you? …Oh my!\nYou have so many manga! What’s going on?",
        "id": ""
      },
      "startTime": 26.1333332499,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "kor",
      "speakerName": "fran",
      "speakerNameEn": "fran",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-fran.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_kor_51_01_short/sud_vo_adv_card_kor_51_01-kor002.m4a",
      "text": "え？　あー、気にしないで。今度の『ミラクル☆\nアイドルバースデー！』で使う資料だから",
      "translations": {
        "en": "Eh? Ahー don’t worry about it. It’s just reference material\nfor the upcoming “Miracle☆ Idol Birthday!”.",
        "id": ""
      },
      "startTime": 36.4666665833,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "suz",
      "speakerName": "成宮すず",
      "speakerNameEn": "Suzu",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-suzu.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_kor_51_01_short/sud_vo_adv_card_kor_51_01-suz003.m4a",
      "text": "それって、アイドルがやってみたいことを叶えてくれる\n雑誌のお誕生日企画ですわよね",
      "translations": {
        "en": "That’s the birthday project in the magazine\nwhere they grant an idol’s wish‚ right?",
        "id": ""
      },
      "startTime": 43.3333368104,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "suz",
      "speakerName": "成宮すず",
      "speakerNameEn": "Suzu",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-suzu.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_kor_51_01_short/sud_vo_adv_card_kor_51_01-suz004.m4a",
      "text": "franさんにもお話が来たんですのね！\nどんなお願いをするんですの？　この漫画と関係が？",
      "translations": {
        "en": "You got an offer for it too‚ fran-san!\nWhat kind of wish are you going to make? Does it have to do with this manga?",
        "id": ""
      },
      "startTime": 49.4333350302,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "kor",
      "speakerName": "fran",
      "speakerNameEn": "fran",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-fran.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_kor_51_01_short/sud_vo_adv_card_kor_51_01-kor003.m4a",
      "text": "ああもう、忙しいんだから絡まないでよ……\n分かったから。説明してあげるから静かにして",
      "translations": {
        "en": "Ugh‚ I’m busy‚ so leave me alone.\nFine‚ fine. I’ll explain‚ so be quiet.",
        "id": ""
      },
      "startTime": 58.6000016969,
      "sfxList": []
    }
  ]
}