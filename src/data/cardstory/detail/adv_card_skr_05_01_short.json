          "startTime": 8.6333333333
        }
      ]
    },
    {
      "type": "dialogue",
      "speakerCode": "koh",
      "speakerName": "{user}",
      "speakerNameEn": "{user}",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-makino.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_skr_05_01_short/sud_vo_adv_card_skr_05_01-koh001.m4a",
      "text": "さくらが登場しただけで凄い歓声だ……\nBIG4になって以来サニピの人気は右肩上がりだな",
      "translations": {
        "en": "Just Sakura's entry gets such a fantastic response…\nSince becoming BIG4‚ Sunny Peace's popularity has been soaring.",
        "id": ""
      },
      "startTime": 14.1,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_cdstage-01-noon.webp",
      "bgName": "cdstage-01-noon",
      "startTime": 18.6333333333
    },
    {
      "type": "dialogue",
      "speakerCode": "skr",
      "speakerName": "川咲さくら",
      "speakerNameEn": "Sakura",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-sakura.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_skr_05_01_short/sud_vo_adv_card_skr_05_01-skr002.m4a",
      "text": "みなさん準備はいいですか？\n今日は一緒に盛り上がっていきますよー！",
      "translations": {
        "en": "Is everyone ready?\nToday‚ let's get excited together!",
        "id": ""
      },
      "startTime": 22.1,
      "sfxList": [
        {
          "src": "https://apiip.dasewasia.my.id/storyBgm/sud_se_adv_cheers-in-01.m4a",
          "delay": 2633.333333299998,
          "startTime": 24.7333333333
        }
      ]
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_shibuya-00-noon.webp",
      "bgName": "shibuya-00-noon",
      "startTime": 27.3
    },
    {
      "type": "background",
