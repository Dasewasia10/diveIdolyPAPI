      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-saki.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_ski_13_01_short/sud_vo_adv_card_ski_13_01-ski002.m4a",
      "text": "いえ、あくまで私の浅い考えですから。もしもこれが\n解決に繋がるのなら、私の力というよりも",
      "startTime": 15.257728828,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_church-00-night.webp",
