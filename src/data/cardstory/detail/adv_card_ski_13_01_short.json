      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_ski_13_01_short/sud_vo_adv_card_ski_13_01-ski003.m4a",
      "text": "――神のお導きかもしれませんね",
      "startTime": 20.0726078669,
      "sfxList": [
        {
          "src": "https://apiip.dasewasia.my.id/storyBgm/sud_se_adv_walk-in-single-02.m4a",
