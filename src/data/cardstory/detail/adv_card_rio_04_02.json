      "startTime": 361.7333333334,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "rio",
      "speakerName": "神崎莉央",
      "speakerNameEn": "Rio",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-rio.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_rio_04_02/sud_vo_adv_card_rio_04_02-rio032.m4a",
      "text": "絶対に失敗出来ないと思って\n無意識に自分を追い込んでいたのかも……",
      "translations": {
        "en": "Thinking I absolutely couldn't fail‚\nI might have been unconsciously pushing myself too hard…",
        "id": ""
