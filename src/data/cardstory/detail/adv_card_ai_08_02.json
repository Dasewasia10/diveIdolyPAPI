    },
    {
      "type": "dialogue",
      "speakerCode": "koh",
      "speakerName": "{user}",
      "speakerNameEn": "{user}",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-makino.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_ai_08_02/sud_vo_adv_card_ai_08_02-koh011.m4a",
      "text": "なんとかって……どうするつもりだ？",
      "translations": {
        "en": "Take care of it? What are you planning to do?",
        "id": ""
      },
      "startTime": 166.7283129378,
      "sfxList": []
    },
    {
