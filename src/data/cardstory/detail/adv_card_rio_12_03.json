      "startTime": 222.8666666667,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "rio",
      "speakerName": "神崎莉央",
      "speakerNameEn": "Rio",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-rio.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_rio_12_03/sud_vo_adv_card_rio_12_03-rio019.m4a",
      "text": "そんなことしたら、葵が怒るわよ\n話すのは貴方だけ。みんなには内緒だから",
      "translations": {
        "en": "If I did that‚ Aoi would get mad.\nYou’re the only one I’m telling. It’s a secret from everyone else.",
        "id": ""
      },
      "startTime": 229.3482036593,
      "sfxList": []
    },
