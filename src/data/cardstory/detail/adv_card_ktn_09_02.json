      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_ktn_09_02/sud_vo_adv_card_ktn_09_02-koh015.m4a",
      "text": "琴乃？　任せるって……どういうことだ？",
      "translations": {
        "en": "Kotono? What do you mean… Leave it to you?",
        "id": ""
      },
      "startTime": 213.7666605592,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_fessmall-01-evening.webp",
      "bgName": "fessmall-01-evening",
      "startTime": 217.7999938925
    },
    {
      "type": "dialogue",
      "speakerCode": "ktn",
      "speakerName": "長瀬琴乃",
      "speakerNameEn": "Kotono",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-kotono.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_ktn_09_02/sud_vo_adv_card_ktn_09_02-ktn015.m4a",
      "text": "渚達が来るまで……私が一人で繋ぎます",
      "translations": {
        "en": "Until the others arrive… I'll hold down the fort alone.",
        "id": ""
      },
      "startTime": 217.7999938925,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "koh",
      "speakerName": "{user}",
