        "id": ""
      },
      "startTime": 256.8333272298,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_fessmall-01-evening.webp",
      "bgName": "fessmall-01-evening",
      "startTime": 264.9999938965
    },
    {
      "type": "dialogue",
      "speakerCode": "koh",
      "speakerName": "{user}",
      "speakerNameEn": "{user}",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-makino.png",
