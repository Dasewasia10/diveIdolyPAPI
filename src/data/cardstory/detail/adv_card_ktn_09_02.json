      "startTime": 249.4333272298,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_fessmall-01-evening.webp",
      "bgName": "fessmall-01-evening",
      "startTime": 252.9333272259
    },
    {
      "type": "dialogue",
      "speakerCode": "ktn",
      "speakerName": "長瀬琴乃",
      "speakerNameEn": "Kotono",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-kotono.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_ktn_09_02/sud_vo_adv_card_ktn_09_02-ktn019.m4a",
      "text": "雨の中でも月ストを待ってくれている人達の期待に……\n真正面から向き合いたいんです",
      "translations": {
