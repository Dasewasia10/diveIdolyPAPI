      "text": "……{user}さん\n私に任せてもらえませんか？",
      "translations": {
        "en": "…{user}-san\nCould you leave it to me?",
        "id": ""
      },
      "startTime": 210.9999938965,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "koh",
      "speakerName": "{user}",
