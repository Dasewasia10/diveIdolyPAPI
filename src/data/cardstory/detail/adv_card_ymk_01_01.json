      "startTime": 156.8776213566,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "rio",
      "speakerName": "神崎莉央",
      "speakerNameEn": "Rio",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-rio.png",
