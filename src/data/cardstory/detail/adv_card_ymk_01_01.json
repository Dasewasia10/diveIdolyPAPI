      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-rio.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_ymk_01_01/sud_vo_adv_card_ymk_01_01-rio012.m4a",
      "text": "業界の先輩としての示しはついたかしら？\nなんてね……ふふっ",
      "translations": {
        "en": "Did we set an example as industry seniors?\nI see… fufu",
        "id": ""
      },
      "startTime": 152.5776213566,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_dressingroom-00-noon.webp",
