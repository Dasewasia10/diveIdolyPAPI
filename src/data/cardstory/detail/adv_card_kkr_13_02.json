      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-ai.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_kkr_13_02/sud_vo_adv_card_kkr_13_02-ai011.m4a",
      "text": "わ、ま、待ってよ、こころ～！\nた、たのもー……！",
      "startTime": 158.6333333333,
      "sfxList": [
        {
          "src": "https://apiip.dasewasia.my.id/storyBgm/sud_se_adv_run-out-single-01.m4a",
