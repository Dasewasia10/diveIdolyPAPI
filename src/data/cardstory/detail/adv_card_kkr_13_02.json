      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-ai.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_kkr_13_02/sud_vo_adv_card_kkr_13_02-ai004.m4a",
      "text": "ちょうど{user}さんから回答が来たよ\n……うん、やっぱりここが合宿先みたい",
      "startTime": 49.7863982285,
      "sfxList": [
        {
          "src": "https://apiip.dasewasia.my.id/storyBgm/sud_se_adv_phone-tap-01.m4a",
          "delay": 3243.3576584000007,
