      "text": "二人とも、ありがとう！　もうチェアに座って大丈夫よ\n夕ご飯を食べつつ、ゆっくりお話ししましょうか",
      "translations": {
        "en": "Thanks‚ you two! You can sit down on the chairs now.\nShall we chat while having dinner?",
        "id": ""
      },
      "startTime": 165.6000724275,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_camp-00-night.webp",
      "bgName": "camp-00-night",
      "startTime": 169.6667390942
    },
    {
      "type": "dialogue",
      "speakerCode": "hrk",
      "speakerName": "佐伯遙子",
      "speakerNameEn": "Haruko",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-haruko.png",
