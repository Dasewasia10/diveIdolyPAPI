      "startTime": 56.8,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_livehousemiddle-00-noon.webp",
      "bgName": "s1",
      "startTime": 61.4010665893
    },
    {
      "type": "dialogue",
      "speakerCode": "kkr",
      "speakerName": "赤崎こころ",
      "speakerNameEn": "赤崎こころ",
