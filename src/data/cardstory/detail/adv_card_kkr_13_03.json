        }
      ]
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_livehousemiddle-00-noon.webp",
      "bgName": "s1",
      "startTime": 10.4348072688
    },
    {
      "type": "dialogue",
      "speakerCode": "ai",
      "speakerName": "小美山愛",
      "speakerNameEn": "小美山愛",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-ai.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_kkr_13_03/sud_vo_adv_card_kkr_13_03-ai001.m4a",
      "text": "私達二人だけなのに、観客席が満員だ～……\nこんなに沢山の人達が来てくれるなんて緊張するなぁ",
      "translations": {
        "en": "私達二人だけなのに、観客席が満員だ～……\nこんなに沢山の人達が来てくれるなんて緊張するなぁ",
        "id": ""
      },
      "startTime": 15.9333333333,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_livehousemiddle-00-noon.webp",
      "bgName": "s1",
      "startTime": 21.6348072688
    },
    {
      "type": "dialogue",
      "speakerCode": "kkr",
      "speakerName": "赤崎こころ",
      "speakerNameEn": "赤崎こころ",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-kokoro.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_kkr_13_03/sud_vo_adv_card_kkr_13_03-kkr002.m4a",
      "text": "こころと愛ちゃんなら、満員御礼は当然だよ～\nだって今から、最高のライブが観れちゃう訳だし！",
      "translations": {
        "en": "こころと愛ちゃんなら、満員御礼は当然だよ～\nだって今から、最高のライブが観れちゃう訳だし！",
        "id": ""
      },
      "startTime": 25.8333333333,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_livehousemiddle-00-noon.webp",
      "bgName": "s1",
      "startTime": 29.9714516322
    },
    {
      "type": "dialogue",
      "speakerCode": "kkr",
      "speakerName": "赤崎こころ",
      "speakerNameEn": "赤崎こころ",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-kokoro.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_kkr_13_03/sud_vo_adv_card_kkr_13_03-kkr003.m4a",
      "text": "それに緊張なんてすぐ吹き飛ばせるでしょ？\nあの地獄のような合宿を乗り越えてきたんだから",
      "translations": {
        "en": "それに緊張なんてすぐ吹き飛ばせるでしょ？\nあの地獄のような合宿を乗り越えてきたんだから",
        "id": ""
      },
      "startTime": 33.3333333333,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_livehousemiddle-00-noon.webp",
      "bgName": "s1",
      "startTime": 37.2595925967
    },
    {
      "type": "dialogue",
      "speakerCode": "ai",
      "speakerName": "小美山愛",
      "speakerNameEn": "小美山愛",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-ai.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_kkr_13_03/sud_vo_adv_card_kkr_13_03-ai002.m4a",
      "text": "そうだね……実は私達、この日のために\n二人でお寺へ合宿という名の修行に行ってきたんです",
      "translations": {
        "en": "そうだね……実は私達、この日のために\n二人でお寺へ合宿という名の修行に行ってきたんです",
        "id": ""
      },
      "startTime": 42.3333333333,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_livehousemiddle-00-noon.webp",
      "bgName": "s1",
      "startTime": 46.2262592633
    },
    {
      "type": "dialogue",
      "speakerCode": "kkr",
      "speakerName": "赤崎こころ",
      "speakerNameEn": "赤崎こころ",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-kokoro.png",
