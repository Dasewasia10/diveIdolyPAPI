      "speakerCode": "kkr",
      "speakerName": "赤崎こころ",
      "speakerNameEn": "赤崎こころ",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-kokoro.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_kkr_13_03/sud_vo_adv_card_kkr_13_03-kkr001.m4a",
      "text": "今日は来てくれてありがとうございまーす！\nみんなが大好きな可愛いこころと愛ちゃんですよ～！",
      "translations": {
        "en": "今日は来てくれてありがとうございまーす！\nみんなが大好きな可愛いこころと愛ちゃんですよ～！",
        "id": ""
      },
      "startTime": 5.7484847792,
      "sfxList": [
        {
          "src": "https://apiip.dasewasia.my.id/storyBgm/sud_se_adv_cheers-in-01.m4a",
