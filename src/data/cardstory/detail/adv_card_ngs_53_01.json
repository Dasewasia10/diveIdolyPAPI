          "src": "https://apiip.dasewasia.my.id/storyBgm/sud_se_adv_walk-out-single-01.m4a",
          "delay": 5833.300431699996,
          "startTime": 172.6333334803
        }
      ]
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_tokyohall-00-noon.webp",
      "bgName": "tokyohall-00-noon",
      "startTime": 172.4666525721
    },
    {
      "type": "dialogue",
      "speakerCode": "chs",
      "speakerName": "白石千紗",
      "speakerNameEn": "白石千紗",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-chisa.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_ngs_53_01/sud_vo_adv_card_ngs_53_01-chs001.m4a",
      "text": "おはよー。渚ちゃんにお誕生日プレゼントを渡し\nたかったんだけど出ちゃった？　あれ、どうしたの？",
      "translations": {
        "en": "おはよー。渚ちゃんにお誕生日プレゼントを渡し\nたかったんだけど出ちゃった？　あれ、どうしたの？",
        "id": ""
      },
      "startTime": 176.9000330486,
      "sfxList": []
