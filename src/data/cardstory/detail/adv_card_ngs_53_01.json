      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_tokyohall-00-noon.webp",
      "bgName": "tokyohall-00-noon",
      "startTime": 182.8666617274
    },
    {
      "type": "dialogue",
      "speakerCode": "rei",
      "speakerName": "一ノ瀬怜",
      "speakerNameEn": "一ノ瀬怜",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-rei.png",
