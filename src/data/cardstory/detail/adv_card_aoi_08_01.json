      "startTime": 170.9333602906,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "koh",
      "speakerName": "{user}",
      "speakerNameEn": "{user}",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-makino.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_aoi_08_01/sud_vo_adv_card_aoi_08_01-koh013.m4a",
      "text": "葵がそこまで言うなら、よっぽど凄いんだな",
      "translations": {
        "en": "If you’re saying that‚ Aoi‚ she must be really something.",
        "id": ""
      },
      "startTime": 175.2033666371,
      "sfxList": []
    },
    {
      "type": "background",
