      "text": "いいものを作るには意見をぶつけ合うことも必要だって\nミクも分かってくれたからね",
      "translations": {
        "en": "We have to clash opinions sometimes to make something good.\nMiku understands that too.",
        "id": ""
      },
      "startTime": 159.4666936239,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "koh",
      "speakerName": "{user}",
      "speakerNameEn": "{user}",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-makino.png",
