      "text": "……は、はい！　分かりました！\nふつつか者ですが、よろしくお願いいたします！",
      "startTime": 259.9,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "koh",
      "speakerName": "{user}",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-makino.png",
