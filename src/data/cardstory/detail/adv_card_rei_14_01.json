    },
    {
      "type": "dialogue",
      "speakerCode": "rei",
      "speakerName": "一ノ瀬怜",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-rei.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_rei_14_01/sud_vo_adv_card_rei_14_01-rei022.m4a",
      "text": "わ、分かりましたから。何度も言わないで下さい！\nもぉ、なんだか暑くなってきちゃった",
      "startTime": 249.9333262126,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_ricefield-00-noon.webp",
