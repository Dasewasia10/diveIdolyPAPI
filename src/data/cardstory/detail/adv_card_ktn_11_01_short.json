      "speakerNameEn": "Kotono",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-kotono.png",
      "voiceUrl": null,
      "text": "新作映画のヒロイン役を演じられるなんて光栄です！",
      "translations": {
        "en": "I'm honored to be playing the heroine in the new movie!",
        "id": ""
