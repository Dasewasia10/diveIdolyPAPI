      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-kotono.png",
      "voiceUrl": null,
      "text": "新作映画のヒロイン役を演じられるなんて光栄です！",
      "startTime": 7.6,
      "sfxList": []
    },
    {
      "type": "dialogue",
