      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-kotono.png",
      "voiceUrl": null,
      "text": "今後の活動の参考にしたくて",
      "startTime": 16.9666666667,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "ktn",
