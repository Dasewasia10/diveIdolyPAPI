      "text": "えっ……私が、BIG4……だから……そう、ですか",
      "startTime": 20.033333985,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "ktn",
      "speakerName": "長瀬琴乃",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-kotono.png",
      "voiceUrl": null,
      "text": "う、浮かない顔だなんてそんな！　嬉しい……です",
      "startTime": 29.1333333333,
      "sfxList": []
    },
    {
      "type": "background",
