      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-mana.png",
      "voiceUrl": null,
      "text": "言った時は{user}くんも道連れだよ",
      "translations": {
        "en": "If I do‚ I'm taking you down with me‚ {user}.",
