      "speakerCode": "mna",
      "speakerName": "長瀬麻奈",
      "speakerNameEn": "Mana",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-mana.png",
      "voiceUrl": null,
      "text": "だいたい、誰からのプロポーズなの！？",
      "translations": {
        "en": "First of all‚ who even proposed to me!?",
        "id": ""
      },
      "startTime": 4.6666667699,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "koh",
      "speakerName": "{user}",
      "speakerNameEn": "{user}",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-makino.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_mna_06_01_short/sud_vo_adv_card_mna_06_01-koh001.m4a",
      "text": "麻奈……。誤解だ\n頼むから、俺の話を聞いてくれ",
      "translations": {
        "en": "Mana… It’s a misunderstanding.\nPlease‚ just listen to me.",
        "id": ""
