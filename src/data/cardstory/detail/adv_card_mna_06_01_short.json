      "text": "嫌！　{user}くんの話なんて",
      "translations": {
        "en": "No! I don’t want to hear anything",
        "id": ""
      },
      "startTime": 13.8999782324,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "mna",
      "speakerName": "長瀬麻奈",
      "speakerNameEn": "Mana",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-mana.png",
      "voiceUrl": null,
      "text": "聞きたくない！　結婚だってしないんだから！",
      "translations": {
        "en": "from you! I’m not getting married anyway!",
        "id": ""
      },
      "startTime": 16.6333128373,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "koh",
      "speakerName": "{user}",
      "speakerNameEn": "{user}",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-makino.png",
