          "delay": 2033.3333333333337,
          "startTime": 4.466666666666667
        }
      ]
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_okinawastreet-00-noon.webp",
      "bgName": "bg1",
      "startTime": 9.2
    },
    {
      "type": "dialogue",
      "speakerCode": "yu",
      "speakerName": "鈴村優",
      "speakerNameEn": "Yu",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-yu.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_yu_02_02/sud_vo_adv_card_yu_02_02-yu001.m4a",
      "text": "{user}さん、こんな所で何してはるん？",
      "translations": {
        "en": "{user}‚ what are you doing here?",
        "id": ""
      },
      "startTime": 9.2,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "koh",
      "speakerName": "{user}",
      "speakerNameEn": "{user}",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-makino.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_yu_02_02/sud_vo_adv_card_yu_02_02-koh002.m4a",
      "text": "鈴村さん？　そっちこそここで何をしてるんだ？",
      "translations": {
        "en": "Suzumura? What are you doing here?",
        "id": ""
      },
      "startTime": 13.033333333333333,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_okinawastreet-00-noon.webp",
      "bgName": "bg1",
      "startTime": 17.766666666666666
    },
    {
      "type": "dialogue",
      "speakerCode": "yu",
      "speakerName": "鈴村優",
      "speakerNameEn": "Yu",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-yu.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_yu_02_02/sud_vo_adv_card_yu_02_02-yu002.m4a",
      "text": "うちはライブ前のサニピを激励しよ思て\n楽屋でみんなに挨拶してきた所や",
      "translations": {
        "en": "I figured I’d encourage Sunny Peace before the show‚\nso I just went to greet them in their dressing rooms.",
        "id": ""
      },
      "startTime": 21.1,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "yu",
      "speakerName": "鈴村優",
      "speakerNameEn": "Yu",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-yu.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_yu_02_02/sud_vo_adv_card_yu_02_02-yu003.m4a",
      "text": "そこで、{user}さんが\n会場の外にいるって聞いて様子を見に来たんよ",
      "translations": {
        "en": "I heard you were outside\nthe venue‚ {user}‚ so I came to see you.",
        "id": ""
      },
      "startTime": 26.533333333333335,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_okinawastreet-00-noon.webp",
      "bgName": "bg1",
      "startTime": 30.566666666666666
    },
    {
      "type": "dialogue",
      "speakerCode": "koh",
      "speakerName": "{user}",
      "speakerNameEn": "{user}",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-makino.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_yu_02_02/sud_vo_adv_card_yu_02_02-koh003.m4a",
      "text": "そうだったのか……\nでもどうして衣装を着てるんだ……？",
      "translations": {
        "en": "I see…\nBut why are you in costume?",
        "id": ""
      },
      "startTime": 32.266666666666666,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_okinawastreet-00-noon.webp",
      "bgName": "bg1",
      "startTime": 36
    },
    {
      "type": "dialogue",
      "speakerCode": "yu",
      "speakerName": "鈴村優",
      "speakerNameEn": "Yu",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-yu.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_yu_02_02/sud_vo_adv_card_yu_02_02-yu004.m4a",
      "text": "うちほどの有名人になると飛び入りで\nステージに出てほしいって言われるかもしらんやろ？",
      "translations": {
        "en": "Someone as famous as I am might get invited\nto get up on stage on the spur of the moment.",
        "id": ""
      },
      "startTime": 39.2,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "yu",
      "speakerName": "鈴村優",
      "speakerNameEn": "Yu",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-yu.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_yu_02_02/sud_vo_adv_card_yu_02_02-yu005.m4a",
      "text": "せやから楽屋で自前のステージ衣装に着替えてん",
      "translations": {
        "en": "So‚ I changed into my own stage costume in the dressing room.",
        "id": ""
      },
      "startTime": 42.56666666666667,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_okinawastreet-00-noon.webp",
      "bgName": "bg1",
      "startTime": 46.666666666666664
    },
    {
      "type": "dialogue",
      "speakerCode": "yu",
      "speakerName": "鈴村優",
      "speakerNameEn": "Yu",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-yu.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_yu_02_02/sud_vo_adv_card_yu_02_02-yu006.m4a",
      "text": "どうやろ？　セクシーやろ～",
      "translations": {
        "en": "What do you think? Pretty sexy‚ huh?",
        "id": ""
      },
      "startTime": 46.666666666666664,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "koh",
      "speakerName": "{user}",
      "speakerNameEn": "{user}",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-makino.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_yu_02_02/sud_vo_adv_card_yu_02_02-koh004.m4a",
      "text": "有名人だって自覚はあるんだし\n頼むから……もう少し控えめな格好にしてくれよ",
      "translations": {
        "en": "You’re aware of being famous‚\nso please… You could have gone with a milder outfit.",
        "id": ""
      },
      "startTime": 52.8,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_okinawastreet-00-noon.webp",
      "bgName": "bg1",
      "startTime": 57.93333333333333
    },
    {
      "type": "dialogue",
      "speakerCode": "yu",
      "speakerName": "鈴村優",
      "speakerNameEn": "Yu",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-yu.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_yu_02_02/sud_vo_adv_card_yu_02_02-yu007.m4a",
      "text": "{user}さんは真面目やな～",
      "translations": {
        "en": "You’re quite the square‚ {user}.",
        "id": ""
      },
      "startTime": 57.93333333333333,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "yu",
      "speakerName": "鈴村優",
      "speakerNameEn": "Yu",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-yu.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_yu_02_02/sud_vo_adv_card_yu_02_02-yu008.m4a",
      "text": "それで、結局{user}さんは\nここで何してはるんですか？",
      "translations": {
        "en": "So‚ {user}‚\nwhat are you doing here?",
        "id": ""
      },
      "startTime": 63.53333333333333,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_okinawastreet-00-noon.webp",
      "bgName": "bg1",
      "startTime": 66.2
    },
    {
      "type": "dialogue",
      "speakerCode": "koh",
      "speakerName": "{user}",
      "speakerNameEn": "{user}",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-makino.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_yu_02_02/sud_vo_adv_card_yu_02_02-koh005.m4a",
      "text": "イベントのスタッフと一緒にビラ配りをしてるんだ",
      "translations": {
        "en": "I’m passing out handbills with the event staff.",
        "id": ""
      },
      "startTime": 66.2,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "yu",
      "speakerName": "鈴村優",
      "speakerNameEn": "Yu",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-yu.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_yu_02_02/sud_vo_adv_card_yu_02_02-yu009.m4a",
      "text": "ビラ配り？\nそれってマネージャーさんのお仕事なん？",
      "translations": {
        "en": "Handbills?\nThat’s a manager’s job?",
        "id": ""
      },
      "startTime": 71.7,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_okinawastreet-00-noon.webp",
      "bgName": "bg1",
      "startTime": 74.53333333333333
    },
    {
      "type": "dialogue",
      "speakerCode": "koh",
      "speakerName": "{user}",
      "speakerNameEn": "{user}",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-makino.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_yu_02_02/sud_vo_adv_card_yu_02_02-koh006.m4a",
      "text": "まぁ、誰の仕事って訳でもないけど\n一人でも多くの人にサニピのライブを観てほしくてね",
      "translations": {
        "en": "It’s not a job for anyone in particular\nbut if I can make one more person want to see Sunny Peace‚",
        "id": ""
      },
      "startTime": 77.9,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "koh",
      "speakerName": "{user}",
      "speakerNameEn": "{user}",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-makino.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_yu_02_02/sud_vo_adv_card_yu_02_02-koh007.m4a",
      "text": "そのために出来ることなら何でもやるさ",
      "translations": {
        "en": "I’ll do whatever I can to make that happen.",
        "id": ""
      },
      "startTime": 81.93333333333334,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_okinawastreet-00-noon.webp",
      "bgName": "bg1",
      "startTime": 85.1
    },
    {
      "type": "dialogue",
      "speakerCode": "yu",
      "speakerName": "鈴村優",
      "speakerNameEn": "Yu",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-yu.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_yu_02_02/sud_vo_adv_card_yu_02_02-yu010.m4a",
      "text": "ふうん……\nほなうちも手伝うわ、そのビラを配ればええんやろ",
      "translations": {
        "en": "Hmm…\nOkay‚ I’ll help out too. I just have to pass them out‚ right?",
        "id": ""
      },
      "startTime": 87.16666666666667,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "koh",
      "speakerName": "{user}",
      "speakerNameEn": "{user}",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-makino.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_yu_02_02/sud_vo_adv_card_yu_02_02-koh008.m4a",
      "text": "いや、イベントと無関係の鈴村さんに\nこんなことをさせる訳には……",
      "translations": {
        "en": "But you’ve got nothing to do with the event‚ Suzumura.\nI couldn’t ask you to do that…",
        "id": ""
      },
      "startTime": 94.16666666666667,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_okinawastreet-00-noon.webp",
      "bgName": "bg1",
      "startTime": 96.96666666666667
    },
    {
      "type": "dialogue",
      "speakerCode": "yu",
      "speakerName": "鈴村優",
      "speakerNameEn": "Yu",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-yu.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_yu_02_02/sud_vo_adv_card_yu_02_02-yu011.m4a",
      "text": "無関係やなんてつれないこと言わんといて\nうちらは仲間やろ",
      "translations": {
        "en": "Don’t say I’ve got nothing to do with it‚ that’s cold.\nWe’re teammates‚ aren’t we?",
        "id": ""
      },
      "startTime": 100.5,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "yu",
      "speakerName": "鈴村優",
      "speakerNameEn": "Yu",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-yu.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_yu_02_02/sud_vo_adv_card_yu_02_02-yu012.m4a",
      "text": "うちがやりたいんやから細かいことは言いっこなしや",
      "translations": {
        "en": "I’m doing this‚ so don’t try to find excuses.",
        "id": ""
      },
      "startTime": 102.5,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_okinawastreet-00-noon.webp",
      "bgName": "bg1",
      "startTime": 106.7
    },
    {
      "type": "dialogue",
      "speakerCode": "koh",
      "speakerName": "{user}",
      "speakerNameEn": "{user}",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-makino.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_yu_02_02/sud_vo_adv_card_yu_02_02-koh009.m4a",
      "text": "でもその格好はさすがに目立つだろ",
      "translations": {
        "en": "But you’re really going to stand out in that costume.",
        "id": ""
      },
      "startTime": 106.7,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "yu",
      "speakerName": "鈴村優",
      "speakerNameEn": "Yu",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-yu.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_yu_02_02/sud_vo_adv_card_yu_02_02-yu013.m4a",
      "text": "宣伝するんやったら目立った方がええんちゃうの？",
      "translations": {
        "en": "If I’m advertising‚ it’s better to stand out‚ no?",
        "id": ""
      },
      "startTime": 110.43333333333334,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "koh",
      "speakerName": "{user}",
      "speakerNameEn": "{user}",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-makino.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_yu_02_02/sud_vo_adv_card_yu_02_02-koh010.m4a",
      "text": "いやいや、トリエルが水着同然の格好で\n客引きしてたら大騒ぎになるから",
      "translations": {
        "en": "But if someone from TRINITYAiLE is dressed in something\nlike a swimsuit to attract a crowd‚ it’ll be a riot.",
        "id": ""
      },
      "startTime": 116.6,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_okinawastreet-00-noon.webp",
      "bgName": "bg1",
      "startTime": 119.1
    },
    {
      "type": "dialogue",
      "speakerCode": "yu",
      "speakerName": "鈴村優",
      "speakerNameEn": "Yu",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-yu.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_yu_02_02/sud_vo_adv_card_yu_02_02-yu014.m4a",
      "text": "その時は{user}さんがうちを\n守ってくれるんやろ？",
      "translations": {
        "en": "If that happens‚ you’ll protect me‚\nwon’t you‚ {user}?",
        "id": ""
      },
      "startTime": 121.6,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "yu",
      "speakerName": "鈴村優",
      "speakerNameEn": "Yu",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-yu.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_yu_02_02/sud_vo_adv_card_yu_02_02-yu015.m4a",
      "text": "うちがお姫様であんたが白馬の騎士や\n頼りにしてるで～",
      "translations": {
        "en": "I’m the princess and you’re my white knight.\nI’m counting on you.",
        "id": ""
      },
      "startTime": 127.6,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_okinawastreet-00-noon.webp",
      "bgName": "bg1",
      "startTime": 129.13333333333333
    },
    {
      "type": "dialogue",
      "speakerCode": "yu",
      "speakerName": "鈴村優",
      "speakerNameEn": "Yu",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-yu.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_yu_02_02/sud_vo_adv_card_yu_02_02-yu016.m4a",
      "text": "ほな、張り切ってビラ配りしよか～！",
      "translations": {
        "en": "Come on‚ let’s do our best and hand out these handbills!",
        "id": ""
      },
      "startTime": 129.13333333333333,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "koh",
      "speakerName": "{user}",
