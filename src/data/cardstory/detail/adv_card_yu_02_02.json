      "voiceUrl": null,
      "text": "――サニーピースの沖縄ライブ当日",
      "translations": {
        "en": "—The day of the Sunny Peace Okinawa concert",
        "id": ""
      },
      "startTime": 0,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "koh",
      "speakerName": "{user}",
      "speakerNameEn": "{user}",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-makino.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_yu_02_02/sud_vo_adv_card_yu_02_02-koh001.m4a",
      "text": "サニーピースの野外ライブをやります！\nすぐそこのビーチです！　よかったら観に来て下さい！",
      "translations": {
        "en": "Sunny Peace is giving an outdoor concert!\nIt’s on the beach just over there. Come and see if you like!",
        "id": ""
      },
      "startTime": 5.066666666666666,
      "sfxList": [
        {
          "src": "https://apiip.dasewasia.my.id/storyBgm/sud_se_adv_paper-01.m4a",
