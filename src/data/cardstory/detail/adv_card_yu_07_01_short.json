      "text": "あ、{user}さん、お疲れ様です～\n今日のうちらのステージ、どうでした？",
      "translations": {
        "en": "Oh‚ {user}-san‚ great job today!\nHow did y’all like our stage today?",
        "id": ""
      },
      "startTime": 25.5,
      "sfxList": [
        {
          "src": "https://apiip.dasewasia.my.id/storyBgm/sud_se_adv_walk-in-single-02.m4a",
          "delay": 0,
          "startTime": 21.8
        }
