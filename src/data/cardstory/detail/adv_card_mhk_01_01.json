    },
    {
      "type": "dialogue",
      "speakerCode": "mhk",
      "speakerName": "miho",
      "speakerNameEn": "miho",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-miho.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_mhk_01_01/sud_vo_adv_card_mhk_01_01-mhk007.m4a",
      "text": "……fran？\nちょっと待って、そこから先に進まないで",
      "translations": {
        "en": "…fran?\nWait a moment‚ don't step forward.",
        "id": ""
      },
      "startTime": 60.5666666667,
      "sfxList": []
    },
    {
      "type": "background",
