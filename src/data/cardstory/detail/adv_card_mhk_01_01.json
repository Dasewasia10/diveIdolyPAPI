      "text": "いつものアレよ\nすぐに見つけるから、少しくらい待っててちょうだい",
      "startTime": 65.6333333333,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "koh",
      "speakerName": "{user}",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-makino.png",
