      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_ktn_04_02/sud_vo_adv_card_ktn_04_02-koh001.m4a",
      "text": "琴乃、お疲れ様……って、うわ\nここにあるの、全部結婚情報誌か？",
      "startTime": 7.9333333333,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_dressingroom-00-noon.webp",
