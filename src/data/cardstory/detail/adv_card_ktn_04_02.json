      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_ktn_04_02/sud_vo_adv_card_ktn_04_02-koh004.m4a",
      "text": "先方も力を入れてる企画だからハードルが高いんだよな",
      "startTime": 74.3,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "ktn",
