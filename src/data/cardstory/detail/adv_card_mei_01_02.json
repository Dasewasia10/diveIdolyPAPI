      "startTime": 91.24731153053808,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "koh",
      "speakerName": "{user}",
      "speakerNameEn": "{user}",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-makino.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_mei_01_02/sud_vo_adv_card_mei_01_02-koh006.m4a",
      "text": "あ、ああ……\nでも、なんかちょっと違うような……？",
      "translations": {
        "en": "R-right…\nBut that doesn’t sound like exactly the same thing.",
        "id": ""
      },
      "startTime": 96.93333333333334,
      "sfxList": []
    },
