        "id": ""
      },
      "startTime": 277.2666947682,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "koh",
      "speakerName": "{user}",
      "speakerNameEn": "{user}",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-makino.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_smr_10_01/sud_vo_adv_card_smr_10_01-koh016.m4a",
      "text": "すみれには風邪引くなと言っておいて、自分がこれか\nマズいな、まだやることが山ほどあるのに……",
      "translations": {
