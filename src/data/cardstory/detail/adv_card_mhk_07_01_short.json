    },
    {
      "type": "dialogue",
      "speakerCode": "koh",
      "speakerName": "{user}",
      "speakerNameEn": "{user}",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-makino.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_mhk_07_01_short/sud_vo_adv_card_mhk_07_01-koh005.m4a",
      "text": "確かにそうですね……最近忙しくて髪を切りに行く\n時間がなくて……すみません",
      "translations": {
        "en": "That's true… I've been so busy lately that I haven't had time to\ngo to the hair salon… I'm sorry",
        "id": ""
      },
