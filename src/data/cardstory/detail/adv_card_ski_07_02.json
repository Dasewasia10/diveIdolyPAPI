      "text": "明日の仕事は午後からなんだが……沙季？　大丈夫か？",
      "translations": {
        "en": "Tomorrow's work starts in the afternoon… Saki? Are you okay?",
        "id": ""
      },
      "startTime": 259.5643167151,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_shibuya-00-night.webp",
      "bgName": "shibuya-00-night",
      "startTime": 264.6309833818
    },
    {
      "type": "dialogue",
      "speakerCode": "ski",
      "speakerName": "白石沙季",
      "speakerNameEn": "Saki",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-saki.png",
