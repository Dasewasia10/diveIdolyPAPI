      "startTime": 345.1770822182,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_shibuya-00-night.webp",
      "bgName": "shibuya-00-night",
      "startTime": 348.5770435626
    },
    {
      "type": "dialogue",
      "speakerCode": "ski",
      "speakerName": "白石沙季",
