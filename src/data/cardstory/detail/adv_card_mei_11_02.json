      "text": "だって『昨日』ドーナツ買いに行くって約束したのに\n急にいなくなっちゃうんだもん……",
      "translations": {
        "en": "だって『昨日』ドーナツ買いに行くって約束したのに\n急にいなくなっちゃうんだもん……",
        "id": ""
      },
      "startTime": 18.7,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "mei",
      "speakerName": "未来の芽衣",
      "speakerNameEn": "未来の芽衣",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-mei.png",
