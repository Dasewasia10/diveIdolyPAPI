    },
    {
      "type": "dialogue",
      "speakerCode": "koh",
      "speakerName": "{user}",
      "speakerNameEn": "{user}",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-makino.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_kor_09_01/sud_vo_adv_card_kor_09_01-koh001.m4a",
      "text": "お疲れ様です、franさん。随分嬉しそうですけど\n何かいいことでもありましたか？",
      "translations": {
        "en": "お疲れ様です、franさん。随分嬉しそうですけど\n何かいいことでもありましたか？",
        "id": ""
      },
      "startTime": 8.4333333333,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "kor",
      "speakerName": "fran",
      "speakerNameEn": "fran",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-fran.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_kor_09_01/sud_vo_adv_card_kor_09_01-kor002.m4a",
      "text": "ほら、このアメリカのニュースサイト\n経済情報のついでに、エンタメ欄も見てたんですよ",
      "translations": {
        "en": "ほら、このアメリカのニュースサイト\n経済情報のついでに、エンタメ欄も見てたんですよ",
        "id": ""
      },
      "startTime": 15.8072336555,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "kor",
      "speakerName": "fran",
      "speakerNameEn": "fran",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-fran.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_kor_09_01/sud_vo_adv_card_kor_09_01-kor003.m4a",
      "text": "そしたら。ほら、ここ\n私達のアメリカ興行のレビューが載ってたんです",
      "translations": {
        "en": "そしたら。ほら、ここ\n私達のアメリカ興行のレビューが載ってたんです",
        "id": ""
      },
      "startTime": 22.4072336555,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "kor",
      "speakerName": "fran",
      "speakerNameEn": "fran",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-fran.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_kor_09_01/sud_vo_adv_card_kor_09_01-kor004.m4a",
      "text": "「メンバーのfranが自らデザインした衣装も\n彼女達を、ステージでより一層輝かせていた」って！",
      "translations": {
        "en": "「メンバーのfranが自らデザインした衣装も\n彼女達を、ステージでより一層輝かせていた」って！",
        "id": ""
      },
      "startTime": 29.1739003222,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "kor",
      "speakerName": "fran",
      "speakerNameEn": "fran",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-fran.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_kor_09_01/sud_vo_adv_card_kor_09_01-kor005.m4a",
      "text": "やっぱり天才は世界に見つかってしまうんですね\nああ、自分の才能が怖いわ……",
      "translations": {
        "en": "やっぱり天才は世界に見つかってしまうんですね\nああ、自分の才能が怖いわ……",
        "id": ""
      },
      "startTime": 38.4072336555,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "koh",
      "speakerName": "{user}",
      "speakerNameEn": "{user}",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-makino.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_kor_09_01/sud_vo_adv_card_kor_09_01-koh002.m4a",
      "text": "アメリカでみなさんが頑張ってくれたおかげで\n日本での注目度も、上がってきてますよ",
      "translations": {
        "en": "アメリカでみなさんが頑張ってくれたおかげで\n日本での注目度も、上がってきてますよ",
        "id": ""
      },
      "startTime": 44.7804088886,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "koh",
      "speakerName": "{user}",
      "speakerNameEn": "{user}",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-makino.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_kor_09_01/sud_vo_adv_card_kor_09_01-koh003.m4a",
      "text": "さっきも来月のテレビ番組のゲストの話がきたんですが\nどうしましょうか、受けていいですか？",
      "translations": {
        "en": "さっきも来月のテレビ番組のゲストの話がきたんですが\nどうしましょうか、受けていいですか？",
        "id": ""
      },
      "startTime": 51.8666666667,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "kor",
      "speakerName": "fran",
      "speakerNameEn": "fran",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-fran.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_kor_09_01/sud_vo_adv_card_kor_09_01-kor006.m4a",
      "text": "大丈夫です。任せて下さい\nあ。それから会議室、空いてる時には貸して下さい",
      "translations": {
        "en": "大丈夫です。任せて下さい\nあ。それから会議室、空いてる時には貸して下さい",
        "id": ""
      },
      "startTime": 57.6480726918,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "kor",
      "speakerName": "fran",
      "speakerNameEn": "fran",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-fran.png",
