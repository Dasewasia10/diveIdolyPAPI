      "speakerCode": "ngs",
      "speakerName": "伊吹渚",
      "speakerNameEn": "Nagisa",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-nagisa.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_ngs_08_03/sud_vo_adv_card_ngs_08_03-ngs025.m4a",
      "text": "えへへ……似合ってますか？",
      "translations": {
        "en": "Ehehe… Does it suit me?",
        "id": ""
      },
      "startTime": 215.8864084563,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "koh",
      "speakerName": "{user}",
      "speakerNameEn": "{user}",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-makino.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_ngs_08_03/sud_vo_adv_card_ngs_08_03-koh011.m4a",
      "text": "ああ、凄く似合ってるよ",
      "translations": {
        "en": "Yeah‚ it suits you really well.",
