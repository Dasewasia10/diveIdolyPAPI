{
  "id": "adv_card_smr_15_03",
  "title": "奥山すみれ 3話 なんでもいける気がします！",
  "script": [
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_ricefield-00-noon.webp",
      "bgName": "ricefield-00-noon",
      "startTime": 0
    },
    {
      "type": "sfx",
      "src": "https://apiip.dasewasia.my.id/storyBgm/sud_se_adv_run-out-single-01.m4a",
