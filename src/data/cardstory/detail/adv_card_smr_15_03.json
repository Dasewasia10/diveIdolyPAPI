      "text": "初めまして、人間さん\n私が空を飛んでるのが、そんなに不思議？",
      "translations": {
        "en": "",
        "id": ""
      },
      "startTime": 255.0665985425,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "smr",
      "speakerName": "奥山すみれ",
      "speakerNameEn": "Sumire Okuyama",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-sumire.png",
