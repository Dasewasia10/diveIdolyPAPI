    {
      "type": "dialogue",
      "speakerCode": "koh",
      "speakerName": "{user}",
      "speakerNameEn": "{user}",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-makino.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_rio_05_02/sud_vo_adv_card_rio_05_02-koh015.m4a",
      "text": "まさか、俺の母校とは……",
      "translations": {
        "en": "I can't believe it's my alma mater…",
        "id": ""
      },
      "startTime": 254.4,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "rio",
      "speakerName": "神崎莉央",
      "speakerNameEn": "Rio",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-rio.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_rio_05_02/sud_vo_adv_card_rio_05_02-rio027.m4a",
      "text": "立ち入りの許可がおりて良かったわ\n卒業生の貴方がいたおかげかしらね",
      "translations": {
        "en": "It's good that we got permission to enter.\nI wonder if it's because you were a graduate.",
