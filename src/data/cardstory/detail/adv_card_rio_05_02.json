      "speakerName": "神崎莉央",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-rio.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_rio_05_02/sud_vo_adv_card_rio_05_02-rio022.m4a",
      "text": "当時の貴方に言ってやりたいわ\n少しは自分のことも考えろって",
      "startTime": 201.6,
      "sfxList": []
    },
    {
      "type": "dialogue",
