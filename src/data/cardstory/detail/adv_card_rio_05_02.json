{
  "id": "adv_card_rio_05_02",
  "title": "神崎莉央",
  "script": [
    {
      "type": "bgm",
      "action": "play",
      "src": "https://apiip.dasewasia.my.id/storyBgm/sud_bgm_adv_pop-01.m4a"
    },
    {
      "type": "bgm",
      "action": "play",
