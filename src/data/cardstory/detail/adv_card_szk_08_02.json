      "speakerName": "",
      "iconUrl": null,
      "voiceUrl": null,
      "text": "――数日後",
      "startTime": 157.1666656494,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "szk",
      "speakerName": "兵藤雫",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-shizuku.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_szk_08_02/sud_vo_adv_card_szk_08_02-szk014.m4a",
      "text": "あ、{user}さん……おはようございます\n私……悟りを得た",
      "startTime": 164.8999969482,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "szk",
      "speakerName": "兵藤雫",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-shizuku.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_szk_08_02/sud_vo_adv_card_szk_08_02-szk015.m4a",
      "text": "サバイバルは――ナイフに始まり、ナイフに終わる\nふん、ふん、ふん……っ！",
      "startTime": 171.933328247,
      "sfxList": [
