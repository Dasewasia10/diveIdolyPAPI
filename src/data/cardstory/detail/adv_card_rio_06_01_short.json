    {
      "type": "dialogue",
      "speakerCode": "rio",
      "speakerName": "神崎莉央",
      "speakerNameEn": "Rio",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-rio.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_rio_06_01_short/sud_vo_adv_card_rio_06_01-rio005.m4a",
      "text": "えっ？　ちょ、ちょっと{user}さん\nどうしてここにいるの？　今、東京のはずじゃ……",
      "translations": {
        "en": "Huh? Wait‚ {user}-san‚ why are you here?\nYou should be in Tokyo…",
        "id": ""
      },
