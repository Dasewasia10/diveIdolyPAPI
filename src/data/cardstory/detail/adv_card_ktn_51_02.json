      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_tokyocafe-00-noon.webp",
      "bgName": "tokyocafe-00-noon"
    },
    {
      "type": "dialogue",
      "speakerCode": null,
      "speakerName": "",
      "iconUrl": null,
      "voiceUrl": null,
      "text": "――撮影終了後",
      "startTime": 105.2333303171,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "skr",
      "speakerName": "川咲さくら",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-sakura.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_ktn_51_02/sud_vo_adv_card_ktn_51_02-skr002.m4a",
      "text": "ふぅ～、一杯買っちゃったね\nこれでもまだ、半分なんだ～",
      "startTime": 112.2666682281,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_tokyocafe-00-noon.webp",
      "bgName": "tokyocafe-00-noon"
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_tokyocafe-00-noon.webp",
      "bgName": "tokyocafe-00-noon"
    },
    {
      "type": "dialogue",
      "speakerCode": "ktn",
      "speakerName": "長瀬琴乃",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-kotono.png",
