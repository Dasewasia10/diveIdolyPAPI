      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_ktn_51_02/sud_vo_adv_card_ktn_51_02-skr004.m4a",
      "text": "良かったね、こころちゃん",
      "startTime": 162.7333420155,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_tokyocafe-00-noon.webp",
      "bgName": "tokyocafe-00-noon"
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_tokyocafe-00-noon.webp",
      "bgName": "tokyocafe-00-noon"
    },
    {
      "type": "dialogue",
      "speakerCode": "kkr",
      "speakerName": "赤崎こころ",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-kokoro.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_ktn_51_02/sud_vo_adv_card_ktn_51_02-kkr008.m4a",
      "text": "や、やめて下さいよー。こころが偉いのは当然ですけど\nなんですか、このふにゃふにゃした空気は",
      "startTime": 171.1000086822,
      "sfxList": []
    },
    {
