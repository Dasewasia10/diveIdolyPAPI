    {
      "type": "dialogue",
      "speakerCode": "rio",
      "speakerName": "神崎莉央",
      "speakerNameEn": "Rio",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-rio.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_aoi_51_02/sud_vo_adv_card_aoi_51_02-rio022.m4a",
      "text": "失礼します。本日、フラメンコを教えていただく\n神崎莉央と、小美山愛です。よろしく――",
      "translations": {
        "en": "Excuse me. We are Kanzaki Rio and Komiyama Ai‚\nhere to learn flamenco today. Please—",
        "id": ""
      },
      "startTime": 327.833307902,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "aoi",
      "speakerName": "井川葵",
      "speakerNameEn": "Aoi",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-aoi.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_aoi_51_02/sud_vo_adv_card_aoi_51_02-aoi012.m4a",
      "text": "このダンス、リズミカルでいいね\n手拍子を使って表現するのも、新鮮でたまらないな",
      "translations": {
        "en": "This dance has a nice rhythm.\nUsing hand claps for expression feels really fresh to me.",
        "id": ""
      },
      "startTime": 333.8666412353,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "rio",
      "speakerName": "神崎莉央",
