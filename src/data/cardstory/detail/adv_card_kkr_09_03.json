      "text": "{user}さんが体を張ってくれたおかげで\n写真も動画も沢山撮れましたよ～",
      "startTime": 7.6046202444,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_bigpool-00-noon.webp",
