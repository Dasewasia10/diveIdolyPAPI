        }
      ]
    },
    {
      "type": "dialogue",
      "speakerCode": "skr",
      "speakerName": "川咲さくら",
      "speakerNameEn": "Sakura",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-sakura.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_ktn_51_01_short/sud_vo_adv_card_ktn_51_01-skr001.m4a",
      "text": "琴乃ちゃーん",
      "translations": {
        "en": "Kotono-chan~!",
        "id": ""
      },
      "startTime": 30.4999977309,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "ktn",
      "speakerName": "長瀬琴乃",
      "speakerNameEn": "Kotono",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-kotono.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_ktn_51_01_short/sud_vo_adv_card_ktn_51_01-ktn004.m4a",
      "text": "わぁっ！？\nす、すみませんっ、それでは失礼します！",
      "translations": {
        "en": "Wah!?\nS-sorry! I will call back later!",
        "id": ""
      },
      "startTime": 33.2999967137,
      "sfxList": [
        {
          "src": "https://apiip.dasewasia.my.id/storyBgm/sud_se_adv_phone-tap-01.m4a",
          "delay": 4590.000000000004,
          "startTime": 37.123330047
        }
      ]
    },
    {
      "type": "dialogue",
      "speakerCode": "skr",
      "speakerName": "川咲さくら",
      "speakerNameEn": "Sakura",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-sakura.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_ktn_51_01_short/sud_vo_adv_card_ktn_51_01-skr002.m4a",
      "text": "あっ、ごめんね。電話してたんだ",
      "translations": {
        "en": "Ah‚ sorry. Were you on the phone?",
        "id": ""
      },
      "startTime": 38.0999967137,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "ktn",
      "speakerName": "長瀬琴乃",
      "speakerNameEn": "Kotono",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-kotono.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_ktn_51_01_short/sud_vo_adv_card_ktn_51_01-ktn005.m4a",
      "text": "だ、大丈夫。もう切るとこだったから\n{user}さんと仕事の話をしてたの",
      "translations": {
        "en": "I-it’s okay. I was just about to hang up.\nI was talking to {user}-san about work.",
        "id": ""
      },
      "startTime": 46.2666633803,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "skr",
      "speakerName": "川咲さくら",
      "speakerNameEn": "Sakura",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-sakura.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_ktn_51_01_short/sud_vo_adv_card_ktn_51_01-skr003.m4a",
      "text": "もしかして\n『ミラクル☆アイドルバースデー！』のこと？\nもうすぐお誕生日だもんね～。何をお願いするの？",
      "translations": {
        "en": "Do you mean…\nabout “Miracle☆ Idol Birthday!”?\nYour birthday’s coming up soon~. What did you wish for?",
        "id": ""
      },
