      "bgName": "famires-00-night",
      "startTime": 199.3666730244
    },
    {
      "type": "dialogue",
      "speakerCode": "rio",
      "speakerName": "神崎莉央",
      "speakerNameEn": "Rio Kanzaki",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-rio.png",
