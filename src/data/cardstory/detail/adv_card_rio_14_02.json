      "speakerCode": "rio",
      "speakerName": "神崎莉央",
      "speakerNameEn": "Rio Kanzaki",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-rio.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_rio_14_02/sud_vo_adv_card_rio_14_02-rio029.m4a",
      "text": "そ、そう……貴方はそういう女性が好きなの……\nじゃあ、このままでもいいかしら",
      "translations": {
        "en": "",
        "id": ""
      },
      "startTime": 316.1000200908,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "koh",
      "speakerName": "{user}",
      "speakerNameEn": "{user}",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-makino.png",
