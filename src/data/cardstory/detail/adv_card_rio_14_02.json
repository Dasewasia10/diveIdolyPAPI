      "text": "莉央さん？　顔が赤いですよ",
      "translations": {
        "en": "",
        "id": ""
      },
      "startTime": 319.3333081564,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_tokyokissa-00-noon.webp",
      "bgName": "bg2",
      "startTime": 322.2666475933
    },
    {
      "type": "dialogue",
      "speakerCode": "rio",
      "speakerName": "神崎莉央",
      "speakerNameEn": "Rio Kanzaki",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-rio.png",
