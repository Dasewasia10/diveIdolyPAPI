      "speakerCode": "koh",
      "speakerName": "{user}",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-makino.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_ktn_02_03/sud_vo_adv_card_ktn_02_03-koh010.m4a",
      "text": "いや……ずっと星見市にいたけど、知らないな\nどんなジンクスなんだ？",
      "startTime": 134.93333333333334,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_summerfes-00-night.webp",
      "bgName": "stage01",
      "startTime": 136.56666666666666
    },
    {
      "type": "dialogue",
      "speakerCode": "ktn",
      "speakerName": "長瀬琴乃",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-kotono.png",
