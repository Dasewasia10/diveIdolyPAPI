      "startTime": 103.7
    },
    {
      "type": "dialogue",
      "speakerCode": "ktn",
      "speakerName": "長瀬琴乃",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-kotono.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_ktn_02_03/sud_vo_adv_card_ktn_02_03-ktn016.m4a",
      "text": "そういえばこの前\nみんなで星見市の花火大会に行ったんです",
      "startTime": 105.4,
      "sfxList": [
        {
          "src": "https://apiip.dasewasia.my.id/storyBgm/sud_se_adv_fireworks-01.m4a",
