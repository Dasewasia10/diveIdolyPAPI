        }
      ]
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_summerfes-00-night.webp",
      "bgName": "stage01",
      "startTime": 123.43333333333334
    },
    {
      "type": "dialogue",
      "speakerCode": "ktn",
      "speakerName": "長瀬琴乃",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-kotono.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_ktn_02_03/sud_vo_adv_card_ktn_02_03-ktn017.m4a",
      "text": "……ねぇ、{user}さん",
      "startTime": 123.43333333333334,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "ktn",
      "speakerName": "長瀬琴乃",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-kotono.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_ktn_02_03/sud_vo_adv_card_ktn_02_03-ktn018.m4a",
      "text": "星見市の花火大会のジンクスって……知ってますか？",
      "startTime": 125.8,
      "sfxList": [
        {
          "src": "https://apiip.dasewasia.my.id/storyBgm/sud_se_adv_fireworks-01.m4a",
          "delay": 0,
          "startTime": 125.8
        }
      ]
    },
    {
