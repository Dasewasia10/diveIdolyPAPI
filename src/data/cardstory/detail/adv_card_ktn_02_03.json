          "delay": 5299.999999999997,
          "startTime": 109
        }
      ]
    },
    {
      "type": "dialogue",
      "speakerCode": "koh",
      "speakerName": "{user}",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-makino.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_ktn_02_03/sud_vo_adv_card_ktn_02_03-koh008.m4a",
      "text": "そうか、だからこの間、橋本さんが\n花火大会うらやましい～！　とか言ってたんだな",
      "startTime": 111.66666666666667,
      "sfxList": []
    },
    {
      "type": "sfx",
      "src": "https://apiip.dasewasia.my.id/storyBgm/sud_se_adv_fireworks-01.m4a",
      "startTime": 114
    },
    {
      "type": "dialogue",
      "speakerCode": "koh",
      "speakerName": "{user}",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-makino.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_ktn_02_03/sud_vo_adv_card_ktn_02_03-koh009.m4a",
      "text": "でも、ついこの間まで星見市にいたのに……\nなんだか懐かしい気がするな",
