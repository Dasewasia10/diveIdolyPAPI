{
  "id": "adv_card_mku_01_03",
  "title": "初音ミク 3話 音楽の三要素",
  "script": [
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_evestage-00-noon.webp",
      "bgName": "stage",
      "startTime": 0
    },
    {
