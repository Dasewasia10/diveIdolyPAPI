      "text": "それも『日々の積み重ね』ってやつだな",
      "translations": {
        "en": "That's also the result of \"accumulated daily efforts‚\" right?",
        "id": ""
      },
      "startTime": 117.5333333333,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "mei",
      "speakerName": "早坂芽衣",
      "speakerNameEn": "Mei",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-mei.png",
