    },
    {
      "type": "dialogue",
      "speakerCode": "koh",
      "speakerName": "{user}",
      "speakerNameEn": "{user}",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-makino.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_ngs_06_03/sud_vo_adv_card_ngs_06_03-koh012.m4a",
      "text": "渚も行ってくるといい。頼んだぞ",
      "translations": {
        "en": "Nagisa‚ you should go too. I'm counting on you.",
        "id": ""
      },
      "startTime": 156.8333333333,
      "sfxList": []
    },
    {
