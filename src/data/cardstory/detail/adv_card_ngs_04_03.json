      "text": "……まぁ、最初は{user}さんを\nイメージしてたんですけどね",
      "startTime": 78.1666666667,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_photostudio-00-noon.webp",
      "bgName": "photostudio-00-noon"
    },
    {
      "type": "dialogue",
      "speakerCode": "ngs",
      "speakerName": "伊吹渚",
