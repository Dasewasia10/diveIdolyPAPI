      "text": "あれ？　{user}さん\n手の指、ちょっと怪我してませんか？",
      "translations": {
        "en": "Oh‚ {user}-san.\nDid you hurt your fingers?",
        "id": ""
      },
      "startTime": 179.2666666667,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "koh",
      "speakerName": "{user}",
      "speakerNameEn": "{user}",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-makino.png",
