      "text": "そしたらカメラマンさんに凄く褒めてもらえたんです\nそれですっごく自信がついて",
      "startTime": 71.9333333333,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_photostudio-00-noon.webp",
