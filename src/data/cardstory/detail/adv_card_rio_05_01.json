      "text": "鏡でも見てみたら？　ずっと顔がにやけてるわよ",
      "translations": {
        "en": "Why don't you take a look in the mirror? Your face has been grinning the whole time.",
        "id": ""
      },
      "startTime": 224.5333333333,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "koh",
      "speakerName": "{user}",
