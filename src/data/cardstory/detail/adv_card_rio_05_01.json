      "text": "…………にやけては、いませんよ",
      "translations": {
        "en": "…………I'm not grinning‚ you know.",
        "id": ""
      },
      "startTime": 230.4,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_hillpark-00-noon.webp",
      "bgName": "hillpark-00-noon",
      "startTime": 232.9333333333
    },
    {
      "type": "dialogue",
      "speakerCode": "rio",
      "speakerName": "神崎莉央",
