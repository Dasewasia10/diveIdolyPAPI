      "bgName": "hillpark-00-noon",
      "startTime": 185.9666666667
    },
    {
      "type": "dialogue",
      "speakerCode": "rio",
      "speakerName": "神崎莉央",
      "speakerNameEn": "Rio",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-rio.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_rio_05_01/sud_vo_adv_card_rio_05_01-rio020.m4a",
      "text": "ふぅん、ここでよく麻奈と打ち合わせをしていたの……\nで、麻奈は作詞もしていたのね",
      "translations": {
        "en": "Hmmm‚ so you used to have meetings with Mana here…\nAnd she even did the lyrics‚ huh?",
        "id": ""
      },
      "startTime": 191.7666666667,
      "sfxList": [
        {
          "src": "https://apiip.dasewasia.my.id/storyBgm/sud_se_adv_walk-out-single-01.m4a",
          "delay": 0,
          "startTime": 186.4333333333
        }
      ]
    },
    {
      "type": "dialogue",
      "speakerCode": "koh",
      "speakerName": "{user}",
      "speakerNameEn": "{user}",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-makino.png",
