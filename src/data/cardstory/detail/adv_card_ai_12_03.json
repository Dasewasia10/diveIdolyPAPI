      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_ai_12_03/sud_vo_adv_card_ai_12_03-tnkokmt001.m4a",
      "text": "ははっ、こんな可愛いアイドルと戦えるなんて……\n楽しみで楽しみで仕方ねぇなぁっ！　くらえっ！",
      "translations": {
        "en": "ははっ、こんな可愛いアイドルと戦えるなんて……\n楽しみで楽しみで仕方ねぇなぁっ！　くらえっ！",
        "id": ""
      },
      "startTime": 19.2,
      "sfxList": [
        {
          "src": "https://apiip.dasewasia.my.id/storyBgm/sud_se_adv_wind-03.m4a",
          "delay": 4466.6681926,
