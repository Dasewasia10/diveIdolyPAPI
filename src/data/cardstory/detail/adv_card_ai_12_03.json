      "bgName": "s1",
      "startTime": 55.9999994915
    },
    {
      "type": "dialogue",
      "speakerCode": "ai",
      "speakerName": "小美山愛",
      "speakerNameEn": "小美山愛",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-ai.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_ai_12_03/sud_vo_adv_card_ai_12_03-ai002.m4a",
      "text": "プロの技を受けられるなんて光栄です！　もっともっと\nタンク岡本さんのプロレスを魅せて下さい！",
      "translations": {
        "en": "プロの技を受けられるなんて光栄です！　もっともっと\nタンク岡本さんのプロレスを魅せて下さい！",
        "id": ""
      },
      "startTime": 60.7,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "unknown",
      "speakerName": "タンク岡本",
      "speakerNameEn": "タンク岡本",
      "iconUrl": null,
