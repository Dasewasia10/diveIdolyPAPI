      "speakerNameEn": "タンク岡本",
      "iconUrl": null,
      "voiceUrl": null,
      "text": "つーか、大したことねぇな、星見プロもよぉ！",
      "translations": {
        "en": "つーか、大したことねぇな、星見プロもよぉ！",
