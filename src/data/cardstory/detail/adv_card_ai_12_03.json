      "startTime": 63.8666661581,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "unknown",
      "speakerName": "タンク岡本",
      "speakerNameEn": "タンク岡本",
      "iconUrl": null,
      "voiceUrl": null,
      "text": "後悔しろ……たっぷり私のプロレスを魅せてやる！",
      "translations": {
        "en": "後悔しろ……たっぷり私のプロレスを魅せてやる！",
        "id": ""
      },
      "startTime": 70.3333348592,
      "sfxList": []
    },
    {
