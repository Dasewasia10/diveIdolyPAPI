      "type": "dialogue",
      "speakerCode": "unknown",
      "speakerName": "タンク岡本",
      "speakerNameEn": "タンク岡本",
      "iconUrl": null,
      "voiceUrl": null,
      "text": "てか、なんで避けねぇんだよ……！",
      "translations": {
        "en": "てか、なんで避けねぇんだよ……！",
        "id": ""
      },
      "startTime": 52.6000015259,
      "sfxList": []
