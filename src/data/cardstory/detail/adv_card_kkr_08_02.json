      "text": "寒さ対策はパーフェクトです！\nさぁ、スタジオに出発です！",
      "startTime": 3.1666666667,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "koh",
      "speakerName": "{user}",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-makino.png",
