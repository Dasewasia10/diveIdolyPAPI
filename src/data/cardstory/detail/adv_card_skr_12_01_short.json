      "speakerName": "{user}",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-makino.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_skr_12_01_short/sud_vo_adv_card_skr_12_01-koh003.m4a",
      "text": "ありがとう。じゃあ本番はそれで……すまない\nちょっとお茶を一口……げほっ、げほっ！？",
      "startTime": 44.4666666667,
      "sfxList": []
    },
