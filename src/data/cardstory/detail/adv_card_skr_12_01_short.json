      "text": "それより、{user}さんは大丈夫ですか？\n最近疲れてるように見えますけど……",
      "startTime": 18.7333333333,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "koh",
      "speakerName": "{user}",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-makino.png",
