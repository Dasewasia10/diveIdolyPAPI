      "text": "私みたいにー、なんて……さくらちゃんから\nそんな風に言われるのは、なんだかむずむずしちゃうよ",
      "translations": {
        "en": "私みたいにー、なんて……さくらちゃんから\nそんな風に言われるのは、なんだかむずむずしちゃうよ",
        "id": ""
      },
      "startTime": 43.6971418144,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "chk",
      "speakerName": "高海千歌",
      "speakerNameEn": "高海千歌",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-chk.png",
