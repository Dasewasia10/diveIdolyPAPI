      "startTime": 95.3331020194
    },
    {
      "type": "dialogue",
      "speakerCode": "suz",
      "speakerName": "成宮すず",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-suzu.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_kor_51_03/sud_vo_adv_card_kor_51_03-suz008.m4a",
      "text": "（遙子さんも寝てしまっていますわね……）\n（締め切り間近とはいえ、根を詰め過ぎですわ……）",
      "startTime": 98.6333267212,
      "sfxList": []
    },
    {
      "type": "background",
