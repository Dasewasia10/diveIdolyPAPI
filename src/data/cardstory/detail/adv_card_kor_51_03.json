      "text": "徹夜上等！　寝なきゃ余裕！",
      "startTime": 58.4667383511,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_tokyosuzroom-00-noon.webp",
