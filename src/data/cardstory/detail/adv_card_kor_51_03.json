      "text": "あ……いえ。手伝うと言ったのは私ですし\nプロとして、ちゃんと最後までやりますわ",
      "startTime": 141.0999933879,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_tokyosuzroom-00-noon.webp",
