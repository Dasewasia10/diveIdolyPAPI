      "speakerName": "",
      "iconUrl": null,
      "voiceUrl": null,
      "text": "――長瀬麻奈がデビューして数ヶ月後",
      "startTime": 0,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_hoshireception-00-noon.webp",
