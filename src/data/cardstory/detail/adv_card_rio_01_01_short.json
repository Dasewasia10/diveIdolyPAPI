      "speakerNameEn": "Rio",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-rio.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_rio_01_01_short/sud_vo_adv_card_rio_01_01-rio004.m4a",
      "text": "あら、ありがとう",
      "translations": {
        "en": "Oh‚ thank you.",
        "id": ""
      },
