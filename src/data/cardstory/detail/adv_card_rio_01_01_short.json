      "text": "先日はうちの子達がお世話になりました",
      "translations": {
        "en": "Thank you for taking care of our girls the other day.",
        "id": ""
      },
      "startTime": 15,
      "sfxList": [
        {
          "src": "https://apiip.dasewasia.my.id/storyBgm/sud_se_adv_paper-01.m4a",
