      "text": "名刺、いただける？",
      "translations": {
        "en": "May I have your business card?",
        "id": ""
      },
      "startTime": 13.066666666666666,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "koh",
