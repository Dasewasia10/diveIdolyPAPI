      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": null,
      "speakerName": "",
      "speakerNameEn": "",
      "iconUrl": null,
      "voiceUrl": null,
      "text": "――莉央は渡された名刺を見もせず、机に置いた",
      "translations": {
        "en": "――but she just lays it on the table without taking a glance.",
        "id": ""
      },
      "startTime": 19.866666666666667,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "rio",
      "speakerName": "神崎莉央",
      "speakerNameEn": "Rio",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-rio.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_rio_01_01_short/sud_vo_adv_card_rio_01_01-rio005.m4a",
      "text": "あの子達の様子はどう？\n私達とレッスンした後、落ち込んでるんじゃない？",
      "translations": {
        "en": "How are they doing?\nDid they feel discouraged after our joint lesson?",
        "id": ""
