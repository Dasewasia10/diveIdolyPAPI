      "speakerNameEn": "",
      "iconUrl": null,
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_rei_16_03/sud_vo_adv_card_rei_16_03-suzukiana001.m4a",
      "text": "戦いの火蓋は切って落とされた！　地下闘技場最強\nアイドルトーナメント第一試合……レディ、ファイト！",
      "translations": {
        "en": "",
        "id": ""
      },
      "startTime": 19.3666666667,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_prowrestlingring-00-noon.webp",
      "bgName": "prowrestlingring-00-noon",
      "startTime": 21.6405883022
    },
    {
      "type": "dialogue",
      "speakerCode": null,
      "speakerName": "",
      "speakerNameEn": "",
      "iconUrl": null,
      "voiceUrl": null,
      "text": "――そして",
      "translations": {
        "en": "",
        "id": ""
      },
      "startTime": 25.2473500888,
      "sfxList": []
    },
    {
      "type": "background",
