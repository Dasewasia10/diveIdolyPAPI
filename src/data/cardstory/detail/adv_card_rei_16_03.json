      "text": "ぶふっ！　げほっ、げほっ！！\n……な、なんだって？",
      "translations": {
        "en": "",
        "id": ""
      },
      "startTime": 186.8527793006,
      "sfxList": []
    },
    {
      "type": "dialogue",
