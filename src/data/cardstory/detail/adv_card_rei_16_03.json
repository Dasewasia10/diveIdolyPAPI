      "bgName": "prowrestlingring-00-noon",
      "startTime": 7.3947845141
    },
    {
      "type": "dialogue",
      "speakerCode": "rei",
      "speakerName": "一ノ瀬怜",
      "speakerNameEn": "Rei Ichinose",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-rei.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_rei_16_03/sud_vo_adv_card_rei_16_03-rei002.m4a",
      "text": "でも、同じステージに立ったからには、関係ない\n正々堂々、勝負よ！　まきびし丸さん！",
      "translations": {
        "en": "",
        "id": ""
      },
      "startTime": 11.7333333333,
      "sfxList": []
    },
    {
      "type": "background",
