      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_ktn_04_01/sud_vo_adv_card_ktn_04_01-koh016.m4a",
      "text": "遙子さんは即答でOKだったんだよ",
      "translations": {
        "en": "Haruko-san immediately said OK without hesitation.",
