      "text": "うん。そうだよ……\nあと、今日の出来栄え……後で教えてほしい",
      "translations": {
        "en": "うん。そうだよ……\nあと、今日の出来栄え……後で教えてほしい",
        "id": ""
      },
      "startTime": 63.1958982308,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_talkstudio-00-noon.webp",
