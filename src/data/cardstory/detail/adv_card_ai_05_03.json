    {
      "type": "dialogue",
      "speakerCode": "ai",
      "speakerName": "小美山愛",
      "speakerNameEn": "Ai",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-ai.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_ai_05_03/sud_vo_adv_card_ai_05_03-ai005.m4a",
      "text": "鏡だったら、もう何十回も見てますよ～",
      "translations": {
        "en": "I've looked at myself in the mirror dozens of times already.",
