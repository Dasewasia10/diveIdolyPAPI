      "translations": {
        "en": "You were in perfect sync. Ai too.\nBut how did you do it… in such a short time?",
        "id": ""
      },
      "startTime": 156.36666666666667,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "aoi",
