      "text": "一個、足りないものがあるんだよね",
      "startTime": 96.5944016215,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "koh",
      "speakerName": "{user}",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-makino.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_mna_06_03/sud_vo_adv_card_mna_06_03-koh008.m4a",
      "text": "足りないもの？　なんだ？　出来る限り用意するけど",
      "startTime": 99.7944058973,
      "sfxList": []
    },
    {
      "type": "background",
