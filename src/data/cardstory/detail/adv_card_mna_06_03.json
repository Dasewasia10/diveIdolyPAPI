      "text": "本格的なセットだね～。まるで本物の式場みたい",
      "startTime": 83.3030489681,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "koh",
      "speakerName": "{user}",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-makino.png",
