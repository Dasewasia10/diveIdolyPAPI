      "text": "って、{user}くん、呼ばれてるよ",
      "startTime": 134.1660446084,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "mna",
      "speakerName": "長瀬麻奈",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-mana.png",
