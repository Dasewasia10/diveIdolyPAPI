      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "mna",
      "speakerName": "長瀬麻奈",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-mana.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_mna_06_03/sud_vo_adv_cmn_mna_enter-01.m4a",
      "text": "あ、時間みたいだよ。式場までのエスコート、お願いね",
      "startTime": 75.8697172083,
      "sfxList": []
    },
    {
      "type": "background",
