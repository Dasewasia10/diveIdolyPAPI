      "text": "確かに凝ってるな\n花嫁の気分にもなりやすいんじゃないか？",
      "startTime": 91.7333297172,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_church-00-night.webp",
      "bgName": "church-00-night"
    },
    {
      "type": "dialogue",
      "speakerCode": "mna",
