    {
      "type": "dialogue",
      "speakerCode": "koh",
      "speakerName": "{user}",
      "speakerNameEn": "{user}",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-makino.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_suz_01_01/sud_vo_adv_card_suz_01_01-koh013.m4a",
      "text": "とにかく、すずはまだ成長期だろうし、地道な\n積み重ねを続ければ、すぐに結果が出るんじゃないか",
      "translations": {
