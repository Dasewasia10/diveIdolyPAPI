      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "koh",
      "speakerName": "{user}",
      "speakerNameEn": "{user}",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-makino.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_suz_01_01/sud_vo_adv_card_suz_01_01-koh012.m4a",
      "text": "健康的な生活を送っている人ほど\nプロポーションも整っていることが多いと思う",
      "translations": {
        "en": "It often happens that the healthier people live‚\nthe better their proportions get.",
