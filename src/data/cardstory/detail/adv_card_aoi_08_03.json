      "text": "急に何を言ってるんだ！？",
      "translations": {
        "en": "What are you talking about all of a sudden!?",
        "id": ""
      },
      "startTime": 160.8983610667,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_hokkastreet-00-noon.webp",
      "bgName": "hokkastreet-00-noon",
      "startTime": 163.1402884917
    },
    {
      "type": "dialogue",
      "speakerCode": "aoi",
