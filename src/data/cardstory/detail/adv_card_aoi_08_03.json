      "text": "そんなに慌てることないのに",
      "translations": {
        "en": "You don’t have to be so flustered.",
        "id": ""
      },
      "startTime": 163.1402884917,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": null,
      "speakerName": "",
      "speakerNameEn": "",
      "iconUrl": null,
      "voiceUrl": null,
      "text": "――ライブ当日",
      "translations": {
        "en": "――The Day of the Live Show",
        "id": ""
      },
