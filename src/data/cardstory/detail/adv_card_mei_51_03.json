      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_mei_51_03/sud_vo_adv_card_mei_51_03-ngs003.m4a",
      "text": "あ、そろそろ時間だし、私達も準備しよっか",
      "startTime": 79.5999983468,
      "sfxList": []
