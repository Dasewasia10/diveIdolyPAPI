      "text": "お店の人達も、お疲れ様でした\n本日はありがとうございました",
      "startTime": 96.8666665394,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "mei",
      "speakerName": "早坂芽衣",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-mei.png",
