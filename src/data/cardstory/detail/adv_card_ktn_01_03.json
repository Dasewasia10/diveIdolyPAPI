      "startTime": 27.056873081678326
    },
    {
      "type": "dialogue",
      "speakerCode": "ktn",
      "speakerName": "長瀬琴乃",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-kotono.png",
