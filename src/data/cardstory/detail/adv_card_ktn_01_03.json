      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_ktn_01_03/sud_vo_adv_card_ktn_01_03-koh006.m4a",
      "text": "……あ、ああ、そうだな。琴乃の口からそんな\n言葉が出ると思っていなかったから、正直戸惑ってる",
      "startTime": 89.49389681231506,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "ktn",
      "speakerName": "長瀬琴乃",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-kotono.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_ktn_01_03/sud_vo_adv_card_ktn_01_03-ktn013.m4a",
      "text": "……っ！",
      "startTime": 93.69389681231506,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "koh",
      "speakerName": "{user}",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-makino.png",
