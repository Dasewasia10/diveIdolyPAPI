        "en": "{user}-san?\nWhat are you grinning about?",
        "id": ""
      },
      "startTime": 212.92353859782432,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "koh",
      "speakerName": "{user}",
