      "text": "……いや、別になんでもありません",
      "translations": {
        "en": "Oh‚ er‚ nothing in particular.",
        "id": ""
      },
      "startTime": 215.290205264491,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "smr",
      "speakerName": "奥山すみれ",
      "speakerNameEn": "Sumire",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-sumire.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_smr_01_02/sud_vo_adv_card_smr_01_02-smr030.m4a",
      "text": "その顔は嘘をついてる顔です！\n話してくれるまで逃がしませんよ！！",
