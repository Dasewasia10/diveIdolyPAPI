      },
      "startTime": 138.1666664918,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "kor",
      "speakerName": "fran",
      "speakerNameEn": "fran",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-fran.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_kor_09_03/sud_vo_adv_card_kor_09_03-kor010.m4a",
      "text": "あー、それは無理です",
      "translations": {
        "en": "あー、それは無理です",
        "id": ""
      },
      "startTime": 141.1364625314,
      "sfxList": []
