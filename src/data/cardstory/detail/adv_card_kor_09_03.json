    },
    {
      "type": "dialogue",
      "speakerCode": "koh",
      "speakerName": "{user}",
      "speakerNameEn": "{user}",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-makino.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_kor_09_03/sud_vo_adv_card_kor_09_03-koh009.m4a",
      "text": "でもfranさん、展示会でも働き詰めでしたし\n休める時にはちゃんと休んだ方が……",
      "translations": {
        "en": "でもfranさん、展示会でも働き詰めでしたし\n休める時にはちゃんと休んだ方が……",
