      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_amepark-00-noon.webp",
      "bgName": "amepark-00-noon",
      "startTime": 121.0179571806
    },
    {
      "type": "dialogue",
      "speakerCode": "kor",
      "speakerName": "fran",
      "speakerNameEn": "fran",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-fran.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_kor_09_03/sud_vo_adv_card_kor_09_03-kor008.m4a",
      "text": "アメリカ行くなら、アイドルの営業もやらなきゃって\nこっちの仕事入れたのは、あなたでしょう",
      "translations": {
        "en": "アメリカ行くなら、アイドルの営業もやらなきゃって\nこっちの仕事入れたのは、あなたでしょう",
        "id": ""
      },
      "startTime": 124.1666664918,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "kor",
      "speakerName": "fran",
      "speakerNameEn": "fran",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-fran.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_kor_09_03/sud_vo_adv_card_kor_09_03-kor009.m4a",
      "text": "明日は移動日、ライブは明後日\nまだ休む時間なんてありませんよ、諦めて下さい",
      "translations": {
        "en": "明日は移動日、ライブは明後日\nまだ休む時間なんてありませんよ、諦めて下さい",
        "id": ""
      },
      "startTime": 129.6999998252,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_amepark-00-noon.webp",
      "bgName": "amepark-00-noon",
