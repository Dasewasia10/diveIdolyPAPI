    {
      "type": "dialogue",
      "speakerCode": "koh",
      "speakerName": "{user}",
      "speakerNameEn": "{user}",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-makino.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_kor_09_03/sud_vo_adv_card_kor_09_03-koh004.m4a",
      "text": "ふぅ……一気に立ち寄る人が増えましたね\n発注書は……おお、だいぶ減ってる",
      "translations": {
        "en": "ふぅ……一気に立ち寄る人が増えましたね\n発注書は……おお、だいぶ減ってる",
        "id": ""
      },
      "startTime": 56.6333331585,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "koh",
      "speakerName": "{user}",
      "speakerNameEn": "{user}",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-makino.png",
