      "speakerCode": "kor",
      "speakerName": "fran",
      "speakerNameEn": "fran",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-fran.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_kor_09_03/sud_vo_adv_card_kor_09_03-kor013.m4a",
      "text": "kanaとmihoがいないからって\nショボいステージだと、思われたくはないですから",
      "translations": {
        "en": "kanaとmihoがいないからって\nショボいステージだと、思われたくはないですから",
        "id": ""
