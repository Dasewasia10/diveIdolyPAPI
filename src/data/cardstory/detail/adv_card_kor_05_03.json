    {
      "type": "dialogue",
      "speakerCode": "kor",
      "speakerName": "fran",
      "speakerNameEn": "fran",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-fran.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_kor_05_03/sud_vo_adv_card_kor_05_03-kor020.m4a",
      "text": "マネージャーの裏切りで傷ついた\n私の心を慰めてくれるようなものですか？",
      "translations": {
        "en": "Is that something\nto comfort my wounded heart?",
        "id": ""
      },
      "startTime": 207.8999522291,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "koh",
      "speakerName": "{user}",
      "speakerNameEn": "{user}",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-makino.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/cardStoryVoice/sud_vo_adv_card_kor_05_03/sud_vo_adv_card_kor_05_03-koh013.m4a",
      "text": "前にベビーカーのお母さんのお手伝いをしたでしょう\nあの方が、事務所にお礼を送ってくれまして",
      "translations": {
        "en": "Do you remember when we helped that mother with the stroller?\nShe sent a thank you gift to the office.",
