    {
      "type": "dialogue",
      "speakerCode": null,
      "speakerName": "",
      "iconUrl": null,
      "voiceUrl": null,
      "text": "自分の想いを、チサに伝えた\nそれを聞き、チサの出した答えは――",
      "startTime": 0.8666666667,
      "sfxList": []
    },
    {
