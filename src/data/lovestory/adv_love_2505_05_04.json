      "voiceUrl": "https://apiip.dasewasia.my.id/loveStoryVoice/sud_vo_adv_love_2505_05_04/sud_vo_adv_love_2505_05_02-chs008.m4a",
      "text": "でも……っ、きっと、長くは続かないから\n私は、サキュバスでも、人間でもないし\nきっと悲しいことになっちゃうと思うから",
      "startTime": 24.300004037,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "chs",
