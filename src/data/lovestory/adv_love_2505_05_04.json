    {
      "type": "dialogue",
      "speakerCode": null,
      "speakerName": "",
      "iconUrl": null,
      "voiceUrl": null,
      "text": "変わったことといえば……\n一年ほど前の記憶に\nぼんやりとしたところがあるくらいだろうか",
      "startTime": 117.2333760261,
      "sfxList": []
    },
    {
