      "speakerName": "{user}",
      "iconUrl": null,
      "voiceUrl": "https://apiip.dasewasia.my.id/loveStoryVoice/sud_vo_adv_love_2603_08_03/sud_vo_adv_love_2603_08_03-koh007.wav",
      "text": "（待てよ\n今ここで莉央さんに土下座して頼めば\nコネで中途採用してもらえるかも！）",
      "startTime": 61.5000045776,
      "sfxList": []
    },
