      "startTime": 44.9561932881
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_preentrance-00-noon.webp",
      "bgName": "preentrance-00-noon",
      "startTime": 45.6666694641
    },
    {
      "type": "dialogue",
      "speakerCode": "rio",
      "speakerName": "神崎莉央",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-rio.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/loveStoryVoice/sud_vo_adv_love_2603_08_03/sud_vo_adv_love_2603_08_03-rio001.wav",
      "text": "あら？　{user}君\nこんな所で何をしているの？",
      "startTime": 45.6666694641,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_preentrance-00-noon.webp",
