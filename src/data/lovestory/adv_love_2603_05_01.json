  "id": "adv_love_2603_05_01",
  "title": "Episode 5 Part 1",
  "script": [
    {
      "type": "bgm",
      "action": "play",
      "src": "https://apiip.dasewasia.my.id/storyBgm/sud_bgm_adv_pop-01.m4a"
    },
    {
      "type": "background",
