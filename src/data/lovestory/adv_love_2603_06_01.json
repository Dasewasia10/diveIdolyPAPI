        {
          "src": "https://apiip.dasewasia.my.id/storyBgm/sud_se_adv_gasa-02.m4a",
          "delay": 2199.9996979
        }
      ]
    },
    {
      "type": "dialogue",
      "speakerCode": "rio",
      "speakerName": "神崎莉央",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-rio.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/loveStoryVoice/sud_vo_adv_love_2603_06_01/sud_vo_adv_love_2603_06_01-rio001.wav",
      "text": "おかえりなさい",
      "startTime": 2.86666646,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_rioroom-00-night.webp",
      "bgName": "rioroom-00-night",
      "startTime": 4.0992741704
    },
    {
      "type": "dialogue",
      "speakerCode": "koh",
      "speakerName": "{user}",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-kohei.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/loveStoryVoice/sud_vo_adv_love_2603_06_01/sud_vo_adv_love_2603_06_01-koh002.wav",
      "text": "莉央さん！？\n急に抱きついてきて、どうしたんですか！？",
      "startTime": 4.8666663964,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_rioroom-00-night.webp",
      "bgName": "rioroom-00-night",
      "startTime": 9.3666663964
    },
    {
      "type": "dialogue",
      "speakerCode": "rio",
      "speakerName": "神崎莉央",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-rio.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/loveStoryVoice/sud_vo_adv_love_2603_06_01/sud_vo_adv_love_2603_06_01-rio002.wav",
      "text": "恋人なんだから抱きついてもいいでしょ\nそれより……ご飯にする？　お風呂にする？\nそれとも、わ……わた……わたたたた……",
      "startTime": 9.3666663964,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_rioroom-00-night.webp",
      "bgName": "rioroom-00-night",
      "startTime": 14.0343379974
    },
    {
      "type": "dialogue",
      "speakerCode": "koh",
      "speakerName": "{user}",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-kohei.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/loveStoryVoice/sud_vo_adv_love_2603_06_01/sud_vo_adv_love_2603_06_01-koh003.wav",
      "text": "恥ずかしいなら言わなければいいのに",
      "startTime": 23.0333331902,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_rioroom-00-night.webp",
      "bgName": "rioroom-00-night",
      "startTime": 26.4666665236
    },
    {
      "type": "dialogue",
      "speakerCode": "rio",
      "speakerName": "神崎莉央",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-rio.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/loveStoryVoice/sud_vo_adv_love_2603_06_01/sud_vo_adv_love_2603_06_01-rio003.wav",
      "text": "いいでしょ！\n会社でずっと我慢してたんだから\n二人きりの時くらい甘えさせなさい！",
      "startTime": 26.4666665236,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "koh",
      "speakerName": "{user}",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-kohei.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/loveStoryVoice/sud_vo_adv_love_2603_06_01/sud_vo_adv_love_2603_06_01-koh004.wav",
      "text": "莉央さんがこんなに甘えたがりだなんて\n同棲する前は想像もしなかったなぁ",
      "startTime": 32.9333334445,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_rioroom-00-night.webp",
      "bgName": "rioroom-00-night",
      "startTime": 39.7666667778
    },
    {
      "type": "dialogue",
      "speakerCode": "rio",
      "speakerName": "神崎莉央",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-rio.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/loveStoryVoice/sud_vo_adv_love_2603_06_01/sud_vo_adv_love_2603_06_01-rio004.wav",
      "text": "私だって、好きな人の前だとこんな風に\nなるなんて、自分でも思わなかったわ",
      "startTime": 39.7666667778,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "rio",
      "speakerName": "神崎莉央",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-rio.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/loveStoryVoice/sud_vo_adv_love_2603_06_01/sud_vo_adv_love_2603_06_01-rio005.wav",
      "text": "貴方と暮らすようになって\n自分の知らなかった一面に\n驚くことばかりよ",
      "startTime": 47.1666667778,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_rioroom-00-night.webp",
      "bgName": "rioroom-00-night",
      "startTime": 53.3999993482
    },
    {
      "type": "dialogue",
      "speakerCode": "rio",
      "speakerName": "神崎莉央",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-rio.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/loveStoryVoice/sud_vo_adv_love_2603_06_01/sud_vo_adv_love_2603_06_01-rio006.wav",
      "text": "……それで、どうするの？\nご飯にする？　ライスにする？\nそれとも、お・こ・め？",
      "startTime": 53.3999993482,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_rioroom-00-night.webp",
      "bgName": "rioroom-00-night",
      "startTime": 56.433332316
    },
    {
      "type": "dialogue",
      "speakerCode": "koh",
      "speakerName": "{user}",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-kohei.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/loveStoryVoice/sud_vo_adv_love_2603_06_01/sud_vo_adv_love_2603_06_01-koh005.wav",
      "text": "選択肢が減ってるんですけど",
      "startTime": 63.4666660148,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "rio",
      "speakerName": "神崎莉央",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-rio.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/loveStoryVoice/sud_vo_adv_love_2603_06_01/sud_vo_adv_love_2603_06_01-rio007.wav",
      "text": "恋人に意地悪を言った罰よ",
      "startTime": 66.0333326815,
      "sfxList": []
    },
    {
      "type": "bgm",
      "action": "stop",
      "startTime": 68.0852374075
    },
    {
      "type": "bgm",
      "action": "play",
      "src": "https://apiip.dasewasia.my.id/storyBgm/sud_bgm_adv_happy-01.m4a",
      "startTime": 70.2000039258
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_rioroom-00-night.webp",
      "bgName": "rioroom-00-night",
      "startTime": 70.2000039258
    },
    {
      "type": "dialogue",
      "speakerCode": "koh",
      "speakerName": "{user}",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-kohei.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/loveStoryVoice/sud_vo_adv_love_2603_06_01/sud_vo_adv_love_2603_06_01-koh006.wav",
      "text": "ごちそうさまでした\nあー、美味しかった\n莉央さんって本当に料理上手ですね",
      "startTime": 70.2000039258,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "koh",
      "speakerName": "{user}",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-kohei.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/loveStoryVoice/sud_vo_adv_love_2603_06_01/sud_vo_adv_love_2603_06_01-koh007.wav",
      "text": "美人で、仕事が出来て、料理も上手で\nこんな素敵な人を恋人に出来て\n俺は幸せ者です",
      "startTime": 78.4333372591,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_rioroom-00-night.webp",
      "bgName": "rioroom-00-night",
      "startTime": 86.5000039258
    },
    {
      "type": "dialogue",
      "speakerCode": "rio",
      "speakerName": "神崎莉央",
