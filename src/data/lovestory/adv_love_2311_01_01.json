    },
    {
      "type": "choice_selection",
      "choices": [
        {
          "text": "妹が出来た渚を祝福する",
          "route": [
            {
              "type": "dialogue",
              "speakerCode": "koh",
              "speakerName": "{user}",
              "speakerNameEn": "{user}",
              "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-kohei.png",
              "voiceUrl": "https://apiip.dasewasia.my.id/loveStoryVoice/sud_vo_adv_love_2311_01_01/sud_vo_adv_love_2311_01_01-koh009.m4a",
              "text": "そういえば前に、妹がほしいって\n言ってたよな？\nおめでとう、渚！",
              "translations": {
                "en": "You said before that you wanted\na younger sister‚ right?\nCongratulations‚ Nagisa!",
                "id": ""
              },
              "startTime": 153.4568850124,
              "sfxList": []
            }
          ]
        },
        {
          "text": "姉が出来たすみれを祝福する",
          "route": [
            {
              "type": "dialogue",
              "speakerCode": "koh",
              "speakerName": "{user}",
              "speakerNameEn": "{user}",
              "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-kohei.png",
              "voiceUrl": "https://apiip.dasewasia.my.id/loveStoryVoice/sud_vo_adv_love_2311_01_01/sud_vo_adv_love_2311_01_01-koh010.m4a",
              "text": "おめでとう、すみれ\nお姉ちゃんが出来たな",
              "translations": {
                "en": "Congratulations‚ Sumire.\nYou have an older sister now.",
                "id": ""
              },
              "startTime": 159.4238694275,
              "sfxList": []
            }
          ]
        }
      ]
    },
    {
      "type": "choice_selection",
      "choices": [
        {
          "text": "可愛いと思う",
          "route": [
            {
              "type": "dialogue",
              "speakerCode": "koh",
              "speakerName": "{user}",
              "speakerNameEn": "{user}",
              "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-kohei.png",
              "voiceUrl": "https://apiip.dasewasia.my.id/loveStoryVoice/sud_vo_adv_love_2311_01_01/sud_vo_adv_love_2311_01_01-koh014.m4a",
              "text": "そりゃまぁ、可愛いとは思うけど",
              "translations": {
                "en": "Well‚ yeah‚\nI guess she is cute‚ but…",
                "id": ""
              },
              "startTime": 231.5643571462,
              "sfxList": [
                {
                  "src": "https://apiip.dasewasia.my.id/storyBgm/sud_se_adv_walk-in-single-02.m4a",
                  "delay": 0
                }
              ]
            },
            {
              "type": "bgm",
              "action": "play",
              "src": "https://apiip.dasewasia.my.id/storyBgm/sud_bgm_adv_pretty-01.m4a",
              "startTime": 235.4650442686
            },
            {
              "type": "dialogue",
              "speakerCode": "ngs",
              "speakerName": "伊吹渚",
              "speakerNameEn": "Nagisa",
              "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-nagisa.png",
              "voiceUrl": "https://apiip.dasewasia.my.id/loveStoryVoice/sud_vo_adv_love_2311_01_01/sud_vo_adv_love_2311_01_01-ngs016.m4a",
              "text": "もう！　聞こえてるよ！\n{user}くんってば\n朝から何言ってるの！？",
              "translations": {
                "en": "Hey! I can hear you!\n{user}-kun‚\nwhat are you saying so\nin the early morning!?",
                "id": ""
              },
              "startTime": 235.4650442686,
              "sfxList": []
            },
            {
              "type": "dialogue",
              "speakerCode": "koh",
              "speakerName": "{user}",
              "speakerNameEn": "{user}",
              "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-kohei.png",
              "voiceUrl": "https://apiip.dasewasia.my.id/loveStoryVoice/sud_vo_adv_love_2311_01_01/sud_vo_adv_love_2311_01_01-koh015.m4a",
              "text": "え？　いや、俺は普通に……\n何をそんなに怒ることがあるんだよ？",
              "translations": {
                "en": "Eh? No‚ I was just…\nWhat's there to be so mad about?",
                "id": ""
              },
              "startTime": 240.6650442686,
              "sfxList": []
            },
            {
              "type": "dialogue",
              "speakerCode": "ngs",
              "speakerName": "伊吹渚",
              "speakerNameEn": "Nagisa",
              "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-nagisa.png",
              "voiceUrl": "https://apiip.dasewasia.my.id/loveStoryVoice/sud_vo_adv_love_2311_01_01/sud_vo_adv_love_2311_01_01-ngs017.m4a",
              "text": "べ、別に怒ってないよ！\n{user}くんが……\nか、可愛いとか言うから……",
              "translations": {
                "en": "I-I'm not mad! It's just that…\n{user}-kun…\ns-said I'm cute…",
                "id": ""
              },
              "startTime": 247.0740014162,
              "sfxList": []
            },
            {
              "type": "dialogue",
              "speakerCode": "unknown",
              "speakerName": "鈴木",
              "speakerNameEn": "Suzuki",
              "iconUrl": null,
              "voiceUrl": "https://apiip.dasewasia.my.id/loveStoryVoice/sud_vo_adv_love_2311_01_01/sud_vo_adv_love_2311_01_01-suzuki005.m4a",
              "text": "……二人とも、ほんとに仲いいな",
              "translations": {
                "en": "…You two are really close‚ huh?",
                "id": ""
              },
              "startTime": 254.2406680829,
              "sfxList": []
            }
          ]
        },
        {
          "text": "分からないと言う",
          "route": [
            {
              "type": "dialogue",
              "speakerCode": "koh",
              "speakerName": "{user}",
              "speakerNameEn": "{user}",
              "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-kohei.png",
              "voiceUrl": "https://apiip.dasewasia.my.id/loveStoryVoice/sud_vo_adv_love_2311_01_01/sud_vo_adv_love_2311_01_01-koh016.m4a",
              "text": "ずっと近くにいるから分からないんだよなぁ",
              "translations": {
                "en": "I guess I don't realize it because\nwe're always together.",
                "id": ""
              },
              "startTime": 261.0740054853,
              "sfxList": [
                {
                  "src": "https://apiip.dasewasia.my.id/storyBgm/sud_se_adv_walk-in-single-02.m4a",
                  "delay": 6325.963870199985
                }
              ]
            },
            {
              "type": "dialogue",
              "speakerCode": "koh",
              "speakerName": "{user}",
              "speakerNameEn": "{user}",
              "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-kohei.png",
              "voiceUrl": "https://apiip.dasewasia.my.id/loveStoryVoice/sud_vo_adv_love_2311_01_01/sud_vo_adv_love_2311_01_01-koh017.m4a",
              "text": "毎日見てると、可愛いとか可愛くないとか\nいまいち……え、渚？\nどうした……？",
              "translations": {
                "en": "Seeing her every day‚ I don't\nreally… know if she's cute\nor not… Huh? Nagisa?\nWhat's wrong…?",
                "id": ""
              },
              "startTime": 264.7075884588,
              "sfxList": []
            },
            {
              "type": "bgm",
              "action": "play",
              "src": "https://apiip.dasewasia.my.id/storyBgm/sud_bgm_adv_dangerous-01.m4a",
              "startTime": 273.0875205286
            },
            {
              "type": "dialogue",
              "speakerCode": "ngs",
              "speakerName": "伊吹渚",
              "speakerNameEn": "Nagisa",
              "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-nagisa.png",
              "voiceUrl": "https://apiip.dasewasia.my.id/loveStoryVoice/sud_vo_adv_love_2311_01_01/sud_vo_adv_love_2311_01_01-ngs018.m4a",
              "text": "もー、聞こえてるんだけどー！\nそういう話は私がいないとこでしてよ",
              "translations": {
                "en": "Geez‚ I can hear you!\nTalk about that kind of stuff\nwhen I'm not around!",
                "id": ""
              },
              "startTime": 273.0875205286,
              "sfxList": []
            },
            {
              "type": "dialogue",
              "speakerCode": "koh",
              "speakerName": "{user}",
              "speakerNameEn": "{user}",
              "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-kohei.png",
              "voiceUrl": "https://apiip.dasewasia.my.id/loveStoryVoice/sud_vo_adv_love_2311_01_01/sud_vo_adv_love_2311_01_01-koh018.m4a",
              "text": "……いててててて\nな、なんで突然頬を\nつねるんだよ！？",
              "translations": {
                "en": "…Ow‚ ow‚ ow!\nW-why are you suddenly\npinching my cheek!?",
                "id": ""
              },
              "startTime": 280.1208538619,
              "sfxList": [
                {
                  "src": "https://apiip.dasewasia.my.id/storyBgm/sud_se_adv_walk-in-single-02.m4a",
                  "delay": 9112.442723400021
                }
              ]
            },
            {
              "type": "dialogue",
              "speakerCode": "ngs",
              "speakerName": "伊吹渚",
              "speakerNameEn": "Nagisa",
              "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-nagisa.png",
              "voiceUrl": "https://apiip.dasewasia.my.id/loveStoryVoice/sud_vo_adv_love_2311_01_01/sud_vo_adv_love_2311_01_01-ngs019.m4a",
              "text": "どーせ、私は可愛くないですよっ！\n{user}くんのバカッ！",
              "translations": {
                "en": "I'm not cute anyway!\nYou idiot‚ {user}-kun!",
                "id": ""
              },
              "startTime": 284.7494255153,
              "sfxList": []
            },
            {
              "type": "dialogue",
              "speakerCode": "koh",
              "speakerName": "{user}",
              "speakerNameEn": "{user}",
              "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-kohei.png",
              "voiceUrl": "https://apiip.dasewasia.my.id/loveStoryVoice/sud_vo_adv_love_2311_01_01/sud_vo_adv_love_2311_01_01-koh019.m4a",
              "text": "って、おい、渚！\nはぁ、説明もなしか……",
              "translations": {
                "en": "Hey‚ Nagisa!\nSigh‚ without even explaining…",
                "id": ""
              },
              "startTime": 291.0827578314,
              "sfxList": []
            },
            {
              "type": "dialogue",
              "speakerCode": "unknown",
              "speakerName": "鈴木",
              "speakerNameEn": "Suzuki",
              "iconUrl": null,
              "voiceUrl": "https://apiip.dasewasia.my.id/loveStoryVoice/sud_vo_adv_love_2311_01_01/sud_vo_adv_love_2311_01_01-suzuki006.m4a",
              "text": "はは、もうちょっと考えて\n発言した方がいいな\n{user}は",
              "translations": {
                "en": "Haha‚ you should think\na little more before you speak.\n{user}…",
                "id": ""
              },
              "startTime": 297.5636649378,
              "sfxList": []
            }
          ]
        }
      ]
    },
    {
      "type": "dialogue",
      "speakerCode": "ngs",
      "speakerName": "？？？",
      "speakerNameEn": "？？？",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-nagisa.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/loveStoryVoice/sud_vo_adv_love_2311_01_01/sud_vo_adv_love_2311_01_01-ngs001.m4a",
      "text": "……ほら、朝だよ\n{user}くん、起きて？",
      "translations": {
        "en": "…Hey‚ it's morning.\n{user}-kun‚ wake up.",
        "id": ""
      },
      "startTime": 2.0333333731,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "koh",
      "speakerName": "{user}",
      "speakerNameEn": "{user}",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-kohei.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/loveStoryVoice/sud_vo_adv_love_2311_01_01/sud_vo_adv_love_2311_01_01-koh001.m4a",
      "text": "ん……んん……？",
      "translations": {
        "en": "Hmm…Nn…?",
        "id": ""
      },
      "startTime": 4.9333333731,
      "sfxList": []
    },
    {
      "type": "bgm",
      "action": "play",
      "src": "https://apiip.dasewasia.my.id/storyBgm/sud_bgm_adv_main-01.m4a",
      "startTime": 7.9730839651
    },
    {
      "type": "dialogue",
      "speakerCode": "ngs",
      "speakerName": "伊吹渚",
      "speakerNameEn": "Nagisa",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-nagisa.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/loveStoryVoice/sud_vo_adv_love_2311_01_01/sud_vo_adv_love_2311_01_01-ngs002.m4a",
      "text": "ふふ、おはよう",
      "translations": {
        "en": "Hehe‚ good morning.",
        "id": ""
      },
      "startTime": 8.9730840922,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "koh",
      "speakerName": "{user}",
      "speakerNameEn": "{user}",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-kohei.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/loveStoryVoice/sud_vo_adv_love_2311_01_01/sud_vo_adv_love_2311_01_01-koh002.m4a",
      "text": "ああ……渚か。おはよう\n毎日ごめんな",
      "translations": {
        "en": "Oh…Nagisa. Good morning.\nSorry for every morning.",
        "id": ""
      },
      "startTime": 11.5730840922,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_lovehroom-00-noon.webp",
      "bgName": "lovehroom",
      "startTime": 18.2547620536
    },
    {
      "type": "dialogue",
      "speakerCode": "ngs",
      "speakerName": "伊吹渚",
      "speakerNameEn": "Nagisa",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-nagisa.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/loveStoryVoice/sud_vo_adv_love_2311_01_01/sud_vo_adv_love_2311_01_01-ngs003.m4a",
      "text": "ほんとだよ、もう\n{user}くんが朝弱いのは\n全然変わんないよね",
      "translations": {
        "en": "Really‚ oh my.\nYou still have troubles\nwaking up early‚ {user}-kun.",
        "id": ""
      },
      "startTime": 18.2547620536,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_lovehroom-00-noon.webp",
      "bgName": "lovehroom",
      "startTime": 24.0880953869
    },
    {
      "type": "dialogue",
      "speakerCode": "ngs",
      "speakerName": "伊吹渚",
      "speakerNameEn": "Nagisa",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-nagisa.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/loveStoryVoice/sud_vo_adv_love_2311_01_01/sud_vo_adv_love_2311_01_01-ngs004.m4a",
      "text": "まったく、{user}くんは\n私がいないと本当にダメなんだから！\nほら、早く起きなさーい！",
      "translations": {
        "en": "Honestly‚ {user}-kun‚\nWhat would you do without me?\nCome on‚ get up now!",
        "id": ""
      },
      "startTime": 24.0880953869,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_lovehroom-00-noon.webp",
      "bgName": "lovehroom",
      "startTime": 31.9214287203
    },
    {
      "type": "dialogue",
      "speakerCode": "koh",
      "speakerName": "{user}",
      "speakerNameEn": "{user}",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-kohei.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/loveStoryVoice/sud_vo_adv_love_2311_01_01/sud_vo_adv_love_2311_01_01-koh003.m4a",
      "text": "なんでそんな嬉しそうなんだよ……\n言われなくても起きるって",
      "translations": {
        "en": "Why are you so happy about it…?\nI'll get up without being told.",
        "id": ""
      },
      "startTime": 31.9214287203,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "ngs",
      "speakerName": "伊吹渚",
      "speakerNameEn": "Nagisa",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-nagisa.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/loveStoryVoice/sud_vo_adv_love_2311_01_01/sud_vo_adv_love_2311_01_01-ngs005.m4a",
      "text": "あ、ここまた寝ぐせついてる～！\nいつもおんなじとこだよね\nふふ、可愛い",
      "translations": {
        "en": "Ah‚ your hair's messed up again!\nIt's always the same spot.\nHehe‚ cute.",
        "id": ""
      },
      "startTime": 36.8157550735,
      "sfxList": [
        {
          "src": "https://apiip.dasewasia.my.id/storyBgm/sud_se_adv_gasa-02.m4a",
          "delay": 8617.578259799999
        }
      ]
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_lovehroom-00-noon.webp",
      "bgName": "lovehroom",
      "startTime": 44.3824232263
    },
    {
      "type": "dialogue",
      "speakerCode": "koh",
      "speakerName": "{user}",
      "speakerNameEn": "{user}",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-kohei.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/loveStoryVoice/sud_vo_adv_love_2311_01_01/sud_vo_adv_love_2311_01_01-koh004.m4a",
      "text": "うわっ、ちょっと自分で直すから\n触るなよ……！",
      "translations": {
        "en": "Whoa‚ wait‚ I'll fix it myself.\nDon't touch…!",
        "id": ""
      },
      "startTime": 45.7490980707,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "ngs",
      "speakerName": "伊吹渚",
      "speakerNameEn": "Nagisa",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-nagisa.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/loveStoryVoice/sud_vo_adv_love_2311_01_01/sud_vo_adv_love_2311_01_01-ngs006.m4a",
      "text": "えー、遠慮しなくていいのに～\nほらほら、私が直してあげるから\nじっとしてて！",
      "translations": {
        "en": "Aw‚ don't be shy~!\nHere‚ here‚ I'll fix it for you.\nStay still!",
        "id": ""
      },
      "startTime": 49.1013685785,
      "sfxList": [
        {
          "src": "https://apiip.dasewasia.my.id/storyBgm/sud_se_adv_walk-living-single-01.m4a",
          "delay": 7666.665903800002
        }
      ]
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_lovehroom-00-noon.webp",
      "bgName": "lovehroom",
      "startTime": 56.6680344823
    },
    {
      "type": "dialogue",
      "speakerCode": "smr",
      "speakerName": "すみれ",
      "speakerNameEn": "Sumire",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-sumire.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/loveStoryVoice/sud_vo_adv_love_2311_01_01/sud_vo_adv_love_2311_01_01-smr001.m4a",
      "text": "おっはよー！　お兄ちゃん、起きた？\n……って、渚ちゃんが起こしてくれてる\nなら安心だね！",
      "translations": {
        "en": "Good morning~!\nBig brother‚ you up?\n…Oh‚ Nagisa-chan is waking you up.\nThen I'm relieved!",
        "id": ""
      },
      "startTime": 58.2013690872,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_lovehroom-00-noon.webp",
      "bgName": "lovehroom",
