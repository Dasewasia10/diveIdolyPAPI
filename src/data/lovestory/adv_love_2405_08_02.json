      "startTime": 19.6000015814,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "koh",
      "speakerName": "{user}",
      "speakerNameEn": "{user}",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-kohei.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/loveStoryVoice/sud_vo_adv_love_2405_08_02/sud_vo_adv_love_2405_08_02-koh004.m4a",
      "text": "ああ、怪我もすっかり治ったし\n最近は陸上も以前のタイムを\n取り戻せるようになってきたよ",
      "translations": {
        "en": "Yeah‚ my injury has completely\nhealed‚ and lately‚ I've been\ngetting back to my old track and\nfield times.",
