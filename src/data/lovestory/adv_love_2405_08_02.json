              },
              "startTime": 387.6000834705,
              "sfxList": []
            },
            {
              "type": "dialogue",
              "speakerCode": "koh",
              "speakerName": "{user}",
              "speakerNameEn": "{user}",
              "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-kohei.png",
              "voiceUrl": "https://apiip.dasewasia.my.id/loveStoryVoice/sud_vo_adv_love_2405_08_02/sud_vo_adv_love_2405_08_02-koh025.m4a",
              "text": "芽衣……ありがとう\nじゃあ、行こうか！",
