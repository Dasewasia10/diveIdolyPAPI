                }
              ]
            },
            {
              "type": "dialogue",
              "speakerCode": "smr",
              "speakerName": "すみれ",
              "speakerNameEn": "Sumire",
              "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-sumire.png",
              "voiceUrl": "https://apiip.dasewasia.my.id/loveStoryVoice/sud_vo_adv_love_2311_08_02/sud_vo_adv_love_2311_08_02-smr001.m4a",
              "text": "お兄ちゃん、やっほー！",
              "translations": {
                "en": "Hi‚ big brother~!",
                "id": ""
              },
              "startTime": 265.2666971199,
              "sfxList": []
            },
            {
              "type": "dialogue",
              "speakerCode": "koh",
              "speakerName": "{user}",
              "speakerNameEn": "{user}",
              "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-kohei.png",
              "voiceUrl": "https://apiip.dasewasia.my.id/loveStoryVoice/sud_vo_adv_love_2311_08_02/sud_vo_adv_love_2311_08_02-koh021.m4a",
              "text": "渚に……すみれ？\nどうして二人が一緒にいるんだ？",
              "translations": {
                "en": "Nagisa… Sumire-chan?\nWhy are you two together?",
                "id": ""
              },
              "startTime": 267.7333637866,
              "sfxList": []
            },
            {
              "type": "dialogue",
              "speakerCode": "ngs",
              "speakerName": "伊吹渚",
              "speakerNameEn": "Nagisa",
              "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-nagisa.png",
              "voiceUrl": "https://apiip.dasewasia.my.id/loveStoryVoice/sud_vo_adv_love_2311_08_02/sud_vo_adv_love_2311_08_02-ngs013.m4a",
              "text": "私ね、大学を卒業してからも\nすみれちゃんとは定期的に\n会ってたんだ",
              "translations": {
                "en": "You know‚ even after I graduated\nfrom university‚ I've been meeting\nwith Sumire-chan regularly.",
                "id": ""
              },
              "startTime": 272.7333637866,
              "sfxList": []
            },
            {
              "type": "dialogue",
              "speakerCode": "smr",
              "speakerName": "すみれ",
              "speakerNameEn": "Sumire",
              "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-sumire.png",
              "voiceUrl": "https://apiip.dasewasia.my.id/loveStoryVoice/sud_vo_adv_love_2311_08_02/sud_vo_adv_love_2311_08_02-smr002.m4a",
              "text": "二人がお別れした後、渚ちゃんが\nも～～～見てられないくらい\n落ち込んじゃってね",
              "translations": {
                "en": "After you two broke up‚\nNagisa-chan was soooo heartbroken‚\nit was painful to watch.",
                "id": ""
              },
              "startTime": 278.7333800626,
              "sfxList": []
            },
            {
              "type": "dialogue",
              "speakerCode": "ngs",
              "speakerName": "伊吹渚",
              "speakerNameEn": "Nagisa",
              "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-nagisa.png",
              "voiceUrl": "https://apiip.dasewasia.my.id/loveStoryVoice/sud_vo_adv_love_2311_08_02/sud_vo_adv_love_2311_08_02-ngs014.m4a",
              "text": "ちょ、ちょっとすみれちゃん！\nそういうのは言わなくていいから……！",
              "translations": {
                "en": "H-hey‚ Sumire-chan!\nYou don't have to say that…!",
                "id": ""
              },
              "startTime": 285.0333800626,
              "sfxList": []
            },
            {
              "type": "dialogue",
              "speakerCode": "smr",
              "speakerName": "すみれ",
              "speakerNameEn": "Sumire",
              "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-sumire.png",
              "voiceUrl": "https://apiip.dasewasia.my.id/loveStoryVoice/sud_vo_adv_love_2311_08_02/sud_vo_adv_love_2311_08_02-smr003.m4a",
              "text": "大丈夫、お兄ちゃんも酷かったから！",
              "translations": {
                "en": "It's okay‚\nbig brother was just as bad!",
                "id": ""
              },
              "startTime": 289.8334146493,
              "sfxList": []
            },
            {
              "type": "dialogue",
              "speakerCode": "koh",
              "speakerName": "{user}",
              "speakerNameEn": "{user}",
              "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-kohei.png",
              "voiceUrl": "https://apiip.dasewasia.my.id/loveStoryVoice/sud_vo_adv_love_2311_08_02/sud_vo_adv_love_2311_08_02-koh022.m4a",
              "text": "お、おい、すみれ……！\nその、なんだ……俺も渚も、すみれに\nかなり世話になったみたいだな",
              "translations": {
                "en": "H-hey‚ Sumire…! So‚ um…\nit seems both Nagisa and I\nowe Sumire a lot.",
                "id": ""
              },
              "startTime": 293.7667276376,
              "sfxList": []
            },
            {
              "type": "dialogue",
              "speakerCode": "ngs",
              "speakerName": "伊吹渚",
              "speakerNameEn": "Nagisa",
              "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-nagisa.png",
              "voiceUrl": "https://apiip.dasewasia.my.id/loveStoryVoice/sud_vo_adv_love_2311_08_02/sud_vo_adv_love_2311_08_02-ngs015.m4a",
              "text": "あはは、そうみたいだね\nとにかく……私はすみれちゃんの\nおかげで、すっかり元気になれたんだ",
              "translations": {
                "en": "Ahaha‚ it seems that way.\nAnyway… thanks to Sumire-chan‚\nI'm completely better now.",
                "id": ""
              },
              "startTime": 304.0000507984,
              "sfxList": []
            },
            {
              "type": "dialogue",
              "speakerCode": "ngs",
              "speakerName": "伊吹渚",
              "speakerNameEn": "Nagisa",
              "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-nagisa.png",
              "voiceUrl": "https://apiip.dasewasia.my.id/loveStoryVoice/sud_vo_adv_love_2311_08_02/sud_vo_adv_love_2311_08_02-ngs016.m4a",
              "text": "だから……今日はその近況報告が\nしたくて",
              "translations": {
                "en": "So… I wanted to tell you\nhow I'm doing.",
                "id": ""
              },
              "startTime": 313.4000507984,
              "sfxList": []
            },
            {
              "type": "dialogue",
              "speakerCode": "koh",
              "speakerName": "{user}",
              "speakerNameEn": "{user}",
              "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-kohei.png",
              "voiceUrl": "https://apiip.dasewasia.my.id/loveStoryVoice/sud_vo_adv_love_2311_08_02/sud_vo_adv_love_2311_08_02-koh023.m4a",
              "text": "なるほど、そういうことだったのか\nすみれ……ありがとな",
              "translations": {
                "en": "I see‚ so that's what happened.\nThank you… Sumire.",
                "id": ""
              },
              "startTime": 317.3333983732,
              "sfxList": []
            },
            {
              "type": "dialogue",
              "speakerCode": "smr",
              "speakerName": "すみれ",
              "speakerNameEn": "Sumire",
              "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-sumire.png",
              "voiceUrl": "https://apiip.dasewasia.my.id/loveStoryVoice/sud_vo_adv_love_2311_08_02/sud_vo_adv_love_2311_08_02-smr004.m4a",
              "text": "渚ちゃんは大切な友達なんだから\nこれくらいなんてことないよ！",
              "translations": {
                "en": "Nagisa-chan is my best friend‚\nso it's no problem at all!",
                "id": ""
              },
              "startTime": 324.0333983732,
              "sfxList": []
            },
            {
              "type": "bgm",
              "action": "stop",
              "startTime": 328.5668449713
            },
            {
              "type": "bgm",
              "action": "play",
              "src": "https://apiip.dasewasia.my.id/storyBgm/sud_bgm_adv_main-01.m4a",
              "startTime": 330.0334248218
            },
            {
              "type": "dialogue",
              "speakerCode": "ngs",
              "speakerName": "伊吹渚",
              "speakerNameEn": "Nagisa",
              "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-nagisa.png",
              "voiceUrl": "https://apiip.dasewasia.my.id/loveStoryVoice/sud_vo_adv_love_2311_08_02/sud_vo_adv_love_2311_08_02-ngs017.m4a",
              "text": "ねぇ、{user}くん\nこれからも……友達でいてくれる？",
              "translations": {
                "en": "Hey‚ {user}-kun‚\nwill you… stay friends with me?",
                "id": ""
              },
              "startTime": 330.0334248218,
              "sfxList": []
            },
            {
              "type": "dialogue",
              "speakerCode": "koh",
              "speakerName": "{user}",
              "speakerNameEn": "{user}",
              "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-kohei.png",
              "voiceUrl": "https://apiip.dasewasia.my.id/loveStoryVoice/sud_vo_adv_love_2311_08_02/sud_vo_adv_love_2311_08_02-koh024.m4a",
              "text": "ああ、もちろんだ\nお互いの道で……頑張っていこうな",
              "translations": {
                "en": "Yeah‚ of course.\nLet's do our best on our own paths.",
                "id": ""
              },
              "startTime": 334.8334451668,
              "sfxList": []
            },
            {
              "type": "dialogue",
              "speakerCode": "ngs",
              "speakerName": "伊吹渚",
              "speakerNameEn": "Nagisa",
              "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-nagisa.png",
