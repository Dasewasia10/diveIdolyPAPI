    },
    {
      "type": "dialogue",
      "speakerCode": "unknown",
      "speakerName": "司会者",
      "speakerNameEn": "Host",
      "iconUrl": null,
      "voiceUrl": null,
      "text": "それじゃ次は……雫ちゃんに質問、いいですか？",
      "translations": {
        "en": "Alright‚ next up… Shizuku-chan‚ can I ask you a question?",
        "id": ""
