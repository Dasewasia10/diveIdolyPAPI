      "startTime": 60.63730150858563,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "unknown",
      "speakerName": "司会者",
      "speakerNameEn": "Host",
      "iconUrl": null,
      "voiceUrl": null,
      "text": "それじゃあ次は、千紗ちゃんに聞きたいんですが",
      "translations": {
        "en": "Now my next question is for Chisa-chan.",
        "id": ""
      },
      "startTime": 63.87063484191897,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_hoshistage-00-noon.webp",
      "bgName": "01-2d",
