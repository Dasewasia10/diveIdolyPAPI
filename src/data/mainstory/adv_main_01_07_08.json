      "bgName": "01-2d",
      "startTime": 40.83730150858561
    },
    {
      "type": "dialogue",
      "speakerCode": "unknown",
      "speakerName": "司会者",
      "speakerNameEn": "Host",
      "iconUrl": null,
      "voiceUrl": null,
      "text": "なるほど！ アイドルって憧れちゃいますもんね！",
      "translations": {
        "en": "I see! Idols truly are admirable‚ aren’t they?",
        "id": ""
      },
      "startTime": 40.83730150858561,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "unknown",
      "speakerName": "司会者",
      "speakerNameEn": "Host",
      "iconUrl": null,
      "voiceUrl": null,
      "text": "どういうところに憧れてました？",
      "translations": {
        "en": "What is about them that you admire?",
        "id": ""
      },
      "startTime": 44.803968175252294,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_hoshistage-00-noon.webp",
