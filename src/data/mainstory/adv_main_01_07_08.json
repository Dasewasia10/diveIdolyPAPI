      "bgName": "01-2d",
      "startTime": 60.63730150858563
    },
    {
      "type": "dialogue",
      "speakerCode": "unknown",
      "speakerName": "司会者",
      "speakerNameEn": "Host",
      "iconUrl": null,
      "voiceUrl": null,
      "text": "なるほどー、ありがとうございます！",
      "translations": {
        "en": "Interesting… Thank you for that answer!",
        "id": ""
