    },
    {
      "type": "dialogue",
      "speakerCode": "unknown",
      "speakerName": "司会者",
      "speakerNameEn": "Host",
      "iconUrl": null,
      "voiceUrl": null,
      "text": "凄いな～、怜ちゃんは何ごとにも真剣なんですね！",
      "translations": {
        "en": "Incredible‚ Rei-chan! You really throw yourself into everything you try!",
        "id": ""
      },
      "startTime": 5.966666666666667,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_hoshistage-00-noon.webp",
