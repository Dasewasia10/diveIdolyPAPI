      "type": "dialogue",
      "speakerCode": "unknown",
      "speakerName": "司会者",
      "speakerNameEn": "Host",
      "iconUrl": null,
      "voiceUrl": null,
      "text": "えっと、他にはありますか？",
      "translations": {
        "en": "Um‚ are there any other reasons?",
        "id": ""
      },
      "startTime": 35.203968175252285,
      "sfxList": []
    },
    {
      "type": "background",
