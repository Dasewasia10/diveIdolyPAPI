      "text": "いつも通りでいいんだからねっ",
      "translations": {
        "en": "Just be your usual self.",
        "id": ""
      },
      "startTime": 16.8053514401118,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_hoshistage-00-noon.webp",
      "bgName": "01-2d",
      "startTime": 19.20535141626994
    },
    {
      "type": "dialogue",
      "speakerCode": "szk",
      "speakerName": "兵藤雫",
      "speakerNameEn": "Shizuku",
