      "startTime": 102.12646241585428,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_hoshistage-00-noon.webp",
      "bgName": "01-2d",
      "startTime": 105.11458216477678
    },
