    },
    {
      "type": "dialogue",
      "speakerCode": "chs",
      "speakerName": "白石千紗",
      "speakerNameEn": "Chisa",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-chisa.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/mainStoryVoice/sud_vo_adv_main_01_07_08/sud_vo_adv_main_01_07_08-chs005.m4a",
      "text": "――きゃっ！ ご、ごめんなさい……",
      "translations": {
        "en": "Eeek! S-sorry…",
        "id": ""
      },
      "startTime": 108.28124883144348,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "koh",
      "speakerName": "{user}",
      "speakerNameEn": "{user}",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-kohei.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/mainStoryVoice/sud_vo_adv_main_01_07_08/sud_vo_adv_main_01_07_08-koh003.m4a",
      "text": "（千紗はいつもは普通に話せるけど）\n（ ステージ上だと極度に緊張してしまうんだな）",
      "translations": {
        "en": "（Chisa can usually have a normal conversation‚）\n（but she gets extremely nervous on stage.）",
