      "text": "…………キラキラ、してるとこ？",
      "translations": {
        "en": "…How sparkly they are?",
        "id": ""
      },
      "startTime": 47.13730150858562,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_hoshistage-00-noon.webp",
      "bgName": "01-2d",
      "startTime": 51.03730150858562
    },
    {
      "type": "dialogue",
      "speakerCode": "koh",
      "speakerName": "{user}",
      "speakerNameEn": "{user}",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-kohei.png",
