      "text": "――麻奈さんだったのかもしれません",
      "translations": {
        "en": "They might have even been Mana.",
        "id": ""
      },
      "startTime": 81.21092979907992,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_garden-00-night.webp",
      "bgName": "stage01",
