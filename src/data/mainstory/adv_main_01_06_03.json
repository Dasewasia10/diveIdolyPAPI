      "text": "はい……負けてしまいました……",
      "translations": {
        "en": "Yeah. I did…",
        "id": ""
      },
      "startTime": 48.53385498523711,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_garden-00-night.webp",
      "bgName": "stage01",
      "startTime": 51.90269854068755
    },
    {
      "type": "dialogue",
      "speakerCode": "koh",
      "speakerName": "{user}",
      "speakerNameEn": "{user}",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-kohei.png",
