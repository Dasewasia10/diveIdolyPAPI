      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-mana.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/mainStoryVoice/sud_vo_adv_main_01_06_03/sud_vo_adv_main_01_06_03-mna003.m4a",
      "text": "……",
      "translations": {
        "en": "…",
        "id": ""
