      "text": "負けちゃったか……",
      "translations": {
        "en": "You gave in to your curiosity.",
        "id": ""
      },
      "startTime": 46.84990944862365,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "ngs",
      "speakerName": "伊吹渚",
      "speakerNameEn": "Nagisa",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-nagisa.png",
