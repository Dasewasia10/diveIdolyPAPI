      "text": "琴乃、怒ったんじゃないのか？",
      "translations": {
        "en": "Did she get angry?",
        "id": ""
      },
      "startTime": 101,
      "sfxList": []
    },
    {
      "type": "bgm",
      "action": "play",
      "src": "https://apiip.dasewasia.my.id/storyBgm/sud_bgm_adv_heart-01.m4a",
      "startTime": 103.03333333333332
    },
    {
      "type": "dialogue",
      "speakerCode": "ngs",
      "speakerName": "伊吹渚",
      "speakerNameEn": "Nagisa",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-nagisa.png",
