      "text": "でも……何？",
      "translations": {
        "en": "But‚‚‚ what?",
        "id": ""
      },
      "startTime": 110.3113649845,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_gpstage-00-noon.webp",
      "bgName": "s1",
      "startTime": 112.7774874528
    },
