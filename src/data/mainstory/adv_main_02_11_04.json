      "text": "でもこうして吐き出して、すっきりしたんじゃないか？",
      "translations": {
        "en": "But by getting it all out like this‚ don't you feel better?",
        "id": ""
      },
      "startTime": 388.8,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "ktn",
      "speakerName": "長瀬琴乃",
      "speakerNameEn": "Kotono",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-kotono.png",
