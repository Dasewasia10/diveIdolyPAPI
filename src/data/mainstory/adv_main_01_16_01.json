      "bgName": "stage02",
      "startTime": 28.433333333333334
    },
    {
      "type": "dialogue",
      "speakerCode": "ngs",
      "speakerName": "伊吹渚",
      "speakerNameEn": "Nagisa",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-nagisa.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/mainStoryVoice/sud_vo_adv_main_01_16_01/sud_vo_adv_main_01_16_01-ngs002.m4a",
      "text": "麻奈さん、喜んでると思うよ。決勝で歌うよりも\nここから私達が、自分の力で進もうとする姿を見て",
      "translations": {
        "en": "I think Mana is very pleased. She may not have been able to sing at the finals‚\nbut I think watching us try to advance on our own merits pleases her even more.",
        "id": ""
      },
      "startTime": 32.93333333333333,
      "sfxList": []
    },
    {
      "type": "background",
