      "bgName": "gpstage-00-noon",
      "startTime": 52.4626095771
    },
    {
      "type": "dialogue",
      "speakerCode": "rui",
      "speakerName": "天動瑠依",
      "speakerNameEn": "Rui Tendo",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-rui.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/mainStoryVoice/sud_vo_adv_main_04_11_05/sud_vo_adv_main_04_11_05-rui004.m4a",
      "text": "TRINITYAiLEは\nこれからも遙かな高みに向かって飛び続けます！",
      "translations": {
        "en": "",
        "id": ""
      },
      "startTime": 54.2333351135,
      "sfxList": [
        {
          "src": "https://apiip.dasewasia.my.id/storyBgm/sud_se_adv_cheers-in-01.m4a",
