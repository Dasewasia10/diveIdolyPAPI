    {
      "type": "dialogue",
      "speakerCode": "host",
      "speakerName": "司会者",
      "speakerNameEn": "",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-host.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/mainStoryVoice/sud_vo_adv_main_04_11_05/sud_vo_adv_main_04_11_05-host005.m4a",
      "text": "優勝は叶わなかったものの、大会を大いに盛り上げて\nくれたアイドルのみなさんを特別賞として表彰致します",
      "translations": {
        "en": "",
        "id": ""
      },
      "startTime": 124.326557282,
      "sfxList": []
    },
