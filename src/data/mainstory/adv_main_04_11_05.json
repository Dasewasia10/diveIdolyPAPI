        }
      ]
    },
    {
      "type": "dialogue",
      "speakerCode": "rui",
      "speakerName": "天動瑠依",
      "speakerNameEn": "Rui Tendo",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-rui.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/mainStoryVoice/sud_vo_adv_main_04_11_05/sud_vo_adv_main_04_11_05-rui005.m4a",
      "text": "今後も感謝の気持ちを忘れずに、最高のステージを\nお見せします！　応援、ありがとうございました！",
      "translations": {
        "en": "",
        "id": ""
      },
      "startTime": 62.3333351135,
      "sfxList": []
    },
