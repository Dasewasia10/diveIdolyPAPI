      "voiceUrl": "https://apiip.dasewasia.my.id/mainStoryVoice/sud_vo_adv_main_01_13_02/sud_vo_adv_main_01_13_02-ngs001.m4a",
      "text": "終わったところだよ\nご飯食べて帰ってきたの",
      "translations": {
        "en": "We just finished.\nWe went out to dinner on the way back.",
        "id": ""
      },
      "startTime": 10.733333333333333,
      "sfxList": []
    },
    {
