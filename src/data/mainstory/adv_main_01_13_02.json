      "voiceUrl": "https://apiip.dasewasia.my.id/mainStoryVoice/sud_vo_adv_main_01_13_02/sud_vo_adv_main_01_13_02-mei001.m4a",
      "text": "焼き肉おいしかったーー",
      "translations": {
        "en": "The Korean BBQ was so yummy!",
        "id": ""
      },
      "startTime": 12.7,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "szk",
