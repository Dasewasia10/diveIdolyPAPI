      "startTime": 21.5,
      "sfxList": [
        {
          "src": "https://apiip.dasewasia.my.id/storyBgm/sud_se_adv_paper-01.m4a",
          "delay": 4660,
          "startTime": 24.76
        }
      ]
    },
    {
      "type": "dialogue",
      "speakerCode": "koh",
      "speakerName": "{user}",
      "speakerNameEn": "{user}",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-kohei.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/mainStoryVoice/sud_vo_adv_main_01_13_02/sud_vo_adv_main_01_13_02-koh002.m4a",
      "text": "……なっ……た、高いっ！\n特上ばかり頼んだんだろ……",
      "translations": {
        "en": "I-it’s so… expensive!\nYou must’ve ordered all the specials!",
        "id": ""
      },
      "startTime": 28.066666666666666,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "suz",
      "speakerName": "成宮すず",
      "speakerNameEn": "Suzu",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-suzu.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/mainStoryVoice/sud_vo_adv_main_01_13_02/sud_vo_adv_main_01_13_02-suz003.m4a",
      "text": "小さいこと言うんじゃありませんわ",
      "translations": {
        "en": "Don’t bicker over such trivial things.",
        "id": ""
      },
      "startTime": 30.4,
      "sfxList": []
