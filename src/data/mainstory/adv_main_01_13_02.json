      "speakerName": "佐伯遙子",
      "speakerNameEn": "Haruko",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-haruko.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/mainStoryVoice/sud_vo_adv_main_01_13_02/sud_vo_adv_main_01_13_02-hrk001.m4a",
      "text": "どうしたの？\n今日はみんなで祝勝会じゃなかったの？",
      "translations": {
        "en": "What’s up?\nWeren’t you all going to have a victory party today?",
        "id": ""
      },
      "startTime": 5.833333333333333,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "ngs",
      "speakerName": "伊吹渚",
