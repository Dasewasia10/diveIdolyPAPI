      "text": "あなた達も頑張りなさい",
      "translations": {
        "en": "You sing your hearts out‚ too‚ girls.",
        "id": ""
      },
      "startTime": 18,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "suz",
      "speakerName": "成宮すず",
      "speakerNameEn": "Suzu",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-suzu.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/mainStoryVoice/sud_vo_adv_main_01_13_02/sud_vo_adv_main_01_13_02-suz002.m4a",
      "text": "勝ったら、{user}さんが\nおごってくれるって言ってましたわよ。はい、領収書",
      "translations": {
        "en": "If you win‚ {user} said\nthat he’ll treat you to dinner. Here’s the bill.",
        "id": ""
