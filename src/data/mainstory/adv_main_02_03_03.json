      "iconUrl": null,
      "voiceUrl": null,
      "text": "――合宿当日",
      "translations": {
        "en": "――First day of bootcamp",
        "id": ""
      },
      "startTime": 0,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_dormitory-00-noon.webp",
      "bgName": "bg1",
