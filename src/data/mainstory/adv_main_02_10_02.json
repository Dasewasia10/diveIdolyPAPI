      "startTime": 97.9666666667
    },
    {
      "type": "dialogue",
      "speakerCode": "smr",
      "speakerName": "奥山すみれ",
      "speakerNameEn": "Sumire",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-sumire.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/mainStoryVoice/sud_vo_adv_main_02_10_02/sud_vo_adv_main_02_10_02-smr005.m4a",
      "text": "え？　瑠依ちゃん、何か用事？",
      "translations": {
        "en": "Huh? You’ve got somewhere to be‚ Rui?",
        "id": ""
      },
      "startTime": 97.9666666667,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_festivalseat-00-noon.webp",
      "bgName": "festivalseat-00-noon",
      "startTime": 101.4
    },
    {
      "type": "dialogue",
      "speakerCode": "rui",
      "speakerName": "天動瑠依",
      "speakerNameEn": "Rui",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-rui.png",
