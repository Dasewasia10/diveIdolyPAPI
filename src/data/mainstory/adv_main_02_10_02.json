    {
      "type": "dialogue",
      "speakerCode": "smr",
      "speakerName": "奥山すみれ",
      "speakerNameEn": "Sumire",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-sumire.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/mainStoryVoice/sud_vo_adv_main_02_10_02/sud_vo_adv_main_02_10_02-smr004.m4a",
      "text": "うん、そうだよね！　頑張ろうね、二人とも！\n……瑠依ちゃん、どうしたの？",
      "translations": {
        "en": "Yeah‚ I agree! Let’s do our best‚ Yu‚ Rui!\nRui‚ what’s the matter?",
        "id": ""
      },
      "startTime": 92.2,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "rui",
      "speakerName": "天動瑠依",
      "speakerNameEn": "Rui",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-rui.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/mainStoryVoice/sud_vo_adv_main_02_10_02/sud_vo_adv_main_02_10_02-rui005.m4a",
      "text": "ごめん、二人は先に帰っててくれる？",
      "translations": {
        "en": "Sorry‚ could you two head back first?",
        "id": ""
      },
      "startTime": 94.6,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_festivalseat-00-noon.webp",
