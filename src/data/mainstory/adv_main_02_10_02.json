      "text": "勝者、ⅢX！",
      "translations": {
        "en": "The winner is IIIX!!",
        "id": ""
      },
      "startTime": 34.33333,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "yu",
