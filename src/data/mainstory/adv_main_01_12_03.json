      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-mei.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/mainStoryVoice/sud_vo_adv_main_01_12_03/sud_vo_adv_main_01_12_03-mei003.m4a",
      "text": "本当？",
      "translations": {
        "en": "Really?",
        "id": ""
