    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_shed-00-night.webp",
      "bgName": "01-2d",
      "startTime": 103.4
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_shed-00-night.webp",
      "bgName": "01-2d",
      "startTime": 105.83333333333333
    },
    {
      "type": "dialogue",
      "speakerCode": "mna",
      "speakerName": "長瀬麻奈",
      "speakerNameEn": "Mana",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-mana.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/mainStoryVoice/sud_vo_adv_main_01_12_03/sud_vo_adv_main_01_12_03-mna010.m4a",
      "text": "芽衣ちゃん、また、遊んじゃう？",
      "translations": {
        "en": "Hi‚ Mei! Wanna play games again?",
        "id": ""
      },
      "startTime": 105.83333333333333,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "mei",
      "speakerName": "早坂芽衣",
