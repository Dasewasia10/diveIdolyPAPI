    {
      "type": "dialogue",
      "speakerCode": "koh",
      "speakerName": "{user}",
      "speakerNameEn": "{user}",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-kohei.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/mainStoryVoice/sud_vo_adv_main_01_12_03/sud_vo_adv_main_01_12_03-koh011.m4a",
      "text": "芽衣か……どうしたんだ、こんな時間に",
      "translations": {
        "en": "Hi‚ Mei. What brings you here this late?",
        "id": ""
      },
      "startTime": 100.3,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "mei",
      "speakerName": "早坂芽衣",
      "speakerNameEn": "Mei",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-mei.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/mainStoryVoice/sud_vo_adv_main_01_12_03/sud_vo_adv_main_01_12_03-mei002.m4a",
