      "voiceUrl": "https://apiip.dasewasia.my.id/mainStoryVoice/sud_vo_adv_main_01_14_05/sud_vo_adv_main_01_14_05-mna003.m4a",
      "text": "体って？",
      "translations": {
        "en": "My health?",
        "id": ""
      },
      "startTime": 35.07714269955953,
      "sfxList": []
    },
    {
