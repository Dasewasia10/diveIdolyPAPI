      "voiceUrl": "https://apiip.dasewasia.my.id/mainStoryVoice/sud_vo_adv_main_01_14_05/sud_vo_adv_main_01_14_05-koh005.m4a",
      "text": "あ、いや……\nそれより、体はどうなんだ？",
      "translations": {
        "en": "Oh‚ uh…\nAnyway‚ how’s your health?",
        "id": ""
      },
      "startTime": 32.4434919198354,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "mna",
      "speakerName": "長瀬麻奈",
