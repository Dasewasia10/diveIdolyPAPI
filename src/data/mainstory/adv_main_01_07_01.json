      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-wmob1.png",
      "voiceUrl": null,
      "text": "もしかして、貴方がすずをそそのかした――",
      "translations": {
        "en": "Wait‚ are you the charlatan who tricked my Suzu?",
        "id": ""
