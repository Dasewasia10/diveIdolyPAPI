  "script": [
    {
      "type": "bgm",
      "action": "play",
      "src": "https://apiip.dasewasia.my.id/storyBgm/sud_bgm_adv_hoshimi-01.m4a",
      "startTime": 0
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_schoolclass-00-night.webp",
      "bgName": "s1",
      "startTime": 0
    },
    {
      "type": "dialogue",
      "speakerCode": "ktn",
      "speakerName": "長瀬琴乃",
      "speakerNameEn": "Kotono",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-kotono.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/mainStoryVoice/sud_vo_adv_main_03_12_01/sud_vo_adv_main_03_12_01-ktn001.m4a",
      "text": "すみません、もうすっかり夜になっちゃいましたね",
      "translations": {
        "en": "Sorry‚ it’s gotten completely dark‚ hasn’t it?",
        "id": ""
      },
      "startTime": 0.8,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "koh",
      "speakerName": "{user}",
      "speakerNameEn": "{user}",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-kohei.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/mainStoryVoice/sud_vo_adv_main_03_12_01/sud_vo_adv_main_03_12_01-koh001.m4a",
      "text": "気にしなくていいよ\n今の琴乃にとって必要な時間なんだろう？",
      "translations": {
        "en": "Don’t worry about it‚\nIt’s probably time you needed‚ right‚ Kotono?",
        "id": ""
      },
      "startTime": 7.8666662852,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_schoolclass-00-night.webp",
      "bgName": "s1",
      "startTime": 10.9217683951
    },
    {
      "type": "dialogue",
      "speakerCode": "ktn",
      "speakerName": "長瀬琴乃",
      "speakerNameEn": "Kotono",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-kotono.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/mainStoryVoice/sud_vo_adv_main_03_12_01/sud_vo_adv_main_03_12_01-ktn002.m4a",
      "text": "……はい、ありがとうございます",
      "translations": {
        "en": "…Yes‚ thank you‚",
        "id": ""
      },
      "startTime": 10.9217683951,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_schoolclass-00-night.webp",
      "bgName": "s1",
      "startTime": 14.7754872481
    },
    {
      "type": "dialogue",
      "speakerCode": "ktn",
      "speakerName": "長瀬琴乃",
      "speakerNameEn": "Kotono",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-kotono.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/mainStoryVoice/sud_vo_adv_main_03_12_01/sud_vo_adv_main_03_12_01-ktn003.m4a",
      "text": "ここが、{user}さんと\nお姉ちゃんが過ごしてた教室……",
      "translations": {
        "en": "This is…the classroom where {user}-san\nwhere {user} and my sister spent their time…",
        "id": ""
      },
      "startTime": 16.9333329518,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "koh",
      "speakerName": "{user}",
      "speakerNameEn": "{user}",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-kohei.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/mainStoryVoice/sud_vo_adv_main_03_12_01/sud_vo_adv_main_03_12_01-koh002.m4a",
      "text": "そうだな。こうして来るのは久しぶりだな……",
      "translations": {
        "en": "That’s right‚ It’s been a while since I’ve come here…",
        "id": ""
      },
      "startTime": 19.5018589496,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": null,
      "speakerName": "",
      "speakerNameEn": "",
      "iconUrl": null,
      "voiceUrl": null,
      "text": "――数時間前",
      "translations": {
        "en": "――A few hours ago",
        "id": ""
      },
      "startTime": 24.598797655,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_office-01-noon.webp",
      "bgName": "env_adv_3d_office-01-000-noon",
      "startTime": 25.8254642645
    },
    {
      "type": "bgm",
      "action": "play",
      "src": "https://apiip.dasewasia.my.id/storyBgm/sud_bgm_adv_tokyo-01.m4a",
      "startTime": 25.9587975978
    },
    {
      "type": "dialogue",
      "speakerCode": "ktn",
      "speakerName": "長瀬琴乃",
      "speakerNameEn": "Kotono",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-kotono.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/mainStoryVoice/sud_vo_adv_main_03_12_01/sud_vo_adv_main_03_12_01-ktn004.m4a",
      "text": "{user}さん、お疲れ様です\nちょっと……お時間いただいてもいいですか？",
      "translations": {
        "en": "{user}-san‚ good work‚\nMay I have a moment of your time?",
        "id": ""
      },
      "startTime": 30.3333329518,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "ktn",
      "speakerName": "長瀬琴乃",
      "speakerNameEn": "Kotono",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-kotono.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/mainStoryVoice/sud_vo_adv_main_03_12_01/sud_vo_adv_main_03_12_01-ktn005.m4a",
      "text": "いろいろと考えていて……\n少し、話を聞いてもらいたいんです",
      "translations": {
        "en": "I’ve been thinking about a lot of things…\n…and I’d like to talk to you for a bit‚",
        "id": ""
      },
      "startTime": 36.7666662852,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "koh",
      "speakerName": "{user}",
      "speakerNameEn": "{user}",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-kohei.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/mainStoryVoice/sud_vo_adv_main_03_12_01/sud_vo_adv_main_03_12_01-koh003.m4a",
      "text": "もちろんだ。ちょうど今手が空いたところだったから",
      "translations": {
        "en": "Of course‚ I just finished up with work‚",
        "id": ""
      },
      "startTime": 40.2836513359,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "ktn",
      "speakerName": "長瀬琴乃",
      "speakerNameEn": "Kotono",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-kotono.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/mainStoryVoice/sud_vo_adv_main_03_12_01/sud_vo_adv_main_03_12_01-ktn006.m4a",
      "text": "ありがとうございます",
      "translations": {
        "en": "Thank you‚",
        "id": ""
      },
      "startTime": 43.9649663924,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "koh",
      "speakerName": "{user}",
      "speakerNameEn": "{user}",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-kohei.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/mainStoryVoice/sud_vo_adv_main_03_12_01/sud_vo_adv_main_03_12_01-koh004.m4a",
      "text": "（最近、琴乃達は「アイドルとは何か」という問いの）\n（答えを出すのにずっと悩んでいた。そのことだろうな）",
      "translations": {
        "en": "（Lately‚ Kotono and the others have been struggling to）\n（answer the question of “what is an idol?”‚ It’s probably about that‚）",
        "id": ""
      },
      "startTime": 49.7333329518,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "koh",
      "speakerName": "{user}",
      "speakerNameEn": "{user}",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-kohei.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/mainStoryVoice/sud_vo_adv_main_03_12_01/sud_vo_adv_main_03_12_01-koh005.m4a",
      "text": "（簡単に答えが出るようなものではないことは分かって）\n（いるけど……琴乃の中で何か見つかったんだろうか）",
      "translations": {
        "en": "（I know it’s not something that can be answered easily‚ but…）\n（…has Kotono found something?）",
        "id": ""
      },
      "startTime": 56.9333329518,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "koh",
      "speakerName": "{user}",
      "speakerNameEn": "{user}",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-kohei.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/mainStoryVoice/sud_vo_adv_main_03_12_01/sud_vo_adv_main_03_12_01-koh006.m4a",
      "text": "話はどこでする？　ここでもいいし\nカフェに移動してもいいけど",
      "translations": {
        "en": "Where do you want to talk? We can do it here‚\nor we can move to a cafe‚",
        "id": ""
      },
      "startTime": 64.0999996185,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "ktn",
      "speakerName": "長瀬琴乃",
      "speakerNameEn": "Kotono",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-kotono.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/mainStoryVoice/sud_vo_adv_main_03_12_01/sud_vo_adv_main_03_12_01-ktn007.m4a",
      "text": "いえ……ちょっと、行きたい場所があるんです\n星見高校に……お姉ちゃんに会いに行きたくて",
      "translations": {
        "en": "No…there’s somewhere I want to go‚\nI want to go to Hoshimi High School…to see my sister‚",
        "id": ""
      },
      "startTime": 71.8666662852,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_schoolclass-00-night.webp",
      "bgName": "s1",
      "startTime": 79.1317688224
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_schoolclass-00-night.webp",
      "bgName": "s1",
      "startTime": 79.1317688224
    },
    {
      "type": "bgm",
      "action": "play",
      "src": "https://apiip.dasewasia.my.id/storyBgm/sud_bgm_adv_flashback-01.m4a",
      "startTime": 79.3784366207
    },
    {
      "type": "dialogue",
      "speakerCode": "ktn",
      "speakerName": "長瀬琴乃",
      "speakerNameEn": "Kotono",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-kotono.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/mainStoryVoice/sud_vo_adv_main_03_12_01/sud_vo_adv_main_03_12_01-ktn008.m4a",
      "text": "{user}さんは……\nここで、お姉ちゃんと再会したんですよね",
      "translations": {
        "en": "{user}-san…\n…you reunited with my sister here‚ right?",
        "id": ""
      },
      "startTime": 82.0666662852,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_schoolclass-00-night.webp",
      "bgName": "s1",
      "startTime": 84.8923831223
    },
    {
      "type": "dialogue",
      "speakerCode": "koh",
      "speakerName": "{user}",
      "speakerNameEn": "{user}",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-kohei.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/mainStoryVoice/sud_vo_adv_main_03_12_01/sud_vo_adv_main_03_12_01-koh007.m4a",
      "text": "あぁ。事故からしばらく経った頃、麻奈はこの教室に\n突然現れて、それから琴乃やさくら達と出会って……",
      "translations": {
        "en": "Yeah‚ A while after the accident‚ Mana suddenly appeared in this classroom‚\nand then she met Kotono‚ Sakura-chan‚ and the others…",
        "id": ""
      },
      "startTime": 89.3453650712,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "koh",
      "speakerName": "{user}",
      "speakerNameEn": "{user}",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-kohei.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/mainStoryVoice/sud_vo_adv_main_03_12_01/sud_vo_adv_main_03_12_01-koh008.m4a",
      "text": "月ストやサニピが生まれ、みんなと一緒に泣いて\n笑って、そして――ここで、麻奈と別れたんだ",
      "translations": {
        "en": "Moon Tempest and Sunny Peace were born‚ we cried\nand laughed together‚ and then――here‚ we parted ways with Mana‚",
        "id": ""
      },
      "startTime": 98.4666662852,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_schoolclass-00-night.webp",
      "bgName": "s1",
      "startTime": 106.6999996185
    },
    {
      "type": "dialogue",
      "speakerCode": "mna",
      "speakerName": "長瀬麻奈",
      "speakerNameEn": "Mana",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-mana.png",
      "voiceUrl": null,
      "text": "変わらないなあ。あの頃と同じ顔してるよ",
      "translations": {
        "en": "You haven’t changed‚ You have the same face as back then‚",
        "id": ""
      },
      "startTime": 107.735283176,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "mna",
      "speakerName": "長瀬麻奈",
      "speakerNameEn": "Mana",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-mana.png",
      "voiceUrl": null,
      "text": "{user}くん",
      "translations": {
        "en": "{user}",
        "id": ""
      },
      "startTime": 112.7333329518,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "koh",
      "speakerName": "{user}",
      "speakerNameEn": "{user}",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-kohei.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/mainStoryVoice/sud_vo_adv_main_03_12_01/sud_vo_adv_main_03_12_01-koh009.m4a",
      "text": "…………もう、大人だよ",
      "translations": {
        "en": "…………I’m an adult now‚",
        "id": ""
      },
      "startTime": 114.0117885826,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "mna",
      "speakerName": "長瀬麻奈",
      "speakerNameEn": "Mana",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-mana.png",
      "voiceUrl": null,
      "text": "そんなことないよ",
      "translations": {
        "en": "That’s not true‚",
        "id": ""
      },
      "startTime": 116.6072309094,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_schoolclass-00-night.webp",
      "bgName": "s1",
      "startTime": 116.6072309094
    },
    {
      "type": "dialogue",
      "speakerCode": "mna",
      "speakerName": "長瀬麻奈",
      "speakerNameEn": "Mana",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-mana.png",
      "voiceUrl": null,
      "text": "純粋で、一生懸命で、真面目で……",
      "translations": {
        "en": "You’re pure‚ hardworking‚ serious…",
        "id": ""
      },
      "startTime": 119.2333370208,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "mna",
      "speakerName": "長瀬麻奈",
      "speakerNameEn": "Mana",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-mana.png",
      "voiceUrl": null,
      "text": "良かった",
      "translations": {
        "en": "――I’m glad‚",
        "id": ""
      },
      "startTime": 123.9472347496,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "mna",
      "speakerName": "長瀬麻奈",
      "speakerNameEn": "Mana",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-mana.png",
      "voiceUrl": null,
      "text": "{user}くんを好きになって",
      "translations": {
        "en": "I’m glad I fell in love with you‚ {user}‚",
        "id": ""
      },
      "startTime": 127.1666744232,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_schoolclass-00-night.webp",
      "bgName": "s1",
      "startTime": 129.0472347496
    },
    {
      "type": "dialogue",
      "speakerCode": "koh",
      "speakerName": "{user}",
      "speakerNameEn": "{user}",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-kohei.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/mainStoryVoice/sud_vo_adv_main_03_12_01/sud_vo_adv_main_03_12_01-koh010.m4a",
      "text": "………………えっ？",
      "translations": {
        "en": "…………Huh?",
        "id": ""
      },
      "startTime": 129.5333329518,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_schoolclass-00-night.webp",
      "bgName": "s1",
      "startTime": 131.7806165931
    },
    {
      "type": "dialogue",
      "speakerCode": "mna",
      "speakerName": "長瀬麻奈",
      "speakerNameEn": "Mana",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-mana.png",
      "voiceUrl": null,
      "text": "本当にダメダメだね",
      "translations": {
        "en": "You’re really hopeless‚",
        "id": ""
      },
      "startTime": 131.7806165931,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "mna",
      "speakerName": "長瀬麻奈",
      "speakerNameEn": "Mana",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-mana.png",
      "voiceUrl": null,
      "text": "もう少し早く気付いてたら……",
      "translations": {
        "en": "If I had realized a little sooner…",
        "id": ""
      },
      "startTime": 135.1000108083,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "mna",
      "speakerName": "長瀬麻奈",
      "speakerNameEn": "Mana",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-mana.png",
      "voiceUrl": null,
      "text": "……キスくらい、出来たかもよ",
      "translations": {
        "en": "…we might have at least kissed‚",
        "id": ""
      },
      "startTime": 137.9608842769,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_schoolclass-00-night.webp",
      "bgName": "s1",
      "startTime": 142.234214107
    },
    {
      "type": "dialogue",
      "speakerCode": "koh",
      "speakerName": "{user}",
      "speakerNameEn": "{user}",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-kohei.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/mainStoryVoice/sud_vo_adv_main_03_12_01/sud_vo_adv_main_03_12_01-koh011.m4a",
      "text": "あの頃のことが……\n今じゃ随分と懐かしく思えるよ",
      "translations": {
        "en": "That time…\n…seems like such a distant memory now‚",
        "id": ""
      },
      "startTime": 145.3686618489,
      "sfxList": []
    },
    {
      "type": "bgm",
      "action": "play",
      "src": "https://apiip.dasewasia.my.id/storyBgm/sud_bgm_adv_pop-01.m4a",
      "startTime": 148.0898729722
    },
    {
      "type": "dialogue",
      "speakerCode": "ktn",
      "speakerName": "長瀬琴乃",
      "speakerNameEn": "Kotono",
