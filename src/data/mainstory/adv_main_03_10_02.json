      "startTime": 209.6000040691,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "suz",
      "speakerName": "成宮すず",
      "speakerNameEn": "Suzu",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-suzu.png",
