      "speakerCode": "unknown",
      "speakerName": "司会者",
      "speakerNameEn": "Host",
      "iconUrl": null,
      "voiceUrl": null,
      "text": "あ……で、では、気を取り直して、どりきゅんの",
      "translations": {
        "en": "Ah… well then‚ let's change the mood and hear from DoriKyun…",
        "id": ""
