      "speakerNameEn": "Nagisa",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-nagisa.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/mainStoryVoice/sud_vo_adv_main_03_10_02/sud_vo_adv_main_03_10_02-ngs002.m4a",
      "text": "{user}さん……あの……",
      "translations": {
        "en": "Manager-san… um…",
        "id": ""
      },
      "startTime": 106.6447704039,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "koh",
      "speakerName": "{user}",
      "speakerNameEn": "{user}",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-kohei.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/mainStoryVoice/sud_vo_adv_main_03_10_02/sud_vo_adv_main_03_10_02-koh002.m4a",
      "text": "……俺との話は、後で構わない\nまずは今後どうしていくのか、五人で話し合ってほしい",
      "translations": {
        "en": "……We can talk later.\nI want you five to discuss what you're going to do from now on.",
        "id": ""
      },
      "startTime": 113.3333374024,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "koh",
      "speakerName": "{user}",
      "speakerNameEn": "{user}",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-kohei.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/mainStoryVoice/sud_vo_adv_main_03_10_02/sud_vo_adv_main_03_10_02-koh003.m4a",
      "text": "五人の結論を聞いた上で、俺の方で判断させてもらうよ",
      "translations": {
        "en": "I'll make a decision after hearing your conclusions.",
        "id": ""
      },
      "startTime": 117.4849066301,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_stagesleeves-00-noon.webp",
