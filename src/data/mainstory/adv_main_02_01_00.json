      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-satomi.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/mainStoryVoice/sud_vo_adv_main_02_01_00/sud_vo_adv_main_02_01_00-stm014.m4a",
      "text": "了解です！\nでは、ご説明しますね！",
      "translations": {
        "en": "Understood!\nWell then‚ let me explain!",
        "id": ""
      },
      "startTime": 181.73333333333332,
      "sfxList": []
    },
    {
      "type": "dialogue",
