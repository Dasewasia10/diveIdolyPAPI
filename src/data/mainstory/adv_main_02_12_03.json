      "text": "……お父さん、を……？\nでも、どうやって？",
      "translations": {
        "en": "…My father…?\nBut how?",
        "id": ""
      },
      "startTime": 239.6,
      "sfxList": []
    },
    {
      "type": "bgm",
      "action": "play",
      "src": "https://apiip.dasewasia.my.id/storyBgm/sud_bgm_adv_meeting-01.m4a",
      "startTime": 242
    },
    {
      "type": "dialogue",
