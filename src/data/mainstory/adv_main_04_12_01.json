      "src": "https://apiip.dasewasia.my.id/storyBgm/sud_bgm_adv_happy-01.m4a",
      "startTime": 152.1535724324
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_arenaseats-00-noon.webp",
      "bgName": "arenaseats-00-noon",
      "startTime": 152.1535724324
    },
    {
      "type": "dialogue",
      "speakerCode": "wmob1",
      "speakerName": "？？？",
      "speakerNameEn": "",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-wmob1.png",
      "voiceUrl": null,
      "text": "凄い……これがVENUSグランプリ……",
      "translations": {
        "en": "",
        "id": ""
      },
      "startTime": 153.0802944452,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "wmob1",
      "speakerName": "？？？",
      "speakerNameEn": "",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-wmob1.png",
      "voiceUrl": null,
      "text": "これが本物のアイドル……本物のサニーピース！",
      "translations": {
        "en": "",
        "id": ""
      },
      "startTime": 157.5999900819,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_arenaseats-00-noon.webp",
      "bgName": "arenaseats-00-noon",
      "startTime": 163.2664752326
    },
    {
      "type": "dialogue",
      "speakerCode": "wmob1",
      "speakerName": "？？？",
      "speakerNameEn": "",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-wmob1.png",
      "voiceUrl": null,
      "text": "思い切ってチケット買って正解だったよ",
      "translations": {
        "en": "",
        "id": ""
      },
      "startTime": 163.2664752326,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "wmob1",
      "speakerName": "？？？",
      "speakerNameEn": "",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-wmob1.png",
      "voiceUrl": null,
      "text": "配信もいいけど、やっぱり生で観るのは全然違うや",
      "translations": {
        "en": "",
        "id": ""
      },
      "startTime": 166.7556374484,
      "sfxList": [
        {
          "src": "https://apiip.dasewasia.my.id/storyBgm/sud_se_adv_cheers-in-01.m4a",
          "delay": 10111.017519900002,
          "startTime": 176.8666549683
        }
      ]
    },
    {
      "type": "dialogue",
      "speakerCode": "wmob1",
      "speakerName": "？？？",
      "speakerNameEn": "",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-wmob1.png",
      "voiceUrl": null,
      "text": "くぅ～！　体中にエネルギーが漲ってくる！",
      "translations": {
        "en": "",
        "id": ""
      },
      "startTime": 172.651622677,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "wmob1",
      "speakerName": "？？？",
      "speakerNameEn": "",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-wmob1.png",
      "voiceUrl": null,
      "text": "サニピの生ライブは、こんなに元気をもらえるんだ！",
      "translations": {
        "en": "",
        "id": ""
      },
      "startTime": 178.0666567486,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_arenaseats-00-noon.webp",
      "bgName": "arenaseats-00-noon",
      "startTime": 182.9163134258
    },
    {
      "type": "dialogue",
      "speakerCode": "wmob1",
      "speakerName": "？？？",
      "speakerNameEn": "",
