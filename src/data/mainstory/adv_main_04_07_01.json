      "text": "今日から一泊二日、朝倉さんと旅行してきなさい",
      "translations": {
        "en": "",
        "id": ""
      },
      "startTime": 0.8,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_station-00-noon.webp",
      "bgName": "env_adv_2d_station-00-noon",
