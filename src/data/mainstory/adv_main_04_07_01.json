    },
    {
      "type": "dialogue",
      "speakerCode": "unknown",
      "speakerName": "一同",
      "speakerNameEn": "",
      "iconUrl": null,
      "voiceUrl": null,
      "text": "……えええっ！？",
      "translations": {
        "en": "",
        "id": ""
      },
      "startTime": 5.2,
      "sfxList": []
    },
    {
      "type": "background",
