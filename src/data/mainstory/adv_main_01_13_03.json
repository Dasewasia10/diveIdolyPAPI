      "sfxList": []
    },
    {
      "type": "bgm",
      "action": "play",
      "src": "https://apiip.dasewasia.my.id/storyBgm/sud_bgm_adv_tears-01.m4a",
      "startTime": 135.36666666666667
    },
    {
      "type": "background",
