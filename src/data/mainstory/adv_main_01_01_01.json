        "en": "It's fine.\nNo one can see or hear me.",
        "id": ""
      },
      "startTime": 154.02223132467452,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "koh",
      "speakerName": "{user}",
