  "script": [
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_coast-00-noon.webp",
      "bgName": "stage01",
      "startTime": null
    },
    {
      "type": "bgm",
      "action": "play",
      "src": "https://apiip.dasewasia.my.id/storyBgm/sud_bgm_adv_trouble-01.m4a",
      "startTime": 0
    },
    {
      "type": "dialogue",
      "speakerCode": "koh",
      "speakerName": "{user}",
      "speakerNameEn": "{user}",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-kohei.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/mainStoryVoice/sud_vo_adv_main_01_05_02/sud_vo_adv_main_01_05_02-koh001.m4a",
      "text": "（さくら達は今の時間、この辺でランニングを）\n（しているはずだけど……）\n（あ、いたな）",
      "translations": {
        "en": "（Sakura’s group should be jogging）\n（somewhere around this area…）\n（Oh‚ there they are.）",
        "id": ""
      },
      "startTime": 5.9,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "skr",
      "speakerName": "川咲さくら",
      "speakerNameEn": "Sakura",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-sakura.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/mainStoryVoice/sud_vo_adv_main_01_05_02/sud_vo_adv_main_01_05_02-skr001.m4a",
      "text": "………………",
      "translations": {
        "en": "…",
        "id": ""
      },
      "startTime": 7.691133785247804,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "koh",
      "speakerName": "{user}",
      "speakerNameEn": "{user}",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-kohei.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/mainStoryVoice/sud_vo_adv_main_01_05_02/sud_vo_adv_main_01_05_02-koh002.m4a",
      "text": "？\n何かあったの？",
      "translations": {
        "en": "Huh?\nDid something happen?",
        "id": ""
      },
      "startTime": 11.657800451914472,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "chs",
      "speakerName": "白石千紗",
      "speakerNameEn": "Chisa",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-chisa.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/mainStoryVoice/sud_vo_adv_main_01_05_02/sud_vo_adv_main_01_05_02-chs001.m4a",
      "text": "あ、{user}さん……",
      "translations": {
        "en": "Oh‚ {user}-san…",
        "id": ""
      },
      "startTime": 12.991133785247806,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "koh",
      "speakerName": "{user}",
      "speakerNameEn": "{user}",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-kohei.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/mainStoryVoice/sud_vo_adv_main_01_05_02/sud_vo_adv_main_01_05_02-koh003.m4a",
      "text": "それは？",
      "translations": {
        "en": "What are those?",
        "id": ""
      },
      "startTime": 15.428956961631778,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "hrk",
      "speakerName": "佐伯遙子",
      "speakerNameEn": "Haruko",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-haruko.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/mainStoryVoice/sud_vo_adv_main_01_05_02/sud_vo_adv_main_01_05_02-hrk001.m4a",
      "text": "TRINITYAiLEの天動瑠依さんの\nダンスシューズよ",
      "translations": {
        "en": "They’re the dance shoes\nof Rui Tendo from TRINITYAiLE.",
        "id": ""
      },
      "startTime": 18.59183675050735,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "szk",
      "speakerName": "兵藤雫",
      "speakerNameEn": "Shizuku",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-shizuku.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/mainStoryVoice/sud_vo_adv_main_01_05_02/sud_vo_adv_main_01_05_02-szk001.m4a",
      "text": "昨日、東京のスタジオで練習していた時に\n置いていったみたいで…………",
      "translations": {
        "en": "Seems she forgot them at the studio in Tokyo\nyesterday after practice.",
        "id": ""
      },
      "startTime": 24.40941040913263,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "skr",
      "speakerName": "川咲さくら",
      "speakerNameEn": "Sakura",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-sakura.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/mainStoryVoice/sud_vo_adv_main_01_05_02/sud_vo_adv_main_01_05_02-skr002.m4a",
      "text": "私たちのシューズ、誰もこんなになっていない",
      "translations": {
        "en": "None of our shoes are in a state like this.",
        "id": ""
      },
      "startTime": 26.3,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "koh",
      "speakerName": "{user}",
      "speakerNameEn": "{user}",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-kohei.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/mainStoryVoice/sud_vo_adv_main_01_05_02/sud_vo_adv_main_01_05_02-koh004.m4a",
      "text": "……それは積み重ねだよ。これから練習していけば\nさくら達のシューズだって……",
      "translations": {
        "en": "They probably got worn out over time. If you girls keep practicing‚\nyour shoes will end up like that eventually—",
        "id": ""
      },
      "startTime": 34.573355925,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "skr",
      "speakerName": "川咲さくら",
      "speakerNameEn": "Sakura",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-sakura.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/mainStoryVoice/sud_vo_adv_main_01_05_02/sud_vo_adv_main_01_05_02-skr003.m4a",
      "text": "違うの。見つけた時、優さんとすみれさんが\n近くにいて教えてくれたんだ",
      "translations": {
        "en": "It’s not like that. You see‚ Yu-san and Sumire-san\nwere nearby when we found them‚ and they told us…",
        "id": ""
      },
      "startTime": 40.50668925841647,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_lesson-02-noon.webp",
      "bgName": "stage02",
      "startTime": 44.0400225917
    },
    {
      "type": "dialogue",
      "speakerCode": "skr",
      "speakerName": "川咲さくら",
      "speakerNameEn": "Sakura",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-sakura.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/mainStoryVoice/sud_vo_adv_main_01_05_02/sud_vo_adv_main_01_05_02-skr004.m4a",
      "text": "一週間？",
      "translations": {
        "en": "A week!",
        "id": ""
      },
      "startTime": 45.14002259174981,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "smr",
      "speakerName": "奥山すみれ",
      "speakerNameEn": "Sumire",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-sumire.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/mainStoryVoice/sud_vo_adv_main_01_05_02/sud_vo_adv_main_01_05_02-smr001.m4a",
      "text": "そう。瑠依ちゃんのシューズは\n新しく下ろして一週間でそうなっちゃうんです",
      "translations": {
        "en": "That’s right. Rui-chan’s shoes end up like that\nafter a week of using a new pair.",
        "id": ""
      },
      "startTime": 49.1967119097,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "yu",
      "speakerName": "鈴村優",
      "speakerNameEn": "Yu",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-yu.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/mainStoryVoice/sud_vo_adv_main_01_05_02/sud_vo_adv_main_01_05_02-yu001.m4a",
      "text": "瑠依ちゃんは、家でもずっと練習しとるからなあ",
      "translations": {
        "en": "Rui-chan practices all the time at home‚ you know.",
        "id": ""
      },
      "startTime": 52.46337857643761,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_coast-00-noon.webp",
      "bgName": "stage01",
      "startTime": 57.36337857643761
    },
    {
      "type": "dialogue",
      "speakerCode": "hrk",
      "speakerName": "佐伯遙子",
      "speakerNameEn": "Haruko",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-haruko.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/mainStoryVoice/sud_vo_adv_main_01_05_02/sud_vo_adv_main_01_05_02-hrk002.m4a",
      "text": "グランプリの優勝候補になるくらい凄いのに\n今でも毎日そんなに猛練習してるんだって……",
      "translations": {
        "en": "She’s one of the favorites to win the Grand Prix‚\nbut still‚ she practices non-stop every day.",
        "id": ""
      },
      "startTime": 62.2967119098,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "szk",
      "speakerName": "兵藤雫",
      "speakerNameEn": "Shizuku",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-shizuku.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/mainStoryVoice/sud_vo_adv_main_01_05_02/sud_vo_adv_main_01_05_02-szk002.m4a",
      "text": "だから、トップ……",
      "translations": {
        "en": "That’s why… she’s at the top.",
        "id": ""
      },
      "startTime": 65.83004524310428,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "skr",
      "speakerName": "川咲さくら",
      "speakerNameEn": "Sakura",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-sakura.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/mainStoryVoice/sud_vo_adv_main_01_05_02/sud_vo_adv_main_01_05_02-skr005.m4a",
      "text": "{user}さん。私達今のままじゃ\nダメですよね……何か変えないとダメですよね",
      "translations": {
        "en": "{user}-san‚ we can’t keep doing what we’re doing now.\nWe need to change something.",
        "id": ""
      },
      "startTime": 71.79671188592908,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "skr",
      "speakerName": "川咲さくら",
      "speakerNameEn": "Sakura",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-sakura.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/mainStoryVoice/sud_vo_adv_main_01_05_02/sud_vo_adv_main_01_05_02-skr006.m4a",
      "text": "どうすればいいと思いますか？",
      "translations": {
        "en": "What do you think we should do?",
        "id": ""
      },
      "startTime": 76.36337855259575,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "koh",
      "speakerName": "{user}",
      "speakerNameEn": "{user}",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-kohei.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/mainStoryVoice/sud_vo_adv_main_01_05_02/sud_vo_adv_main_01_05_02-koh005.m4a",
      "text": "……少しだけ時間をくれないか",
      "translations": {
        "en": "…Give me some time to think about it.",
        "id": ""
      },
      "startTime": 78.8300452192624,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "hrk",
      "speakerName": "佐伯遙子",
      "speakerNameEn": "Haruko",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-haruko.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/mainStoryVoice/sud_vo_adv_main_01_05_02/sud_vo_adv_main_01_05_02-hrk003.m4a",
      "text": "……",
      "translations": {
        "en": "…",
        "id": ""
      },
      "startTime": 81.6300452192624,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "koh",
      "speakerName": "{user}",
      "speakerNameEn": "{user}",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-kohei.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/mainStoryVoice/sud_vo_adv_main_01_05_02/sud_vo_adv_main_01_05_02-koh006.m4a",
      "text": "自分たちに何が足りなくて、どう努力していくのか\nそれを分からず漫然と流されていたら、すぐダメになる",
      "translations": {
        "en": "If you don’t know what you’re missing‚ how to improve‚\nor where you’re headed‚ you’ll only end up going backward.",
        "id": ""
      },
      "startTime": 86.8300452193,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "szk",
      "speakerName": "兵藤雫",
      "speakerNameEn": "Shizuku",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-shizuku.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/mainStoryVoice/sud_vo_adv_main_01_05_02/sud_vo_adv_main_01_05_02-szk003.m4a",
      "text": "……そういうアイドルもたくさんいる……",
      "translations": {
        "en": "There are plenty of idols like that.",
        "id": ""
      },
      "startTime": 90.66337855259576,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "koh",
      "speakerName": "{user}",
      "speakerNameEn": "{user}",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-kohei.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/mainStoryVoice/sud_vo_adv_main_01_05_02/sud_vo_adv_main_01_05_02-koh007.m4a",
      "text": "デビューする以上、トップを狙える可能性を持った\nグループであって欲しい。何が必要か考えてみる",
      "translations": {
        "en": "If you’re going to debut‚ I want you to have the potential as a group\nto reach the top. I’ll try to figure out what’s missing.",
        "id": ""
      },
      "startTime": 96.54015858570732,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "koh",
      "speakerName": "{user}",
      "speakerNameEn": "{user}",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-kohei.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/mainStoryVoice/sud_vo_adv_main_01_05_02/sud_vo_adv_main_01_05_02-koh008.m4a",
      "text": "（みんなはランニングに戻り、海に背を向けると）\n（人が立っていた。こちらをもの凄い目で睨んでいる）",
      "translations": {
        "en": "（The group continues on their jog‚ and I turn my back to the sea）\n（only to find someone standing there‚ glaring at me.）",
        "id": ""
      },
      "startTime": 104.4921042084,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "koh",
      "speakerName": "{user}",
      "speakerNameEn": "{user}",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-kohei.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/mainStoryVoice/sud_vo_adv_main_01_05_02/sud_vo_adv_main_01_05_02-koh009.m4a",
      "text": "……一ノ瀬怜！",
      "translations": {
        "en": "….Rei Ichinose!",
        "id": ""
      },
      "startTime": 108.653850154082,
      "sfxList": []
    },
    {
      "type": "bgm",
      "action": "play",
      "src": "https://apiip.dasewasia.my.id/storyBgm/sud_bgm_adv_dangerous-01.m4a",
      "startTime": 109.72051682074871
    },
    {
      "type": "dialogue",
      "speakerCode": "mna",
      "speakerName": "長瀬麻奈",
      "speakerNameEn": "Mana",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-mana.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/mainStoryVoice/sud_vo_adv_main_01_05_02/sud_vo_adv_main_01_05_02-mna001.m4a",
      "text": "あ～～～～あ、マズイね～",
      "translations": {
        "en": "Oooh… Not good.",
        "id": ""
      },
      "startTime": 110.43407686154048,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "koh",
      "speakerName": "{user}",
      "speakerNameEn": "{user}",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-kohei.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/mainStoryVoice/sud_vo_adv_main_01_05_02/sud_vo_adv_main_01_05_02-koh010.m4a",
      "text": "（まずい）\n（まさか、俺のことをまだ覗きだと思っているのか）",
      "translations": {
        "en": "（Not good at all.）\n（Does she still think I’m spying on her?）",
        "id": ""
      },
      "startTime": 115.0840768139,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "mna",
      "speakerName": "長瀬麻奈",
      "speakerNameEn": "Mana",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-mana.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/mainStoryVoice/sud_vo_adv_main_01_05_02/sud_vo_adv_main_01_05_02-mna002.m4a",
      "text": "早く彼女の所に行った方がいいんじゃない",
      "translations": {
        "en": "You should probably talk to her right away.",
        "id": ""
      },
      "startTime": 119.08407681385684,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "mna",
      "speakerName": "長瀬麻奈",
      "speakerNameEn": "Mana",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-mana.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/mainStoryVoice/sud_vo_adv_main_01_05_02/sud_vo_adv_main_01_05_02-mna003.m4a",
      "text": "放っておくと\n{user}くんのことみんなに話すよ",
      "translations": {
        "en": "If you wait‚ {user}‚\nshe might end up telling on you to everyone.",
        "id": ""
      },
      "startTime": 123.3902673523,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "koh",
      "speakerName": "{user}",
      "speakerNameEn": "{user}",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-kohei.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/mainStoryVoice/sud_vo_adv_main_01_05_02/sud_vo_adv_main_01_05_02-koh011.m4a",
      "text": "（三枝さんは信じてくれるだろうけど）\n（まだ知り合って日の浅いさくらや琴乃達は……）",
      "translations": {
        "en": "（I’m sure Saegusa-san would take my side‚）\n（but I’ve only recently gotten to know Sakura‚ Kotono‚ and the others.）",
        "id": ""
      },
      "startTime": 128.35693401892988,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_office-00-noon.webp",
      "bgName": "stage03",
      "startTime": 132.75693401893002
    },
    {
      "type": "dialogue",
      "speakerCode": "skr",
      "speakerName": "川咲さくら",
      "speakerNameEn": "Sakura",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-sakura.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/mainStoryVoice/sud_vo_adv_main_01_05_02/sud_vo_adv_main_01_05_02-skr007.m4a",
      "text": "最低",
      "translations": {
        "en": "You pervert.",
        "id": ""
      },
      "startTime": 133.82360068559677,
      "sfxList": []
    },
