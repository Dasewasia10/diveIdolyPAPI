      "speakerCode": null,
      "speakerName": "",
      "speakerNameEn": "",
      "iconUrl": null,
      "voiceUrl": null,
      "text": "――そして、練習会当日",
      "translations": {
        "en": "—Day of the mock tournament",
        "id": ""
      },
      "startTime": 239.2,
      "sfxList": []
