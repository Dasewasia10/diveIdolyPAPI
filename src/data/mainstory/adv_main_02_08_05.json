      "speakerName": "{user}",
      "speakerNameEn": "{user}",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-kohei.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/mainStoryVoice/sud_vo_adv_main_02_08_05/sud_vo_adv_main_02_08_05-koh005.m4a",
      "text": "（これで練習会の結果が）\n（いよいよ分からなくなってきたな）",
