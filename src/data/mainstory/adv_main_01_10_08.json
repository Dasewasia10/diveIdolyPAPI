      "voiceUrl": "https://apiip.dasewasia.my.id/mainStoryVoice/sud_vo_adv_main_01_10_08/sud_vo_adv_main_01_10_08-koh001.m4a",
      "text": "着替え中なんですけど",
      "translations": {
        "en": "Um‚ I’m getting dressed‚ you know.",
        "id": ""
      },
      "startTime": 3.8216779708862303,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "mna",
      "speakerName": "長瀬麻奈",
      "speakerNameEn": "Mana",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-mana.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/mainStoryVoice/sud_vo_adv_main_01_10_08/sud_vo_adv_main_01_10_08-mna002.m4a",
      "text": "気にしないよ\n{user}くんの着替えなんて",
      "translations": {
        "en": "I don’t mind.\nIt’s just you getting dressed.",
        "id": ""
      },
      "startTime": 7.348843510945637,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "koh",
