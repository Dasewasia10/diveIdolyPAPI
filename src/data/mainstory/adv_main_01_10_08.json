      "startTime": 60.36666666666667,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "wmob2",
      "speakerName": "看護師",
      "speakerNameEn": "Nurse",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-wmob2.png",
      "voiceUrl": null,
      "text": "元気そうで良かったわね",
      "translations": {
        "en": "Glad to see you’re looking so well.",
        "id": ""
      },
      "startTime": 65.53333333333333,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "wmob2",
      "speakerName": "看護師",
      "speakerNameEn": "Nurse",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-wmob2.png",
      "voiceUrl": null,
      "text": "今は芸能人なんでしょ？",
      "translations": {
        "en": "You’re a celebrity now‚ right?",
        "id": ""
      },
      "startTime": 68.53333333333333,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "wmob2",
      "speakerName": "看護師",
      "speakerNameEn": "Nurse",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-wmob2.png",
      "voiceUrl": null,
      "text": "この前、イベントに出てるところ、ちらっと見たよ",
      "translations": {
        "en": "I caught a glimpse of you at an event a little while ago.",
        "id": ""
      },
      "startTime": 71.03333333333333,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_hospital-02-noon.webp",
      "bgName": "2d-02",
      "startTime": 75.23333333333333
    },
    {
      "type": "dialogue",
