      "text": "ほんと？　ありがとう！",
      "translations": {
        "en": "Wow‚ really? Thanks!",
        "id": ""
      },
      "startTime": 75.23333333333333,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_hospital-02-noon.webp",
      "bgName": "2d-02",
