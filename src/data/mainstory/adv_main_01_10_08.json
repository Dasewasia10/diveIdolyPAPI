      "speakerNameEn": "Nurse",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-wmob2.png",
      "voiceUrl": null,
      "text": "あら、さくらちゃん。ホント、大きくなって……",
      "translations": {
        "en": "Well‚ if it isn’t little Sakura! Look how big you’ve grown.",
        "id": ""
