      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_dressingroom-00-noon.webp",
      "bgName": "bg1",
      "startTime": 84.4666666667
    },
    {
      "type": "dialogue",
      "speakerCode": "skr",
      "speakerName": "川咲さくら",
      "speakerNameEn": "Sakura",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-sakura.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/mainStoryVoice/sud_vo_adv_main_02_08_03/sud_vo_adv_main_02_08_03-skr001.m4a",
      "text": "あ、はい……！\nサニーピースの川咲さくらです！",
      "translations": {
        "en": "Uh‚ yes!\nI’m Sakura Kawasaki of Sunny Peace!",
        "id": ""
