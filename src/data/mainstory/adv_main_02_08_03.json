      "text": "は、はい！　そのつもりです！",
      "translations": {
        "en": "Y-yes! That’s the plan!",
        "id": ""
      },
      "startTime": 118.2,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_dressingroom-00-noon.webp",
      "bgName": "bg1",
