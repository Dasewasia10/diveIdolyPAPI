      "voiceUrl": "https://apiip.dasewasia.my.id/mainStoryVoice/sud_vo_adv_main_02_08_03/sud_vo_adv_main_02_08_03-skr003.m4a",
      "text": "え、えっと、その……せ、精一杯頑張ります！",
      "translations": {
        "en": "Uh‚ w-well… W-we’re going to try our best!",
        "id": ""
      },
      "startTime": 128.8666666667,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_dressingroom-00-noon.webp",
      "bgName": "bg1",
      "startTime": 135.3
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_dressingroom-00-noon.webp",
      "bgName": "bg1",
      "startTime": 140.1
    },
    {
      "type": "dialogue",
      "speakerCode": "mhk",
      "speakerName": "miho",
      "speakerNameEn": "miho",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-miho.png",
