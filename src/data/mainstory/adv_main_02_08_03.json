      "bgName": "bg1",
      "startTime": 67.8666666667
    },
    {
      "type": "dialogue",
      "speakerCode": "unknown",
      "speakerName": "姫野霧子",
      "speakerNameEn": "Kiriko",
      "iconUrl": null,
      "voiceUrl": null,
      "text": "星見プロさんの所属アイドルよ",
      "translations": {
        "en": "They’re idols signed with Hoshimi Productions.",
        "id": ""
      },
      "startTime": 67.8666666667,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "unknown",
      "speakerName": "姫野霧子",
      "speakerNameEn": "Kiriko",
      "iconUrl": null,
      "voiceUrl": null,
      "text": "写真付きの資料は渡してたはずよね。見てないの？",
      "translations": {
        "en": "I believe I gave you their files. Didn’t you read them?",
        "id": ""
      },
      "startTime": 70.2,
      "sfxList": []
