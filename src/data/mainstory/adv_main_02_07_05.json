          "startTime": 332.46666666666664
        }
      ]
    },
    {
      "type": "dialogue",
      "speakerCode": "rio",
      "speakerName": "神崎莉央",
      "speakerNameEn": "Rio",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-rio.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/mainStoryVoice/sud_vo_adv_main_02_07_05/sud_vo_adv_main_02_07_05-rio010.m4a",
      "text": "なるほど\nそれなら意図的に潰し合いを回避出来るわね",
      "translations": {
        "en": "I see.\nThat way‚ we can deliberately avoid taking each other out.",
        "id": ""
      },
      "startTime": 342.93333333333334,
      "sfxList": []
    },
    {
      "type": "dialogue",
