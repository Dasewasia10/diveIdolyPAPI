      "src": "https://apiip.dasewasia.my.id/storyBgm/sud_bgm_adv_moon-01.m4a",
      "startTime": 297.8090229507
    },
    {
      "type": "dialogue",
      "speakerCode": "ski",
      "speakerName": "白石沙季",
      "speakerNameEn": "Saki",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-saki.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/mainStoryVoice/sud_vo_adv_main_03_08_05/sud_vo_adv_main_03_08_05-ski013.m4a",
      "text": "なるほど。今の私達は図らずもグループ名の\nテンペストを表すパフォーマンスをしていた訳ですね",
      "translations": {
        "en": "I see. We’ve unwittingly been doing\nperformances that represent the tempest in our group name.",
        "id": ""
      },
      "startTime": 302,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "ngs",
      "speakerName": "伊吹渚",
      "speakerNameEn": "Nagisa",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-nagisa.png",
