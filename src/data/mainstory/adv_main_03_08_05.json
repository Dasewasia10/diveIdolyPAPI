      "text": "内なる野生……ワイルドな響きですわね！",
      "translations": {
        "en": "Inner wildness… It has a wild ring to it!",
        "id": ""
      },
      "startTime": 248.7821979042,
      "sfxList": []
    },
    {
      "type": "bgm",
      "action": "play",
      "src": "https://apiip.dasewasia.my.id/storyBgm/sud_bgm_adv_comical-01.m4a",
