    {
      "type": "sfx",
      "src": "https://apiip.dasewasia.my.id/storyBgm/sud_se_adv_cheers-out-01.m4a",
      "startTime": 0.6666666666666666
    },
    {
      "type": "dialogue",
      "speakerCode": "koh",
      "speakerName": "{user}",
      "speakerNameEn": "{user}",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-kohei.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/mainStoryVoice/sud_vo_adv_main_01_20_02/sud_vo_adv_main_01_20_02-koh001.m4a",
      "text": "（開演の数時間前だというのに、会場周辺は観客で）\n（溢れ返っていた。さくらや琴乃達に声援が飛んでくる）",
      "translations": {
        "en": "(Even though it’s hours before house doors open‚ the area around the venue)\n(is overflowing with fans. Some of them are calling out to Sakura‚ Kotono‚ and the others.)",
        "id": ""
      },
      "startTime": 4.7,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_outsidehall-00-noon.webp",
      "bgName": "stage01",
      "startTime": 4.7
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_outsidehall-00-noon.webp",
      "bgName": "stage01",
      "startTime": 9.726291351318356
    },
    {
      "type": "dialogue",
      "speakerCode": "skr",
      "speakerName": "川咲さくら",
      "speakerNameEn": "Sakura",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-sakura.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/mainStoryVoice/sud_vo_adv_main_01_20_02/sud_vo_adv_main_01_20_02-skr001.m4a",
      "text": "なんか凄いですね",
      "translations": {
        "en": "This feels kinda amazing.",
        "id": ""
      },
      "startTime": 9.733333333333333,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "chs",
      "speakerName": "白石千紗",
      "speakerNameEn": "Chisa",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-chisa.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/mainStoryVoice/sud_vo_adv_main_01_20_02/sud_vo_adv_main_01_20_02-chs001.m4a",
      "text": "す、スターみたい……",
      "translations": {
        "en": "I feel like a s-star.",
        "id": ""
      },
      "startTime": 12.192958017985026,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_outsidehall-00-noon.webp",
      "bgName": "stage01",
      "startTime": 15.026291351318326
    },
    {
      "type": "dialogue",
      "speakerCode": "suz",
      "speakerName": "成宮すず",
      "speakerNameEn": "Suzu",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-suzu.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/mainStoryVoice/sud_vo_adv_main_01_20_02/sud_vo_adv_main_01_20_02-suz001.m4a",
      "text": "みたいじゃなくて\n本当にスターになるのですわ",
      "translations": {
        "en": "You’re not “like a star.”\nWe really will become stars.",
        "id": ""
      },
      "startTime": 16.459624684651697,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_outsidehall-00-noon.webp",
      "bgName": "stage01",
      "startTime": 19.159624684651728
    },
    {
      "type": "dialogue",
      "speakerCode": "rei",
      "speakerName": "一ノ瀬怜",
      "speakerNameEn": "Rei",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-rei.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/mainStoryVoice/sud_vo_adv_main_01_20_02/sud_vo_adv_main_01_20_02-rei001.m4a",
      "text": "そうね。ここをきっかけに……",
      "translations": {
        "en": "True. This could be where it all begins.",
        "id": ""
      },
      "startTime": 19.166666666666668,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_outsidehall-00-noon.webp",
      "bgName": "stage01",
      "startTime": 22.19295801798503
    },
    {
      "type": "dialogue",
      "speakerCode": "hrk",
      "speakerName": "佐伯遙子",
      "speakerNameEn": "Haruko",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-haruko.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/mainStoryVoice/sud_vo_adv_main_01_20_02/sud_vo_adv_main_01_20_02-hrk001.m4a",
      "text": "……アイドル……みたい……",
      "translations": {
        "en": "I feel like… a real idol.",
        "id": ""
      },
      "startTime": 22.2,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "mei",
      "speakerName": "早坂芽衣",
      "speakerNameEn": "Mei",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-mei.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/mainStoryVoice/sud_vo_adv_main_01_20_02/sud_vo_adv_main_01_20_02-mei001.m4a",
      "text": "遙子ちゃん、泣いてる……",
      "translations": {
        "en": "Look. Haruko’s crying.",
        "id": ""
      },
      "startTime": 24.69295801798503,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_outsidehall-00-noon.webp",
      "bgName": "stage01",
      "startTime": 26.52629135131833
    },
    {
      "type": "dialogue",
      "speakerCode": "hrk",
      "speakerName": "佐伯遙子",
      "speakerNameEn": "Haruko",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-haruko.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/mainStoryVoice/sud_vo_adv_main_01_20_02/sud_vo_adv_main_01_20_02-hrk002.m4a",
      "text": "だって、ずっと憧れていたんだもん\nこういうの……",
      "translations": {
        "en": "Well‚ it’s been my lifelong dream.\nDoing this…",
        "id": ""
      },
      "startTime": 29.864264450967312,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_outsidehall-00-noon.webp",
      "bgName": "stage01",
      "startTime": 31.159624684651696
    },
    {
      "type": "dialogue",
      "speakerCode": "ngs",
      "speakerName": "伊吹渚",
      "speakerNameEn": "Nagisa",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-nagisa.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/mainStoryVoice/sud_vo_adv_main_01_20_02/sud_vo_adv_main_01_20_02-ngs001.m4a",
      "text": "もう何年も前からだもんね",
      "translations": {
        "en": "It’s been years for you‚ huh.",
        "id": ""
      },
      "startTime": 31.166666666666668,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "ktn",
      "speakerName": "長瀬琴乃",
      "speakerNameEn": "Kotono",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-kotono.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/mainStoryVoice/sud_vo_adv_main_01_20_02/sud_vo_adv_main_01_20_02-ktn001.m4a",
      "text": "お姉ちゃんがデビューする前から事務所にいたから\nええと……",
      "translations": {
        "en": "Since you were already signed at the agency before my sister’s debut‚\nUmm…",
        "id": ""
      },
      "startTime": 37.81148877166566,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "szk",
      "speakerName": "兵藤雫",
      "speakerNameEn": "Shizuku",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-shizuku.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/mainStoryVoice/sud_vo_adv_main_01_20_02/sud_vo_adv_main_01_20_02-szk001.m4a",
      "text": "三年、四年……",
      "translations": {
        "en": "Three… four years?",
        "id": ""
      },
      "startTime": 39.46334328333536,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_outsidehall-00-noon.webp",
      "bgName": "stage01",
      "startTime": 39.46334328333539
    },
    {
      "type": "dialogue",
      "speakerCode": "hrk",
      "speakerName": "佐伯遙子",
      "speakerNameEn": "Haruko",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-haruko.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/mainStoryVoice/sud_vo_adv_main_01_20_02/sud_vo_adv_main_01_20_02-hrk003.m4a",
      "text": "数えなくていいから",
      "translations": {
        "en": "You don’t need to count it!",
        "id": ""
      },
      "startTime": 42.333333333333336,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_outsidehall-00-noon.webp",
      "bgName": "stage01",
      "startTime": 42.34343404452005
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_livecorridor-00-noon.webp",
      "bgName": "stage02",
      "startTime": 45.53333333333333
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_livecorridor-00-noon.webp",
      "bgName": "stage02",
      "startTime": 45.53333333333333
    },
    {
      "type": "bgm",
      "action": "play",
      "src": "https://apiip.dasewasia.my.id/storyBgm/sud_bgm_adv_backstage-01.m4a",
      "startTime": 45.8
    },
    {
      "type": "dialogue",
      "speakerCode": "skr",
      "speakerName": "川咲さくら",
      "speakerNameEn": "Sakura",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-sakura.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/mainStoryVoice/sud_vo_adv_main_01_20_02/sud_vo_adv_main_01_20_02-skr002.m4a",
      "text": "みなさん……",
      "translations": {
        "en": "Oh‚ girls…",
        "id": ""
      },
      "startTime": 46.6,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_livecorridor-00-noon.webp",
      "bgName": "stage02",
      "startTime": 48.36666666666667
    },
    {
      "type": "dialogue",
      "speakerCode": "ktn",
      "speakerName": "長瀬琴乃",
      "speakerNameEn": "Kotono",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-kotono.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/mainStoryVoice/sud_vo_adv_main_01_20_02/sud_vo_adv_main_01_20_02-ktn002.m4a",
      "text": "来てくれたんですね！",
      "translations": {
        "en": "You came to see us!",
        "id": ""
      },
      "startTime": 48.36666666666667,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_livecorridor-00-noon.webp",
      "bgName": "stage02",
      "startTime": 50.46666666666667
    },
    {
      "type": "dialogue",
      "speakerCode": "yu",
      "speakerName": "鈴村優",
      "speakerNameEn": "Yu",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-yu.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/mainStoryVoice/sud_vo_adv_main_01_20_02/sud_vo_adv_main_01_20_02-yu001.m4a",
      "text": "そら、来るやろ～？\nグランプリの決勝なんやし",
      "translations": {
        "en": "Well‚ of course we came.\nIt’s the Grand Prix finals‚ after all.",
        "id": ""
      },
      "startTime": 52.166666666666664,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_livecorridor-00-noon.webp",
      "bgName": "stage02",
      "startTime": 55.233333333333334
    },
    {
      "type": "dialogue",
      "speakerCode": "rio",
      "speakerName": "神崎莉央",
      "speakerNameEn": "Rio",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-rio.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/mainStoryVoice/sud_vo_adv_main_01_20_02/sud_vo_adv_main_01_20_02-rio001.m4a",
      "text": "この目にしっかりと焼き付けないとね\nどっちが優勝するか",
      "translations": {
        "en": "I want to see it clearly with my own eyes.\nWhen the winner is crowned‚",
        "id": ""
      },
      "startTime": 55.233333333333334,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_livecorridor-00-noon.webp",
      "bgName": "stage02",
      "startTime": 60.266666666666666
    },
    {
      "type": "dialogue",
      "speakerCode": "ktn",
      "speakerName": "長瀬琴乃",
      "speakerNameEn": "Kotono",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-kotono.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/mainStoryVoice/sud_vo_adv_main_01_20_02/sud_vo_adv_main_01_20_02-ktn003.m4a",
      "text": "ありがとうございます",
      "translations": {
        "en": "Thank you.",
        "id": ""
      },
      "startTime": 60.266666666666666,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_livecorridor-00-noon.webp",
      "bgName": "stage02",
      "startTime": 62.13333333333333
    },
    {
      "type": "dialogue",
      "speakerCode": "rui",
      "speakerName": "天動瑠依",
      "speakerNameEn": "Rui",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-rui.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/mainStoryVoice/sud_vo_adv_main_01_20_02/sud_vo_adv_main_01_20_02-rui001.m4a",
      "text": "調子はどう？",
      "translations": {
        "en": "How are you feeling?",
        "id": ""
      },
      "startTime": 62.13333333333333,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "smr",
      "speakerName": "奥山すみれ",
      "speakerNameEn": "Sumire",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-sumire.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/mainStoryVoice/sud_vo_adv_main_01_20_02/sud_vo_adv_main_01_20_02-smr001.m4a",
      "text": "寝不足……って訳じゃ\nなさそうですけど",
      "translations": {
        "en": "Sleep-deprived? No‚ wait‚\ndoesn’t look like it.",
        "id": ""
      },
      "startTime": 65.73333333333333,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_livecorridor-00-noon.webp",
      "bgName": "stage02",
      "startTime": 68.03333333333333
    },
    {
      "type": "dialogue",
      "speakerCode": "skr",
      "speakerName": "川咲さくら",
      "speakerNameEn": "Sakura",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-sakura.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/mainStoryVoice/sud_vo_adv_main_01_20_02/sud_vo_adv_main_01_20_02-skr003.m4a",
      "text": "ぐっすり眠りました！\nもう、嫌っていうくらい",
      "translations": {
        "en": "I slept like a log!\nI almost slept too much.",
        "id": ""
      },
      "startTime": 69.9,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_livecorridor-00-noon.webp",
      "bgName": "stage02",
      "startTime": 72.13333333333334
    },
    {
      "type": "dialogue",
      "speakerCode": "aoi",
      "speakerName": "井川葵",
      "speakerNameEn": "Aoi",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-aoi.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/mainStoryVoice/sud_vo_adv_main_01_20_02/sud_vo_adv_main_01_20_02-aoi001.m4a",
      "text": "ふふ。鋼のメンタルだね",
      "translations": {
        "en": "Hehe. Nerves of steel‚ huh.",
        "id": ""
      },
      "startTime": 72.13333333333334,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_livecorridor-00-noon.webp",
      "bgName": "stage02",
      "startTime": 75.53333333333333
    },
    {
      "type": "dialogue",
      "speakerCode": "skr",
      "speakerName": "川咲さくら",
      "speakerNameEn": "Sakura",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-sakura.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/mainStoryVoice/sud_vo_adv_main_01_20_02/sud_vo_adv_main_01_20_02-skr004.m4a",
      "text": "これで最後だし\nもう思い切りやるだけだって思ったし。それに……",
      "translations": {
        "en": "This is it‚ after all.\nI know that all we have to do is give it our all. Besides…",
        "id": ""
      },
      "startTime": 77.13333333333334,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "ktn",
      "speakerName": "長瀬琴乃",
      "speakerNameEn": "Kotono",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-kotono.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/mainStoryVoice/sud_vo_adv_main_01_20_02/sud_vo_adv_main_01_20_02-ktn004.m4a",
      "text": "……うん",
      "translations": {
        "en": "…Yeah.",
        "id": ""
      },
      "startTime": 81.2,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_livecorridor-00-noon.webp",
      "bgName": "stage02",
      "startTime": 82.46666666666667
    },
    {
      "type": "dialogue",
      "speakerCode": "rui",
      "speakerName": "天動瑠依",
      "speakerNameEn": "Rui",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-rui.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/mainStoryVoice/sud_vo_adv_main_01_20_02/sud_vo_adv_main_01_20_02-rui002.m4a",
      "text": "何？　何かあるの？",
      "translations": {
        "en": "What? You’ve got a secret?",
        "id": ""
      },
      "startTime": 82.46666666666667,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_livecorridor-00-noon.webp",
      "bgName": "stage02",
      "startTime": 85.13333333333334
    },
    {
      "type": "dialogue",
      "speakerCode": "skr",
      "speakerName": "川咲さくら",
      "speakerNameEn": "Sakura",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-sakura.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/mainStoryVoice/sud_vo_adv_main_01_20_02/sud_vo_adv_main_01_20_02-skr005.m4a",
      "text": "はい。ステージを見ていてもらえれば\n分かると思います",
      "translations": {
