      "voiceUrl": "https://apiip.dasewasia.my.id/mainStoryVoice/sud_vo_adv_main_02_14_02/sud_vo_adv_main_02_14_02-szk001.m4a",
      "text": "（呼吸が……続か、ない……）",
      "translations": {
        "en": "(I-I can't… breathe…)",
        "id": ""
      },
      "startTime": 17.7333333333,
      "sfxList": []
    },
    {
