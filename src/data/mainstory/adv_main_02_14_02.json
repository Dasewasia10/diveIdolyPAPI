      "speakerName": "川咲さくら",
      "speakerNameEn": "Sakura",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-sakura.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/mainStoryVoice/sud_vo_adv_main_02_14_02/sud_vo_adv_main_02_14_02-skr001.m4a",
      "text": "（……はぁっ、はぁっ、……うん！）",
      "translations": {
        "en": "(…Huff‚ huff… …Yeah!)",
        "id": ""
      },
      "startTime": 24.9333333333,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_festivalstage-00-noon.webp",
      "bgName": "stage01",
