    },
    {
      "type": "dialogue",
      "speakerCode": "hrk",
      "speakerName": "佐伯遙子",
      "speakerNameEn": "Haruko",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-haruko.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/mainStoryVoice/sud_vo_adv_main_02_14_02/sud_vo_adv_main_02_14_02-hrk001.m4a",
      "text": "（……っ、でも……）",
      "translations": {
        "en": "(…But…)",
        "id": ""
      },
      "startTime": 22.4,
      "sfxList": []
    },
    {
      "type": "background",
