      },
      "startTime": 44.43333333333333,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_gpstage-00-noon.webp",
      "bgName": "stage02",
      "startTime": 44.44424358601687
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_gpstage-00-noon.webp",
      "bgName": "stage02",
      "startTime": 46.90108457004346
    },
    {
      "type": "dialogue",
      "speakerCode": "host",
      "speakerName": "司会者",
      "speakerNameEn": "Host",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-host.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/mainStoryVoice/sud_vo_adv_main_01_16_02/sud_vo_adv_main_01_16_02-host002.m4a",
      "text": "まず、バトルワン、セミファイナル一組目は\nサニーピース！　続いて、バトルツー！",
      "translations": {
        "en": "First‚ Battle One! Our group for the semi-finals is…\nSunny Peace! And now‚ for Battle Two!",
        "id": ""
      },
      "startTime": 51.10108457004347,
      "sfxList": [
        {
          "src": "https://apiip.dasewasia.my.id/storyBgm/sud_se_adv_cheers-in-01.m4a",
          "delay": 4200.00000000001,
          "startTime": 51.10108457004347
        }
      ]
    },
    {
      "type": "background",
