      },
      "startTime": 414.0332800984,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "unknown",
      "speakerName": "男性アナウンサー",
      "speakerNameEn": "Male",
      "iconUrl": null,
      "voiceUrl": null,
      "text": "ライブバトル100連勝の大記録を打ち立てて",
      "translations": {
        "en": "TRINITYAiLE‚ who set a great record of 100 consecutive wins in live battles",
        "id": ""
      },
      "startTime": 418.1666096169,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "unknown",
      "speakerName": "男性アナウンサー",
      "speakerNameEn": "Male",
      "iconUrl": null,
      "voiceUrl": null,
      "text": "内外に実力を示したTRINITYAiLE",
      "translations": {
        "en": "and showed off their skills both inside and outside",
        "id": ""
      },
      "startTime": 421.7332780639,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "unknown",
      "speakerName": "男性アナウンサー",
      "speakerNameEn": "Male",
      "iconUrl": null,
      "voiceUrl": null,
      "text": "ランキング五位まで登り詰めた彼女達の次の目標は……",
