        "id": ""
      },
      "startTime": 455.1999447305,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "szk",
      "speakerName": "兵藤雫",
      "speakerNameEn": "Shizuku",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-shizuku.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/mainStoryVoice/sud_vo_adv_main_04_01_01/sud_vo_adv_main_04_01_01-szk002.m4a",
      "text": "もしかして……自分のインタビューがいつ流れるか\n気になって落ち着かない……？",
      "translations": {
        "en": "Maybe… you're worried about\nwhen your interview will come out…?",
