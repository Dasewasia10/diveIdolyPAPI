      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_living-00-night.webp",
      "bgName": "stage01",
      "startTime": null
    },
    {
      "type": "dialogue",
      "speakerCode": "koh",
      "speakerName": "{user}",
      "speakerNameEn": "{user}",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-kohei.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/mainStoryVoice/sud_vo_adv_main_01_19_04/sud_vo_adv_main_01_19_04-koh001.m4a",
      "text": "（記者会見や写真撮影を終えて）\n（寮に戻ったのは、夜も遅くなってからだった）",
      "translations": {
        "en": "(After the press conference and photo-ops‚)\n(we don’t get back to the dorm until late at night.)",
        "id": ""
      },
      "startTime": 3.2666666666666666,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "suz",
      "speakerName": "成宮すず",
      "speakerNameEn": "Suzu",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-suzu.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/mainStoryVoice/sud_vo_adv_main_01_19_04/sud_vo_adv_main_01_19_04-suz001.m4a",
      "text": "ああ～～～、お腹がもう限界ですわ",
      "translations": {
        "en": "Ohhh‚ my stomach is at its limits!",
        "id": ""
      },
      "startTime": 7.325600719451904,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "szk",
      "speakerName": "兵藤雫",
      "speakerNameEn": "Shizuku",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-shizuku.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/mainStoryVoice/sud_vo_adv_main_01_19_04/sud_vo_adv_main_01_19_04-szk002.m4a",
      "text": "……何か……食べ物……",
      "translations": {
        "en": "We need… something to eat.",
        "id": ""
      },
      "startTime": 12.578548336029051,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "hrk",
      "speakerName": "佐伯遙子",
      "speakerNameEn": "Haruko",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-haruko.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/mainStoryVoice/sud_vo_adv_main_01_19_04/sud_vo_adv_main_01_19_04-hrk001.m4a",
      "text": "焼き肉とか……",
      "translations": {
        "en": "Like Korean BBQ?",
        "id": ""
      },
      "startTime": 15.878548336029052,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "skr",
      "speakerName": "川咲さくら",
      "speakerNameEn": "Sakura",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-sakura.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/mainStoryVoice/sud_vo_adv_main_01_19_04/sud_vo_adv_main_01_19_04-skr002.m4a",
      "text": "あーー、食べたい〜〜",
      "translations": {
        "en": "Ooh‚ I want it!",
        "id": ""
      },
      "startTime": 18.311881669362386,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "koh",
      "speakerName": "{user}",
      "speakerNameEn": "{user}",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-kohei.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/mainStoryVoice/sud_vo_adv_main_01_19_04/sud_vo_adv_main_01_19_04-koh002.m4a",
      "text": "もう遅いから、今から出かける訳にもいかないだろう\n今日はあるもので済ませて、週末にでもみんなで行こう",
      "translations": {
        "en": "But it’s late. We can’t go out to eat now.\nLet’s just eat what we have at home and go somewhere this weekend together.",
        "id": ""
      },
      "startTime": 24.93349207469395,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "ski",
      "speakerName": "白石沙季",
      "speakerNameEn": "Saki",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-saki.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/mainStoryVoice/sud_vo_adv_main_01_19_04/sud_vo_adv_main_01_19_04-ski002.m4a",
      "text": "本当ですか？　メモしておきますよ",
      "translations": {
        "en": "Do you mean it? I’ll jot that into the schedule.",
        "id": ""
      },
      "startTime": 29.24521500269572,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "suz",
      "speakerName": "成宮すず",
      "speakerNameEn": "Suzu",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-suzu.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/mainStoryVoice/sud_vo_adv_main_01_19_04/sud_vo_adv_main_01_19_04-suz003.m4a",
      "text": "焼き肉っと",
      "translations": {
        "en": "Korean BBQ… check.",
        "id": ""
      },
      "startTime": 32.378548336029056,
      "sfxList": [
        {
          "src": "https://apiip.dasewasia.my.id/storyBgm/sud_se_adv_paper-01.m4a",
          "delay": 4.263256414560601e-11,
          "startTime": 32.3785483360291
        }
      ]
    },
    {
      "type": "dialogue",
      "speakerCode": "koh",
      "speakerName": "{user}",
      "speakerNameEn": "{user}",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-kohei.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/mainStoryVoice/sud_vo_adv_main_01_19_04/sud_vo_adv_main_01_19_04-koh003.m4a",
      "text": "誰も焼き肉とは言ってないだろ",
      "translations": {
        "en": "Nobody said anything about Korean BBQ.",
        "id": ""
      },
      "startTime": 34.71188166936239,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "hrk",
      "speakerName": "佐伯遙子",
      "speakerNameEn": "Haruko",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-haruko.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/mainStoryVoice/sud_vo_adv_main_01_19_04/sud_vo_adv_main_01_19_04-hrk003.m4a",
      "text": "そうよ\n北京ダック北京ダック",
      "translations": {
        "en": "He did.\nPeking Duck! Peking Duck!",
        "id": ""
      },
      "startTime": 38.969160620371504,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "koh",
      "speakerName": "{user}",
      "speakerNameEn": "{user}",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-kohei.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/mainStoryVoice/sud_vo_adv_main_01_19_04/sud_vo_adv_main_01_19_04-koh004.m4a",
      "text": "そんなことも言ってない",
      "translations": {
        "en": "I didn’t promise that either.",
        "id": ""
      },
      "startTime": 41.233333333333334,
      "sfxList": []
    },
    {
      "type": "bgm",
      "action": "play",
      "src": "https://apiip.dasewasia.my.id/storyBgm/sud_bgm_adv_pop-01.m4a",
      "startTime": 45.03582728703817
    },
    {
      "type": "dialogue",
      "speakerCode": "koh",
      "speakerName": "{user}",
      "speakerNameEn": "{user}",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-kohei.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/mainStoryVoice/sud_vo_adv_main_01_19_04/sud_vo_adv_main_01_19_04-koh005.m4a",
      "text": "えーと、じゃあ、解散する前に簡単に挨拶だけ……\n……今日は本当にお疲れ様でした",
      "translations": {
        "en": "Well‚ before I let you go‚ let me say a few brief words.\nYou all truly did an amazing job today.",
        "id": ""
      },
      "startTime": 51.93582728703818,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "unknown",
      "speakerName": "一同",
      "speakerNameEn": "Everyone",
      "iconUrl": null,
      "voiceUrl": null,
      "text": "お疲れ様でした！",
      "translations": {
        "en": "Thank you‚ coach!",
        "id": ""
      },
      "startTime": 54.833333333333336,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "koh",
      "speakerName": "{user}",
      "speakerNameEn": "{user}",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-kohei.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/mainStoryVoice/sud_vo_adv_main_01_19_04/sud_vo_adv_main_01_19_04-koh006.m4a",
      "text": "正直、今日みんながセミファイナルのステージに\n上がる前までは、決勝にいけるとは……",
      "translations": {
        "en": "To be honest‚ before you all performed in the semi-finals today‚\nwhenever I thought about the finals‚ I…",
        "id": ""
      },
      "startTime": 60.00249395370484,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "rei",
      "speakerName": "一ノ瀬怜",
      "speakerNameEn": "Rei",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-rei.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/mainStoryVoice/sud_vo_adv_main_01_19_04/sud_vo_adv_main_01_19_04-rei002.m4a",
      "text": "まさか、思ってなかったって\n言うんじゃないでしょうね？",
      "translations": {
        "en": "Don’t tell me you didn’t think we’d make it?\nYou’d better not say that.",
        "id": ""
      },
      "startTime": 66.40249395370483,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "koh",
      "speakerName": "{user}",
      "speakerNameEn": "{user}",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-kohei.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/mainStoryVoice/sud_vo_adv_main_01_19_04/sud_vo_adv_main_01_19_04-koh007.m4a",
      "text": "いや、思ってはいた。けどダメだった時のことも\n考えていた。それがマネージャーの仕事でもあるから",
      "translations": {
        "en": "Oh‚ no‚ I did think you’d make it. But I also considered what might happen\nif you didn’t make it. That’s part of a manager’s job.",
        "id": ""
      },
      "startTime": 72.96916062037151,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "ski",
      "speakerName": "白石沙季",
      "speakerNameEn": "Saki",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-saki.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/mainStoryVoice/sud_vo_adv_main_01_19_04/sud_vo_adv_main_01_19_04-ski003.m4a",
      "text": "まあ、そうですね",
      "translations": {
        "en": "Well… that is true.",
        "id": ""
      },
      "startTime": 77.40249395370485,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "koh",
      "speakerName": "{user}",
      "speakerNameEn": "{user}",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-kohei.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/mainStoryVoice/sud_vo_adv_main_01_19_04/sud_vo_adv_main_01_19_04-koh008.m4a",
      "text": "みんなが落ち込んだ時こそ、フォローが必要だし\nでも、俺の出番はほとんど……いや、全くなかった",
      "translations": {
        "en": "It’s important to know what to say‚ especially when you’re all disappointed.\nBut you barely needed me… actually‚ you didn’t need me at all.",
        "id": ""
      },
      "startTime": 83.12353698412576,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "koh",
      "speakerName": "{user}",
      "speakerNameEn": "{user}",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-kohei.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/mainStoryVoice/sud_vo_adv_main_01_19_04/sud_vo_adv_main_01_19_04-koh009.m4a",
      "text": "みんなアイドルとして、最高のパフォーマンスをして\n観客と一体になって、素晴らしい空間を作り出した",
      "translations": {
        "en": "You all gave your best performances as idols.\nYou all united with the audience and created a fantastic atmosphere.",
        "id": ""
      },
      "startTime": 94.13798152605693,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "skr",
      "speakerName": "川咲さくら",
      "speakerNameEn": "Sakura",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-sakura.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/mainStoryVoice/sud_vo_adv_main_01_19_04/sud_vo_adv_main_01_19_04-skr003.m4a",
      "text": "{user}さんは観客席で見ていて\nそう思ってくれたんですね",
      "translations": {
        "en": "From your vantage point in the audience‚\nthat’s the impression you had‚ huh.",
        "id": ""
      },
      "startTime": 101.10464819272357,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "koh",
      "speakerName": "{user}",
      "speakerNameEn": "{user}",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-kohei.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/mainStoryVoice/sud_vo_adv_main_01_19_04/sud_vo_adv_main_01_19_04-koh010.m4a",
      "text": "きっと……麻奈も喜んでいると思う\n本当に、本当にありがとう",
      "translations": {
        "en": "I’m sure… that Mana loved it.\nI really… I really can’t thank you enough.",
        "id": ""
      },
      "startTime": 107.47131485939018,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "ktn",
      "speakerName": "長瀬琴乃",
      "speakerNameEn": "Kotono",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-kotono.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/mainStoryVoice/sud_vo_adv_main_01_19_04/sud_vo_adv_main_01_19_04-ktn002.m4a",
      "text": "きっと……って……？",
      "translations": {
        "en": "What do you mean‚ “I’m sure”?",
        "id": ""
      },
      "startTime": 111.20464819272355,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "skr",
      "speakerName": "川咲さくら",
      "speakerNameEn": "Sakura",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-sakura.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/mainStoryVoice/sud_vo_adv_main_01_19_04/sud_vo_adv_main_01_19_04-skr004.m4a",
      "text": "麻奈さん、見ていたんですよね？",
      "translations": {
        "en": "Mana was watching‚ wasn’t she?",
        "id": ""
      },
      "startTime": 113.58580468495684,
      "sfxList": []
    },
    {
      "type": "bgm",
      "action": "play",
      "src": "https://apiip.dasewasia.my.id/storyBgm/sud_bgm_adv_serious-01.m4a",
      "startTime": 116.4358047326405
    },
    {
      "type": "dialogue",
      "speakerCode": "koh",
      "speakerName": "{user}",
      "speakerNameEn": "{user}",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-kohei.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/mainStoryVoice/sud_vo_adv_main_01_19_04/sud_vo_adv_main_01_19_04-koh011.m4a",
      "text": "ああ。終わった後、確かに言っていた。ありがとうって\nそれが最後だった。探しても探しても見つからなかった",
      "translations": {
        "en": "Yeah. I heard her clearly say “thank you” when it was over.\nThat was the last I heard from her. I looked all over but couldn’t find her.",
        "id": ""
      },
      "startTime": 123.23580473264056,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "suz",
      "speakerName": "成宮すず",
      "speakerNameEn": "Suzu",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-suzu.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/mainStoryVoice/sud_vo_adv_main_01_19_04/sud_vo_adv_main_01_19_04-suz004.m4a",
      "text": "ちょっと。何を言ってるんですの？\n麻奈様がいる訳ないでしょう？",
      "translations": {
        "en": "Wait a minute. What are you saying?\nNo way is Goddess Mana here.",
        "id": ""
      },
      "startTime": 131.06913806597396,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "mei",
      "speakerName": "早坂芽衣",
      "speakerNameEn": "Mei",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-mei.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/mainStoryVoice/sud_vo_adv_main_01_19_04/sud_vo_adv_main_01_19_04-mei002.m4a",
      "text": "すずちゃんはちょっと黙ってて",
      "translations": {
        "en": "Suzu‚ you stay quiet.",
        "id": ""
      },
      "startTime": 133.63333333333333,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "suz",
      "speakerName": "成宮すず",
      "speakerNameEn": "Suzu",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-suzu.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/mainStoryVoice/sud_vo_adv_main_01_19_04/sud_vo_adv_main_01_19_04-suz005.m4a",
      "text": "へ？　何？",
      "translations": {
        "en": "Huh? What?",
        "id": ""
      },
      "startTime": 135.66913806597415,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "mei",
      "speakerName": "早坂芽衣",
      "speakerNameEn": "Mei",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-mei.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/mainStoryVoice/sud_vo_adv_main_01_19_04/sud_vo_adv_main_01_19_04-mei003.m4a",
      "text": "私、小屋の方を見てくる",
      "translations": {
        "en": "I’m gonna go check the shed.",
        "id": ""
      },
      "startTime": 137.33580473264084,
      "sfxList": [
        {
          "src": "https://apiip.dasewasia.my.id/storyBgm/sud_se_adv_run-living-single-01.m4a",
          "delay": 2000,
          "startTime": 139.33580473264084
        }
      ]
    },
    {
      "type": "dialogue",
      "speakerCode": "mei",
      "speakerName": "早坂芽衣",
      "speakerNameEn": "Mei",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-mei.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/mainStoryVoice/sud_vo_adv_main_01_19_04/sud_vo_adv_main_01_19_04-mei004.m4a",
      "text": "……いない",
      "translations": {
        "en": "She’s gone.",
        "id": ""
      },
      "startTime": 142.13333333333333,
      "sfxList": [
        {
          "src": "https://apiip.dasewasia.my.id/storyBgm/sud_se_adv_walk-living-single-01.m4a",
          "delay": 0,
          "startTime": 141.83333333333334
        }
      ]
    },
    {
      "type": "dialogue",
      "speakerCode": "ktn",
      "speakerName": "長瀬琴乃",
      "speakerNameEn": "Kotono",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-kotono.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/mainStoryVoice/sud_vo_adv_main_01_19_04/sud_vo_adv_main_01_19_04-ktn003.m4a",
      "text": "……お姉ちゃんは……",
      "translations": {
        "en": "My sister…",
        "id": ""
      },
      "startTime": 143.76666666666668,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "hrk",
