      "text": "そんなの――今まで私達を応援してくれた人達を\n裏切ることになります！",
      "translations": {
        "en": "That would be… betraying all the people\nwho’ve supported us until now!",
        "id": ""
      },
      "startTime": 214.6,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_preconference-00-noon.webp",
      "bgName": "preconference-00-noon",
      "startTime": 220.8666666667
    },
    {
      "type": "dialogue",
      "speakerCode": "smr",
      "speakerName": "奥山すみれ",
      "speakerNameEn": "Sumire",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-sumire.png",
