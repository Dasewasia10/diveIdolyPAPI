      "text": "大人やらビジネスの話いうんなら\nもうちょっと頑張ってもらわな",
      "translations": {
        "en": "If you wanna talk about adults and business‚\nyou’ll have to step up your game a little.",
        "id": ""
      },
      "startTime": 240.8666666667,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_preconference-00-noon.webp",
      "bgName": "preconference-00-noon",
      "startTime": 243.3333333333
    },
    {
      "type": "dialogue",
      "speakerCode": "yu",
      "speakerName": "鈴村優",
      "speakerNameEn": "Yu",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-yu.png",
