      "text": "ふざけないで下さい！",
      "translations": {
        "en": "You’ve got to be kidding!",
        "id": ""
      },
      "startTime": 208.5,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_preconference-00-noon.webp",
      "bgName": "preconference-00-noon",
      "startTime": 210.5
    },
    {
      "type": "dialogue",
      "speakerCode": "smr",
      "speakerName": "奥山すみれ",
      "speakerNameEn": "Sumire",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-sumire.png",
