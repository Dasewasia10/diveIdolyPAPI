      "speakerNameEn": "Yu",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-yu.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/mainStoryVoice/sud_vo_adv_main_02_10_01/sud_vo_adv_main_02_10_01-yu004.m4a",
      "text": "うちもすみれちゃんに賛成です\nこんな条件でうちらを説得出来ると思ったんですか？",
      "translations": {
        "en": "I agree with Sumire.\nDo you really expect us to go along with your outrageous conditions?",
        "id": ""
      },
      "startTime": 233.3333333333,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_preconference-00-noon.webp",
      "bgName": "preconference-00-noon",
      "startTime": 237.8666666667
    },
    {
      "type": "dialogue",
      "speakerCode": "yu",
      "speakerName": "鈴村優",
      "speakerNameEn": "Yu",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-yu.png",
