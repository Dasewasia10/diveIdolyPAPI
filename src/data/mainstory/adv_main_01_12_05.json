      "bgName": "01-2d",
      "startTime": 33.39702955087026
    },
    {
      "type": "dialogue",
      "speakerCode": "hrk",
      "speakerName": "佐伯遙子",
      "speakerNameEn": "Haruko",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-haruko.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/mainStoryVoice/sud_vo_adv_main_01_12_05/sud_vo_adv_main_01_12_05-hrk001.m4a",
      "text": "ビ、ビビってんじゃねーぞ……",
      "translations": {
        "en": "H-hey! Don’t freak out‚ dudes!",
        "id": ""
      },
      "startTime": 33.39702955087026,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "szk",
      "speakerName": "兵藤雫",
      "speakerNameEn": "Shizuku",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-shizuku.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/mainStoryVoice/sud_vo_adv_main_01_12_05/sud_vo_adv_main_01_12_05-szk001.m4a",
      "text": "遙子さんが、一番ビビってる……",
      "translations": {
        "en": "Haruko‚ you’re the most freaked out of all.",
        "id": ""
      },
      "startTime": 36.54702964623769,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_arenaseats-00-noon.webp",
      "bgName": "01-2d",
      "startTime": 36.54702964623771
    },
    {
      "type": "background",
