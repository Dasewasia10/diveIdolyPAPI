      "text": "琴乃ちゃん、どう？",
      "translations": {
        "en": "How do you feel‚ Kotono?",
        "id": ""
      },
      "startTime": 98.27696141401934,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_stagesleeves-00-noon.webp",
      "bgName": "03-2d",
      "startTime": 100.4585259834926
    },
    {
      "type": "dialogue",
      "speakerCode": "ktn",
      "speakerName": "長瀬琴乃",
      "speakerNameEn": "Kotono",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-kotono.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/mainStoryVoice/sud_vo_adv_main_01_12_05/sud_vo_adv_main_01_12_05-ktn001.m4a",
      "text": "……うん、いい感じだと思う",
      "translations": {
        "en": "Feeling good.",
        "id": ""
      },
      "startTime": 100.4585259834926,
      "sfxList": []
    },
    {
      "type": "background",
