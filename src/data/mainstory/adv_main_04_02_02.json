      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "chs",
      "speakerName": "白石千紗",
      "speakerNameEn": "Chisa",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-chisa.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/mainStoryVoice/sud_vo_adv_main_04_02_02/sud_vo_adv_main_04_02_02-chs002.m4a",
      "text": "私も試してみたいことがあるんだけど、いいかな……？",
      "translations": {
        "en": "There's something I'd like to try‚ is that okay…?",
        "id": ""
      },
      "startTime": 102.7333259582,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_tokyoconference-00-noon.webp",
      "bgName": "tokyoconference-00-noon",
      "startTime": 107.4999926249
    },
    {
      "type": "dialogue",
      "speakerCode": "skr",
      "speakerName": "川咲さくら",
      "speakerNameEn": "Sakura",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-sakura.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/mainStoryVoice/sud_vo_adv_main_04_02_02/sud_vo_adv_main_04_02_02-skr005.m4a",
      "text": "どんどん意見を出し合って、最高のステージに……\nううん、最高を超えるステージにしよう！",
      "translations": {
        "en": "Let's share our opinions further‚ and make it the best stage…\nNo‚ let's make it even better!",
        "id": ""
      },
      "startTime": 111.8999977112,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_tokyoconference-00-noon.webp",
      "bgName": "tokyoconference-00-noon",
