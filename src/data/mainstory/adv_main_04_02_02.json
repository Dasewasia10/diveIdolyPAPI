    {
      "type": "dialogue",
      "speakerCode": "koh",
      "speakerName": "{user}",
      "speakerNameEn": "{user}",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-kohei.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/mainStoryVoice/sud_vo_adv_main_04_02_02/sud_vo_adv_main_04_02_02-koh006.m4a",
      "text": "トリエルが相手と聞いて、怯むどころか\nこんなに前向きに向かっていくなんて……",
      "translations": {
        "en": "Hearing that TRINITYAiLE was the opponent‚ instead of being scared‚\nthey approached it with such positivity…",
        "id": ""
      },
      "startTime": 118.5999977112,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_tokyoconference-00-noon.webp",
      "bgName": "tokyoconference-00-noon",
      "startTime": 118.5999977112
    },
    {
      "type": "dialogue",
      "speakerCode": "hrk",
      "speakerName": "佐伯遙子",
      "speakerNameEn": "Haruko",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-haruko.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/mainStoryVoice/sud_vo_adv_main_04_02_02/sud_vo_adv_main_04_02_02-hrk002.m4a",
      "text": "どう？　君が思ってたより、みんなずっと強いでしょ？",
      "translations": {
        "en": "How is it? They're all much stronger than you though?",
        "id": ""
      },
      "startTime": 121.2666592915,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_tokyoconference-00-noon.webp",
