      "text": "……分かった。サニピの次の対戦相手は\nTRINITYAiLEだ",
      "translations": {
        "en": "…Okay. Sunny Peace's next opponent is\nTRINITYAiLE",
        "id": ""
      },
      "startTime": 86.3999977112,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_tokyoconference-00-noon.webp",
      "bgName": "tokyoconference-00-noon",
      "startTime": 87.9999956767
    },
    {
      "type": "dialogue",
      "speakerCode": "skr",
      "speakerName": "川咲さくら",
      "speakerNameEn": "Sakura",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-sakura.png",
