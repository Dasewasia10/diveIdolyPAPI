      "speakerNameEn": "Suzu",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-suzu.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/mainStoryVoice/sud_vo_adv_main_02_12_01/sud_vo_adv_main_02_12_01-suz001.m4a",
      "text": "（ハッキリと手応えを感じましたわ）\n（後は、結果を待つだけ）",
      "translations": {
        "en": "(I definitely felt a response.)\n(Now all that's left is to wait for the results.)",
        "id": ""
      },
      "startTime": 18.2666666667,
      "sfxList": []
    },
    {
      "type": "background",
