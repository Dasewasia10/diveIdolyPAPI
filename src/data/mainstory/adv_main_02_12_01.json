    },
    {
      "type": "dialogue",
      "speakerCode": "mei",
      "speakerName": "早坂芽衣",
      "speakerNameEn": "Mei",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-mei.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/mainStoryVoice/sud_vo_adv_main_02_12_01/sud_vo_adv_main_02_12_01-mei001.m4a",
      "text": "……お願い、神様！　芽衣達、頑張ったもん！",
      "translations": {
        "en": "…Please‚ God! Mei and the others worked hard!",
        "id": ""
      },
      "startTime": 21.3,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "ski",
      "speakerName": "白石沙季",
      "speakerNameEn": "Saki",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-saki.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/mainStoryVoice/sud_vo_adv_main_02_12_01/sud_vo_adv_main_02_12_01-ski001.m4a",
      "text": "大丈夫です、芽衣ちゃん\n信じましょう……私達のパフォーマンスを",
      "translations": {
        "en": "It's okay‚ Mei-chan.\nLet's believe… in our performance.",
        "id": ""
      },
      "startTime": 27.6,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_festivalstage-00-noon.webp",
      "bgName": "stage01",
      "startTime": 31.6333333333
    },
    {
      "type": "dialogue",
      "speakerCode": "ngs",
      "speakerName": "伊吹渚",
      "speakerNameEn": "Nagisa",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-nagisa.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/mainStoryVoice/sud_vo_adv_main_02_12_01/sud_vo_adv_main_02_12_01-ngs001.m4a",
      "text": "……あ\n結果発表、始まったよ……っ！",
      "translations": {
        "en": "…Ah.\nThe announcement of the results is starting…!",
        "id": ""
      },
      "startTime": 32.7433333333,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_dressingroom-00-noon.webp",
