    {
      "type": "dialogue",
      "speakerCode": "ngs",
      "speakerName": "伊吹渚",
      "speakerNameEn": "Nagisa",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-nagisa.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/mainStoryVoice/sud_vo_adv_main_03_01_05/sud_vo_adv_main_03_01_05-ngs005.m4a",
      "text": "琴乃ちゃんがずっと悩んでるの、気付いてたんだ",
      "translations": {
        "en": "I've noticed you've been worrying all this time",
        "id": ""
      },
      "startTime": 90.3,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "ngs",
      "speakerName": "伊吹渚",
      "speakerNameEn": "Nagisa",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-nagisa.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/mainStoryVoice/sud_vo_adv_main_03_01_05/sud_vo_adv_main_03_01_05-ngs006.m4a",
      "text": "I-UNITYのセミファイナル以来\n私達が調子を落としちゃってるのは間違いないと思う",
      "translations": {
        "en": "Since the I-UNITY semifinals\nIt's true that we've been in a slump",
        "id": ""
