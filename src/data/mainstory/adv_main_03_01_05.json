      "voiceUrl": "https://apiip.dasewasia.my.id/mainStoryVoice/sud_vo_adv_main_03_01_05/sud_vo_adv_main_03_01_05-ktn003.m4a",
      "text": "明日のセミファイナル、絶対に勝ってきます",
      "translations": {
        "en": "I'll definitely win tomorrow's semifinal",
        "id": ""
      },
      "startTime": 9.6666666667,
      "sfxList": []
    },
    {
      "type": "background",
