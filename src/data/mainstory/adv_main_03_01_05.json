      "startTime": 104.3333333333,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "ngs",
      "speakerName": "伊吹渚",
      "speakerNameEn": "Nagisa",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-nagisa.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/mainStoryVoice/sud_vo_adv_main_03_01_05/sud_vo_adv_main_03_01_05-ngs008.m4a",
      "text": "月ストは、リズノワにもトリエルにも\nサニピにだって負けない、凄いグループだよ",
      "translations": {
        "en": "Moon's Tempest isn't losing to LizNoir‚ TRINITYAiLE\nor even Sunny Peace‚ we're an amazing group",
        "id": ""
      },
      "startTime": 110.2666666667,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "ngs",
      "speakerName": "伊吹渚",
      "speakerNameEn": "Nagisa",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-nagisa.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/mainStoryVoice/sud_vo_adv_main_03_01_05/sud_vo_adv_main_03_01_05-ngs009.m4a",
      "text": "スリクスにだって……勝てる",
      "translations": {
        "en": "We can even… beat IIIX",
        "id": ""
      },
      "startTime": 113.9,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "ktn",
      "speakerName": "長瀬琴乃",
      "speakerNameEn": "Kotono",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-kotono.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/mainStoryVoice/sud_vo_adv_main_03_01_05/sud_vo_adv_main_03_01_05-ktn012.m4a",
      "text": "そう……なのかな",
      "translations": {
