      "startTime": 117.1666666667,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "ngs",
      "speakerName": "伊吹渚",
      "speakerNameEn": "Nagisa",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-nagisa.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/mainStoryVoice/sud_vo_adv_main_03_01_05/sud_vo_adv_main_03_01_05-ngs010.m4a",
      "text": "そうだよ、私が保証する",
      "translations": {
        "en": "It is‚ I guarantee it",
        "id": ""
      },
      "startTime": 120.4666666667,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "ngs",
      "speakerName": "伊吹渚",
      "speakerNameEn": "Nagisa",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-nagisa.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/mainStoryVoice/sud_vo_adv_main_03_01_05/sud_vo_adv_main_03_01_05-ngs011.m4a",
      "text": "琴乃ちゃんだけじゃない。沙季ちゃんも、すずちゃんも\n芽衣ちゃんも……みんなとっても凄いんだから",
      "translations": {
        "en": "It's not just you‚ Kotono. Saki‚ Suzu\nMei… everyone is really amazing",
