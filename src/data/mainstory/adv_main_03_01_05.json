      "startTime": 96.7666666667,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "ngs",
      "speakerName": "伊吹渚",
      "speakerNameEn": "Nagisa",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-nagisa.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/mainStoryVoice/sud_vo_adv_main_03_01_05/sud_vo_adv_main_03_01_05-ngs007.m4a",
      "text": "でも、私達の本当の力は……\n他のグループにも絶対負けてない",
      "translations": {
        "en": "But our true strength…\nIt's not inferior to any other group",
        "id": ""
