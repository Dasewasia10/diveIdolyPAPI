      "text": "ないってどういうことですの！？",
      "translations": {
        "en": "Nothing?! What is the meaning of this?",
        "id": ""
      },
      "startTime": 112.29958658315044,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "hrk",
      "speakerName": "佐伯遙子",
