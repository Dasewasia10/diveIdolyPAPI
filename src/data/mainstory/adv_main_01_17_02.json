      "text": "麻奈さんと話さなくていいの？\n話したいこと、一杯あるんじゃないの？",
      "translations": {
        "en": "Are you sure you don’t want to talk to Mana?\nIsn’t there lots you want to talk about?",
        "id": ""
      },
      "startTime": 41.3,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_ktnroom-00-night.webp",
      "bgName": "02-2d",
      "startTime": 44.63333333333333
    },
    {
      "type": "dialogue",
      "speakerCode": "ktn",
      "speakerName": "長瀬琴乃",
      "speakerNameEn": "Kotono",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-kotono.png",
