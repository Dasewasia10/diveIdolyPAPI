    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_ktnroom-00-night.webp",
      "bgName": "02-2d",
      "startTime": 24.742380992571515
    },
    {
      "type": "dialogue",
      "speakerCode": "skr",
      "speakerName": "川咲さくら",
      "speakerNameEn": "Sakura",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-sakura.png",
