      "text": "みんなのいるこの場所が、私の居場所なんだ、って……",
      "translations": {
        "en": "This place with everyone here is‚ where I belong…",
        "id": ""
      },
      "startTime": 221.7922920624,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "ktn",
      "speakerName": "長瀬琴乃",
      "speakerNameEn": "Kotono",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-kotono.png",
