      "text": "そんな準備あるのか？",
      "translations": {
        "en": "Did they bother to prepare one?",
        "id": ""
      },
      "startTime": 87.96666666666667,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "koh",
      "speakerName": "{user}",
