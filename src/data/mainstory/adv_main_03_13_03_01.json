{
  "id": "adv_main_03_13_03_01",
  "title": "BIG4編1章63話",
  "script": [
    {
      "type": "bgm",
      "action": "play",
      "src": "https://apiip.dasewasia.my.id/storyBgm/sud_bgm_adv_main_03_13_03_movie-01.m4a",
      "startTime": 0
    },
    {
      "type": "dialogue",
      "speakerCode": "ngs",
      "speakerName": "伊吹渚",
      "speakerNameEn": "Nagisa",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-nagisa.png",
      "voiceUrl": null,
      "text": "（初めは、ひたすら頑張れば）",
      "translations": {
        "en": "（At first‚ I thought if I just worked hard‚）",
        "id": ""
      },
      "startTime": 7.1666666667,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "ngs",
      "speakerName": "伊吹渚",
      "speakerNameEn": "Nagisa",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-nagisa.png",
      "voiceUrl": null,
      "text": "（今は辛くても、いつかなんとかなると思ってた）",
      "translations": {
        "en": "（even if things were tough now‚ they'd work out somehow.）",
        "id": ""
      },
      "startTime": 10.2,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "ski",
      "speakerName": "白石沙季",
      "speakerNameEn": "Saki",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-saki.png",
      "voiceUrl": null,
      "text": "（でも……進んだ先は行き止まりだった）",
      "translations": {
        "en": "（But… the path ahead led to a dead end.）",
        "id": ""
      },
      "startTime": 15.6,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "ski",
      "speakerName": "白石沙季",
      "speakerNameEn": "Saki",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-saki.png",
      "voiceUrl": null,
      "text": "（琴乃ちゃんという月が消えて、真っ暗闇になった）",
      "translations": {
        "en": "（Kotono‚ our moon‚ disappeared‚ and all that remained was pitch-black darkness.）",
        "id": ""
      },
      "startTime": 21.7666666667,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "suz",
      "speakerName": "成宮すず",
      "speakerNameEn": "Suzu",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-suzu.png",
      "voiceUrl": null,
      "text": "（四人でもがいて、もがいて、もがき続けて……）",
      "translations": {
        "en": "（The four of us struggled and struggled‚ and kept struggling…）",
        "id": ""
      },
      "startTime": 27.2,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "suz",
      "speakerName": "成宮すず",
      "speakerNameEn": "Suzu",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-suzu.png",
      "voiceUrl": null,
      "text": "（自分達なりの答えを見つけて……そして、また負けた）",
      "translations": {
        "en": "（We found our own answers… and then lost again.）",
        "id": ""
      },
      "startTime": 32.8,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "mei",
      "speakerName": "早坂芽衣",
      "speakerNameEn": "Mei",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-mei.png",
      "voiceUrl": null,
      "text": "（だけど、私達は強くなれた。琴乃ちゃんも戻って来て）",
      "translations": {
        "en": "（But we've gotten stronger. Kotono has come back.）",
        "id": ""
      },
      "startTime": 40.5333333333,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "mei",
      "speakerName": "早坂芽衣",
      "speakerNameEn": "Mei",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-mei.png",
      "voiceUrl": null,
      "text": "（私達は新しい月ストに生まれ変われた）",
      "translations": {
        "en": "（We've been reborn as a new Moon Tempest.）",
        "id": ""
      },
      "startTime": 47.4666666667,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "ktn",
      "speakerName": "長瀬琴乃",
      "speakerNameEn": "Kotono",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-kotono.png",
      "voiceUrl": null,
      "text": "（これまでの努力も、不安も、後悔も――全部、全部）",
      "translations": {
        "en": "（All of our efforts‚ anxieties‚ and regrets――）",
        "id": ""
      },
      "startTime": 52.5,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "ktn",
      "speakerName": "長瀬琴乃",
      "speakerNameEn": "Kotono",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-kotono.png",
      "voiceUrl": null,
      "text": "全てをこのパフォーマンスにぶつける！",
      "translations": {
        "en": "（We'll pour everything into this performance!）",
        "id": ""
      },
      "startTime": 61.4333333333,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "ktn",
      "speakerName": "長瀬琴乃",
      "speakerNameEn": "Kotono",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-kotono.png",
      "voiceUrl": null,
      "text": "聴いて下さい――",
      "translations": {
        "en": "Please listen――",
        "id": ""
      },
      "startTime": 64.5666666667,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "ktn",
      "speakerName": "長瀬琴乃",
      "speakerNameEn": "Kotono",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-kotono.png",
      "voiceUrl": null,
      "text": "『月ノヒカリ』",
      "translations": {
        "en": "\"Moonlight\"",
        "id": ""
      },
      "startTime": 67.2666666667,
      "sfxList": []
    }
  ]
}