      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-rui.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/mainStoryVoice/sud_vo_adv_main_02_02_03/sud_vo_adv_main_02_02_03-rui023.m4a",
