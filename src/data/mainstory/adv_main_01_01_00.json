      "text": "（そんな俺も、高校を卒業して今や）\n（アシスタントマネージャーという肩書きを得ていた）",
      "translations": {
        "en": "（Now‚ having graduated from high school‚）\n（I have the title of Assistant Manager.）",
        "id": ""
      },
      "startTime": 172.33333333333334,
      "sfxList": []
    },
    {
      "type": "bgm",
      "action": "play",
      "src": "https://apiip.dasewasia.my.id/storyBgm/sud_bgm_adv_lesson-01.m4a",
      "startTime": 175.43333333333334
    },
    {
      "type": "dialogue",
      "speakerCode": "koh",
      "speakerName": "{user}",
      "speakerNameEn": "{user}",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-kohei.png",
