      "translations": {
        "en": "It's nice to meet you.",
        "id": ""
      },
      "startTime": 0.8,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_hoshifacade-00-noon.webp",
