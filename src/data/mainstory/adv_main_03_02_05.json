      "sfxList": [
        {
          "src": "https://apiip.dasewasia.my.id/storyBgm/sud_se_adv_book-01.m4a",
          "delay": 2866.6666666999986,
          "startTime": 87.1666666667
        }
      ]
    },
    {
      "type": "dialogue",
      "speakerCode": "koh",
      "speakerName": "{user}",
      "speakerNameEn": "{user}",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-kohei.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/mainStoryVoice/sud_vo_adv_main_03_02_05/sud_vo_adv_main_03_02_05-koh009.m4a",
      "text": "これは……企画書ですか\n……BIG4、チャレンジ？",
      "translations": {
        "en": "Is this… a project proposal?\n…BIG4 Challenge?",
