      "text": "今までなら良しとしていた部分でも\nまだまだ改善の余地がありそうですね",
      "translations": {
        "en": "Even parts that we would’ve been okay with before\nstill have room for improvement.",
        "id": ""
      },
      "startTime": 86.3666702271,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_tokyoconference-00-noon.webp",
      "bgName": "tokyoconference-00-noon",
      "startTime": 89.0122234506
    },
    {
      "type": "dialogue",
      "speakerCode": "ngs",
      "speakerName": "伊吹渚",
      "speakerNameEn": "Nagisa",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-nagisa.png",
