      "text": "それなら……ここ！　ここのステップをもっと――",
      "translations": {
        "en": "Then… here! We can make this step more――",
        "id": ""
      },
      "startTime": 109.9219056291,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_tokyoconference-00-noon.webp",
      "bgName": "tokyoconference-00-noon",
