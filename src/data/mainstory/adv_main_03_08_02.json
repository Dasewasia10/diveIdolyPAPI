      "speakerNameEn": "Nagisa",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-nagisa.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/mainStoryVoice/sud_vo_adv_main_03_08_02/sud_vo_adv_main_03_08_02-ngs004.m4a",
      "text": "ふぅ。わ、もうこんな時間？",
      "translations": {
        "en": "Phew. Wow‚ it’s already this late?",
        "id": ""
      },
      "startTime": 117.7552471004,
      "sfxList": []
    },
    {
      "type": "background",
