      "speakerName": "成宮すず",
      "speakerNameEn": "Suzu",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-suzu.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/mainStoryVoice/sud_vo_adv_main_03_08_02/sud_vo_adv_main_03_08_02-suz003.m4a",
      "text": "あ……確かにそうですわね",
      "translations": {
        "en": "Ah… you’re right.",
        "id": ""
      },
      "startTime": 79.4120421571,
      "sfxList": []
    },
    {
      "type": "background",
