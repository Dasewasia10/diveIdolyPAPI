      "bgName": "tokyoconference-00-noon",
      "startTime": 121.7219137671
    },
    {
      "type": "dialogue",
      "speakerCode": "ski",
      "speakerName": "白石沙季",
      "speakerNameEn": "Saki",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-saki.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/mainStoryVoice/sud_vo_adv_main_03_08_02/sud_vo_adv_main_03_08_02-ski005.m4a",
      "text": "集中しているとあっという間ですね\nそろそろ寮に……芽衣ちゃん？　どうしたんですか？",
      "translations": {
        "en": "Time flies when you’re focused.\nIt’s about time to head back to the dorm… Mei-chan? What’s wrong?",
        "id": ""
      },
