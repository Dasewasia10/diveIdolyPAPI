      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-kotono.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/mainStoryVoice/sud_vo_adv_main_03_04_01/sud_vo_adv_main_03_04_01-ktn001.m4a",
      "text": "こんな、はずじゃ……っ",
      "translations": {
        "en": "This… can't be…!",
        "id": ""
      },
      "startTime": 5.3666667521,
      "sfxList": []
    },
    {
