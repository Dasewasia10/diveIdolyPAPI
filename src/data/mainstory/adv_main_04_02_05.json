      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "mhk",
      "speakerName": "miho",
      "speakerNameEn": "miho",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-miho.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/mainStoryVoice/sud_vo_adv_main_04_02_05/sud_vo_adv_main_04_02_05-mhk002.m4a",
      "text": "トリエルも必死に食らいつきましたが\nそれでも相手にならないくらいサニピが強過ぎました",
      "translations": {
        "en": "TRINITYAiLE tried desperately‚\nbut Sunny Peace was too strong to be a match",
        "id": ""
      },
      "startTime": 69.6,
      "sfxList": []
    },
    {
      "type": "background",
