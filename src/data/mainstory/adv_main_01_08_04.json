    },
    {
      "type": "dialogue",
      "speakerCode": "koh",
      "speakerName": "{user}",
      "speakerNameEn": "{user}",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-kohei.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/mainStoryVoice/sud_vo_adv_main_01_08_04/sud_vo_adv_main_01_08_04-koh011.m4a",
      "text": "芽衣が俺の小屋に来てることがバレてる！？",
      "translations": {
        "en": "They found out you’ve been visiting my shed?!",
        "id": ""
      },
      "startTime": 105.0602895353862,
      "sfxList": []
    },
    {
      "type": "background",
