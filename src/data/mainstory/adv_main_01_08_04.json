      "startTime": 42.166666666666664,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "ngs",
      "speakerName": "伊吹渚",
      "speakerNameEn": "Nagisa",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-nagisa.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/mainStoryVoice/sud_vo_adv_main_01_08_04/sud_vo_adv_main_01_08_04-ngs003.m4a",
      "text": "きゃっ……\nえっと……今、練習中なのでちょっと……",
      "translations": {
        "en": "Eek!\nUh‚ well‚ we’re in the middle of practice‚ so…",
        "id": ""
      },
      "startTime": 44.56711844948758,
      "sfxList": [
        {
          "src": "https://apiip.dasewasia.my.id/storyBgm/sud_se_adv_walk-in-single-01.m4a",
          "delay": 5749.110917250313,
          "startTime": 50.31622936673789
        }
      ]
    },
    {
      "type": "dialogue",
      "speakerCode": "koh",
      "speakerName": "{user}",
      "speakerNameEn": "{user}",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-kohei.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/mainStoryVoice/sud_vo_adv_main_01_08_04/sud_vo_adv_main_01_08_04-koh005.m4a",
      "text": "そ、そうか……ごめん\nすずはどうだ？",
      "translations": {
        "en": "R-really? Oh. Sorry.\nWould you like a snack‚ Suzu?",
        "id": ""
      },
      "startTime": 52.64956270007123,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "suz",
      "speakerName": "成宮すず",
      "speakerNameEn": "Suzu",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-suzu.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/mainStoryVoice/sud_vo_adv_main_01_08_04/sud_vo_adv_main_01_08_04-suz003.m4a",
      "text": "……フンッッッッ！",
      "translations": {
        "en": "Humph!",
        "id": ""
      },
      "startTime": 54.14956270007123,
      "sfxList": [
        {
          "src": "https://apiip.dasewasia.my.id/storyBgm/sud_se_adv_walk-in-single-01.m4a",
