  "script": [
    {
      "type": "bgm",
      "action": "play",
      "src": "https://apiip.dasewasia.my.id/storyBgm/sud_bgm_adv_pop-01.m4a",
      "startTime": 0
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_tokyocafe-00-noon.webp",
      "bgName": "stgae01",
      "startTime": 0
    },
    {
      "type": "dialogue",
      "speakerCode": "yu",
      "speakerName": "鈴村優",
      "speakerNameEn": "Yu",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-yu.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/mainStoryVoice/sud_vo_adv_main_01_06_05/sud_vo_adv_main_01_06_05-yu001.m4a",
      "text": "先ほどはどうも",
      "translations": {
        "en": "It was nice meeting you earlier.",
        "id": ""
      },
      "startTime": 0.8,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "yu",
      "speakerName": "鈴村優",
      "speakerNameEn": "Yu",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-yu.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/mainStoryVoice/sud_vo_adv_main_01_06_05/sud_vo_adv_main_01_06_05-yu002.m4a",
      "text": "実はうち{user}さんに頼んで\n伊吹さんのこと連れてきてもらったんですわぁ",
      "translations": {
        "en": "You see‚ I actually asked {user}\nto bring you here to talk to me.",
        "id": ""
      },
      "startTime": 5.880544265111287,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_tokyocafe-00-noon.webp",
      "bgName": "stgae01",
      "startTime": 8.9805442651
    },
    {
      "type": "dialogue",
      "speakerCode": "ngs",
      "speakerName": "伊吹渚",
      "speakerNameEn": "Nagisa",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-nagisa.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/mainStoryVoice/sud_vo_adv_main_01_06_05/sud_vo_adv_main_01_06_05-ngs001.m4a",
      "text": "ええっ！？　じゃあ\n美人で優しい女の子、って……",
      "translations": {
        "en": "What?! So‚\nthat nice‚ pretty girl he mentioned was you?",
        "id": ""
      },
      "startTime": 10.827057184,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_tokyocafe-00-noon.webp",
      "bgName": "stgae01",
      "startTime": 14.19941061337789
    },
    {
      "type": "dialogue",
      "speakerCode": "yu",
      "speakerName": "鈴村優",
      "speakerNameEn": "Yu",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-yu.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/mainStoryVoice/sud_vo_adv_main_01_06_05/sud_vo_adv_main_01_06_05-yu003.m4a",
      "text": "あら、そんなこと言いはったんですか？\n嬉しいわぁ",
      "translations": {
        "en": "Ooh! Did he really say that about me?\nThat’s so sweet.",
        "id": ""
      },
      "startTime": 17.132743946711226,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_tokyocafe-00-noon.webp",
      "bgName": "stgae01",
      "startTime": 18.999410613377893
    },
    {
      "type": "dialogue",
      "speakerCode": "ngs",
      "speakerName": "伊吹渚",
      "speakerNameEn": "Nagisa",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-nagisa.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/mainStoryVoice/sud_vo_adv_main_01_06_05/sud_vo_adv_main_01_06_05-ngs002.m4a",
      "text": "あの、なんで私を……？",
      "translations": {
        "en": "Um‚ but why me?",
        "id": ""
      },
      "startTime": 18.999410613377897,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "yu",
      "speakerName": "鈴村優",
      "speakerNameEn": "Yu",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-yu.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/mainStoryVoice/sud_vo_adv_main_01_06_05/sud_vo_adv_main_01_06_05-yu004.m4a",
      "text": "いややわぁ……うちに熱い視線を送ってくれたんは\n伊吹さんの方やんか",
      "translations": {
        "en": "Aw‚ please‚ who was making dreamy eyes at who back there?\nIt was you‚ Nagisa. At me.",
        "id": ""
      },
      "startTime": 26.2911986997,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_tokyocafe-00-noon.webp",
      "bgName": "stgae01",
      "startTime": 28.4575061639
    },
    {
      "type": "dialogue",
      "speakerCode": "ngs",
      "speakerName": "伊吹渚",
      "speakerNameEn": "Nagisa",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-nagisa.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/mainStoryVoice/sud_vo_adv_main_01_06_05/sud_vo_adv_main_01_06_05-ngs003.m4a",
      "text": "あ、そ、それは…………",
      "translations": {
        "en": "W-well‚ I was just…",
        "id": ""
      },
      "startTime": 28.45750616391501,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_tokyocafe-00-noon.webp",
      "bgName": "stgae01",
      "startTime": 31.524172830581676
    },
    {
      "type": "dialogue",
      "speakerCode": "ngs",
      "speakerName": "伊吹渚",
      "speakerNameEn": "Nagisa",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-nagisa.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/mainStoryVoice/sud_vo_adv_main_01_06_05/sud_vo_adv_main_01_06_05-ngs004.m4a",
      "text": "……あ、あの、実は私\n鈴村さんのお話がぜひ聞きたくてっ",
      "translations": {
        "en": "W-well‚ actually‚ I…\nI’d love to have a chat with you‚ Yu!",
        "id": ""
      },
      "startTime": 34.457506163915006,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_tokyocafe-00-noon.webp",
      "bgName": "stgae01",
      "startTime": 37.824172830581674
    },
    {
      "type": "dialogue",
      "speakerCode": "yu",
      "speakerName": "鈴村優",
      "speakerNameEn": "Yu",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-yu.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/mainStoryVoice/sud_vo_adv_main_01_06_05/sud_vo_adv_main_01_06_05-yu005.m4a",
      "text": "ええよ。うちも伊吹さんのお話、聞きたいです\n悩みがあるんやんなぁ？",
      "translations": {
        "en": "It’s all good. I wanna have a chat with you too‚ Nagisa.\nSomethin’ troubling you?",
        "id": ""
      },
      "startTime": 42.3241728306,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_tokyocafe-00-noon.webp",
      "bgName": "stgae01",
      "startTime": 44.12417283058168
    },
    {
      "type": "dialogue",
      "speakerCode": "ngs",
      "speakerName": "伊吹渚",
      "speakerNameEn": "Nagisa",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-nagisa.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/mainStoryVoice/sud_vo_adv_main_01_06_05/sud_vo_adv_main_01_06_05-ngs005.m4a",
      "text": "はい……ありがとうございます\n私、実は――",
      "translations": {
        "en": "Yes… Thank you.\nYou see‚ the truth is…",
        "id": ""
      },
      "startTime": 47.75750616391502,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_tokyocafe-00-noon.webp",
      "bgName": "stgae01",
      "startTime": 50.25750616391502
    },
    {
      "type": "dialogue",
      "speakerCode": "koh",
      "speakerName": "{user}",
      "speakerNameEn": "{user}",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-kohei.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/mainStoryVoice/sud_vo_adv_main_01_06_05/sud_vo_adv_main_01_06_05-koh001.m4a",
      "text": "（あの日彼女は、挨拶の時の渚が気になったらしく）\n（渚がどんな子なのかを俺に尋ねてきた）",
      "translations": {
        "en": "(Apparently‚ Yu had taken an interest in Nagisa the day they’d met.)\n(She asked me what kind of girl Nagisa is.)",
        "id": ""
      },
      "startTime": 54.35750616391503,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_dancestudiocorridor-00-noon.webp",
      "bgName": "stage02",
      "startTime": 57.9632134597
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_dancestudiocorridor-00-noon.webp",
      "bgName": "stage02",
      "startTime": 57.9632134597
    },
    {
      "type": "bgm",
      "action": "play",
      "src": "https://apiip.dasewasia.my.id/storyBgm/sud_bgm_adv_tension-01.m4a",
      "startTime": 58.32417283058168
    },
    {
      "type": "dialogue",
      "speakerCode": "koh",
      "speakerName": "{user}",
      "speakerNameEn": "{user}",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-kohei.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/mainStoryVoice/sud_vo_adv_main_01_06_05/sud_vo_adv_main_01_06_05-koh002.m4a",
      "text": "……すみません\nうちの者が失礼な真似を",
      "translations": {
        "en": "…Sorry.\nThat was rude of Nagisa.",
        "id": ""
      },
      "startTime": 60.99083949724836,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "yu",
      "speakerName": "鈴村優",
      "speakerNameEn": "Yu",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-yu.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/mainStoryVoice/sud_vo_adv_main_01_06_05/sud_vo_adv_main_01_06_05-yu006.m4a",
      "text": "ああいえ、そんなん\n気にせんといてください",
      "translations": {
        "en": "Oh‚ no. I don’t\nmind one bit about that.",
        "id": ""
      },
      "startTime": 64.6241728305,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_dancestudiocorridor-00-noon.webp",
      "bgName": "stage02",
      "startTime": 66.85848123232525
    },
    {
      "type": "dialogue",
      "speakerCode": "yu",
      "speakerName": "鈴村優",
      "speakerNameEn": "Yu",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-yu.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/mainStoryVoice/sud_vo_adv_main_01_06_05/sud_vo_adv_main_01_06_05-yu007.m4a",
      "text": "なんかうちに言いたいことがあるんとちゃうか\nうち、知らん間になんかしたんちゃうかって",
      "translations": {
        "en": "It just seemed like she had something she wanted to tell me.\nI wonder if I unknowingly did something to make her mad.",
        "id": ""
      },
      "startTime": 70.2133593787992,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_dancestudiocorridor-00-noon.webp",
      "bgName": "stage02",
      "startTime": 73.9202699432528
    },
    {
      "type": "dialogue",
      "speakerCode": "yu",
      "speakerName": "鈴村優",
      "speakerNameEn": "Yu",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-yu.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/mainStoryVoice/sud_vo_adv_main_01_06_05/sud_vo_adv_main_01_06_05-yu008.m4a",
      "text": "ただ、怒ってるようにも見えへんかったから……\nどんな子か気になってきたんです",
      "translations": {
        "en": "Except‚ she didn’t look mad…\nSo I’m just wondering what kind of girl she is.",
        "id": ""
      },
      "startTime": 77.4536032766,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "koh",
      "speakerName": "{user}",
      "speakerNameEn": "{user}",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-kohei.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/mainStoryVoice/sud_vo_adv_main_01_06_05/sud_vo_adv_main_01_06_05-koh003.m4a",
      "text": "そういうことでしたか\n……それなら、もし良かったらなんですが",
      "translations": {
        "en": "Oh‚ so that’s all?\nIn that case‚ you can say no if you want‚ but…",
        "id": ""
      },
      "startTime": 82.7666666667,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_dancestudiocorridor-00-noon.webp",
      "bgName": "stage02",
      "startTime": 86.10727116814864
    },
    {
      "type": "dialogue",
      "speakerCode": "yu",
      "speakerName": "鈴村優",
      "speakerNameEn": "Yu",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-yu.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/mainStoryVoice/sud_vo_adv_main_01_06_05/sud_vo_adv_main_01_06_05-yu009.m4a",
      "text": "はい？",
      "translations": {
        "en": "Yes?",
        "id": ""
      },
      "startTime": 86.10727116814864,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "koh",
      "speakerName": "{user}",
      "speakerNameEn": "{user}",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-kohei.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/mainStoryVoice/sud_vo_adv_main_01_06_05/sud_vo_adv_main_01_06_05-koh004.m4a",
      "text": "渚は今、悩みを抱えているんです。良かったら……\n少し渚の話し相手になってはもらえないでしょうか",
      "translations": {
        "en": "Nagisa is struggling with a dilemma right now. If you don’t mind…\nWould you have a little chat with her?",
        "id": ""
      },
      "startTime": 92.50727116814868,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_dancestudiocorridor-00-noon.webp",
      "bgName": "stage02",
      "startTime": 92.50727116814869
    },
    {
      "type": "dialogue",
      "speakerCode": "yu",
      "speakerName": "鈴村優",
      "speakerNameEn": "Yu",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-yu.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/mainStoryVoice/sud_vo_adv_main_01_06_05/sud_vo_adv_main_01_06_05-yu010.m4a",
      "text": "あら、嬉しいわぁ",
      "translations": {
        "en": "Ooh! I’d be honored.",
        "id": ""
      },
      "startTime": 95.97393783481532,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_dancestudiocorridor-00-noon.webp",
      "bgName": "stage02",
      "startTime": 98.49799689205103
    },
    {
      "type": "dialogue",
      "speakerCode": "yu",
      "speakerName": "鈴村優",
      "speakerNameEn": "Yu",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-yu.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/mainStoryVoice/sud_vo_adv_main_01_06_05/sud_vo_adv_main_01_06_05-yu011.m4a",
      "text": "うちに解決ができるとは思えませんが\n伊吹さんとぜひおしゃべりしたいとは思います",
      "translations": {
        "en": "I’m not sure if I can help at all‚\nbut I definitely would love to talk to her.",
        "id": ""
      },
      "startTime": 101.6313302254,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_dancestudiocorridor-00-noon.webp",
      "bgName": "stage02",
      "startTime": 104.83133022538432
    },
    {
      "type": "dialogue",
      "speakerCode": "yu",
      "speakerName": "鈴村優",
      "speakerNameEn": "Yu",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-yu.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/mainStoryVoice/sud_vo_adv_main_01_06_05/sud_vo_adv_main_01_06_05-yu012.m4a",
      "text": "お友達になってもらえるやろか\nふふ……楽しみやわぁ",
      "translations": {
        "en": "Maybe she’ll become my friend.\nHehe. I can’t wait!",
        "id": ""
      },
      "startTime": 108.0313302254,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_tokyocafe-00-noon.webp",
      "bgName": "stgae01",
      "startTime": 111.83133022538439
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_tokyocafe-00-noon.webp",
      "bgName": "stgae01",
      "startTime": 111.83133022538439
    },
    {
      "type": "dialogue",
      "speakerCode": "koh",
      "speakerName": "{user}",
      "speakerNameEn": "{user}",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-kohei.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/mainStoryVoice/sud_vo_adv_main_01_06_05/sud_vo_adv_main_01_06_05-koh005.m4a",
      "text": "鈴村さん、本当にいい子だよなあ……",
      "translations": {
        "en": "Yu really is a sweet girl.",
        "id": ""
      },
      "startTime": 112.99799689205108,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_tokyocafe-00-noon.webp",
      "bgName": "stgae01",
      "startTime": 116.85568388851104
    },
    {
      "type": "dialogue",
      "speakerCode": "mna",
      "speakerName": "長瀬麻奈",
      "speakerNameEn": "Mana",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-mana.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/mainStoryVoice/sud_vo_adv_main_01_06_05/sud_vo_adv_main_01_06_05-mna001.m4a",
      "text": "そうね\n……でもあの子、ただのいい子じゃないと思うけど",
      "translations": {
        "en": "Okay.\nBut I don’t think she’s your average sweet girl.",
        "id": ""
      },
      "startTime": 118.45568388851096,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_tokyocafe-00-noon.webp",
      "bgName": "stgae01",
      "startTime": 122.02235055517764
    },
    {
      "type": "dialogue",
      "speakerCode": "koh",
      "speakerName": "{user}",
      "speakerNameEn": "{user}",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-kohei.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/mainStoryVoice/sud_vo_adv_main_01_06_05/sud_vo_adv_main_01_06_05-koh006.m4a",
      "text": "ん？　どういう意味だ？",
      "translations": {
        "en": "Huh? What do you mean?",
        "id": ""
      },
      "startTime": 122.02235055517764,
      "sfxList": []
    },
    {
      "type": "dialogue",
