      "voiceUrl": "https://apiip.dasewasia.my.id/mainStoryVoice/sud_vo_adv_main_01_19_02/sud_vo_adv_main_01_19_02-mei002.m4a",
      "text": "そう言っても、すずちゃんだって……",
      "translations": {
        "en": "You may talk a big game‚ Suzu‚ but…",
        "id": ""
      },
      "startTime": 24.433333333333334,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "suz",
