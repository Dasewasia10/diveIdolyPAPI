      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-suzu.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/mainStoryVoice/sud_vo_adv_main_01_19_02/sud_vo_adv_main_01_19_02-suz003.m4a",
      "text": "泣いてないですわ\n私は……私は……",
      "translations": {
        "en": "I am not crying!\nI… I…",
        "id": ""
      },
      "startTime": 29.433333333333334,
      "sfxList": []
    },
