    {
      "type": "dialogue",
      "speakerCode": "ktn",
      "speakerName": "長瀬琴乃",
      "speakerNameEn": "Kotono",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-kotono.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/mainStoryVoice/sud_vo_adv_main_01_01_04/sud_vo_adv_main_01_01_04-ktn014.m4a",
      "text": "質問に答えていません",
      "translations": {
        "en": "You haven’t answered my question.",
        "id": ""
      },
      "startTime": 168.7,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "koh",
      "speakerName": "{user}",
      "speakerNameEn": "{user}",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-kohei.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/mainStoryVoice/sud_vo_adv_main_01_01_04/sud_vo_adv_main_01_01_04-koh018.m4a",
      "text": "三枝さんは、二人のことは担当の俺に預けると言った\n事務所はそれを全面的にバックアップすると",
      "translations": {
        "en": "Saegusa-san entrusted you two into my care‚\nalong with the full support of the agency.",
        "id": ""
      },
      "startTime": 174.96666666666667,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "ktn",
      "speakerName": "長瀬琴乃",
      "speakerNameEn": "Kotono",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-kotono.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/mainStoryVoice/sud_vo_adv_main_01_01_04/sud_vo_adv_main_01_01_04-ktn015.m4a",
      "text": "私がここに来たのは\nお姉ちゃんのマネジメントをしている人がいたからです",
      "translations": {
        "en": "The reason I came to this agency\nwas because the individual who managed my sister was here.",
        "id": ""
