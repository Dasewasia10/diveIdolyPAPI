    },
    {
      "type": "dialogue",
      "speakerCode": "kor",
      "speakerName": "fran",
      "speakerNameEn": "fran",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-fran.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/mainStoryVoice/sud_vo_adv_main_02_12_04/sud_vo_adv_main_02_12_04-kor002.m4a",
