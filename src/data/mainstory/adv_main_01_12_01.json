      "text": "……さすがですね",
      "translations": {
        "en": "I knew they could do it.",
        "id": ""
      },
      "startTime": 83.76174607276913,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_arenaseats-00-noon.webp",
      "bgName": "02-2d",
      "startTime": 85.73147394657131
    },
    {
      "type": "dialogue",
      "speakerCode": "mei",
      "speakerName": "早坂芽衣",
      "speakerNameEn": "Mei",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-mei.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/mainStoryVoice/sud_vo_adv_main_01_12_01/sud_vo_adv_main_01_12_01-mei001.m4a",
      "text": "いえーーーーー！\n次のライブも見に来るよーーー！！",
      "translations": {
        "en": "Yay!\nI’m gonna come to your next concert‚ too!",
        "id": ""
      },
      "startTime": 87.59814061323796,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_arenaseats-00-noon.webp",
      "bgName": "02-2d",
      "startTime": 91.36480727990462
    },
    {
      "type": "dialogue",
      "speakerCode": "suz",
      "speakerName": "成宮すず",
      "speakerNameEn": "Suzu",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-suzu.png",
