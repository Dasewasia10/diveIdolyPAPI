      "type": "dialogue",
      "speakerCode": "unknown",
      "speakerName": "司会者",
      "speakerNameEn": "Host",
      "iconUrl": null,
      "voiceUrl": null,
      "text": "リズノワもクォーターファイナルに進出！",
      "translations": {
        "en": "LizNoir will join them in the quarter-finals!",
        "id": ""
      },
