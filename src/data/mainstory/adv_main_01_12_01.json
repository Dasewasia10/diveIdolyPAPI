      "speakerName": "司会者",
      "speakerNameEn": "Host",
      "iconUrl": null,
      "voiceUrl": null,
      "text": "こ、これは！　凄いです。奇跡的にも同点！",
      "translations": {
        "en": "M-my goodness! That’s amazing! Miraculously‚ it’s a tie!",
        "id": ""
