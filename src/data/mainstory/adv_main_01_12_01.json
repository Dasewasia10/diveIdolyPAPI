      "type": "dialogue",
      "speakerCode": "unknown",
      "speakerName": "司会者",
      "speakerNameEn": "Host",
      "iconUrl": null,
      "voiceUrl": null,
      "text": "お二人の声を聞いてみましょう。感想は？",
      "translations": {
        "en": "Let’s hear what they have to say about it. Your thoughts‚ ladies?",
        "id": ""
      },
      "startTime": 59.72841273943586,
      "sfxList": []
    },
    {
      "type": "background",
