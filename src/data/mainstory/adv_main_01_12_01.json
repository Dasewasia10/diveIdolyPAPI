      "text": "って、何、敵のライブに\n盛り上がっているんですの！",
      "translations": {
        "en": "Wait a minute‚ why are you\ngetting excited over our enemy’s concert?!",
        "id": ""
      },
      "startTime": 92.86480727990464,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_arenaseats-00-noon.webp",
      "bgName": "02-2d",
      "startTime": 94.76480727990464
    },
