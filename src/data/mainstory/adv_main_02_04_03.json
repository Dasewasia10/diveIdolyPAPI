      "startTime": 344.6333333333333,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "rui",
      "speakerName": "天動瑠依",
      "speakerNameEn": "Rui",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-rui.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/mainStoryVoice/sud_vo_adv_main_02_04_03/sud_vo_adv_main_02_04_03-rui026.m4a",
      "text": "けれど、今の月ストからは\nあの時の凄みをまるで感じない",
      "translations": {
        "en": "But when I look at Moon Tempest now‚\nI don’t feel awestruck by them at all.",
        "id": ""
