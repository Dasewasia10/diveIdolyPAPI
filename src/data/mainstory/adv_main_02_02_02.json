      "speakerNameEn": "Kyoichi",
      "iconUrl": null,
      "voiceUrl": null,
      "text": "移籍することについては、すでに手を回してある",
      "translations": {
        "en": "Regarding the transfer‚ I’ve already made the arrangements.",
        "id": ""
