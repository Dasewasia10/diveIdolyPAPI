      "text": "…………？\n茂みの中に、誰かいる？",
      "translations": {
        "en": "…?\nIs there someone in the bushes?",
        "id": ""
      },
      "startTime": 49.333333333333336,
      "sfxList": []
    },
    {
      "type": "bgm",
