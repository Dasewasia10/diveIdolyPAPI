      "text": "はい？",
      "translations": {
        "en": "Yes?",
        "id": ""
      },
      "startTime": 1.9333333333333333,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "koh",
      "speakerName": "{user}",
      "speakerNameEn": "{user}",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-kohei.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/mainStoryVoice/sud_vo_adv_main_01_13_04/sud_vo_adv_main_01_13_04-koh002.m4a",
      "text": "いや……ちょっと虫がいてさ\n……ごめん、ちょっと待っててくれ",
      "translations": {
        "en": "Nothing. It was just an insect.\nSorry. Can you give me a minute?",
        "id": ""
      },
      "startTime": 6,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_garden-00-night.webp",
