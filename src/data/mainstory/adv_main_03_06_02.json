          "startTime": 6.853093747
        }
      ]
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_tokyocorridor-00-noon.webp",
      "bgName": "tokyocorridor-00-noon",
      "startTime": 6.853093747
    },
    {
      "type": "dialogue",
      "speakerCode": "ngs",
      "speakerName": "伊吹渚",
      "speakerNameEn": "Nagisa",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-nagisa.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/mainStoryVoice/sud_vo_adv_main_03_06_02/sud_vo_adv_main_03_06_02-ngs001.m4a",
      "text": "{user}さん",
      "translations": {
        "en": "{user}-san.",
        "id": ""
      },
      "startTime": 8.453093747,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "koh",
      "speakerName": "{user}",
      "speakerNameEn": "{user}",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-kohei.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/mainStoryVoice/sud_vo_adv_main_03_06_02/sud_vo_adv_main_03_06_02-koh002.m4a",
      "text": "渚、どうしたんだ？\n話し合いは……",
      "translations": {
        "en": "Nagisa‚ what’s wrong?\nThe discussion…",
        "id": ""
      },
      "startTime": 12.4469166597,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_tokyocorridor-00-noon.webp",
      "bgName": "tokyocorridor-00-noon",
      "startTime": 13.8802499931
    },
    {
      "type": "dialogue",
      "speakerCode": "ngs",
      "speakerName": "伊吹渚",
      "speakerNameEn": "Nagisa",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-nagisa.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/mainStoryVoice/sud_vo_adv_main_03_06_02/sud_vo_adv_main_03_06_02-ngs002.m4a",
      "text": "みんな{user}さんのことを心配してて\n大丈夫かなって思って見に来たんです",
      "translations": {
        "en": "Everyone was worried about you‚\nso I came to see if you were okay.",
        "id": ""
      },
      "startTime": 17.0000003815,
      "sfxList": []
    },
    {
      "type": "bgm",
      "action": "play",
      "src": "https://apiip.dasewasia.my.id/storyBgm/sud_bgm_adv_tokyo-01.m4a",
      "startTime": 19.1333333333
    },
    {
      "type": "dialogue",
      "speakerCode": "koh",
      "speakerName": "{user}",
      "speakerNameEn": "{user}",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-kohei.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/mainStoryVoice/sud_vo_adv_main_03_06_02/sud_vo_adv_main_03_06_02-koh003.m4a",
      "text": "気を遣わせてしまったか……すまない\nみんなの方が辛いはずなのに",
      "translations": {
        "en": "I made you worry… I'm sorry.\nYou all should be the ones hurting.",
        "id": ""
      },
      "startTime": 24.2210436345,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_tokyocorridor-00-noon.webp",
      "bgName": "tokyocorridor-00-noon",
      "startTime": 26.6543769678
    },
    {
      "type": "dialogue",
      "speakerCode": "ngs",
      "speakerName": "伊吹渚",
      "speakerNameEn": "Nagisa",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-nagisa.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/mainStoryVoice/sud_vo_adv_main_03_06_02/sud_vo_adv_main_03_06_02-ngs003.m4a",
      "text": "{user}さんは六人目の月ストですから\nそんな悲しいこと、言わないで下さい",
      "translations": {
        "en": "You’re the sixth member of Moon Tempest‚ {user}-san.\nDon’t say such sad things.",
        "id": ""
      },
      "startTime": 29.6333337148,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_tokyocorridor-00-noon.webp",
      "bgName": "tokyocorridor-00-noon",
      "startTime": 32.7319737276
    },
    {
      "type": "dialogue",
      "speakerCode": "ngs",
      "speakerName": "伊吹渚",
      "speakerNameEn": "Nagisa",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-nagisa.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/mainStoryVoice/sud_vo_adv_main_03_06_02/sud_vo_adv_main_03_06_02-ngs004.m4a",
      "text": "最高のマネージャーだって、みんな分かってますよ\nきっと琴乃ちゃんだってそうです",
      "translations": {
        "en": "Everyone knows you’re the best manager.\nI’m sure Kotono-chan thinks so too.",
        "id": ""
      },
      "startTime": 36.7322827432,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_tokyocorridor-00-noon.webp",
      "bgName": "tokyocorridor-00-noon",
      "startTime": 39.4600917658
    },
    {
      "type": "dialogue",
      "speakerCode": "koh",
      "speakerName": "{user}",
      "speakerNameEn": "{user}",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-kohei.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/mainStoryVoice/sud_vo_adv_main_03_06_02/sud_vo_adv_main_03_06_02-koh004.m4a",
      "text": "（渚が一番辛いはずなのに、率先して動いて）\n（俺のことまで気遣ってくれるとは……）",
      "translations": {
        "en": "(Nagisa should be the one who’s hurting the most‚ yet she’s taking)\n(the initiative and even worrying about me…)",
        "id": ""
      },
      "startTime": 43.8600917658,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_tokyocorridor-00-noon.webp",
      "bgName": "tokyocorridor-00-noon",
      "startTime": 46.6600917658
    },
    {
      "type": "dialogue",
      "speakerCode": "koh",
      "speakerName": "{user}",
      "speakerNameEn": "{user}",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-kohei.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/mainStoryVoice/sud_vo_adv_main_03_06_02/sud_vo_adv_main_03_06_02-koh005.m4a",
      "text": "渚は、本当に変わったな",
      "translations": {
        "en": "You’ve really changed‚ Nagisa.",
        "id": ""
      },
      "startTime": 46.6600917658,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "ngs",
      "speakerName": "伊吹渚",
      "speakerNameEn": "Nagisa",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-nagisa.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/mainStoryVoice/sud_vo_adv_main_03_06_02/sud_vo_adv_main_03_06_02-ngs005.m4a",
      "text": "それ、琴乃ちゃんにも言われました、えへへ",
      "translations": {
        "en": "Kotono-chan told me that too‚ eheh.",
        "id": ""
      },
      "startTime": 50.0600922745,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_tokyocorridor-00-noon.webp",
      "bgName": "tokyocorridor-00-noon",
      "startTime": 54.9266461533
    },
    {
      "type": "dialogue",
      "speakerCode": "koh",
      "speakerName": "{user}",
      "speakerNameEn": "{user}",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-kohei.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/mainStoryVoice/sud_vo_adv_main_03_06_02/sud_vo_adv_main_03_06_02-koh006.m4a",
      "text": "……渚、月ストの話し合いの件、よろしく頼む",
      "translations": {
        "en": "…Nagisa‚ please handle the Moon Tempest discussion.",
        "id": ""
      },
      "startTime": 54.9266461533,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "ngs",
      "speakerName": "伊吹渚",
      "speakerNameEn": "Nagisa",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-nagisa.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/mainStoryVoice/sud_vo_adv_main_03_06_02/sud_vo_adv_main_03_06_02-ngs006.m4a",
      "text": "分かりました",
      "translations": {
        "en": "Okay.",
        "id": ""
      },
      "startTime": 59.8266461533,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_lesson-01-noon.webp",
      "bgName": "lesson-01-000-noon",
      "startTime": 62.3766470481
    },
    {
      "type": "bgm",
      "action": "play",
      "src": "https://apiip.dasewasia.my.id/storyBgm/sud_bgm_adv_pop-01.m4a",
      "startTime": 62.6633121889
    },
    {
      "type": "dialogue",
      "speakerCode": "ngs",
      "speakerName": "伊吹渚",
      "speakerNameEn": "Nagisa",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-nagisa.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/mainStoryVoice/sud_vo_adv_main_03_06_02/sud_vo_adv_main_03_06_02-ngs008.m4a",
      "text": "それじゃあ、今後についてなんだけど……\n……とりあえず、お話ししよっか",
      "translations": {
        "en": "So‚ about the future…\n…Let's just talk‚ for now.",
        "id": ""
      },
      "startTime": 67.7333352406,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "ski",
      "speakerName": "白石沙季",
      "speakerNameEn": "Saki",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-saki.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/mainStoryVoice/sud_vo_adv_main_03_06_02/sud_vo_adv_main_03_06_02-ski001.m4a",
      "text": "そうですね。{user}さんの言葉を聞いて\n多少は落ち着きましたが……",
      "translations": {
        "en": "Yes. After hearing what {user}-san said‚\nI've calmed down a bit…",
        "id": ""
      },
      "startTime": 74.8170551699,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "ski",
      "speakerName": "白石沙季",
      "speakerNameEn": "Saki",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-saki.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/mainStoryVoice/sud_vo_adv_main_03_06_02/sud_vo_adv_main_03_06_02-ski002.m4a",
      "text": "それでもまだ、気持ちの整理がつきません",
      "translations": {
        "en": "but I still can't sort out my feelings.",
        "id": ""
      },
      "startTime": 77.517053644,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "suz",
      "speakerName": "成宮すず",
      "speakerNameEn": "Suzu",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-suzu.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/mainStoryVoice/sud_vo_adv_main_03_06_02/sud_vo_adv_main_03_06_02-suz001.m4a",
      "text": "まったく、琴乃ったら。どうしてこんな大事な決断を\n一人でしてしまうんですの！",
      "translations": {
        "en": "Honestly‚ Kotono. Why would she make such an\nimportant decision by herself?!",
        "id": ""
      },
      "startTime": 84.8555920869,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "mei",
      "speakerName": "早坂芽衣",
      "speakerNameEn": "Mei",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-mei.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/mainStoryVoice/sud_vo_adv_main_03_06_02/sud_vo_adv_main_03_06_02-mei001.m4a",
      "text": "相談、してほしかったな。同じグループなんだよ？\nずっと一緒に、頑張ってきたのに……っ",
      "translations": {
        "en": "I wish she had consulted with us. We’re in the same group!\nWe’ve worked hard together all this time…",
        "id": ""
      },
      "startTime": 96.0000019073,
      "sfxList": []
    },
    {
      "type": "bgm",
      "action": "play",
      "src": "https://apiip.dasewasia.my.id/storyBgm/sud_bgm_adv_serious-01.m4a",
      "startTime": 100.7508863848
    },
    {
      "type": "dialogue",
      "speakerCode": "suz",
      "speakerName": "成宮すず",
      "speakerNameEn": "Suzu",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-suzu.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/mainStoryVoice/sud_vo_adv_main_03_06_02/sud_vo_adv_main_03_06_02-suz003.m4a",
      "text": "め、芽衣？　元気を出して……\n……なんて、今は無理ですわよね",
      "translations": {
        "en": "M-Mei? Cheer up…\n…But I guess that’s impossible right now.",
        "id": ""
      },
      "startTime": 105.584221244,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "mei",
      "speakerName": "早坂芽衣",
      "speakerNameEn": "Mei",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-mei.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/mainStoryVoice/sud_vo_adv_main_03_06_02/sud_vo_adv_main_03_06_02-mei002.m4a",
      "text": "……すずにゃん、ありがと",
      "translations": {
        "en": "…Thank you‚ Suzu-nyan.",
        "id": ""
      },
      "startTime": 111.7000019073,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "mei",
      "speakerName": "早坂芽衣",
      "speakerNameEn": "Mei",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-mei.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/mainStoryVoice/sud_vo_adv_main_03_06_02/sud_vo_adv_main_03_06_02-mei003.m4a",
      "text": "相談もしてほしかったけど\n芽衣も琴乃ちゃんのお話、もっと聞けば良かったな",
      "translations": {
        "en": "I wish she had consulted with us‚\nbut Mei also wishes Mei had listened to Kotono-chan more.",
        "id": ""
      },
      "startTime": 117.9333352406,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "mei",
      "speakerName": "早坂芽衣",
      "speakerNameEn": "Mei",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-mei.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/mainStoryVoice/sud_vo_adv_main_03_06_02/sud_vo_adv_main_03_06_02-mei005.m4a",
      "text": "悩んでるのは気付いてたし\nもっとお話ししてたら、違ってたかも",
      "translations": {
        "en": "I knew she was troubled‚\nand maybe things would have been different if I’d talked to her more.",
        "id": ""
      },
      "startTime": 127.3000019073,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "ski",
      "speakerName": "白石沙季",
      "speakerNameEn": "Saki",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-saki.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/mainStoryVoice/sud_vo_adv_main_03_06_02/sud_vo_adv_main_03_06_02-ski004.m4a",
      "text": "それは私も同じです\nもっと、力になれていれば……",
      "translations": {
        "en": "I feel the same way.\nIf only I could have been more helpful…",
        "id": ""
      },
      "startTime": 134.1093687934,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "unknown",
      "speakerName": "一同",
      "speakerNameEn": "Everyone",
      "iconUrl": null,
      "voiceUrl": null,
      "text": "っ……",
      "translations": {
        "en": "…",
        "id": ""
      },
      "startTime": 136.9093672675,
      "sfxList": []
    },
    {
      "type": "bgm",
      "action": "play",
      "src": "https://apiip.dasewasia.my.id/storyBgm/sud_bgm_adv_dangerous-01.m4a",
      "startTime": 139.3108393354
    },
    {
      "type": "dialogue",
      "speakerCode": "suz",
      "speakerName": "成宮すず",
      "speakerNameEn": "Suzu",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-suzu.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/mainStoryVoice/sud_vo_adv_main_03_06_02/sud_vo_adv_main_03_06_02-suz004.m4a",
      "text": "……こ、これではまるでお通夜ですわ！\n辛い時こそ元気を出さなければ！",
      "translations": {
        "en": "…Th-This is like a wake!\nWe have to cheer up‚ especially in times like this!",
        "id": ""
      },
      "startTime": 142.9333352406,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "suz",
      "speakerName": "成宮すず",
      "speakerNameEn": "Suzu",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-suzu.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/mainStoryVoice/sud_vo_adv_main_03_06_02/sud_vo_adv_main_03_06_02-suz005.m4a",
      "text": "ほら、こんな時、琴乃だったらなんて言うか\n……あ……で、ではなく、そのっ……！",
      "translations": {
        "en": "Come on‚ what would Kotono say in a situation like this?\n…Ah… No‚ not that‚ uh…!",
        "id": ""
      },
      "startTime": 150.1961682507,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "ngs",
      "speakerName": "伊吹渚",
      "speakerNameEn": "Nagisa",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-nagisa.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/mainStoryVoice/sud_vo_adv_main_03_06_02/sud_vo_adv_main_03_06_02-ngs009.m4a",
      "text": "そういえば、すずちゃん\nアイドルミュージックフェスに出演した時も……",
      "translations": {
        "en": "Speaking of which‚ Suzu-chan‚\nat the Idol Music Festival‚ you…",
        "id": ""
      },
      "startTime": 156.1392918881,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_dressingroom-00-noon.webp",
      "bgName": "dressingroom-00-noon",
      "startTime": 160.4603502913
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_dressingroom-00-noon.webp",
      "bgName": "dressingroom-00-noon",
      "startTime": 160.4603502913
    },
    {
      "type": "dialogue",
      "speakerCode": "suz",
