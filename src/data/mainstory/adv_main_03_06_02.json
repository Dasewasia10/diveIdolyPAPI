      "bgName": "tokyocorridor-00-noon",
      "startTime": 0
    },
    {
      "type": "dialogue",
      "speakerCode": "koh",
      "speakerName": "{user}",
      "speakerNameEn": "{user}",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-kohei.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/mainStoryVoice/sud_vo_adv_main_03_06_02/sud_vo_adv_main_03_06_02-koh001.m4a",
      "text": "伝えるべきことは、伝えた……\nあと、俺に今出来ることは……ん？",
      "translations": {
        "en": "I’ve said what I needed to say…\nNow‚ all I can do… Huh?",
        "id": ""
      },
      "startTime": 3.6,
      "sfxList": [
        {
          "src": "https://apiip.dasewasia.my.id/storyBgm/sud_se_adv_walk-in-single-02.m4a",
