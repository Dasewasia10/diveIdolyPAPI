      "startTime": 0
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_lesson-00-noon.webp",
      "bgName": "stage1",
      "startTime": null
    },
    {
      "type": "dialogue",
      "speakerCode": "koh",
      "speakerName": "{user}",
      "speakerNameEn": "{user}",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-kohei.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/mainStoryVoice/sud_vo_adv_main_01_02_02/sud_vo_adv_main_01_02_02-koh001.m4a",
      "text": "早速だけど、今日から一緒に事務所で頑張って\nもらうことになった三人を紹介するね",
      "translations": {
        "en": "Well‚ without further ado‚\nlet me introduce the three new girls who will join you.",
        "id": ""
      },
      "startTime": 4,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "ktn",
      "speakerName": "長瀬琴乃",
      "speakerNameEn": "Kotono",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-kotono.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/mainStoryVoice/sud_vo_adv_main_01_02_02/sud_vo_adv_main_01_02_02-ktn001.m4a",
      "text": "ちょっと待って、その……女の子同士っていうのは……\n初対面が大事っていうか……いろいろ……",
      "translations": {
        "en": "Hold it. Since we’re all‚ you know‚ girls…\nFirst impressions are really critical‚ so I’d rather not—",
        "id": ""
      },
      "startTime": 11.26666666666667,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "koh",
      "speakerName": "{user}",
      "speakerNameEn": "{user}",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-kohei.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/mainStoryVoice/sud_vo_adv_main_01_02_02/sud_vo_adv_main_01_02_02-koh002.m4a",
      "text": "おーい、じゃあ入って",
      "translations": {
        "en": "Alright‚ come on in.",
        "id": ""
      },
      "startTime": 14.600000000000003,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "ktn",
      "speakerName": "長瀬琴乃",
      "speakerNameEn": "Kotono",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-kotono.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/mainStoryVoice/sud_vo_adv_main_01_02_02/sud_vo_adv_main_01_02_02-ktn002.m4a",
      "text": "いいっ……",
      "translations": {
        "en": "Erk!",
        "id": ""
      },
      "startTime": 16.749999976158144,
      "sfxList": [
        {
          "src": "https://apiip.dasewasia.my.id/storyBgm/sud_se_adv_walk-in-single-01.m4a",
          "delay": 316.66669050852295,
          "startTime": 17.066666666666666
        },
        {
          "src": "https://apiip.dasewasia.my.id/storyBgm/sud_se_adv_door-open-01.m4a",
          "delay": 133.33333333333286,
          "startTime": 16.883333309491476
        }
      ]
    },
    {
      "type": "dialogue",
      "speakerCode": "ngs",
      "speakerName": "伊吹渚",
      "speakerNameEn": "Nagisa",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-nagisa.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/mainStoryVoice/sud_vo_adv_main_01_02_02/sud_vo_adv_main_01_02_02-ngs001.m4a",
      "text": "伊吹渚といいます、高校二年生です",
      "translations": {
        "en": "My name is Nagisa Ibuki‚ and I’m the sophomore in high school.",
        "id": ""
      },
      "startTime": 18.016666642824816,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "ngs",
      "speakerName": "伊吹渚",
      "speakerNameEn": "Nagisa",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-nagisa.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/mainStoryVoice/sud_vo_adv_main_01_02_02/sud_vo_adv_main_01_02_02-ngs002.m4a",
      "text": "八月三日生まれのO型\n琴乃ちゃんとは友達です、よろしく",
      "translations": {
        "en": "My birthday is August 3rd‚ and my blood type is O.\nI’m also friends with Kotono-chan. Nice to meet you.",
        "id": ""
      },
      "startTime": 23.616666642824818,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "suz",
      "speakerName": "成宮すず",
      "speakerNameEn": "Suzu",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-suzu.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/mainStoryVoice/sud_vo_adv_main_01_02_02/sud_vo_adv_main_01_02_02-suz001.m4a",
      "text": "成宮すずですわ",
      "translations": {
        "en": "I am Suzu Narumiya.",
        "id": ""
      },
      "startTime": 27.34189605284961,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "suz",
      "speakerName": "成宮すず",
      "speakerNameEn": "Suzu",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-suzu.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/mainStoryVoice/sud_vo_adv_main_01_02_02/sud_vo_adv_main_01_02_02-suz002.m4a",
      "text": "成宮と聞いてピンときた人もいるかもしれないけど\n正真正銘あの成宮家の令嬢ですわ",
      "translations": {
        "en": "Surely the name Narumiya resonates with some of you.\nI am indeed the heiress to the esteemed Narumiya family.",
        "id": ""
      },
      "startTime": 33.10620446571939,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "suz",
      "speakerName": "成宮すず",
      "speakerNameEn": "Suzu",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-suzu.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/mainStoryVoice/sud_vo_adv_main_01_02_02/sud_vo_adv_main_01_02_02-suz003.m4a",
      "text": "なんですの？　そのうっす～～いリアクションは\nこの町のあらゆる企業に融資している成宮家ですわよ",
      "translations": {
        "en": "What is this lackluster response I’m sensing?\nDo you not realize that the Narumiya name has funded countless ventures in this town?",
        "id": ""
      },
      "startTime": 43.3,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "suz",
      "speakerName": "成宮すず",
      "speakerNameEn": "Suzu",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-suzu.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/mainStoryVoice/sud_vo_adv_main_01_02_02/sud_vo_adv_main_01_02_02-suz004.m4a",
      "text": "盆暮れ正月ともなれば、町中の議員やら社長やらが\nひっきりなしに挨拶に訪れる……",
      "translations": {
        "en": "On New Year's Day‚ local dignitaries and esteemed nobles\nline up eagerly to pay homage to our family…",
        "id": ""
      },
      "startTime": 50.333333333333336,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "koh",
      "speakerName": "{user}",
      "speakerNameEn": "{user}",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-kohei.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/mainStoryVoice/sud_vo_adv_main_01_02_02/sud_vo_adv_main_01_02_02-koh003.m4a",
      "text": "あ、あぁ、自分の紹介してくれないかな……\n例えば、アイドルにどうしてなりたいのかとか",
      "translations": {
        "en": "Er‚ uh‚ could you maybe tell us a bit about yourself?\nLike‚ what you wish to accomplish as an idol.",
        "id": ""
      },
      "startTime": 57.4,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "suz",
      "speakerName": "成宮すず",
      "speakerNameEn": "Suzu",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-suzu.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/mainStoryVoice/sud_vo_adv_main_01_02_02/sud_vo_adv_main_01_02_02-suz005.m4a",
      "text": "フン、別に――\n簡単にトップを取れそうだと思ったからですわね",
      "translations": {
        "en": "Hmph! Of course\nI simply knew it would be easy to climb to the top.",
        "id": ""
      },
      "startTime": 63.63333333333333,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "suz",
      "speakerName": "成宮すず",
      "speakerNameEn": "Suzu",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-suzu.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/mainStoryVoice/sud_vo_adv_main_01_02_02/sud_vo_adv_main_01_02_02-suz006.m4a",
      "text": "まあ、そういうことですので、センターの私の足を\n引っ張らないよう、皆様よろしくお願いしますわ",
      "translations": {
        "en": "On that note‚ as I’ll be the center of this group‚\ntry not to hold me back‚ please. Thank you.",
        "id": ""
      },
      "startTime": 70.93333333333334,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "ngs",
      "speakerName": "伊吹渚",
      "speakerNameEn": "Nagisa",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-nagisa.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/mainStoryVoice/sud_vo_adv_main_01_02_02/sud_vo_adv_main_01_02_02-ngs003.m4a",
      "text": "そうなの？",
      "translations": {
        "en": "Our center?",
        "id": ""
      },
      "startTime": 75,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "ktn",
      "speakerName": "長瀬琴乃",
      "speakerNameEn": "Kotono",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-kotono.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/mainStoryVoice/sud_vo_adv_main_01_02_02/sud_vo_adv_main_01_02_02-ktn003.m4a",
      "text": "聞いてない",
      "translations": {
        "en": "That’s news to me.",
        "id": ""
      },
      "startTime": 76.7,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "koh",
      "speakerName": "{user}",
      "speakerNameEn": "{user}",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-kohei.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/mainStoryVoice/sud_vo_adv_main_01_02_02/sud_vo_adv_main_01_02_02-koh004.m4a",
      "text": "何もまだ決まってないので\n勝手なことを言わないように",
      "translations": {
        "en": "Nothing’s been decided yet‚\nso please don’t jump to conclusions.",
        "id": ""
      },
      "startTime": 80.36666666666666,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "suz",
      "speakerName": "成宮すず",
      "speakerNameEn": "Suzu",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-suzu.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/mainStoryVoice/sud_vo_adv_main_01_02_02/sud_vo_adv_main_01_02_02-suz007.m4a",
      "text": "な！\nですが、この中を見回してみればどう考えても……",
      "translations": {
        "en": "What!\nA quick look around the room should make it evident that only I—",
        "id": ""
      },
      "startTime": 83.83333333333333,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "koh",
      "speakerName": "{user}",
      "speakerNameEn": "{user}",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-kohei.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/mainStoryVoice/sud_vo_adv_main_01_02_02/sud_vo_adv_main_01_02_02-koh005.m4a",
      "text": "家柄でセンターが決まる訳じゃない\nなりたければ、これから練習でみんなを納得させて",
      "translations": {
        "en": "We don’t pick our centers based on their upbringing.\nIf you want to be the center‚ you’ll have to earn everyone’s approval.",
        "id": ""
      },
      "startTime": 90.4,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "suz",
      "speakerName": "成宮すず",
      "speakerNameEn": "Suzu",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-suzu.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/mainStoryVoice/sud_vo_adv_main_01_02_02/sud_vo_adv_main_01_02_02-suz008.m4a",
      "text": "…………フン",
      "translations": {
        "en": "…Hmph.",
        "id": ""
      },
      "startTime": 93.8,
      "sfxList": [
        {
          "src": "https://apiip.dasewasia.my.id/storyBgm/sud_se_adv_walk-in-single-01.m4a",
          "delay": 1633.3333333333399,
          "startTime": 95.43333333333334
        }
      ]
    },
    {
      "type": "bgm",
      "action": "play",
      "src": "https://apiip.dasewasia.my.id/storyBgm/sud_bgm_adv_pop-01.m4a",
      "startTime": 96.8
    },
    {
      "type": "dialogue",
      "speakerCode": "ski",
      "speakerName": "白石沙季",
      "speakerNameEn": "Saki",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-saki.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/mainStoryVoice/sud_vo_adv_main_01_02_02/sud_vo_adv_main_01_02_02-ski001.m4a",
      "text": "白石沙季です\n十八歳の高校三年生です",
      "translations": {
        "en": "I’m Saki Shiraishi.\nI’m 18 years old and a senior in high school.",
        "id": ""
      },
      "startTime": 98.79550700262189,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "ski",
      "speakerName": "白石沙季",
      "speakerNameEn": "Saki",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-saki.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/mainStoryVoice/sud_vo_adv_main_01_02_02/sud_vo_adv_main_01_02_02-ski002.m4a",
      "text": "小さい頃からアイドルが好きで、高校の最後だし\nチャレンジしてみよう、と思ってここに来ました",
      "translations": {
        "en": "I’ve loved idols ever since I was little‚\nand since I’ll be graduating soon‚ I figured I should give it a go.",
        "id": ""
      },
      "startTime": 104.43333333333334,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "ski",
      "speakerName": "白石沙季",
      "speakerNameEn": "Saki",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-saki.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/mainStoryVoice/sud_vo_adv_main_01_02_02/sud_vo_adv_main_01_02_02-ski003.m4a",
      "text": "皆さんと一緒に精一杯頑張っていきますので\nよろしくお願いします",
      "translations": {
        "en": "I look forward to working alongside all of you.\nNice to meet you all.",
        "id": ""
      },
      "startTime": 110.4,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "skr",
      "speakerName": "川咲さくら",
      "speakerNameEn": "Sakura",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-sakura.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/mainStoryVoice/sud_vo_adv_main_01_02_02/sud_vo_adv_main_01_02_02-skr001.m4a",
      "text": "凄い\n沙季ちゃんの方がずっとお嬢様っぽい",
      "translations": {
        "en": "Whoa.\nNow that’s real class.",
        "id": ""
      },
      "startTime": 114.36666666666666,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "suz",
      "speakerName": "成宮すず",
      "speakerNameEn": "Suzu",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-suzu.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/mainStoryVoice/sud_vo_adv_main_01_02_02/sud_vo_adv_main_01_02_02-suz009.m4a",
      "text": "聞こえていますわよ……！",
      "translations": {
        "en": "I heard that!",
        "id": ""
      },
      "startTime": 117.76666666666667,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "skr",
      "speakerName": "川咲さくら",
      "speakerNameEn": "Sakura",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-sakura.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/mainStoryVoice/sud_vo_adv_main_01_02_02/sud_vo_adv_main_01_02_02-skr002.m4a",
      "text": "あ、いや……はは……",
      "translations": {
        "en": "Oh‚ uh‚ hahaha…",
        "id": ""
      },
      "startTime": 119.76666666666667,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "ngs",
      "speakerName": "伊吹渚",
      "speakerNameEn": "Nagisa",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-nagisa.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/mainStoryVoice/sud_vo_adv_main_01_02_02/sud_vo_adv_main_01_02_02-ngs004.m4a",
      "text": "お嬢様というか、クラス委員っていうか……",
      "translations": {
        "en": "Speaking of class‚ she seems like she’d be a class president or something.",
        "id": ""
      },
      "startTime": 123.3,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "ski",
      "speakerName": "白石沙季",
      "speakerNameEn": "Saki",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-saki.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/mainStoryVoice/sud_vo_adv_main_01_02_02/sud_vo_adv_main_01_02_02-ski004.m4a",
      "text": "あ、学校では生徒会長やっています",
      "translations": {
        "en": "Oh‚ actually‚ I’m the student council president.",
        "id": ""
      },
      "startTime": 127.7,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "ngs",
      "speakerName": "伊吹渚",
      "speakerNameEn": "Nagisa",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-nagisa.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/mainStoryVoice/sud_vo_adv_main_01_02_02/sud_vo_adv_main_01_02_02-ngs005.m4a",
      "text": "やっぱり\n勉強とか分からないことあったら聞いちゃおうかな",
      "translations": {
        "en": "I thought so!\nMaybe you can help me with my homework.",
        "id": ""
      },
      "startTime": 132.62902725487947,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "koh",
      "speakerName": "{user}",
      "speakerNameEn": "{user}",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-kohei.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/mainStoryVoice/sud_vo_adv_main_01_02_02/sud_vo_adv_main_01_02_02-koh006.m4a",
      "text": "二人も、自己紹介は？",
      "translations": {
        "en": "And what about you two?",
        "id": ""
      },
      "startTime": 136.23333333333332,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "skr",
      "speakerName": "川咲さくら",
      "speakerNameEn": "Sakura",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-sakura.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/mainStoryVoice/sud_vo_adv_main_01_02_02/sud_vo_adv_main_01_02_02-skr003.m4a",
