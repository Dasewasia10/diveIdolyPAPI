      "bgName": "countryroad-00-night",
      "startTime": 48.0666666667
    },
    {
      "type": "dialogue",
      "speakerCode": "ktn",
      "speakerName": "長瀬琴乃",
      "speakerNameEn": "Kotono",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-kotono.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/mainStoryVoice/sud_vo_adv_main_03_03_05/sud_vo_adv_main_03_03_05-ktn005.m4a",
      "text": "め、芽衣。言わなくていいから……",
      "translations": {
        "en": "M-Mei. You don’t have to say it…",
        "id": ""
      },
      "startTime": 48.0666666667,
      "sfxList": []
