    },
    {
      "type": "dialogue",
      "speakerCode": "mei",
      "speakerName": "早坂芽衣",
      "speakerNameEn": "Mei",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-mei.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/mainStoryVoice/sud_vo_adv_main_03_03_05/sud_vo_adv_main_03_03_05-mei003.m4a",
      "text": "あ、琴乃ちゃんがこっちに戻ってきた",
      "translations": {
        "en": "Ah‚ Kotono-chan is back to her usual self.",
        "id": ""
      },
      "startTime": 44.6,
      "sfxList": []
    },
    {
      "type": "background",
