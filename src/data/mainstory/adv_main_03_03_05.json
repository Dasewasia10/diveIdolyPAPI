      "startTime": 54.4,
      "sfxList": []
    },
    {
      "type": "dialogue",
      "speakerCode": "koh",
      "speakerName": "{user}",
      "speakerNameEn": "{user}",
      "iconUrl": "https://apiip.dasewasia.my.id/iconCharacter/chara-kohei.png",
      "voiceUrl": "https://apiip.dasewasia.my.id/mainStoryVoice/sud_vo_adv_main_03_03_05/sud_vo_adv_main_03_03_05-koh003.m4a",
      "text": "オカピ？　なんだそれ？",
      "translations": {
        "en": "Okapi? What’s that?",
        "id": ""
      },
      "startTime": 57.8,
      "sfxList": []
    },
    {
      "type": "background",
      "src": "https://apiip.dasewasia.my.id/storyBackground/env_adv_2d_countryroad-00-night.webp",
      "bgName": "countryroad-00-night",
