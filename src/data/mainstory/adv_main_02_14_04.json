      "voiceUrl": "https://apiip.dasewasia.my.id/mainStoryVoice/sud_vo_adv_main_02_14_04/sud_vo_adv_main_02_14_04-skr005.m4a",
      "text": "そうですね……ふふっ、そうかも",
      "translations": {
        "en": "Yeah… Hehe‚ maybe so.",
        "id": ""
      },
      "startTime": 79.9666666667,
      "sfxList": []
